	if[%floor% = 0] AddShaftWall %12%, Shaft%12%LeftEX, %SHWallTex%, %WallThick%, -%10%, -%11%, -%10%, 0, %interfloorheight%, %interfloorheight%, 0, 0, 0, 0
	AddShaftWall %12%, Shaft%12%Left, %SHWallTex%, %WallThick%, -%10%, 0, -%10%, %11%, %fullheight%, %fullheight%, 0, 0, 0, 0
