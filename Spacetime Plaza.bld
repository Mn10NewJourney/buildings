		if[%floor% = -2] AddWall WestZoneRightWall2B, %5%Wall, 0.5, -%1% + 240, -31, -%1% + 240, %2% - 260 + 0.5, %fullheight% + Floor(-1).InterfloorHeight, %fullheight% + Floor(-1).InterfloorHeight, 0, 0, 0, 0, true

		AddWall WestZoneBackWall, %5%Wall, 0.5, -416, %2%, -%1%, %2%, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		#Center Zone
		WallOrientation = left
		DrawWalls = false, true, false, true, false, false
		if[%floor% = -1] AddWall CenterZoneFrontWallA, %5%Wall, 0.5, -%1% + 240, %2% - 260 - 320, 10 - 15, %2% - 260 - 320, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		DrawWalls = false, true, false, false, false, false
