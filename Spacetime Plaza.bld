		AddRails ElevRail, ElevRailSide, 0, %Position%, false, 1 + 0.06, 0.1
<EndElevators>

<Elevators 16 to 21>
	#DETAILED INTERIORS
	#1. Ceiling lights
	CreateWallBox2 elevator, E%elevator%_LightA1, %Prefix%ElevCeilingLight, 0, 0, 3, 6.1, 0.04, 8 - 0.04, 0, 0, false, true, true, true

		#1a. Ceiling trims
		CreateWallBox2 elevator, E%elevator%_TrimInner_Left, %Prefix%ElevCeilingTrim, -1.5 - 0.1, 0, 0.2, 6.1, 0.04, 8 - 0.04, 0, 0, false, true, true, true
		CreateWallBox2 elevator, E%elevator%_TrimInner_Right, %Prefix%ElevCeilingTrim, 1.5 + 0.1, 0, 0.2, 6.1, 0.04, 8 - 0.04, 0, 0, false, true, true, true

	#2. Downlights
	DrawWalls = true, false, false, false, false, false
	Set DLOffset = 8 - 0.001 #Offsets for downlights
	AddFloor Downlight1/1, %Prefix%ElevCeilingDL, 0, -3.3 + 0.75 - 0.11, (-3.05 + 1.75) - 0.11, -3.3 + 0.75 + 0.11, (-3.05 + 1.75) + 0.11, %DLOffset%, %DLOffset%, 0, 0
	AddFloor Downlight1/2, %Prefix%ElevCeilingDL, 0, 3.3 - 0.75 - 0.11, (-3.05 + 1.75) - 0.11, 3.3 - 0.75 + 0.11, (-3.05 + 1.75) + 0.11, %DLOffset%, %DLOffset%, 0, 0
	AddFloor Downlight2/2, %Prefix%ElevCeilingDL, 0, -3.3 + 0.75 - 0.11, (3.05 - 1.75) - 0.11, -3.3 + 0.75 + 0.11, (3.05 - 1.75) + 0.11, %DLOffset%, %DLOffset%, 0, 0
	AddFloor Downlight2/2, %Prefix%ElevCeilingDL, 0, 3.3 - 0.75 - 0.11, (3.05 - 1.75) - 0.11, 3.3 - 0.75 + 0.11, (3.05 - 1.75) + 0.11, %DLOffset%, %DLOffset%, 0, 0

	#3. Panels on walls
	Set WPTex = %Prefix%ElevWallPanel
	if[%elevator% > 19] Set WPTex = %Prefix%ElevWallPanel2
	Set WPanelHeight = 8

		#Front/back panels
		if[%elevator% > 19] CreateWallBox2 elevator, Panel_F1, %WPTex%, 0, -3.05 + 0.01, 3, 0.02, %WPanelHeight%, 0, 0, 0, false, true, true, true
		if[%elevator% < 20] CreateWallBox2 elevator, Panel_B1, %WPTex%, 0, 3.05 - 0.01, 3, 0.02, %WPanelHeight%, 0, 0, 0, false, true, true, true

		#Left panels
		CreateWallBox2 elevator, Panel_L1, %WPTex%, -3.3 + 0.01, 0, 0.02, 2, %WPanelHeight%, 0, 0, 0, false, true, true, true

		#Right panels
		CreateWallBox2 elevator, Panel_R1, %WPTex%, 3.3 - 0.01, 0, 0.02, 2, %WPanelHeight%, 0, 0, 0, false, true, true, true
<EndElevators>

