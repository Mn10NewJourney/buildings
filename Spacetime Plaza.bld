	#Set textures and dimensions
	M10_ElevCabTex(ElevExt, %Prefix%ElevFloor2, %Prefix%ElevCeiling, %Prefix%ElevWall, %Prefix%ElevWall)
	M10_ElevDimensions(7, 6.5, 8, 0.2, 0.2, true, true, true, false)
