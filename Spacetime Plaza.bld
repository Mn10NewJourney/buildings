	if[%floor% ! 8] AddWall EA1FrontRailB, %5%%Suffix%, 0.5, 210 + 15, -180, 240, -180, %RailingHeight%, %RailingHeight%, %RailingOffset%, %RailingOffset%, 0, 0, true
	if[%floor% ! 8] AddWall EA1FrontRail_Mid, %5%%Suffix%, 0.5, 210 - 15, -180 - 8.5, 210 + 15, -180 - 8.5, %RailingHeight%, %RailingHeight%, %RailingOffset%, %RailingOffset%, 0, 0, true

	if[%floor% = 6] AddWall EA1FrontRail_Left, %5%%Suffix%, 0.5, 210 - 15, -189, 210 - 15, -184.5, %RailingHeight%, %RailingHeight%, %RailingOffset%, %RailingOffset%, 0, 0, true
	WallOrientation = left
	if[%floor% = 6] AddWall EA1FrontRail_Right, %5%%Suffix%, 0.5, 210 + 15, -184.5, 210 + 15, -180.5, %RailingHeight%, %RailingHeight%, %RailingOffset%, %RailingOffset%, 0, 0, true

	WallOrientation = right
	AddWall EA1LeftRail, %5%%Suffix%, 0.5, 180, -180 - 0.5, 180, -60 + 0.5, %RailingHeight%, %RailingHeight%, %RailingOffset%, %RailingOffset%, 0, 0, true
	WallOrientation = left
	AddWall EA1RightRail, %5%%Suffix%, 0.5, 240, -180 - 0.5, 240, -60 + 0.5, %RailingHeight%, %RailingHeight%, %RailingOffset%, %RailingOffset%, 0, 0, true
	AddWall EA1BackRail, %5%%Suffix%, 0.5, 180, -60, 240, -60, %RailingHeight%, %RailingHeight%, %RailingOffset%, %RailingOffset%, 0, 0, true
