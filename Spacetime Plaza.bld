		AddFloorIndicator 19, false, NewOtisInd_Button, front, %Shaft1CX% + 0.15, %Shaft1CZ% - 5.052, 0.3, 0.3, 4.5
<EndFunction>

<Function E20-21HallStation>
	#Shaft Doors
	ElevHallTex_East(false) #Set shaft door and panel textures
	Set StartNo = 20 #Number of the first elevator

	Set ElevDoorTex = %Prefix%ElevDoors
	Set IDP = 3.25 + 0.3

	WallOrientation = left
	AddShaftDoorComponent %StartNo%, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, right, 0.8, 0.6, 0, %IDP%, 2, %IDP%, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo%, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, left, 0.8, 0.6, -2, %IDP%, 0, %IDP%, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo%, 1, %AutoFiller%, false

	WallOrientation = left
	AddShaftDoorComponent %StartNo% + 1, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, right, 0.8, 0.6, 0, %IDP%, 2, %IDP%, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo% + 1, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, left, 0.8, 0.6, -2, %IDP%, 0, %IDP%, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo% + 1, 1, %AutoFiller%, false

	#Door tracks
	AddShaftTrack(20, 8, 5 - 4, 5 + 4, 4.14, 4.34, ElevDoorTrackZ, ElevExt, 0.05, 1, 7)
	AddShaftTrack(21, 8, -5 - 4, -5 + 4, 4.14, 4.34, ElevDoorTrackZ, ElevExt, 0.05, 1, 7)

	#****************************************#

	#Door trims/fillers
	WallTex() #Set filler textures to match with shaft walls
	Set Shaft1CX = 294
	Set Shaft1CZ = 196

		AddDecoObject(Elev20_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, back, true, false, 0.05, 0.2, %Shaft1CX% + 5, %Shaft1CZ% + 5, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		AddDecoObject(Elev21_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, back, true, false, 0.05, 0.2, %Shaft1CX% - 5, %Shaft1CZ% + 5, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)

	#****************************************#

	#Call buttons
		#Button panels
		CreateWallBox2 external, E20-21ExtPanel, %BPanelTexture%, %Shaft1CX%, %Shaft1CZ% + 5.025, 0.6 + 0.2, 0.05, 1 + 0.6 + 0.15, 3.5, 0, 0, false, true, true, true

		#Create buttons
		CallButtonElevators = 20, 21
		CreateCallButtons %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft1CX%, %Shaft1CZ% + 5.051, 4 - 0.3, back, 0.3, 0.6, false, 0, 0

		#Signs
		WallOrientation = left
		DrawWalls = false, true, false, false, false, false
		AddBoxSign(E20-21_FloorSign, Blank, BlankSign%floorid%, Blank, 0, true, false, false, %Shaft1CX%, %Shaft1CZ% + 5.001, 1.5, 1.5, 7 - 0.75 + %interfloorheight%, true)
		AddWall E20-21_HallSign, ElevHallSign, 0, %Shaft1CX% - 0.25, %Shaft1CZ% + 5.001, %Shaft1CX% + 0.25, %Shaft1CZ% + 5.001, 0.75, 0.75, 2.6, 2.6, 0, 0, false

	#****************************************#

	#Indicators above call buttons
		#Background
		Set WH = 0.6	
		Set WO = 4.5 + %interfloorheight%
		DrawWalls = false, true, false, false, false, false
		AddWall E20-21-PA-IndBG, NewOtisInd_BG, 0, %Shaft1CX% - 0.3, %Shaft1CZ% + 5.051, %Shaft1CX% + 0.3, %Shaft1CZ% + 5.051, %WH%, %WH%, %WO%, %WO%, 0, 0, true
	
		#Directional arrows
		AddDirectionalIndicator 20, false, true, true, true, Blank, NewOtisArrow_Blank, NewOtisArrow_LitUp, NewOtisArrow_Blank, NewOtisArrow_LitDown, %Shaft1CX% + 0.15, %Shaft1CZ% + 5.051, 4.5 + 0.3 + 0.15 - 0.125, back, 0.2, 0.25, false, 0, 0
		AddDirectionalIndicator 21, false, true, true, true, Blank, NewOtisArrow_Blank, NewOtisArrow_LitUp, NewOtisArrow_Blank, NewOtisArrow_LitDown, %Shaft1CX% - 0.15, %Shaft1CZ% + 5.051, 4.5 + 0.3 + 0.15 - 0.125, back, 0.2, 0.25, false, 0, 0
	
		#Floor indicators
		AddFloorIndicator 20, false, NewOtisInd_Button, back, %Shaft1CX% + 0.15, %Shaft1CZ% + 5.052, 0.3, 0.3, 4.5
		AddFloorIndicator 21, false, NewOtisInd_Button, back, %Shaft1CX% - 0.15, %Shaft1CZ% + 5.052, 0.3, 0.3, 4.5
<EndFunction>

<Function E22-23HallStation>
	#Shaft Doors
	ElevHallTex_East(true) #Set shaft door and panel textures
	Set StartNo = 22 #Number of the first elevator

	Set ElevDoorTex = %Prefix%ElevDoors
	Set IDP = -4.64 - 0.4

		WallOrientation = right
		AddShaftDoorComponent %StartNo%, 1, 2Speed_Fast, %DoorTexture%, %DoorTexture%, 0.15, left, 0.8, 0.6, %IDP%, 2.75 - (2.25 * 1), %IDP%, 2.75, 7, 0, -1, 0, -1, 0
		AddShaftDoorComponent %StartNo%, 1, 2Speed_Slow, %DoorTexture%2, %DoorTexture%2, 0.15, left, 0.4, 0.3, %IDP% - (0.15 * 1), 2.75 - (2.25 * 2), %IDP% - (0.15 * 1), 2.75 - (2.25 * 1), 7, 0, 0, 0, 0, 0
		FinishShaftDoor %StartNo%, 1, %AutoFiller%, false

		WallOrientation = right
		AddShaftDoorComponent %StartNo% + 1, 1, 2Speed_Fast, %DoorTexture%, %DoorTexture%, 0.15, right, 0.8, 0.6, %IDP%, -2.75, %IDP%, -2.75 + (2.25 * 1), 7, 0, 0, 0, 0, 0
		AddShaftDoorComponent %StartNo% + 1, 1, 2Speed_Slow, (%DoorTexture%)2, (%DoorTexture%)2, 0.15, right, 0.4, 0.3, %IDP% - (0.15 * 1), -2.75 + (2.25 * 1), %IDP% - (0.15 * 1), -2.75 + (2.25 * 2), 7, 0, -1, 0, -1, 0
		FinishShaftDoor %StartNo% + 1, 1, %AutoFiller%, false

	#Door tracks
	AddShaftTrack(22, 9, -5.34, -5.04, -4 - 4.5, -4 + 2.25, ElevDoorTrackX, ElevExt, 0.05, 1, 7)
	AddShaftTrack(23, 9, -5.34, -5.04, 4 - 2.25, 4 + 4.5, ElevDoorTrackX, ElevExt, 0.05, 1, 7)

		#Top fillers
		AddShaftTrack(22, 9, -5.34, -5.34 + 0.15, -4, -4 + 2.25, %DoorTrimTexture%, ElevExt, 0.05, 2, 7)
		AddShaftTrack(23, 9, -5.34, -5.34 + 0.15, 4 - 2.25, 4, %DoorTrimTexture_Top%, ElevExt, 0.05, 2, 7)

	#Gap fillers
		WallOrientation = left
		DrawWalls = true, true, true, true, true, true
		TextureOverride ElevExt, ElevExt, %DoorTrimTexture%, %DoorTrimTexture%, ElevExt, ElevExt
		AddShaftWall 9, GapFiller_Elev22-23, ElevExt, 0.15 * 2, -5.34, -4 + 2.25, -5.34, 4 - 2.25, 7, 7, %interfloorheight%, %interfloorheight%, 0, 0

	#****************************************#

	#Door trims/fillers
	TexPrefix() #Set filler textures to match with shaft walls
	Set Shaft1CX = 133
	Set Shaft1CZ = -190

		AddDecoObject(E22_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, left, true, false, 0.05, 0.2, %Shaft1CX% - 6, %Shaft1CZ% - 4, 4.5, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		AddDecoObject(E23_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, left, true, false, 0.05, 0.2, %Shaft1CX% - 6, %Shaft1CZ% + 4, 4.5, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)

	#****************************************#

	#Call buttons
		#Button panels
		CreateWallBox2 external, E22-23ExtPanel, %BPanelTexture%, %Shaft1CX% - 6.025, %Shaft1CZ%, 0.05, 0.6 + 0.2, 1 + 0.6 + 0.15, 3.5, 0, 0, false, true, true, true

		#Create buttons
		CallButtonElevators = 22, 23
		CreateCallButtons %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft1CX% - 6.051, %Shaft1CZ%, 4 - 0.3, left, 0.3, 0.6, false, 0, 0

		#Signs
		WallOrientation = right
		DrawWalls = true, false, false, false, false, false
		AddBoxSign(E22-23_FloorSign, BlankSign%floorid%, Blank, Blank, 0, false, false, false, %Shaft1CX% - 6.001, %Shaft1CZ%, 1.5, 1.5, 7 - 0.75 + %interfloorheight%, true)
		AddWall E22-23_HallSign, ElevHallSign, 0, %Shaft1CX% - 6.001, %Shaft1CZ% - 0.25, %Shaft1CX% - 6.001, %Shaft1CZ% + 0.25, 0.75, 0.75, 2.6, 2.6, 0, 0, false

	#****************************************#

	#Indicators above call buttons
		#Background
		Set WH = 0.6	
		Set WO = 4.5 + %interfloorheight%
		DrawWalls = true, false, false, false, false, false
		AddWall E16-17-PA-IndBG, NewOtisInd_BG, 0, %Shaft1CX% - 6.051, %Shaft1CZ% - 0.3, %Shaft1CX% - 6.051, %Shaft1CZ% + 0.3, %WH%, %WH%, %WO%, %WO%, 0, 0, true
	
		#Directional arrows
		AddDirectionalIndicator 22, false, true, true, true, Blank, NewOtisArrow_Blank, NewOtisArrow_LitUp, NewOtisArrow_Blank, NewOtisArrow_LitDown, %Shaft1CX% - 6.051, %Shaft1CZ% - 0.15, 4.5 + 0.3 + 0.15 - 0.125, left, 0.2, 0.25, false, 0, 0
		AddDirectionalIndicator 23, false, true, true, true, Blank, NewOtisArrow_Blank, NewOtisArrow_LitUp, NewOtisArrow_Blank, NewOtisArrow_LitDown, %Shaft1CX% - 6.051, %Shaft1CZ% + 0.15, 4.5 + 0.3 + 0.15 - 0.125, left, 0.2, 0.25, false, 0, 0
	
		#Floor indicators
		AddFloorIndicator 22, false, NewOtisInd_Button, left, %Shaft1CX% - 6.052, %Shaft1CZ% - 0.15, 0.3, 0.3, 4.5
		AddFloorIndicator 23, false, NewOtisInd_Button, left, %Shaft1CX% - 6.052, %Shaft1CZ% + 0.15, 0.3, 0.3, 4.5
<EndFunction>

