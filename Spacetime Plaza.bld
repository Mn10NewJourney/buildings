<Elevators 11 to 13>
	Set Prefix = Parking

	#Set textures and dimensions
	M10_ElevCabTex(ElevExt, %Prefix%ElevFloor, %Prefix%ElevCeiling, %Prefix%ElevWall, %Prefix%ElevWall)
	M10_ElevDimensions(6.5, 7, 8, 0.2, 0.2, true, false, true, true)
	M10_ElevPanels(%Prefix%ElevPanelMain, %Prefix%ElevPanelTop, 1.5, 1.5, 1, 0.2, false, true, false, false)

	#Finish elevator assembly
	M10_ElevInterior()
	#--------------------
	#Car Doors
	Set ElevDoorTex = %Prefix%ElevDoors
	Set IDP = -3.25

	WallOrientation = right
	AddDoorComponent 1, Left, %ElevDoorTex%, %ElevDoorTex%, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	AddDoorComponent 1, Right, %ElevDoorTex%2, %ElevDoorTex%2, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	FinishDoors 1, false, false

		#Door track
		FloorOrientation = top
		DrawWalls = true, true, true, true, true, true
		TextureOverride ElevExt, ElevDoorTrackX, ElevExt, ElevExt, ElevExt, ElevExt
		AddFloor DoorTrack, ElevDoorTrackX, 0.05, %IDP% - 0.2, -2 - (2 * 1), %IDP%, 2 + (2 * 1), 0, 0, 0, 0
	#--------------------
	#Right Panel
	Set P1_PositionX = -3.05 + 0.001
	Set P1_PositionZ = 2.65

		#Panels
		CreateWallBox2 elevator, RightPB, ElevPanel, %P1_PositionX% - 0.001 + 0.025, %P1_PositionZ%, 0.05, 0.8, 4.75, 2.25, 0, 0, false, true, true, true
		CreatePanel , 11, 2, right, %P1_PositionX% + 0.05, %P1_PositionZ%, 0.15, 0.15, 0.5, 0.25, 3.75, 0, 0
		CreatePanel , 11, 1, right, %P1_PositionX% + 0.05, %P1_PositionZ%, 0.15, 0.15, 0.5, 0.25, 3.75, 0, 0

			#Buttons
			BtnPanelTowerPK(1)
			
	#Left Panel
	Set P2_PositionX = -3.05 + 0.001
	Set P2_PositionZ = -2.65

		#Panels
		CreateWallBox2 elevator, RightPB, ElevPanel, %P2_PositionX% - 0.001 + 0.025, %P2_PositionZ%, 0.05, 0.8, 4.75, 2.25, 0, 0, false, true, true, true
		CreatePanel , 11, 2, right, %P2_PositionX% + 0.05, %P2_PositionZ%, 0.15, 0.15, 0.5, 0.25, 3.75, 0, 0
		CreatePanel , 11, 1, right, %P2_PositionX% + 0.05, %P2_PositionZ%, 0.15, 0.15, 0.5, 0.25, 3.75, 0, 0

			#Buttons
			BtnPanelTowerPK(3)
	#--------------------
	#Elevator number sign
	DrawWalls = false, true, false, false, false, false
	AddWall ElevNo%elevator%_Inside, IN_ElevNo%elevator%, 0, -3.05 + 0.001, 0 - 0.25, -3.05 + 0.001, 0 + 0.25, 0.5, 0.5, 7.05, 7.05, 0, 0
	#--------------------
	#Indicator sets
	Set IndOffset = 6

		#Right
		DrawWalls = false, true, false, false, false, false
		AddWall RightIndBack1, IndBack2, 0, %P1_PositionX% + 0.051, %P1_PositionZ% - 0.3, %P1_PositionX% + 0.051, %P1_PositionZ% + 0.3, 0.95, 0.95, %IndOffset% - 0.15, %IndOffset% - 0.15, 0, 0
		AddWall RightIndBack2, IndBack, 0, %P1_PositionX% + 0.052, %P1_PositionZ% - 0.2, %P1_PositionX% + 0.052, %P1_PositionZ% + 0.2, 0.8, 0.8, %IndOffset%, %IndOffset%, 0, 0

		AddFloorIndicator Ind_Button, right, %P1_PositionX% + 0.053, %P1_PositionZ%, 0.4, 0.4, %IndOffset%
		AddDirectionalIndicator true, true, true, IndBack, ArrowUp, ArrowUpLit, ArrowDown, ArrowDownLit, %P1_PositionX% + 0.053, %P1_PositionZ%, %IndOffset% + 0.375, right, 0.45, 0.4, false, 0, 0

		#Left
		DrawWalls = false, true, false, false, false, false
		AddWall LeftIndBack1, IndBack2, 0, %P2_PositionX% + 0.051, %P2_PositionZ% - 0.3, %P2_PositionX% + 0.051, %P2_PositionZ% + 0.3, 0.95, 0.95, %IndOffset% - 0.15, %IndOffset% - 0.15, 0, 0
		AddWall LeftIndBack2, IndBack, 0, %P2_PositionX% + 0.052, %P2_PositionZ% - 0.2, %P2_PositionX% + 0.052, %P2_PositionZ% + 0.2, 0.8, 0.8, %IndOffset%, %IndOffset%, 0, 0

		AddFloorIndicator Ind_Button, right, %P2_PositionX% + 0.053, %P2_PositionZ%, 0.4, 0.4, %IndOffset%
		AddDirectionalIndicator true, true, true, IndBack, ArrowUp, ArrowUpLit, ArrowDown, ArrowDownLit, %P2_PositionX% + 0.053, %P2_PositionZ%, %IndOffset% + 0.375, right, 0.45, 0.4, false, 0, 0
	#--------------------
	#Shaft components
	DrawWalls = true, true, true, true, true, true
		#Ropes
		RopePosition = 0, 8 + 0.2, 0
		RopeTexture = Ropes
	
		#Counterweight
		Set Position = 3.25 + 0.75

		CreateCounterweight CWeight_Frame, CWeight, %Position%, 0, 0.5, 6, 2, 0.5
	
		#Rails
		AddRails ElevRail, ElevRailSide, 0, 0, true, 3.5 + 0.06, 0.1
		AddRails ElevRail, ElevRailSide, %Position%, 0, true, 1 + 0.06, 0.1
<EndElevators>

<Elevators 8 to 13>
	#DETAILED INTERIORS
	#1. Lights
	CreateWallBox2 elevator, E%elevator%_Light1/1, %Prefix%ElevCeilingLight, 0 - 2, -3.3 + 0.8, 1.8, 1.5, 0.1, 8 - 0.1, 0, 0, false, true, true, true
	CreateWallBox2 elevator, E%elevator%_Light1/2, %Prefix%ElevCeilingLight, 0, -3.3 + 0.8, 1.8, 1.5, 0.1, 8 - 0.1, 0, 0, false, true, true, true
	CreateWallBox2 elevator, E%elevator%_Light1/3, %Prefix%ElevCeilingLight, 0 + 2, -3.3 + 0.8, 1.8, 1.5, 0.1, 8 - 0.1, 0, 0, false, true, true, true
	CreateWallBox2 elevator, E%elevator%_Light2/1, %Prefix%ElevCeilingLight, 0 - 2, 3.3 - 0.8, 1.8, 1.5, 0.1, 8 - 0.1, 0, 0, false, true, true, true
	CreateWallBox2 elevator, E%elevator%_Light2/2, %Prefix%ElevCeilingLight, 0, 3.3 - 0.8, 1.8, 1.5, 0.1, 8 - 0.1, 0, 0, false, true, true, true
	CreateWallBox2 elevator, E%elevator%_Light2/3, %Prefix%ElevCeilingLight, 0 + 2, 3.3 - 0.8, 1.8, 1.5, 0.1, 8 - 0.1, 0, 0, false, true, true, true

	#2. Panels on walls
	Set WPTex = %Prefix%ElevWallPanel
	Set WPanelHeight = 8 - 0.5

		#Front panels
		CreateWallBox2 elevator, Panel_B1, %WPTex%, 0 - (6.1 * 1/4), -3.3 + 0.01, (6.1 * 1/2) - 0.3, 0.02, %WPanelHeight%, 0.25, 0, 0, false, true, true, true
		CreateWallBox2 elevator, Panel_B2, %WPTex%, 0 + (6.1 * 1/4), -3.3 + 0.01, (6.1 * 1/2) - 0.3, 0.02, %WPanelHeight%, 0.25, 0, 0, false, true, true, true

		#Back panels
		CreateWallBox2 elevator, Panel_B1, %WPTex%, 0 - (6.1 * 1/4), 3.3 - 0.01, (6.1 * 1/2) - 0.3, 0.02, %WPanelHeight%, 0.25, 0, 0, false, true, true, true
		CreateWallBox2 elevator, Panel_B2, %WPTex%, 0 + (6.1 * 1/4), 3.3 - 0.01, (6.1 * 1/2) - 0.3, 0.02, %WPanelHeight%, 0.25, 0, 0, false, true, true, true

		#Left panels
		if[%elevator% < 11] CreateWallBox2 elevator, Panel_L1, %WPTex%, -3.05 + 0.01, 0 - (6.6 * 1/4), 0.02, (6.6 * 1/2) - 0.3, %WPanelHeight%, 0.25, 0, 0, false, true, true, true
		if[%elevator% < 11] CreateWallBox2 elevator, Panel_L2, %WPTex%, -3.05 + 0.01, 0 + (6.6 * 1/4), 0.02, (6.6 * 1/2) - 0.3, %WPanelHeight%, 0.25, 0, 0, false, true, true, true

		#Right panels
		if[%elevator% > 10] CreateWallBox2 elevator, Panel_R1, %WPTex%, 3.05 - 0.01, 0 - (6.6 * 1/4), 0.02, (6.6 * 1/2) - 0.3, %WPanelHeight%, 0.25, 0, 0, false, true, true, true
		if[%elevator% > 10] CreateWallBox2 elevator, Panel_R2, %WPTex%, 3.05 - 0.01, 0 + (6.6 * 1/4), 0.02, (6.6 * 1/2) - 0.3, %WPanelHeight%, 0.25, 0, 0, false, true, true, true
<EndElevators>

#HALL STATIONS
#Set textures (Interior Elevators)
<Function ElevHallTex>
	TexPrefix() #Set prefixes for shaft doors

	#Shaft doors
	Set DoorTexture = %5%ShaftDoors

	#Use automatic filler walls or not
	Set AutoFiller = false

	#Door trims
		#Sides
		Set DoorTrimTexture = %DoorTexture%_Trim

		#Top
		Set DoorTrimTexture_Top = %DoorTrimTexture%

	#Deco dimensions
		Set SideDecoH = 7.2
		Set TopDecoH = 0.2
		if[%floor% > 5] Set SideDecoH = %height%
		if[%floor% > 5] Set TopDecoH = %height% - 7

	#Call button panels
	Set BPanelTexture = ElevExtPanels
	Set ButtonPrefix = Button

	#Lantern panels
	Set LPanelTexture = %BPanelTexture%
	Set LanternPrefix = Lantern

		#Lateral offset for lantern panels
		Set ExtraLateralOffset = 0
		if[%floor% > 5] Set ExtraLateralOffset = 0.01
<EndFunction>

#Set textures (Glass Elevators)
<Function ElevHallTex_Glass>
	TexPrefix() #Set prefixes for shaft doors
	Set 5 = Glass #Override

	#Shaft doors
	Set DoorTexture = %5%ShaftDoors

	#Use automatic filler walls or not
	Set AutoFiller = false

	#Door trims
		#Sides
		Set DoorTrimTexture = %DoorTexture%_Trim

		#Top
		Set DoorTrimTexture_Top = %DoorTrimTexture%

	#Deco dimensions
		Set SideDecoH = 7.2
		Set TopDecoH = 0.2

	#Call button panels
	Set BPanelTexture = ElevExtPanels
	Set ButtonPrefix = Button

	#Lantern panels
	Set LPanelTexture = %BPanelTexture%
	Set LanternPrefix = Lantern

		#Lateral offset for lantern panels
		Set ExtraLateralOffset = 0
<EndFunction>

#Set textures (Parking Elevators)
<Function ElevHallTex_Parking>
	TexPrefix() #Set prefixes for shaft doors

	#Shaft doors
	if[%floor% < 0] Set DoorTexture = %5%ShaftDoors
	if[%floor% > -1] Set DoorTexture = %LobbyPrefix%ShaftDoors

	#Use automatic filler walls or not
	Set AutoFiller = false

	#Door trims
		#Sides
		Set DoorTrimTexture = %DoorTexture%_Trim

		#Top
		Set DoorTrimTexture_Top = %DoorTrimTexture%

	#Deco dimensions
		Set SideDecoH = 7.2
		Set TopDecoH = 0.2
		if[%floor% > -1 & %floor% < 6] Set SideDecoH = %height%
		if[%floor% > -1 & %floor% < 6] Set TopDecoH = %height% - 7

	#Call button panels
	Set BPanelTexture = ElevExtPanels
	Set ButtonPrefix = Button

	#Lantern panels
	Set LPanelTexture = %BPanelTexture%
	Set LanternPrefix = Lantern

		#Lateral offset for lantern panels
		Set ExtraLateralOffset = 0
		if[%floor% > -1 & %floor% < 6] Set ExtraLateralOffset = 0.01
<EndFunction>


#South Elevators
<Floors -2 to 3>
	#Shaft Doors
	ElevHallTex() #Set shaft door and panel textures
	Set StartNo = 1 #Number of the first elevator

	Set ElevDoorTex = %Prefix%ElevDoors
	Set IDP = 3.25 + 0.3

	WallOrientation = left
	AddShaftDoorComponent %StartNo%, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo%, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo%, 1, %AutoFiller%, false

	WallOrientation = left
	AddShaftDoorComponent %StartNo% + 1, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo% + 1, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo% + 1, 1, %AutoFiller%, false

	WallOrientation = left
	AddShaftDoorComponent %StartNo% + 2, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo% + 2, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo% + 2, 1, %AutoFiller%, false

	#Door tracks
	AddShaftTrack(1, 1, 4.14, 4.34, -10 - 4, -10 + 4, ElevDoorTrackX, ElevExt, 0.05, 1, 7)
	AddShaftTrack(2, 1, 4.14, 4.34, 0 - 4, 0 + 4, ElevDoorTrackX, ElevExt, 0.05, 1, 7)
	AddShaftTrack(3, 1, 4.14, 4.34, 10 - 4, 10 + 4, ElevDoorTrackX, ElevExt, 0.05, 1, 7)

	#****************************************#

	#Door trims/fillers
	WallTex() #Set filler textures to match with shaft walls
	Set Shaft1CX = -85 #1st shaft for elevator bank
	Set Shaft1CZ = -165

		AddDecoObject(Elev1_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, right, true, false, 0.05, 0.2, %Shaft1CX% + 5, %Shaft1CZ% - 10, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		AddDecoObject(Elev2_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, right, true, false, 0.05, 0.2, %Shaft1CX% + 5, %Shaft1CZ% - 0, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		AddDecoObject(Elev3_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, right, true, false, 0.05, 0.2, %Shaft1CX% + 5, %Shaft1CZ% + 10, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)

	#****************************************#

	#Call buttons
		#Button panels
		CreateWallBox2 external, E1-3ExtPanel1, %BPanelTexture%, %Shaft1CX% + 5 + 0.025, %Shaft1CZ% - 5, 0.05, 0.5, 1, 3.5, 0, 0, false, true, true, true
		CreateWallBox2 external, E1-3ExtPanel2, %BPanelTexture%, %Shaft1CX% + 5 + 0.025, %Shaft1CZ% + 5, 0.05, 0.5, 1, 3.5, 0, 0, false, true, true, true

		#Create buttons
		CallButtonElevators = 1, 2, 3
		CreateCallButtons KW_Sounds/konecallbuttonbeep.wav, KW_Sounds/konecallbuttonbeep.wav, %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft1CX% + 5 + 0.051, %Shaft1CZ% - 5, 4 - 0.4, right, 0.4, 0.8, false, 0, 0
		CreateCallButtons KW_Sounds/konecallbuttonbeep.wav, KW_Sounds/konecallbuttonbeep.wav, %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft1CX% + 5 + 0.051, %Shaft1CZ% + 5, 4 - 0.4, right, 0.4, 0.8, false, 0, 0

		#Signs
		WallOrientation = left
		DrawWalls = false, true, false, false, false, false
		AddBoxSign(E1-3_FS1, Blank, BlankSign%floorid%, Blank, 0, false, false, false, %Shaft1CX% + 5.001, %Shaft1CZ% - 5, 1.5, 1.5, 6.5 - 0.75 + %interfloorheight%, true)
		AddBoxSign(E1-3_FS2, Blank, BlankSign%floorid%, Blank, 0, false, false, false, %Shaft1CX% + 5.001, %Shaft1CZ% + 5, 1.5, 1.5, 6.5 - 0.75 + %interfloorheight%, true)

		AddWall E1-3HallSign, ElevHallSign, 0, %Shaft1CX% + 5.001, %Shaft1CZ% - 5 - 0.25, %Shaft1CX% + 5.001, %Shaft1CZ% - 5 + 0.25, 0.75, 0.75, 2.6, 2.6, 0, 0, false

	#****************************************#

	#Indicator sets
	Set Offset = 7.5

		#Elevator 1
		CreateWallBox2 external, E1LanternPanel, %LPanelTexture%, %Shaft1CX% + 5 + 0.025 + %ExtraLateralOffset%, %Shaft1CZ% - 10, 0.05, 1.2, 0.6, %Offset%, 0, 0, false, true, true, true
		DrawWalls = false, true, false, false, false, false
		AddWall E1BlankInd, IndBack, 0, %Shaft1CX% + 5.052, %Shaft1CZ% - 10 - 0.5, %Shaft1CX% + 5.052, %Shaft1CZ% - 10, 0.5, 0.5, %Offset% + 0.05, %Offset% + 0.05, 0, 0, false

		AddDirectionalIndicator 1, true, false, true, true, IndBack, %LanternPrefix%Up, %LanternPrefix%UpLit, %LanternPrefix%Down, %LanternPrefix%DownLit, 3.75 + 0.66 + %ExtraLateralOffset% + 0.053, 0 - 0.25, %Offset% + 0.05, right, 0.65, 0.5, false, 0, 0
		AddFloorIndicator 1, true, Ind_Button, right, 3.75 + 0.66 + %ExtraLateralOffset% + 0.053, 0 + 0.25, 0.5, 0.5, %Offset% + 0.05

		#Elevator 2
		CreateWallBox2 external, E2LanternPanel, %LPanelTexture%, %Shaft1CX% + 5 + 0.025 + %ExtraLateralOffset%, %Shaft1CZ% - 0, 0.05, 1.2, 0.6, %Offset%, 0, 0, false, true, true, true
		DrawWalls = false, true, false, false, false, false
		AddWall E2BlankInd, IndBack, 0, %Shaft1CX% + 5.052, %Shaft1CZ% - 0 - 0.5, %Shaft1CX% + 5.052, %Shaft1CZ% - 0, 0.5, 0.5, %Offset% + 0.05, %Offset% + 0.05, 0, 0, false

		AddDirectionalIndicator 2, true, false, true, true, IndBack, %LanternPrefix%Up, %LanternPrefix%UpLit, %LanternPrefix%Down, %LanternPrefix%DownLit, 3.75 + 0.66 + %ExtraLateralOffset% + 0.053, 0 - 0.25, %Offset% + 0.05, right, 0.65, 0.5, false, 0, 0
		AddFloorIndicator 2, true, Ind_Button, right, 3.75 + 0.66 + %ExtraLateralOffset% + 0.053, 0 + 0.25, 0.5, 0.5, %Offset% + 0.05

		#Elevator 3
		CreateWallBox2 external, E3LanternPanel, %LPanelTexture%, %Shaft1CX% + 5 + 0.025 + %ExtraLateralOffset%, %Shaft1CZ% + 10, 0.05, 1.2, 0.6, %Offset%, 0, 0, false, true, true, true
		DrawWalls = false, true, false, false, false, false
		AddWall E3BlankInd, IndBack, 0, %Shaft1CX% + 5.052, %Shaft1CZ% + 10 - 0.5, %Shaft1CX% + 5.052, %Shaft1CZ% + 10, 0.5, 0.5, %Offset% + 0.05, %Offset% + 0.05, 0, 0, false

		AddDirectionalIndicator 3, true, false, true, true, IndBack, %LanternPrefix%Up, %LanternPrefix%UpLit, %LanternPrefix%Down, %LanternPrefix%DownLit, 3.75 + 0.66 + %ExtraLateralOffset% + 0.053, 0 - 0.25, %Offset% + 0.05, right, 0.65, 0.5, false, 0, 0
		AddFloorIndicator 3, true, Ind_Button, right, 3.75 + 0.66 + %ExtraLateralOffset% + 0.053, 0 + 0.25, 0.5, 0.5, %Offset% + 0.05
<EndFloors>

#Central Elevators
#1. Express Car
<Function E4HallStation>
	#Shaft Doors
	ElevHallTex_Glass() #Set shaft door and panel textures
	Set StartNo = 4 #Number of the first elevator
	Set ElevDoorTex = %Prefix%ElevDoors
	Set IDP = 1.92 + 0.3

	WallOrientation = left
	AddShaftDoorComponent %StartNo%, 1, Left, %DoorTexture%, %DoorTexture%Side, 0.2, right, 0.8, 0.6, 0, %IDP%, 2, %IDP%, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo%, 1, Right, %DoorTexture%2, %DoorTexture%2Side, 0.2, left, 0.8, 0.6, -2, %IDP%, 0, %IDP%, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo%, 1, %AutoFiller%, false


	#Door tracks
	AddShaftTrack(4, 2, 15 - 4, 15 + 4, 4.14, 4.34, ElevDoorTrackZ, ElevExt, 0.05, 1, 7)

	#****************************************#

	#Door trims/fillers
	WallTex() #Set filler textures to match with shaft walls
	Set Shaft1CX = 5 #1st shaft for elevator bank
	Set Shaft1CZ = 140

		AddDecoObject(Elev4_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, back, true, false, 0.05, 0.2, %Shaft1CX% + 15, %Shaft1CZ% + 5, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)

	#****************************************#

	#Call buttons
		#Button panels
		CreateWallBox2 external, E4ExtPanel, %BPanelTexture%, %Shaft1CX% + 15 + 2 + 1.25, %Shaft1CZ% + 5 + 0.025, 0.5, 0.05, 1, 3.5, 0, 0, false, true, true, true

		#Create buttons
		CallButtonElevators = 4
		CreateCallButtons KW_Sounds/konecallbuttonbeep.wav, KW_Sounds/konecallbuttonbeep.wav, %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft1CX% + 15 + 2 + 1.25, %Shaft1CZ% + 5.051, 4 - 0.4, back, 0.4, 0.8, false, 0, 0

		#Signs
		WallOrientation = left
		DrawWalls = false, true, false, false, false, false
		AddWall E4HallSign, ElevHallSign, 0, %Shaft1CX% + 15 + 2 + 1.25 - 0.25, %Shaft1CZ% + 5.001, %Shaft1CX% + 15 + 2 + 1.25 + 0.25, %Shaft1CZ% + 5.001, 0.75, 0.75, 2.6, 2.6, 0, 0, false

	#****************************************#

	#Indicator sets
	Set Offset = 7.5
	Set BoxWidth = 1.2
	if[%floor% ! 0] Set BoxWidth = 0.6
	Set IndWidth = 1
	if[%floor% ! 0] Set IndWidth = 0.5
	Set IndWidth2 = %IndWidth% / 2

	Set IEP = 0.25 #IEP = Indicator Extra Position
	if[%floor% ! 0] Set IEP = 0

		#Elevator 4
		CreateWallBox2 external, E5LanternPanel, %LPanelTexture%, %Shaft1CX% + 15, %Shaft1CZ% + 5 + 0.025 + %ExtraLateralOffset%, %BoxWidth%, 0.05, 0.6, %Offset%, 0, 0, false, true, true, true

		DrawWalls = false, true, false, false, false, false
		AddWall E4BlankInd, IndBack, 0, %Shaft1CX% + 15 - %IndWidth2%, %Shaft1CZ% + 5.052, %Shaft1CX% + 15 + %IndWidth2%, %Shaft1CZ% + 5.052, 0.5, 0.5, %Offset% + 0.05, %Offset% + 0.05, 0, 0, false

		AddDirectionalIndicator 4, true, false, true, true, IndBack, %LanternPrefix%Up, %LanternPrefix%UpLit, %LanternPrefix%Down, %LanternPrefix%DownLit, 0 + %IEP%, 2.42 + 0.66 + %ExtraLateralOffset% + 0.053, %Offset% + 0.05, back, 0.65, 0.5, false, 0, 0
		AddFloorIndicator 4, true, Ind_Button, back, 0 - %IEP%, 2.42 + 0.66 + %ExtraLateralOffset% + 0.053, 0.5, 0.5, %Offset% + 0.05
<EndFunction>

#2. Local Cars
<Function E5-7HallStation>
	#Shaft Doors
	ElevHallTex_Glass() #Set shaft door and panel textures
	Set StartNo = 5 #Number of the first elevator
	Set ElevDoorTex = %Prefix%ElevDoors
	Set IDP = 1.92 + 0.3

	WallOrientation = left
	AddShaftDoorComponent %StartNo%, 1, Left, %DoorTexture%, %DoorTexture%Side, 0.2, right, 0.8, 0.6, 0, %IDP%, 2, %IDP%, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo%, 1, Right, %DoorTexture%2, %DoorTexture%2Side, 0.2, left, 0.8, 0.6, -2, %IDP%, 0, %IDP%, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo%, 1, %AutoFiller%, false

	WallOrientation = left
	AddShaftDoorComponent %StartNo% + 1, 1, Left, %DoorTexture%, %DoorTexture%Side, 0.2, right, 0.8, 0.6, 0, %IDP%, 2, %IDP%, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo% + 1, 1, Right, %DoorTexture%2, %DoorTexture%2Side, 0.2, left, 0.8, 0.6, -2, %IDP%, 0, %IDP%, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo% + 1, 1, %AutoFiller%, false

	WallOrientation = left
	AddShaftDoorComponent %StartNo% + 2, 1, Left, %DoorTexture%, %DoorTexture%Side, 0.2, right, 0.8, 0.6, 0, %IDP%, 2, %IDP%, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo% + 2, 1, Right, %DoorTexture%2, %DoorTexture%2Side, 0.2, left, 0.8, 0.6, -2, %IDP%, 0, %IDP%, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo% + 2, 1, %AutoFiller%, false

	#Door tracks
	AddShaftTrack(5, 2, 5 - 4, 5 + 4, 4.14, 4.34, ElevDoorTrackZ, ElevExt, 0.05, 1, 7)
	AddShaftTrack(6, 2, -5 - 4, -5 + 4, 4.14, 4.34, ElevDoorTrackZ, ElevExt, 0.05, 1, 7)
	AddShaftTrack(7, 2, -15 - 4, -15 + 4, 4.14, 4.34, ElevDoorTrackZ, ElevExt, 0.05, 1, 7)

	#****************************************#

	#Door trims/fillers
	WallTex() #Set filler textures to match with shaft walls
	Set Shaft1CX = 5 #1st shaft for elevator bank
	Set Shaft1CZ = 140

		AddDecoObject(Elev5_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, back, true, false, 0.05, 0.2, %Shaft1CX% + 5, %Shaft1CZ% + 5, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		AddDecoObject(Elev6_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, back, true, false, 0.05, 0.2, %Shaft1CX% - 5, %Shaft1CZ% + 5, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		AddDecoObject(Elev7_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, back, true, false, 0.05, 0.2, %Shaft1CX% - 15, %Shaft1CZ% + 5, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)

	#****************************************#

	#Call buttons
		#Button panels
		CreateWallBox2 external, E5-7ExtPanel1, %BPanelTexture%, %Shaft1CX%, %Shaft1CZ% + 5 + 0.025, 0.5, 0.05, 1, 3.5, 0, 0, false, true, true, true
		CreateWallBox2 external, E5-7ExtPanel2, %BPanelTexture%, %Shaft1CX% - 10, %Shaft1CZ% + 5 + 0.025, 0.5, 0.05, 1, 3.5, 0, 0, false, true, true, true

		#Create buttons
		CallButtonElevators = 5, 6, 7
		CreateCallButtons KW_Sounds/konecallbuttonbeep.wav, KW_Sounds/konecallbuttonbeep.wav, %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft1CX%, %Shaft1CZ% + 5.051, 4 - 0.4, back, 0.4, 0.8, false, 0, 0
		CreateCallButtons KW_Sounds/konecallbuttonbeep.wav, KW_Sounds/konecallbuttonbeep.wav, %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft1CX% - 10, %Shaft1CZ% + 5.051, 4 - 0.4, back, 0.4, 0.8, false, 0, 0

		#Signs
		WallOrientation = left
		DrawWalls = false, true, false, false, false, false
		#AddBoxSign(E4-7_FS1, Blank, BlankSign%floorid%, Blank, 0, true, false, false, %Shaft1CX% + 10, %Shaft1CZ% + 5.001, 1.5, 1.5, 6.5 - 0.75 + %interfloorheight%, true)
		AddBoxSign(E4-7_FS2, Blank, BlankSign%floorid%, Blank, 0, true, false, false, %Shaft1CX%, %Shaft1CZ% + 5.001, 1.5, 1.5, 6.5 - 0.75 + %interfloorheight%, true)
		AddBoxSign(E4-7_FS3, Blank, BlankSign%floorid%, Blank, 0, true, false, false, %Shaft1CX% - 10, %Shaft1CZ% + 5.001, 1.5, 1.5, 6.5 - 0.75 + %interfloorheight%, true)

		AddWall E4-7HallSign, ElevHallSign, 0, %Shaft1CX% - 0.25, %Shaft1CZ% + 5.001, %Shaft1CX% + 0.25, %Shaft1CZ% + 5.001, 0.75, 0.75, 2.6, 2.6, 0, 0, false

	#****************************************#

	#Indicator sets
	Set Offset = 7.5
	Set BoxWidth = 1.2
	if[%floor% ! 0] Set BoxWidth = 0.6
	Set IndWidth = 1
	if[%floor% ! 0] Set IndWidth = 0.5
	Set IndWidth2 = %IndWidth% / 2

	Set IEP = 0.25 #IEP = Indicator Extra Position
	if[%floor% ! 0] Set IEP = 0

		#Elevator 5
		CreateWallBox2 external, E5LanternPanel, %LPanelTexture%, %Shaft1CX% + 5, %Shaft1CZ% + 5 + 0.025 + %ExtraLateralOffset%, %BoxWidth%, 0.05, 0.6, %Offset%, 0, 0, false, true, true, true

		DrawWalls = false, true, false, false, false, false
		AddWall E5BlankInd, IndBack, 0, %Shaft1CX% + 5 - %IndWidth2%, %Shaft1CZ% + 5.052, %Shaft1CX% + 5 + %IndWidth2%, %Shaft1CZ% + 5.052, 0.5, 0.5, %Offset% + 0.05, %Offset% + 0.05, 0, 0, false

		AddDirectionalIndicator 5, true, false, true, true, IndBack, %LanternPrefix%Up, %LanternPrefix%UpLit, %LanternPrefix%Down, %LanternPrefix%DownLit, 0 + %IEP%, 2.42 + 0.66 + %ExtraLateralOffset% + 0.053, %Offset% + 0.05, back, 0.65, 0.5, false, 0, 0
		AddFloorIndicator 5, true, Ind_Button, back, 0 - %IEP%, 2.42 + 0.66 + %ExtraLateralOffset% + 0.053, 0.5, 0.5, %Offset% + 0.05


		#Elevator 6
		CreateWallBox2 external, E6LanternPanel, %LPanelTexture%, %Shaft1CX% - 5, %Shaft1CZ% + 5 + 0.025 + %ExtraLateralOffset%, %BoxWidth%, 0.05, 0.6, %Offset%, 0, 0, false, true, true, true

		DrawWalls = false, true, false, false, false, false
		AddWall E6BlankInd, IndBack, 0, %Shaft1CX% - 5 - %IndWidth2%, %Shaft1CZ% + 5.052, %Shaft1CX% - 5 + %IndWidth2%, %Shaft1CZ% + 5.052, 0.5, 0.5, %Offset% + 0.05, %Offset% + 0.05, 0, 0, false

		AddDirectionalIndicator 6, true, false, true, true, IndBack, %LanternPrefix%Up, %LanternPrefix%UpLit, %LanternPrefix%Down, %LanternPrefix%DownLit, 0 + %IEP%, 2.42 + 0.66 + %ExtraLateralOffset% + 0.053, %Offset% + 0.05, back, 0.65, 0.5, false, 0, 0
		AddFloorIndicator 6, true, Ind_Button, back, 0 - %IEP%, 2.42 + 0.66 + %ExtraLateralOffset% + 0.053, 0.5, 0.5, %Offset% + 0.05


		#Elevator 7
		CreateWallBox2 external, E7LanternPanel, %LPanelTexture%, %Shaft1CX% - 15, %Shaft1CZ% + 5 + 0.025 + %ExtraLateralOffset%, %BoxWidth%, 0.05, 0.6, %Offset%, 0, 0, false, true, true, true

		DrawWalls = false, true, false, false, false, false
		AddWall E7BlankInd, IndBack, 0, %Shaft1CX% - 15 - %IndWidth2%, %Shaft1CZ% + 5.052, %Shaft1CX% - 15 + %IndWidth2%, %Shaft1CZ% + 5.052, 0.5, 0.5, %Offset% + 0.05, %Offset% + 0.05, 0, 0, false

		AddDirectionalIndicator 7, true, false, true, true, IndBack, %LanternPrefix%Up, %LanternPrefix%UpLit, %LanternPrefix%Down, %LanternPrefix%DownLit, 0 + %IEP%, 2.42 + 0.66 + %ExtraLateralOffset% + 0.053, %Offset% + 0.05, back, 0.65, 0.5, false, 0, 0
		AddFloorIndicator 7, true, Ind_Button, back, 0 - %IEP%, 2.42 + 0.66 + %ExtraLateralOffset% + 0.053, 0.5, 0.5, %Offset% + 0.05
<EndFunction>

#Elevator 4 (Express)
<Floor 0>
	E4HallStation()
<EndFloor>

<Floor 3>
	E4HallStation()
<EndFloor>

<Floors 6 to 8>
	if[%floor% ! 7] E4HallStation()
<EndFloors>

#Elevator 5-7 (Local)
<Floors 0 to 8>
	if[%floor% ! 7] E5-7HallStation()
<EndFloors>

#Tower Parking Elevators
<Floors -2 to 11>
	#Shaft Doors
	ElevHallTex_Parking() #Set shaft door and panel textures
	Set StartNo = 8 #Number of the first elevator

	Set ElevDoorTex = %Prefix%ElevDoors
	Set IDP = 3.25 + 0.3

	WallOrientation = left
	AddShaftDoorComponent %StartNo%, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo%, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo%, 1, %AutoFiller%, false

	WallOrientation = left
	AddShaftDoorComponent %StartNo% + 1, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo% + 1, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo% + 1, 1, %AutoFiller%, false

	WallOrientation = left
	AddShaftDoorComponent %StartNo% + 2, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo% + 2, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo% + 2, 1, %AutoFiller%, false
	
	Set IDP = -3.25 - 0.3
	WallOrientation = right
	AddShaftDoorComponent %StartNo% + 3, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo% + 3, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo% + 3, 1, %AutoFiller%, false

	Set IDP = -3.25 - 0.3
	WallOrientation = right
	AddShaftDoorComponent %StartNo% + 4, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo% + 4, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo% + 4, 1, %AutoFiller%, false

	WallOrientation = right
	AddShaftDoorComponent %StartNo% + 5, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo% + 5, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo% + 5, 1, %AutoFiller%, false

	#Door tracks
	AddShaftTrack(8, 3, 4.14, 4.34, -10 - 4, -10 + 4, ElevDoorTrackX, ElevExt, 0.05, 1, 7)
	AddShaftTrack(9, 3, 4.14, 4.34, 0 - 4, 0 + 4, ElevDoorTrackX, ElevExt, 0.05, 1, 7)
	AddShaftTrack(10, 3, 4.14, 4.34, 10 - 4, 10 + 4, ElevDoorTrackX, ElevExt, 0.05, 1, 7)
	AddShaftTrack(11, 4, -4.34, -4.14, -10 - 4, -10 + 4, ElevDoorTrackX, ElevExt, 0.05, 1, 7)
	AddShaftTrack(12, 4, -4.34, -4.14, 0 - 4, 0 + 4, ElevDoorTrackX, ElevExt, 0.05, 1, 7)
	AddShaftTrack(13, 4, -4.34, -4.14, 10 - 4, 10 + 4, ElevDoorTrackX, ElevExt, 0.05, 1, 7)

	#****************************************#

	#Door trims/fillers
	WallTex() #Set filler textures to match with shaft walls
	Set Shaft1CX = -205 #1st shaft for elevator bank
	Set Shaft1CZ = 225
	Set Shaft2CX = -180 #1st shaft for elevator bank
	Set Shaft2CZ = 225

		AddDecoObject(PKE1_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, right, true, false, 0.01, 0.2, %Shaft1CX% + 5, %Shaft1CZ% - 10, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		AddDecoObject(PKE2_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, right, true, false, 0.01, 0.2, %Shaft1CX% + 5, %Shaft1CZ% - 0, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		AddDecoObject(PKE3_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, right, true, false, 0.01, 0.2, %Shaft1CX% + 5, %Shaft1CZ% + 10, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)

		AddDecoObject(PKE4_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, left, true, false, 0.01, 0.2, %Shaft2CX% - 5, %Shaft2CZ% - 10, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		AddDecoObject(PKE5_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, left, true, false, 0.01, 0.2, %Shaft2CX% - 5, %Shaft2CZ% - 0, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		AddDecoObject(PKE6_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, left, true, false, 0.01, 0.2, %Shaft2CX% - 5, %Shaft2CZ% + 10, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)

	#****************************************#

	#Call buttons
		#Button panels
		CreateWallBox2 external, PKE_ExtPanel_1/1, %BPanelTexture%, %Shaft1CX% + 5.025, %Shaft1CZ% - 5, 0.05, 0.5, 1, 3.5, 0, 0, false, true, true, true
		CreateWallBox2 external, PKE_ExtPanel_1/2, %BPanelTexture%, %Shaft1CX% + 5.025, %Shaft1CZ% + 5, 0.05, 0.5, 1, 3.5, 0, 0, false, true, true, true
		CreateWallBox2 external, PKE_ExtPanel_2/1, %BPanelTexture%, %Shaft2CX% - 5.025, %Shaft2CZ% - 5, 0.05, 0.5, 1, 3.5, 0, 0, false, true, true, true
		CreateWallBox2 external, PKE_ExtPanel_2/2, %BPanelTexture%, %Shaft2CX% - 5.025, %Shaft2CZ% + 5, 0.05, 0.5, 1, 3.5, 0, 0, false, true, true, true

		#Create buttons
		CallButtonElevators = 8, 9, 10, 11, 12, 13
		CreateCallButtons KW_Sounds/konecallbuttonbeep.wav, KW_Sounds/konecallbuttonbeep.wav, %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft1CX% + 5.051, %Shaft1CZ% - 5, 4 - 0.4, right, 0.4, 0.8, false, 0, 0
		CreateCallButtons KW_Sounds/konecallbuttonbeep.wav, KW_Sounds/konecallbuttonbeep.wav, %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft1CX% + 5.051, %Shaft1CZ% + 5, 4 - 0.4, right, 0.4, 0.8, false, 0, 0

		CreateCallButtons KW_Sounds/konecallbuttonbeep.wav, KW_Sounds/konecallbuttonbeep.wav, %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft2CX% - 5.051, %Shaft2CZ% - 5, 4 - 0.4, left, 0.4, 0.8, false, 0, 0
		CreateCallButtons KW_Sounds/konecallbuttonbeep.wav, KW_Sounds/konecallbuttonbeep.wav, %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft2CX% - 5.051, %Shaft2CZ% + 5, 4 - 0.4, left, 0.4, 0.8, false, 0, 0

		#Signs
		WallOrientation = left
		DrawWalls = false, true, false, false, false, false
		AddBoxSign(PKE_FS1, Blank, BlankSign%floorid%, Blank, 0, false, false, false, %Shaft1CX% + 5.001, %Shaft1CZ% - 5, 1.5, 1.5, 6.5 - 0.75 + %interfloorheight%, true)
		AddBoxSign(PKE_FS2, Blank, BlankSign%floorid%, Blank, 0, false, false, false, %Shaft1CX% + 5.001, %Shaft1CZ% + 5, 1.5, 1.5, 6.5 - 0.75 + %interfloorheight%, true)

		AddWall PKE_HallSign1, ElevHallSign, 0, %Shaft1CX% + 5.001, %Shaft1CZ% - 5 - 0.25, %Shaft1CX% + 5.001, %Shaft1CZ% - 5 + 0.25, 0.75, 0.75, 2.6, 2.6, 0, 0, false

		WallOrientation = right
		DrawWalls = true, false, false, false, false, false
		AddBoxSign(PKE_FS3, BlankSign%floorid%, Blank, Blank, 0, false, false, false, %Shaft2CX% - 5.001, %Shaft2CZ% - 5, 1.5, 1.5, 6.5 - 0.75 + %interfloorheight%, true)
		AddBoxSign(PKE_FS4, BlankSign%floorid%, Blank, Blank, 0, false, false, false, %Shaft2CX% - 5.001, %Shaft2CZ% + 5, 1.5, 1.5, 6.5 - 0.75 + %interfloorheight%, true)

		AddWall PKE_HallSign2, ElevHallSign, 0, %Shaft2CX% - 5.001, %Shaft2CZ% - 5 - 0.25, %Shaft2CX% - 5.001, %Shaft2CZ% - 5 + 0.25, 0.75, 0.75, 2.6, 2.6, 0, 0, false

	#****************************************#

	#Indicator sets
	Set Offset = 7.5

		#Elevator 8
		CreateWallBox2 external, E8LanternPanel, %LPanelTexture%, %Shaft1CX% + 5 + 0.025 + %ExtraLateralOffset%, %Shaft1CZ% - 10, 0.05, 1.2, 0.6, %Offset%, 0, 0, false, true, true, true
		DrawWalls = false, true, false, false, false, false
		AddWall E8BlankInd, IndBack, 0, %Shaft1CX% + 5.052 + %ExtraLateralOffset%, %Shaft1CZ% - 10 - 0.5, %Shaft1CX% + 5.052 + %ExtraLateralOffset%, %Shaft1CZ% - 10, 0.5, 0.5, %Offset% + 0.05, %Offset% + 0.05, 0, 0, false

		AddDirectionalIndicator 8, true, false, true, true, IndBack, %LanternPrefix%Up, %LanternPrefix%UpLit, %LanternPrefix%Down, %LanternPrefix%DownLit, 3.75 + 0.66 + %ExtraLateralOffset% + 0.053, 0 - 0.25, %Offset% + 0.05, right, 0.65, 0.5, false, 0, 0
		AddFloorIndicator 8, true, Ind_Button, right, 3.75 + 0.66 + %ExtraLateralOffset% + 0.053, 0 + 0.25, 0.5, 0.5, %Offset% + 0.05

		#Elevator 9
		CreateWallBox2 external, E9LanternPanel, %LPanelTexture%, %Shaft1CX% + 5 + 0.025 + %ExtraLateralOffset%, %Shaft1CZ% - 0, 0.05, 1.2, 0.6, %Offset%, 0, 0, false, true, true, true
		DrawWalls = false, true, false, false, false, false
		AddWall E9BlankInd, IndBack, 0, %Shaft1CX% + 5.052 + %ExtraLateralOffset%, %Shaft1CZ% - 0 - 0.5, %Shaft1CX% + 5.052 + %ExtraLateralOffset%, %Shaft1CZ% - 0, 0.5, 0.5, %Offset% + 0.05, %Offset% + 0.05, 0, 0, false

		AddDirectionalIndicator 9, true, false, true, true, IndBack, %LanternPrefix%Up, %LanternPrefix%UpLit, %LanternPrefix%Down, %LanternPrefix%DownLit, 3.75 + 0.66 + %ExtraLateralOffset% + 0.053, 0 - 0.25, %Offset% + 0.05, right, 0.65, 0.5, false, 0, 0
		AddFloorIndicator 9, true, Ind_Button, right, 3.75 + 0.66 + %ExtraLateralOffset% + 0.053, 0 + 0.25, 0.5, 0.5, %Offset% + 0.05

		#Elevator 10
		CreateWallBox2 external, E10LanternPanel, %LPanelTexture%, %Shaft1CX% + 5 + 0.025 + %ExtraLateralOffset%, %Shaft1CZ% + 10, 0.05, 1.2, 0.6, %Offset%, 0, 0, false, true, true, true
		DrawWalls = false, true, false, false, false, false
		AddWall E10BlankInd, IndBack, 0, %Shaft1CX% + 5.052 + %ExtraLateralOffset%, %Shaft1CZ% + 10 - 0.5, %Shaft1CX% + 5.052 + %ExtraLateralOffset%, %Shaft1CZ% + 10, 0.5, 0.5, %Offset% + 0.05, %Offset% + 0.05, 0, 0, false

		AddDirectionalIndicator 10, true, false, true, true, IndBack, %LanternPrefix%Up, %LanternPrefix%UpLit, %LanternPrefix%Down, %LanternPrefix%DownLit, 3.75 + 0.66 + %ExtraLateralOffset% + 0.053, 0 - 0.25, %Offset% + 0.05, right, 0.65, 0.5, false, 0, 0
		AddFloorIndicator 10, true, Ind_Button, right, 3.75 + 0.66 + %ExtraLateralOffset% + 0.053, 0 + 0.25, 0.5, 0.5, %Offset% + 0.05

		#Elevator 11
		CreateWallBox2 external, E11LanternPanel, %LPanelTexture%, %Shaft2CX% - 5 - 0.025 - %ExtraLateralOffset%, %Shaft2CZ% - 10, 0.05, 1.2, 0.6, %Offset%, 0, 0, false, true, true, true
		DrawWalls = true, false, false, false, false, false
		AddWall E11BlankInd, IndBack, 0, %Shaft2CX% - 5.052 - %ExtraLateralOffset%, %Shaft2CZ% - 10, %Shaft2CX% - 5.052 - %ExtraLateralOffset%, %Shaft2CZ% - 10 + 0.5, 0.5, 0.5, %Offset% + 0.05, %Offset% + 0.05, 0, 0, false

		AddDirectionalIndicator 11, true, false, true, true, IndBack, %LanternPrefix%Up, %LanternPrefix%UpLit, %LanternPrefix%Down, %LanternPrefix%DownLit, -3.75 - 0.66 - %ExtraLateralOffset% - 0.053, 0 + 0.25, %Offset% + 0.05, left, 0.65, 0.5, false, 0, 0
		AddFloorIndicator 11, true, Ind_Button, left, -3.75 - 0.66 - %ExtraLateralOffset% - 0.053, 0 - 0.25, 0.5, 0.5, %Offset% + 0.05

		#Elevator 12
		CreateWallBox2 external, E12LanternPanel, %LPanelTexture%, %Shaft2CX% - 5 - 0.025 - %ExtraLateralOffset%, %Shaft2CZ% - 0, 0.05, 1.2, 0.6, %Offset%, 0, 0, false, true, true, true
		DrawWalls = true, false, false, false, false, false
		AddWall E12BlankInd, IndBack, 0, %Shaft2CX% - 5.052 - %ExtraLateralOffset%, %Shaft2CZ% - 0, %Shaft2CX% - 5.052 - %ExtraLateralOffset%, %Shaft2CZ% - 0 + 0.5, 0.5, 0.5, %Offset% + 0.05, %Offset% + 0.05, 0, 0, false

		AddDirectionalIndicator 12, true, false, true, true, IndBack, %LanternPrefix%Up, %LanternPrefix%UpLit, %LanternPrefix%Down, %LanternPrefix%DownLit, -3.75 - 0.66 - %ExtraLateralOffset% - 0.053, 0 + 0.25, %Offset% + 0.05, left, 0.65, 0.5, false, 0, 0
		AddFloorIndicator 12, true, Ind_Button, left, -3.75 - 0.66 - %ExtraLateralOffset% - 0.053, 0 - 0.25, 0.5, 0.5, %Offset% + 0.05

		#Elevator 13
		CreateWallBox2 external, E13LanternPanel, %LPanelTexture%, %Shaft2CX% - 5 - 0.025 - %ExtraLateralOffset%, %Shaft2CZ% + 10, 0.05, 1.2, 0.6, %Offset%, 0, 0, false, true, true, true
		DrawWalls = true, false, false, false, false, false
		AddWall E13BlankInd, IndBack, 0, %Shaft2CX% - 5.052 - %ExtraLateralOffset%, %Shaft2CZ% + 10, %Shaft2CX% - 5.052 - %ExtraLateralOffset%, %Shaft2CZ% + 10 + 0.5, 0.5, 0.5, %Offset% + 0.05, %Offset% + 0.05, 0, 0, false

		AddDirectionalIndicator 13, true, false, true, true, IndBack, %LanternPrefix%Up, %LanternPrefix%UpLit, %LanternPrefix%Down, %LanternPrefix%DownLit, -3.75 - 0.66 - %ExtraLateralOffset% - 0.053, 0 + 0.25, %Offset% + 0.05, left, 0.65, 0.5, false, 0, 0
		AddFloorIndicator 13, true, Ind_Button, left, -3.75 - 0.66 - %ExtraLateralOffset% - 0.053, 0 - 0.25, 0.5, 0.5, %Offset% + 0.05
<EndFloors>

#GLOBAL SETTINGS
<Elevators 1 to 13>
	#Notifications
	UpChimeSound 1 = KW_Sounds/konechimeup.wav
	DownChimeSound 1 = KW_Sounds/konechimedown.wav
	NotifyEarly = 1
	QueueResets = true
	RecallFloor = 0

	#Door settings
	DoorTimer 1 = 12000
	QuickClose 1 = 8000
	OpenSound 1 = EG881Sounds/elevopenquick2.wav #EG881
	CloseSound 1 = EG881Sounds/elevclosequick2.wav #EG881

	#Motor sounds
	MotorStartSound = EG881Sounds/motor_start3.wav #EG881
	MotorRunSound = EG881Sounds/motor_running3.wav #EG881
	MotorStopSound = EG881Sounds/motor_stop3.wav #EG881
<EndElevators>

<Elevators 1 to 7>
	CarStartSound = EG881Sounds/elevstart11.wav #EG881
	CarMoveSound = EG881Sounds/elevmove11.wav #EG881
	CarStopSound = EG881Sounds/elevstop11.wav #EG881
<EndElevators>

<Elevators 8 to 13>
	CarStartSound = elevstart3.wav
	CarMoveSound = elevmove3.wav
	CarStopSound = elevstop3.wav
<EndElevators>

##--------------------------------------------------------------------------------##

#STAIRWELLS
<Function StairwellSets>
	#Set Values
	Set NumSteps = 9 #Total: 36 steps (Double stairs)
	if[%floor% < 0 | %floor% > 5] Set NumSteps = 12 #Total: 24 steps

	#Floors with double stairs
	Set DblStairs = false
	if[%floor% > -1 & %floor% < 6] Set DblStairs = true
<EndFunction>

##--------------------------------------------------------------------------------##

#External stairwell walls
<Floors -2 to -1>
	TexPrefix()

	#South Zone Stairwells
	CreateShaftWall(%5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, -85, -284, 5, 15, ST1, %SHeight%, %SOffset%, true, true, true, true, false, false, true)
	CreateShaftWall(%5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, -85, -124, 5, 15, ST2, %SHeight%, %SOffset%, true, true, true, true, false, false, true)
<EndFloors>

<Floor 0>
	#TexPrefix()
	Set 5 = Parking #Override for the interfloor area

	#South Zone Stairwells
	CreateShaftWall(%5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, 85, -284, 5, 15, ST3_IFloor, %interfloorheight% - 0.5 + 0.1, -0.1, true, true, true, true, false, true, true)
	CreateShaftWall(%5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, 85, -124, 5, 15, ST4_IFloor, %interfloorheight% - 0.5 + 0.1, -0.1, true, true, true, true, false, true, true)
<EndFloor>

<Floors 0 to 3>
	TexPrefix()

	#South Zone Stairwells
	CreateShaftWall(%5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, -85, -284, 5, 15, ST1, %SHeight%, %SOffset%, true, false, true, true, false, false, true)
	CreateShaftWall(%5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, -85, -124, 5, 15, ST2, %SHeight%, %SOffset%, true, false, true, true, false, false, true)

	Set ShowRight = false
	if[%floor% = 2] Set ShowRight = true
	CreateShaftWall(%5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, 85, -284, 5, 15, ST3, %SHeight%, %SOffset%, true, true, %ShowRight%, true, false, false, true)

	CreateShaftWall(%5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, 85, -124, 5, 15, ST4, %SHeight%, %SOffset%, true, true, false, true, false, false, true)
<EndFloors>

<Floor 4>
	TexPrefix()

	#South Zone Stairwells (Roof area)
	CreateShaftWall(ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, 0.33, -85, -284, 5, 15, ST1_Top, %fullheight%, 0, true, true, true, true, true, false, true)
	CreateShaftWall(ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, 0.33, -85, -124, 5, 15, ST2_Top, %fullheight%, 0, true, true, true, true, true, false, true)
	CreateShaftWall(ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, 0.33, 85, -284, 5, 15, ST3_Top, %fullheight%, 0, true, true, true, true, true, false, true)
	CreateShaftWall(ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, 0.33, 85, -124, 5, 15, ST4_Top, %fullheight%, 0, true, true, true, true, true, false, true)
<EndFloor>

<Floors -2 to 9>
	TexPrefix()

	#Central Zone Stairwells
		#South Edge
		Set ShowRight = true
		if[%floor% > -1] Set ShowRight = false
		CreateShaftWall(%5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, 85, -36, 5, 15, ST5, %SHeight%, %SOffset%, true, true, %ShowRight%, true, false, false, true)

		CreateShaftWall(%5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, -95, -46, 5, 15, ST6, %SHeight%, %SOffset%, true, true, true, true, false, false, true)
		CreateShaftWall(%5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, -244, -46, 5, 15, ST7, %SHeight%, %SOffset%, true, true, true, true, false, false, true)
	
		#North Edge
		Set ShowBack = true
		if[%floor% > -1] Set ShowBack = false
		CreateShaftWall(%5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, 20, 225, 5, 15, ST8, %SHeight%, %SOffset%, true, true, true, %ShowBack%, false, false, true)
		CreateShaftWall(%5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, -124, 225, 5, 15, ST9, %SHeight%, %SOffset%, true, true, true, %ShowBack%, false, false, true)
		CreateShaftWall(%5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, -284, 225, 5, 15, ST10, %SHeight%, %SOffset%, true, true, true, %ShowBack%, false, false, true)
<EndFloors>

<Floor 10>
	TexPrefix()

	#Central Zone Stairwells
		#South Edge
		CreateShaftWall(ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, 0.33, 85, -36, 5, 15, ST5_Top, %SHeight%, %SOffset%, true, true, true, true, true, false, true)
		CreateShaftWall(ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, 0.33, -95, -46, 5, 15, ST6_Top, %SHeight%, %SOffset%, true, true, true, true, true, false, true)
		CreateShaftWall(ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, 0.33, -244, -46, 5, 15, ST7_Top, %SHeight%, %SOffset%, true, true, true, true, true, false, true)
	
		#North Edge
		Set ShowBack = false
		CreateShaftWall(ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, 0.33, 20, 225, 5, 15, ST8_Top, %SHeight%, %SOffset%, true, true, true, %ShowBack%, true, false, true)
		CreateShaftWall(ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, 0.33, -124, 225, 5, 15, ST9_Top, %SHeight%, %SOffset%, true, true, true, %ShowBack%, true, false, true)
		CreateShaftWall(ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, 0.33, -284, 225, 5, 15, ST10_Top, %SHeight%, %SOffset%, true, true, true, %ShowBack%, true, false, true)
<EndFloor>

#****************************************#

#South Zone West Stairwell A
	#Wall cuts for stairwell walls
	<Floors -2 to 3>
		CutAll -89.5 - 0.1, 0, -284 - 14.5, -89.5 + 0.1, %fullheight%, -284 + 14.5, true, false #Left wall cuts
	<EndFloors>

CreateStairwell 1, -85, -284, -2, 4
CutStairwell 1, -4.5, -14.5, 4.5, 14.5, 0, 5
ShowFullStairs 1 = always

<Floors -2 to 4>
	StairwellSets() #Determine stairs' size

	Set 21 = -85 #Center X
	Set 22 = -284 #Center Z
	Set 23 = 4.5 #Cut X
	Set 24 = 14.5 #Cut Z
	Set 25 = 1 #Stairwell Number
	Set 26 = 0.5 #Riser Size

	#Walls
	WallOrientation = right
	DrawWalls = false, true, false, false, false, false
	AddStairsWall %25%, Stair%25%Front, StairsWall, 0.5, -%23%, -%24%, %23%, -%24%, %fullheight%, %fullheight%, -%interfloorheight%, -%interfloorheight%, 0, 0
	AddStairsWall %25%, Stair%25%Left, StairsWall, 0.5, -%23%, -%24%, -%23%, %24%, %fullheight%, %fullheight%, -%interfloorheight%, -%interfloorheight%, 0, 0
	WallOrientation = left
	DrawWalls = true, false, false, false, false, false
	AddStairsWall %25%, Stair%25%Right, StairsWall, 0.5, %23%, -%24%, %23%, %24%, %fullheight%, %fullheight%, -%interfloorheight%, -%interfloorheight%, 0, 0
	AddStairsWall %25%, Stair%25%Back, StairsWall, 0.5, -%23%, %24%, %23%, %24%, %fullheight%, %fullheight%, -%interfloorheight%, -%interfloorheight%, 0, 0

	WallOrientation = center
	DrawWalls = true, true, true, true, false, true
	AddStairsWall %25%, Stair%25%Center, StairsWall2, 1, 0, -%24% + 5, 0, -%24% + 5 + %NumSteps%, %fullheight%, %fullheight%, -%interfloorheight%, -%interfloorheight%, 0, 0

	DrawWalls = true, true, true, true, true, true
	if[%floor% = 0] AddStairsWall %25%, Stair%25%Center_T1, StairsWall2, 1, 0, -%24% + 5 + 9, 0, -%24% + 5 + 12, %interfloorheight% + 3, %interfloorheight% + 3, -%interfloorheight%, -%interfloorheight%, 0, 0

	#Railing
	WallOrientation = right
	DrawWalls = true, true, true, true, true, true
	if[%floor% = 4] AddStairsWall %25%, Stair%25%Rail, StairsWall2, 0.5, -%23%, -%24% + 5 + %NumSteps%, -%23% + 4, -%24% + 5 + %NumSteps%, 0.5 + 3.5, 0.5 + 3.5, -0.5, -0.5, 0, 0

	#Ceiling
	FloorOrientation = top
	DrawWalls = true, false, false, false, false, false
	if[%floor% = 4] AddStairsFloor %25%, Stairs%25%Ceiling, StairsCeiling, 0.5, -%23%, -%24%, %23%, %24%, %height%, %height%, false, false, 0, 0

	#Stairs
	Set NumStepsU2 = %NumSteps% * 2
	Set NumStepsU3 = %NumSteps% * 3

	OP_Draw(true, true, true, true, true, true)
	if[%floor% < 4] OP_OrthoStair(%25%, ST%25%_LowerStairs, Stairs, -%23%, -%23% + 4, back, -%24% + 5 + %NumSteps%, %NumSteps%, 1, %26%, 0, 0.5)
	if[%floor% < 4] OP_OrthoStair(%25%, ST%25%_UpperStairs, Stairs, %23% - 4, %23%, front, -%24% + 5, %NumSteps%, 1, %26%, %26% * %NumSteps%, 0.5)
	if[%DblStairs% = true & %floor% < 4] OP_OrthoStair(%25%, ST%25%_LowerStairsEX, Stairs, -%23%, -%23% + 4, back, -%24% + 5 + %NumSteps%, %NumSteps%, 1, %26%, %26% * %NumStepsU2%, 0.5)
	if[%DblStairs% = true & %floor% < 4] OP_OrthoStair(%25%, ST%25%_UpperStairsEX, Stairs, %23% - 4, %23%, front, -%24% + 5, %NumSteps%, 1, %26%, %26% * %NumStepsU3%, 0.5)

	#Landings
	FloorOrientation = top
	DrawWalls = true, true, false, false, false, false
	if[%floor% = -2] AddStairsFloor %25%, Stairs%25%LandingLower, StairsFloor, 0.5, -%23%, -%24%, %23%, %24%, 0, 0, false, false, 0, 0
	if[%floor% > -2 & %floor% ! 0] AddStairsFloor %25%, Stairs%25%LandingLower, StairsFloor, 0.5, -%23%, -%24% + 5 + %NumSteps%, %23%, %24%, 0, 0, false, false, 0, 0
	if[%floor% = 0] AddStairsFloor %25%, Stairs%25%LandingLower, StairsFloor, 0.5, -%23%, -%24% + 5 + 12, %23%, %24%, 0, 0, false, false, 0, 0
	if[%floor% = 0] AddStairsFloor %25%, Stairs%25%Transition1, StairsFloor, 0.5, -%23%, -%24% + 5 + 9, -%23% + 4, -%24% + 5 + 12, 0, 0, false, false, 0, 0

	if[%floor% < 4] AddStairsFloor %25%, Stairs%25%LandingUpper, StairsFloor, 0.5, -%23%, -%24%, %23%, -%24% + 5, %26% * %NumSteps%, %26% * %NumSteps%, false, false, 0, 0

	if[%DblStairs% = true & %floor% < 4] AddStairsFloor %25%, Stairs%25%LandingLowerEX, StairsFloor, 0.5, -%23%, -%24% + 5 + %NumSteps%, %23%, %24%, %26% * %NumStepsU2%, %26% * %NumStepsU2%, false, false, 0, 0
	if[%DblStairs% = true & %floor% < 4] AddStairsFloor %25%, Stairs%25%LandingUpperEX, StairsFloor, 0.5, -%23%, -%24%, %23%, -%24% + 5, %26% * %NumStepsU3%, %26% * %NumStepsU3%, false, false, 0, 0

	#Floor Signs
	Set Suffix = %floorid%
	Set SignCenterPoint = 0

	DrawWalls = true, false, false, false, false, false
	AddStairsWall %25%, ST%25%FloorSign, BlankSign%Suffix%, 0, %SignCenterPoint% - 0.75, %24% - 0.001, %SignCenterPoint% + 0.75, %24% - 0.001, 1.5, 1.5, 3.75, 3.75, 0, 0

	#Doors
	WallOrientation = left
	TextureOverride ServiceDoor2, ServiceDoor2B, ServiceDoor2Side, ServiceDoor2Side, ServiceDoor2Side, ServiceDoor2Side
	if[%floor% ! 0 & %floor% ! 3] AddStairsDoor %25%, , , false, ServiceDoor2, 0.2, 4, 75, %23%, %24% - 2, 3, 7, 0, 0, 0
	WallOrientation = right
	TextureOverride ServiceDoor2B, ServiceDoor2, ServiceDoor2Side, ServiceDoor2Side, ServiceDoor2Side, ServiceDoor2Side
	if[%floor% = 0] AddStairsDoor %25%, , , false, ServiceDoor2, 0.2, 3, 75, %23% + 0.5, %24% - 2, 3, 7, 0, 0, 0

		#Filler walls
		WallOrientation = left
		if[%floor% ! 3] AddFillerWalls ConnectionWall, 0.5, %21% + %23%, %22% + %24% - 2, 3, 7 - 0.001, %interfloorheight%, false, 0, 0, true

	#Exit Signs
	Set SignTex = ExitSign
	if[%floor% < 0] Set SignTex = ExitSignUp

	if[%floor% ! 0 & %floor% ! 3] AddBoxSign(Stair%25%_SignMain, StainlessSteel, %SignTex%, StainlessSteel, 0.1, false, true, true, %21% + %23% + 0.55, %22% + %24% - 2, 1.8, 0.9, %interfloorheight% + 7.2, true)
	if[%floor% = 0] AddBoxSign(Stair%25%_SignStreet, ExitSign, StainlessSteel, StainlessSteel, 0.1, false, true, true, %21% + %23% - 0.05, %22% + %24% - 2, 1.8, 0.9, %interfloorheight% + 7.2, true)
<EndFloors>

#****************************************#

#South Zone West Stairwell B
	#Wall cuts for stairwell walls
	<Floors -2 to 3>
		CutAll -89.5 - 0.1, 0, -124 - 14.5, -89.5 + 0.1, %fullheight%, -124 + 14.5, true, false #Left wall cuts
	<EndFloors>

CreateStairwell 2, -85, -124, -2, 4
CutStairwell 2, -4.5, -14.5, 4.5, 14.5, 0, 5
ShowFullStairs 2 = always

<Floors -2 to 4>
	StairwellSets() #Determine stairs' size

	Set 21 = -85 #Center X
	Set 22 = -124 #Center Z
	Set 23 = 4.5 #Cut X
	Set 24 = 14.5 #Cut Z
	Set 25 = 2 #Stairwell Number
	Set 26 = 0.5 #Riser Size

	#Walls
	WallOrientation = right
	DrawWalls = false, true, false, false, false, false
	AddStairsWall %25%, Stair%25%Front, StairsWall, 0.5, -%23%, -%24%, %23%, -%24%, %fullheight%, %fullheight%, -%interfloorheight%, -%interfloorheight%, 0, 0
	AddStairsWall %25%, Stair%25%Left, StairsWall, 0.5, -%23%, -%24%, -%23%, %24%, %fullheight%, %fullheight%, -%interfloorheight%, -%interfloorheight%, 0, 0
	WallOrientation = left
	DrawWalls = true, false, false, false, false, false
	AddStairsWall %25%, Stair%25%Right, StairsWall, 0.5, %23%, -%24%, %23%, %24%, %fullheight%, %fullheight%, -%interfloorheight%, -%interfloorheight%, 0, 0
	AddStairsWall %25%, Stair%25%Back, StairsWall, 0.5, -%23%, %24%, %23%, %24%, %fullheight%, %fullheight%, -%interfloorheight%, -%interfloorheight%, 0, 0

	WallOrientation = center
	DrawWalls = true, true, true, true, false, true
	AddStairsWall %25%, Stair%25%Center, StairsWall2, 1, 0, %24% - 5 - %NumSteps%, 0, %24% - 5, %fullheight%, %fullheight%, -%interfloorheight%, -%interfloorheight%, 0, 0

	DrawWalls = true, true, true, true, true, true
	if[%floor% = 0] AddStairsWall %25%, Stair%25%Center_T1, StairsWall2, 1, 0, %24% - 5 - 12, 0, %24% - 5 - 9, %interfloorheight% + 3, %interfloorheight% + 3, -%interfloorheight%, -%interfloorheight%, 0, 0

	#Railing
	WallOrientation = left
	DrawWalls = true, true, true, true, true, true
	if[%floor% = 4] AddStairsWall %25%, Stair%25%Rail, StairsWall2, 0.5, -%23%, %24% - 5 - %NumSteps%, -%23% + 4, %24% - 5 - %NumSteps%, 0.5 + 3.5, 0.5 + 3.5, -0.5, -0.5, 0, 0

	#Ceiling
	FloorOrientation = top
	DrawWalls = true, false, false, false, false, false
	if[%floor% = 4] AddStairsFloor %25%, Stairs%25%Ceiling, StairsCeiling, 0.5, -%23%, -%24%, %23%, %24%, %height%, %height%, false, false, 0, 0

	#Stairs
	Set NumStepsU2 = %NumSteps% * 2
	Set NumStepsU3 = %NumSteps% * 3

	OP_Draw(true, true, true, true, true, true)
	if[%floor% < 4] OP_OrthoStair(%25%, ST%25%_LowerStairs, Stairs, -%23%, -%23% + 4, front, %24% - 5 - %NumSteps%, %NumSteps%, 1, %26%, 0, 0.5)
	if[%floor% < 4] OP_OrthoStair(%25%, ST%25%_UpperStairs, Stairs, %23% - 4, %23%, back, %24% - 5, %NumSteps%, 1, %26%, %26% * %NumSteps%, 0.5)
	if[%DblStairs% = true & %floor% < 4] OP_OrthoStair(%25%, ST%25%_LowerStairsEX, Stairs, -%23%, -%23% + 4, front, %24% - 5 - %NumSteps%, %NumSteps%, 1, %26%, %26% * %NumStepsU2%, 0.5)
	if[%DblStairs% = true & %floor% < 4] OP_OrthoStair(%25%, ST%25%_UpperStairsEX, Stairs, %23% - 4, %23%, back, %24% - 5, %NumSteps%, 1, %26%, %26% * %NumStepsU3%, 0.5)

	#Landings
	FloorOrientation = top
	DrawWalls = true, true, false, false, false, false
	if[%floor% = -2] AddStairsFloor %25%, Stairs%25%LandingLower, StairsFloor, 0.5, -%23%, -%24%, %23%, %24%, 0, 0, false, false, 0, 0
	if[%floor% > -2 & %floor% ! 0] AddStairsFloor %25%, Stairs%25%LandingLower, StairsFloor, 0.5, -%23%, -%24%, %23%, %24% - 5 - %NumSteps%, 0, 0, false, false, 0, 0
	if[%floor% = 0] AddStairsFloor %25%, Stairs%25%LandingLower, StairsFloor, 0.5, -%23%, -%24%, %23%, %24% - 5 - 12, 0, 0, false, false, 0, 0
	if[%floor% = 0] AddStairsFloor %25%, Stairs%25%Transition1, StairsFloor, 0.5, -%23%, %24% - 5 - 12, -%23% + 4, %24% - 5 - 9, 0, 0, false, false, 0, 0

	if[%floor% < 4] AddStairsFloor %25%, Stairs%25%LandingUpper, StairsFloor, 0.5, -%23%, %24% - 5, %23%, %24%, %26% * %NumSteps%, %26% * %NumSteps%, false, false, 0, 0

	if[%DblStairs% = true & %floor% < 4] AddStairsFloor %25%, Stairs%25%LandingLowerEX, StairsFloor, 0.5, -%23%, -%24%, %23%, %24% - 5 - %NumSteps%, %26% * %NumStepsU2%, %26% * %NumStepsU2%, false, false, 0, 0
	if[%DblStairs% = true & %floor% < 4] AddStairsFloor %25%, Stairs%25%LandingUpperEX, StairsFloor, 0.5, -%23%, %24% - 5, %23%, %24%, %26% * %NumStepsU3%, %26% * %NumStepsU3%, false, false, 0, 0

	#Floor Signs
	Set Suffix = %floorid%
	Set SignCenterPoint = 0

	DrawWalls = false, true, false, false, false, false
	AddStairsWall %25%, ST%25%FloorSign, BlankSign%Suffix%, 0, %SignCenterPoint% - 0.75, -%24% + 0.001, %SignCenterPoint% + 0.75, -%24% + 0.001, 1.5, 1.5, 3.75, 3.75, 0, 0

	#Doors
	WallOrientation = left
	TextureOverride ServiceDoor2, ServiceDoor2B, ServiceDoor2Side, ServiceDoor2Side, ServiceDoor2Side, ServiceDoor2Side
	if[%floor% ! 0] AddStairsDoor %25%, , , false, ServiceDoor2, 0.2, 1, 75, %23%, -%24% + 2, 3, 7, 0, 0, 0
	WallOrientation = right
	TextureOverride ServiceDoor2B, ServiceDoor2, ServiceDoor2Side, ServiceDoor2Side, ServiceDoor2Side, ServiceDoor2Side
	if[%floor% = 0] AddStairsDoor %25%, , , false, ServiceDoor2, 0.2, 2, 75, %23% + 0.5, -%24% + 2, 3, 7, 0, 0, 0

		#Filler walls
		WallOrientation = left
		AddFillerWalls ConnectionWall, 0.5, %21% + %23%, %22% - %24% + 2, 3, 7 - 0.001, %interfloorheight%, false, 0, 0, true

	#Exit Signs
	Set SignTex = ExitSign
	if[%floor% < 0] Set SignTex = ExitSignUp

	if[%floor% ! 0] AddBoxSign(Stair%25%_SignMain, StainlessSteel, %SignTex%, StainlessSteel, 0.1, false, true, true, %21% + %23% + 0.55, %22% - %24% + 2, 1.8, 0.9, %interfloorheight% + 7.2, true)
	if[%floor% = 0] AddBoxSign(Stair%25%_SignStreet, ExitSign, StainlessSteel, StainlessSteel, 0.1, false, true, true, %21% + %23% - 0.05, %22% - %24% + 2, 1.8, 0.9, %interfloorheight% + 7.2, true)
<EndFloors>

