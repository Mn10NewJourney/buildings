<Function BtnPanelEastElev2> #Used by Elevators 26-27
	Set PanelNumber = %param1%
	Set PanelNumber2 = %PanelNumber% + 1
	Set BtnPrefix = NewOtisButton

	if[%PanelNumber% = 1] AddButton %PanelNumber2%, , %BtnPrefix%Alarm, %BtnPrefix%Alarm, 1, 1, alarm, 1, 1

	AddButton %PanelNumber%, , %BtnPrefix%8, %BtnPrefix%LitBlue8, 3, 2, 8, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%7, %BtnPrefix%LitBlue7, 3, 1, 6, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%6, %BtnPrefix%LitBlue6, 4, 2, 5, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%5, %BtnPrefix%LitBlue5, 4, 1, 4, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%4, %BtnPrefix%LitBlue4, 5, 2, 3, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%3, %BtnPrefix%LitBlue3, 5, 1, 2, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%2, %BtnPrefix%LitBlue2, 6, 2, 1, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%1, %BtnPrefix%LitBlue1, 6, 1, 0, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%B1, %BtnPrefix%LitBlueB1, 7, 2, -1, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%B2, %BtnPrefix%LitBlueB2, 7, 1, -2, 1, 1
	
	AddButton %PanelNumber%, , %BtnPrefix%Open, %BtnPrefix%Open, 9, 1, open, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%Close, %BtnPrefix%Close, 9, 2, close, 1, 1
<EndFunction>

<Elevators 24 to 27>
	Set Prefix = East
	Set Suffix = 
	if[%elevator% > 25] Set Suffix = 2 #Override for elevators 26-27
	Set FlrSuffix = 
	if[%elevator% > 25] Set FlrSuffix = 3 #Override for elevators 26-27

	#Set textures and dimensions
	M10_ElevCabTex(ElevExt, %Prefix%ElevFloor%FlrSuffix%, %Prefix%ElevCeiling2, %Prefix%ElevWall%Suffix%, %Prefix%ElevWall%Suffix%)
	M10_ElevDimensions(7.68, 6.2, 8, 0.2, 0.2, true, false, true, true)
	M10_ElevPanels(%Prefix%ElevPanelMain%Suffix%, %Prefix%ElevPanelTop%Suffix%, 1.1, 1.1, 1, 0.2, false, true, false, false)

	#Finish elevator assembly
	M10_ElevInterior()
	#--------------------
	#Car Doors
	Set ElevDoorTex = %Prefix%ElevDoors
	Set IDP = -3.84

	WallOrientation = right
	AddDoorComponent 1, Left, %ElevDoorTex%, %ElevDoorTex%, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	AddDoorComponent 1, Right, %ElevDoorTex%2, %ElevDoorTex%2, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	FinishDoors 1, false, false

		#Door track
		FloorOrientation = top
		DrawWalls = true, true, true, true, true, true
		TextureOverride ElevExt, ElevDoorTrackX, ElevExt, ElevExt, ElevExt, ElevExt
		AddFloor DoorTrack, ElevDoorTrackX, 0.05, %IDP% - 0.2, -2 - (2 * 1), %IDP%, 2 + (2 * 1), 0, 0, 0, 0
	#--------------------
	#Elevator number sign
	DrawWalls = false, true, false, false, false, false
	AddWall ElevNo%elevator%_Inside, IN_ElevNo%elevator%, 0, -3.64 + 0.001, 0 - 0.25, -3.64 + 0.001, 0 + 0.25, 0.5, 0.5, 7.05, 7.05, 0, 0
	#--------------------
	#Shaft components
	DrawWalls = true, true, true, true, true, true
		#Ropes
		RopePosition = 0, 8 + 0.2, 0
		RopeTexture = Ropes
	
		#Counterweight
		if[%elevator% = 24 | %elevator% = 26] Set Position = -3.1 - 0.8
		if[%elevator% = 25 | %elevator% = 27] Set Position = 3.1 + 0.8

		CreateCounterweight CWeight_Frame, CWeight, 0, %Position%, 2, 6, 0.5, 0.5
	
		#Rails
		AddRails ElevRail, ElevRailSide, 0, 0, true, 3 + 0.06, 0.1
		AddRails ElevRail, ElevRailSide, 0, %Position%, false, 1 + 0.06, 0.1
<EndElevators>

<Elevators 24 to 25>
	#Button Panels
	Set P1_PositionX = -3.64 + 0.051 #Right panel
	Set P1_PositionZ = 2.45
	Set P2_PositionX = -3.64 + 0.051 #Left panel
	Set P2_PositionZ = -2.45

		#Panel backs
		CreateWallBox2 elevator, RightPanelBack, ElevPanel, %P1_PositionX% - 0.051 + 0.025, %P1_PositionZ%, 0.05, 0.8, 4.25 + 0.125 + 0.5, 2.5 - 0.125 - 0.5, 0, 0, false, true, true, true
		CreateWallBox2 elevator, LeftPanelBack, ElevPanel, %P2_PositionX% - 0.051 + 0.025, %P2_PositionZ%, 0.05, 0.8, 2 + 0.125, 2.5 - 0.125, 0, 0, false, true, true, true

		#Right panel
		CreatePanel , 9, 2, right, %P1_PositionX%, %P1_PositionZ%, 0.3, 0.15, 0.125, 0.25, 3.625, 0, 0
		CreatePanel , 9, 1, right, %P1_PositionX%, %P1_PositionZ%, 0.3, 0.15, 0.125, 0.25, 3.625, 0, 0 #Alarm button only

			#Buttons
			BtnPanelEastElev(1)

		#Left panel
		CreatePanel , 9, 2, right, %P2_PositionX%, %P2_PositionZ%, 0.3, 0.15, 0.125, 0.25, 3.625, 0, 0

			#Buttons
			BtnPanelEastElev(3)

	#--------------------
	#Indicator sets
	Set IndOffset = 5.75

		#Right
		DrawWalls = false, true, false, false, false, false
		AddWall RightIndBack, NewOtisInd_BG, 0, %P1_PositionX%, %P1_PositionZ% - 0.25, %P1_PositionX%, %P1_PositionZ% + 0.25, 0.9, 0.9, %IndOffset% - 0.15, %IndOffset% - 0.15, 0, 0

		AddFloorIndicator NewOtisInd_Button, right, %P1_PositionX% + 0.001, %P1_PositionZ%, 0.4, 0.4, %IndOffset% + 0.15 - 0.1
		AddDirectionalIndicator true, true, true, Blank, NewOtisArrow_Blank, NewOtisArrow_LitUp, NewOtisArrow_Blank, NewOtisArrow_LitDown, %P1_PositionX% + 0.001, %P1_PositionZ%, %IndOffset% + 0.15 + 0.3, right, 0.24, 0.3, true, 0, 0
<EndElevators>

<Elevators 26 to 27>
	#Button Panels
	Set P1_PositionX = -3.64 + 0.001 #Right panel
	Set P1_PositionZ = 2.45
	Set P2_PositionX = -3.64 + 0.001 #Left panel
	Set P2_PositionZ = -2.45

		#Right panel
		CreatePanel , 9, 2, right, %P1_PositionX%, %P1_PositionZ%, 0.3, 0.15, 0.125, 0.25, 3.625, 0, 0
		CreatePanel , 9, 1, right, %P1_PositionX%, %P1_PositionZ%, 0.3, 0.15, 0.125, 0.25, 3.625, 0, 0 #Alarm button only

			#Buttons
			BtnPanelEastElev2(1)

		#Left panel
		CreatePanel , 9, 2, right, %P2_PositionX%, %P2_PositionZ%, 0.3, 0.15, 0.125, 0.25, 3.625, 0, 0

			#Buttons
			BtnPanelEastElev2(3)

	#Indicator sets
	Set IndOffset = 5.75 + 0.25 - (0.4 / 2)

		#Right
		DrawWalls = false, true, false, false, false, false
		AddWall RightIndBack, NewOtisInd_BG2, 0, %P1_PositionX%, %P1_PositionZ% - 0.25, %P1_PositionX%, %P1_PositionZ% + 0.25, 0.3, 0.3, %IndOffset%, %IndOffset%, 0, 0

		AddFloorIndicator NewOtisInd2_Button, right, %P1_PositionX% + 0.001, %P1_PositionZ% + 0.25 - 0.15, 0.3, 0.3, %IndOffset%
		AddDirectionalIndicator true, true, true, Blank, NewOtisArrow_Blank, NewOtisArrow_LitUp2, NewOtisArrow_Blank, NewOtisArrow_LitDown2, %P1_PositionX% + 0.002, %P1_PositionZ% - 0.25 + 0.1, %IndOffset% + 0.15 - 0.1375, right, 0.25, 0.275, true, 0, 0

		#Left
		DrawWalls = false, true, false, false, false, false
		AddWall LeftIndBack, NewOtisInd_BG2, 0, %P2_PositionX%, %P2_PositionZ% - 0.25, %P2_PositionX%, %P2_PositionZ% + 0.25, 0.3, 0.3, %IndOffset%, %IndOffset%, 0, 0

		AddFloorIndicator NewOtisInd2_Button, right, %P2_PositionX% + 0.001, %P2_PositionZ% + 0.25 - 0.15, 0.3, 0.3, %IndOffset%
		AddDirectionalIndicator true, true, true, Blank, NewOtisArrow_Blank, NewOtisArrow_LitUp2, NewOtisArrow_Blank, NewOtisArrow_LitDown2, %P2_PositionX% + 0.002, %P2_PositionZ% - 0.25 + 0.1, %IndOffset% + 0.15 - 0.1375, right, 0.25, 0.275, true, 0, 0
<EndElevators>

<Elevators 24 to 27>
	#DETAILED INTERIORS
	#1. Lights
		#1a. Downlights
		Set DLOffset = 8 - 0.001
		FloorOrientation = top
		DrawWalls = true, false, false, false, true, true
		AddFloor Downlight1/1, %Prefix%ElevCeilingDL, 0, -2.25 - 0.11, 2.2 - 0.11, -2.25 + 0.11, 2.2 + 0.11, %DLOffset%, %DLOffset%, 0, 0
		AddFloor Downlight1/2, %Prefix%ElevCeilingDL, 0, 0 - 0.11, 2.2 - 0.11, 0 + 0.11, 2.2 + 0.11, %DLOffset%, %DLOffset%, 0, 0
		AddFloor Downlight1/3, %Prefix%ElevCeilingDL, 0, 2.25 - 0.11, 2.2 - 0.11, 2.25 + 0.11, 2.2 + 0.11, %DLOffset%, %DLOffset%, 0, 0
		AddFloor Downlight2/1, %Prefix%ElevCeilingDL, 0, -2.25 - 0.11, -2.2 - 0.11, -2.25 + 0.11, -2.2 + 0.11, %DLOffset%, %DLOffset%, 0, 0
		AddFloor Downlight2/2, %Prefix%ElevCeilingDL, 0, 0 - 0.11, -2.2 - 0.11, 0 + 0.11, -2.2 + 0.11, %DLOffset%, %DLOffset%, 0, 0
		AddFloor Downlight2/3, %Prefix%ElevCeilingDL, 0, 2.25 - 0.11, -2.2 - 0.11, 2.25 + 0.11, -2.2 + 0.11, %DLOffset%, %DLOffset%, 0, 0
	
		#1b. Center light
		CreateWallBox2 elevator, E%elevator%_MidLight, %Prefix%ElevCeilingLight2, 0, 0, 7.28, 2.5, 0.04, 8 - 0.04, 0, 0, false, true, true, true
	
		#1c. Ceiling trims
		CreateWallBox2 elevator, E%elevator%_Trim1, %Prefix%ElevCeilingTrim2, 0, 1.5 - 0.125, 7.28, 0.25, 0.04, 8 - 0.04, 0, 0, false, true, true, true
		CreateWallBox2 elevator, E%elevator%_Trim2, %Prefix%ElevCeilingTrim2, 0, -1.5 + 0.125, 7.28, 0.25, 0.04, 8 - 0.04, 0, 0, false, true, true, true

	#2. Panels on walls
	Set WPTex = %Prefix%ElevWallPanel3
	if[%elevator% > 25] Set WPTex = %Prefix%ElevWallPanel4
	Set WPanelHeight = 8

	Set Direction = %param2%

		#Front/back panels
		CreateWallBox2 elevator, E%elevator%Panel_Front, %WPTex%, 0, -2.9 + 0.01, 3, 0.02, %WPanelHeight%, 0, 0, 0, false, true, true, true
		CreateWallBox2 elevator, E%elevator%Panel_Back, %WPTex%, 0, 2.9 - 0.01, 3, 0.02, %WPanelHeight%, 0, 0, 0, false, true, true, true

		#Right panel
		CreateWallBox2 elevator, E%elevator%Panel_Right, %WPTex%, 3.64 - 0.01, 0, 0.02, 2, %WPanelHeight%, 0, 0, 0, false, true, true, true
<EndElevators>

##--------------------------------------------------------------------------------##

#HALL STATIONS
#Set textures (South elevators)
<Function ElevHallTex>
	TexPrefix() #Set prefixes for shaft doors

	#Shaft doors
	Set DoorTexture = %5%ShaftDoors

	#Use automatic filler walls or not
	Set AutoFiller = false

	#Door trims
		#Sides
		Set DoorTrimTexture = %DoorTexture%_Trim

		#Top
		Set DoorTrimTexture_Top = %DoorTrimTexture%

	#Deco dimensions
		Set SideDecoH = %height%
		Set TopDecoH = %height% - 7

	#Call button panels
	Set BPanelTexture = ElevExtPanels
	Set ButtonPrefix = Button

	#Lantern panels
	Set LPanelTexture = %BPanelTexture%
	Set LanternPrefix = Lantern

		#Lateral offset for lantern panels
		Set ExtraLateralOffset = 0.05
<EndFunction>

#Set textures (Central Elevators)
<Function ElevHallTex_Glass>
	TexPrefix() #Set prefixes for shaft doors
	Set 5 = Glass #Override

	#Shaft doors
	Set DoorTexture = %5%ShaftDoors

	#Use automatic filler walls or not
	Set AutoFiller = false

	#Door trims
		#Sides
		Set DoorTrimTexture = %DoorTexture%_Trim

		#Top
		Set DoorTrimTexture_Top = %DoorTrimTexture%

	#Deco dimensions
		Set SideDecoH = 7.2
		Set TopDecoH = 0.2

	#Call button panels
	Set BPanelTexture = ElevExtPanels
	Set ButtonPrefix = Button

	#Lantern panels
	Set LPanelTexture = %BPanelTexture%
	Set LanternPrefix = Lantern

		#Lateral offset for lantern panels
		Set ExtraLateralOffset = 0
<EndFunction>

#Set textures (Parking Elevators)
<Function ElevHallTex_Parking>
	TexPrefix() #Set prefixes for shaft doors

	#Shaft doors
	if[%floor% < 0] Set DoorTexture = %5%ShaftDoors
	if[%floor% > -1] Set DoorTexture = %LobbyPrefix%ShaftDoors

	#Use automatic filler walls or not
	Set AutoFiller = false

	#Door trims
		#Sides
		Set DoorTrimTexture = %DoorTexture%_Trim

		#Top
		Set DoorTrimTexture_Top = %DoorTrimTexture%

	#Deco dimensions
		Set SideDecoH = 7.2
		Set TopDecoH = 0.2
		if[%floor% > -1 & %floor% < 6] Set SideDecoH = %height%
		if[%floor% > -1 & %floor% < 6] Set TopDecoH = %height% - 7

	#Call button panels
	Set BPanelTexture = ElevExtPanels
	Set ButtonPrefix = Button

	#Lantern panels
	Set LPanelTexture = %BPanelTexture%
	Set LanternPrefix = Lantern

		#Lateral offset for lantern panels
		Set ExtraLateralOffset = 0
		if[%floor% > -1 & %floor% < 6] Set ExtraLateralOffset = 0.05
<EndFunction>

#South Elevators
<Floors 0 to 3>
	#Shaft Doors
	ElevHallTex() #Set shaft door and panel textures
	Set StartNo = 1 #Number of the first elevator

	Set ElevDoorTex = %Prefix%ElevDoors
	Set IDP = 3.25 + 0.3

	WallOrientation = left
	AddShaftDoorComponent %StartNo%, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo%, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo%, 1, %AutoFiller%, false

	WallOrientation = left
	AddShaftDoorComponent %StartNo% + 1, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo% + 1, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo% + 1, 1, %AutoFiller%, false

	WallOrientation = left
	AddShaftDoorComponent %StartNo% + 2, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo% + 2, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo% + 2, 1, %AutoFiller%, false

	#Door tracks
	AddShaftTrack(1, 1, 4.14, 4.34, -10 - 4, -10 + 4, ElevDoorTrackX, ElevExt, 0.05, 1, 7)
	AddShaftTrack(2, 1, 4.14, 4.34, 0 - 4, 0 + 4, ElevDoorTrackX, ElevExt, 0.05, 1, 7)
	AddShaftTrack(3, 1, 4.14, 4.34, 10 - 4, 10 + 4, ElevDoorTrackX, ElevExt, 0.05, 1, 7)

	#****************************************#

	#Door trims/fillers
	WallTex() #Set filler textures to match with shaft walls
	Set Shaft1CX = -85 #1st shaft for elevator bank
	Set Shaft1CZ = -165

		AddDecoObject(Elev1_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, right, true, false, 0.05, 0.2, %Shaft1CX% + 5, %Shaft1CZ% - 10, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		AddDecoObject(Elev2_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, right, true, false, 0.05, 0.2, %Shaft1CX% + 5, %Shaft1CZ% - 0, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		AddDecoObject(Elev3_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, right, true, false, 0.05, 0.2, %Shaft1CX% + 5, %Shaft1CZ% + 10, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)

	#****************************************#

	#Call buttons
		#Button panels
		CreateWallBox2 external, E1-3ExtPanel1, %BPanelTexture%, %Shaft1CX% + 5 + 0.025, %Shaft1CZ% - 5, 0.05, 0.5, 1, 3.5, 0, 0, false, true, true, true
		CreateWallBox2 external, E1-3ExtPanel2, %BPanelTexture%, %Shaft1CX% + 5 + 0.025, %Shaft1CZ% + 5, 0.05, 0.5, 1, 3.5, 0, 0, false, true, true, true

		#Create buttons
		CallButtonElevators = 1, 2, 3
		CreateCallButtons KW_Sounds/konecallbuttonbeep.wav, KW_Sounds/konecallbuttonbeep.wav, %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft1CX% + 5 + 0.051, %Shaft1CZ% - 5, 4 - 0.4, right, 0.4, 0.8, false, 0, 0
		CreateCallButtons KW_Sounds/konecallbuttonbeep.wav, KW_Sounds/konecallbuttonbeep.wav, %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft1CX% + 5 + 0.051, %Shaft1CZ% + 5, 4 - 0.4, right, 0.4, 0.8, false, 0, 0

		#Signs
		WallOrientation = left
		DrawWalls = false, true, false, false, false, false
		AddBoxSign(E1-3_FS1, Blank, BlankSign%floorid%, Blank, 0, false, false, false, %Shaft1CX% + 5.001, %Shaft1CZ% - 5, 1.5, 1.5, 6.5 - 0.75 + %interfloorheight%, true)
		AddBoxSign(E1-3_FS2, Blank, BlankSign%floorid%, Blank, 0, false, false, false, %Shaft1CX% + 5.001, %Shaft1CZ% + 5, 1.5, 1.5, 6.5 - 0.75 + %interfloorheight%, true)

		AddWall E1-3HallSign, ElevHallSign, 0, %Shaft1CX% + 5.001, %Shaft1CZ% - 5 - 0.25, %Shaft1CX% + 5.001, %Shaft1CZ% - 5 + 0.25, 0.75, 0.75, 2.6, 2.6, 0, 0, false

	#****************************************#

	#Indicator sets
	Set Offset = 7.5

		#Elevator 1
		CreateWallBox2 external, E1LanternPanel, %LPanelTexture%, %Shaft1CX% + 5 + 0.025 + %ExtraLateralOffset%, %Shaft1CZ% - 10, 0.05, 1.2, 0.6, %Offset%, 0, 0, false, true, true, true
		DrawWalls = false, true, false, false, false, false
		AddWall E1BlankInd, IndBack, 0, %Shaft1CX% + 5.052 + %ExtraLateralOffset%, %Shaft1CZ% - 10 - 0.5, %Shaft1CX% + 5.052 + %ExtraLateralOffset%, %Shaft1CZ% - 10 + 0.5, 0.5, 0.5, %Offset% + 0.05, %Offset% + 0.05, 0, 0, false

		AddDirectionalIndicator 1, true, false, true, true, IndBack, %LanternPrefix%Up, %LanternPrefix%UpLit, %LanternPrefix%Down, %LanternPrefix%DownLit, 3.75 + 0.66 + %ExtraLateralOffset% + 0.053, 0 - 0.25, %Offset% + 0.05, right, 0.65, 0.5, false, 0, 0
		AddFloorIndicator 1, true, Ind_Button, right, 3.75 + 0.66 + %ExtraLateralOffset% + 0.053, 0 + 0.25, 0.5, 0.5, %Offset% + 0.05

		#Elevator 2
		CreateWallBox2 external, E2LanternPanel, %LPanelTexture%, %Shaft1CX% + 5 + 0.025 + %ExtraLateralOffset%, %Shaft1CZ% - 0, 0.05, 1.2, 0.6, %Offset%, 0, 0, false, true, true, true
		DrawWalls = false, true, false, false, false, false
		AddWall E2BlankInd, IndBack, 0, %Shaft1CX% + 5.052 + %ExtraLateralOffset%, %Shaft1CZ% - 0 - 0.5, %Shaft1CX% + 5.052 + %ExtraLateralOffset%, %Shaft1CZ% - 0 + 0.5, 0.5, 0.5, %Offset% + 0.05, %Offset% + 0.05, 0, 0, false

		AddDirectionalIndicator 2, true, false, true, true, IndBack, %LanternPrefix%Up, %LanternPrefix%UpLit, %LanternPrefix%Down, %LanternPrefix%DownLit, 3.75 + 0.66 + %ExtraLateralOffset% + 0.053, 0 - 0.25, %Offset% + 0.05, right, 0.65, 0.5, false, 0, 0
		AddFloorIndicator 2, true, Ind_Button, right, 3.75 + 0.66 + %ExtraLateralOffset% + 0.053, 0 + 0.25, 0.5, 0.5, %Offset% + 0.05

		#Elevator 3
		CreateWallBox2 external, E3LanternPanel, %LPanelTexture%, %Shaft1CX% + 5 + 0.025 + %ExtraLateralOffset%, %Shaft1CZ% + 10, 0.05, 1.2, 0.6, %Offset%, 0, 0, false, true, true, true
		DrawWalls = false, true, false, false, false, false
		AddWall E3BlankInd, IndBack, 0, %Shaft1CX% + 5.052 + %ExtraLateralOffset%, %Shaft1CZ% + 10 - 0.5, %Shaft1CX% + 5.052 + %ExtraLateralOffset%, %Shaft1CZ% + 10 + 0.5, 0.5, 0.5, %Offset% + 0.05, %Offset% + 0.05, 0, 0, false

		AddDirectionalIndicator 3, true, false, true, true, IndBack, %LanternPrefix%Up, %LanternPrefix%UpLit, %LanternPrefix%Down, %LanternPrefix%DownLit, 3.75 + 0.66 + %ExtraLateralOffset% + 0.053, 0 - 0.25, %Offset% + 0.05, right, 0.65, 0.5, false, 0, 0
		AddFloorIndicator 3, true, Ind_Button, right, 3.75 + 0.66 + %ExtraLateralOffset% + 0.053, 0 + 0.25, 0.5, 0.5, %Offset% + 0.05
<EndFloors>

#Central Elevators
#1. Express Car
<Function E4HallStation>
	#Shaft Doors
	ElevHallTex_Glass() #Set shaft door and panel textures
	Set StartNo = 4 #Number of the first elevator
	Set ElevDoorTex = %Prefix%ElevDoors
	Set IDP = 1.92 + 0.3

	WallOrientation = left
	AddShaftDoorComponent %StartNo%, 1, Left, %DoorTexture%, %DoorTexture%Side, 0.2, right, 0.8, 0.6, 0, %IDP%, 2, %IDP%, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo%, 1, Right, %DoorTexture%2, %DoorTexture%2Side, 0.2, left, 0.8, 0.6, -2, %IDP%, 0, %IDP%, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo%, 1, %AutoFiller%, false


	#Door tracks
	AddShaftTrack(4, 2, 15 - 4, 15 + 4, 4.14, 4.34, ElevDoorTrackZ, ElevExt, 0.05, 1, 7)

	#****************************************#

	#Door trims/fillers
	WallTex() #Set filler textures to match with shaft walls
	Set Shaft1CX = 5 #1st shaft for elevator bank
	Set Shaft1CZ = 140

		AddDecoObject(Elev4_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, back, true, false, 0.05, 0.2, %Shaft1CX% + 15, %Shaft1CZ% + 5, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)

	#****************************************#

	#Call buttons
		#Button panels
		CreateWallBox2 external, E4ExtPanel, %BPanelTexture%, %Shaft1CX% + 15 + 2 + 1.25, %Shaft1CZ% + 5 + 0.025, 0.5, 0.05, 1, 3.5, 0, 0, false, true, true, true

		#Create buttons
		CallButtonElevators = 4
		CreateCallButtons KW_Sounds/konecallbuttonbeep.wav, KW_Sounds/konecallbuttonbeep.wav, %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft1CX% + 15 + 2 + 1.25, %Shaft1CZ% + 5.051, 4 - 0.4, back, 0.4, 0.8, false, 0, 0

		#Signs
		WallOrientation = left
		DrawWalls = false, true, false, false, false, false
		AddWall E4HallSign, ElevHallSign, 0, %Shaft1CX% + 15 + 2 + 1.25 - 0.25, %Shaft1CZ% + 5.001, %Shaft1CX% + 15 + 2 + 1.25 + 0.25, %Shaft1CZ% + 5.001, 0.75, 0.75, 2.6, 2.6, 0, 0, false

	#****************************************#

	#Indicator sets
	Set Offset = 7.5
	Set BoxWidth = 1.2
	if[%floor% ! 0] Set BoxWidth = 0.6
	Set IndWidth = 1
	if[%floor% ! 0] Set IndWidth = 0.5
	Set IndWidth2 = %IndWidth% / 2

	Set IEP = 0.25 #IEP = Indicator Extra Position
	if[%floor% ! 0] Set IEP = 0

		#Elevator 4
		CreateWallBox2 external, E5LanternPanel, %LPanelTexture%, %Shaft1CX% + 15, %Shaft1CZ% + 5 + 0.025 + %ExtraLateralOffset%, %BoxWidth%, 0.05, 0.6, %Offset%, 0, 0, false, true, true, true

		DrawWalls = false, true, false, false, false, false
		AddWall E4BlankInd, IndBack, 0, %Shaft1CX% + 15 - %IndWidth2%, %Shaft1CZ% + 5.052, %Shaft1CX% + 15 + %IndWidth2%, %Shaft1CZ% + 5.052, 0.5, 0.5, %Offset% + 0.05, %Offset% + 0.05, 0, 0, false

		AddDirectionalIndicator 4, true, false, true, true, IndBack, %LanternPrefix%Up, %LanternPrefix%UpLit, %LanternPrefix%Down, %LanternPrefix%DownLit, 0 + %IEP%, 2.42 + 0.66 + %ExtraLateralOffset% + 0.053, %Offset% + 0.05, back, 0.65, 0.5, false, 0, 0
		AddFloorIndicator 4, true, Ind_Button, back, 0 - %IEP%, 2.42 + 0.66 + %ExtraLateralOffset% + 0.053, 0.5, 0.5, %Offset% + 0.05
<EndFunction>

#2. Local Cars
<Function E5-7HallStation>
	#Shaft Doors
	ElevHallTex_Glass() #Set shaft door and panel textures
	Set StartNo = 5 #Number of the first elevator
	Set ElevDoorTex = %Prefix%ElevDoors
	Set IDP = 1.92 + 0.3

	WallOrientation = left
	AddShaftDoorComponent %StartNo%, 1, Left, %DoorTexture%, %DoorTexture%Side, 0.2, right, 0.8, 0.6, 0, %IDP%, 2, %IDP%, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo%, 1, Right, %DoorTexture%2, %DoorTexture%2Side, 0.2, left, 0.8, 0.6, -2, %IDP%, 0, %IDP%, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo%, 1, %AutoFiller%, false

	WallOrientation = left
	AddShaftDoorComponent %StartNo% + 1, 1, Left, %DoorTexture%, %DoorTexture%Side, 0.2, right, 0.8, 0.6, 0, %IDP%, 2, %IDP%, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo% + 1, 1, Right, %DoorTexture%2, %DoorTexture%2Side, 0.2, left, 0.8, 0.6, -2, %IDP%, 0, %IDP%, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo% + 1, 1, %AutoFiller%, false

	WallOrientation = left
	AddShaftDoorComponent %StartNo% + 2, 1, Left, %DoorTexture%, %DoorTexture%Side, 0.2, right, 0.8, 0.6, 0, %IDP%, 2, %IDP%, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo% + 2, 1, Right, %DoorTexture%2, %DoorTexture%2Side, 0.2, left, 0.8, 0.6, -2, %IDP%, 0, %IDP%, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo% + 2, 1, %AutoFiller%, false

	#Door tracks
	AddShaftTrack(5, 2, 5 - 4, 5 + 4, 4.14, 4.34, ElevDoorTrackZ, ElevExt, 0.05, 1, 7)
	AddShaftTrack(6, 2, -5 - 4, -5 + 4, 4.14, 4.34, ElevDoorTrackZ, ElevExt, 0.05, 1, 7)
	AddShaftTrack(7, 2, -15 - 4, -15 + 4, 4.14, 4.34, ElevDoorTrackZ, ElevExt, 0.05, 1, 7)

	#****************************************#

	#Door trims/fillers
	WallTex() #Set filler textures to match with shaft walls
	Set Shaft1CX = 5 #1st shaft for elevator bank
	Set Shaft1CZ = 140

		AddDecoObject(Elev5_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, back, true, false, 0.05, 0.2, %Shaft1CX% + 5, %Shaft1CZ% + 5, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		AddDecoObject(Elev6_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, back, true, false, 0.05, 0.2, %Shaft1CX% - 5, %Shaft1CZ% + 5, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		AddDecoObject(Elev7_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, back, true, false, 0.05, 0.2, %Shaft1CX% - 15, %Shaft1CZ% + 5, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)

	#****************************************#

	#Call buttons
		#Button panels
		CreateWallBox2 external, E5-7ExtPanel1, %BPanelTexture%, %Shaft1CX%, %Shaft1CZ% + 5 + 0.025, 0.5, 0.05, 1, 3.5, 0, 0, false, true, true, true
		CreateWallBox2 external, E5-7ExtPanel2, %BPanelTexture%, %Shaft1CX% - 10, %Shaft1CZ% + 5 + 0.025, 0.5, 0.05, 1, 3.5, 0, 0, false, true, true, true

		#Create buttons
		CallButtonElevators = 5, 6, 7
		CreateCallButtons KW_Sounds/konecallbuttonbeep.wav, KW_Sounds/konecallbuttonbeep.wav, %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft1CX%, %Shaft1CZ% + 5.051, 4 - 0.4, back, 0.4, 0.8, false, 0, 0
		CreateCallButtons KW_Sounds/konecallbuttonbeep.wav, KW_Sounds/konecallbuttonbeep.wav, %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft1CX% - 10, %Shaft1CZ% + 5.051, 4 - 0.4, back, 0.4, 0.8, false, 0, 0

		#Signs
		WallOrientation = left
		DrawWalls = false, true, false, false, false, false
		#AddBoxSign(E4-7_FS1, Blank, BlankSign%floorid%, Blank, 0, true, false, false, %Shaft1CX% + 10, %Shaft1CZ% + 5.001, 1.5, 1.5, 6.5 - 0.75 + %interfloorheight%, true)
		AddBoxSign(E4-7_FS2, Blank, BlankSign%floorid%, Blank, 0, true, false, false, %Shaft1CX%, %Shaft1CZ% + 5.001, 1.5, 1.5, 6.5 - 0.75 + %interfloorheight%, true)
		AddBoxSign(E4-7_FS3, Blank, BlankSign%floorid%, Blank, 0, true, false, false, %Shaft1CX% - 10, %Shaft1CZ% + 5.001, 1.5, 1.5, 6.5 - 0.75 + %interfloorheight%, true)

		AddWall E4-7HallSign, ElevHallSign, 0, %Shaft1CX% - 0.25, %Shaft1CZ% + 5.001, %Shaft1CX% + 0.25, %Shaft1CZ% + 5.001, 0.75, 0.75, 2.6, 2.6, 0, 0, false

	#****************************************#

	#Indicator sets
	Set Offset = 7.5
	Set BoxWidth = 1.2
	if[%floor% ! 0] Set BoxWidth = 0.6
	Set IndWidth = 1
	if[%floor% ! 0] Set IndWidth = 0.5
	Set IndWidth2 = %IndWidth% / 2

	Set IEP = 0.25 #IEP = Indicator Extra Position
	if[%floor% ! 0] Set IEP = 0

		#Elevator 5
		CreateWallBox2 external, E5LanternPanel, %LPanelTexture%, %Shaft1CX% + 5, %Shaft1CZ% + 5 + 0.025 + %ExtraLateralOffset%, %BoxWidth%, 0.05, 0.6, %Offset%, 0, 0, false, true, true, true

		DrawWalls = false, true, false, false, false, false
		AddWall E5BlankInd, IndBack, 0, %Shaft1CX% + 5 - %IndWidth2%, %Shaft1CZ% + 5.052, %Shaft1CX% + 5 + %IndWidth2%, %Shaft1CZ% + 5.052, 0.5, 0.5, %Offset% + 0.05, %Offset% + 0.05, 0, 0, false

		AddDirectionalIndicator 5, true, false, true, true, IndBack, %LanternPrefix%Up, %LanternPrefix%UpLit, %LanternPrefix%Down, %LanternPrefix%DownLit, 0 + %IEP%, 2.42 + 0.66 + %ExtraLateralOffset% + 0.053, %Offset% + 0.05, back, 0.65, 0.5, false, 0, 0
		AddFloorIndicator 5, true, Ind_Button, back, 0 - %IEP%, 2.42 + 0.66 + %ExtraLateralOffset% + 0.053, 0.5, 0.5, %Offset% + 0.05

		#Elevator 6
		CreateWallBox2 external, E6LanternPanel, %LPanelTexture%, %Shaft1CX% - 5, %Shaft1CZ% + 5 + 0.025 + %ExtraLateralOffset%, %BoxWidth%, 0.05, 0.6, %Offset%, 0, 0, false, true, true, true

		DrawWalls = false, true, false, false, false, false
		AddWall E6BlankInd, IndBack, 0, %Shaft1CX% - 5 - %IndWidth2%, %Shaft1CZ% + 5.052, %Shaft1CX% - 5 + %IndWidth2%, %Shaft1CZ% + 5.052, 0.5, 0.5, %Offset% + 0.05, %Offset% + 0.05, 0, 0, false

		AddDirectionalIndicator 6, true, false, true, true, IndBack, %LanternPrefix%Up, %LanternPrefix%UpLit, %LanternPrefix%Down, %LanternPrefix%DownLit, 0 + %IEP%, 2.42 + 0.66 + %ExtraLateralOffset% + 0.053, %Offset% + 0.05, back, 0.65, 0.5, false, 0, 0
		AddFloorIndicator 6, true, Ind_Button, back, 0 - %IEP%, 2.42 + 0.66 + %ExtraLateralOffset% + 0.053, 0.5, 0.5, %Offset% + 0.05

		#Elevator 7
		CreateWallBox2 external, E7LanternPanel, %LPanelTexture%, %Shaft1CX% - 15, %Shaft1CZ% + 5 + 0.025 + %ExtraLateralOffset%, %BoxWidth%, 0.05, 0.6, %Offset%, 0, 0, false, true, true, true

		DrawWalls = false, true, false, false, false, false
		AddWall E7BlankInd, IndBack, 0, %Shaft1CX% - 15 - %IndWidth2%, %Shaft1CZ% + 5.052, %Shaft1CX% - 15 + %IndWidth2%, %Shaft1CZ% + 5.052, 0.5, 0.5, %Offset% + 0.05, %Offset% + 0.05, 0, 0, false

		AddDirectionalIndicator 7, true, false, true, true, IndBack, %LanternPrefix%Up, %LanternPrefix%UpLit, %LanternPrefix%Down, %LanternPrefix%DownLit, 0 + %IEP%, 2.42 + 0.66 + %ExtraLateralOffset% + 0.053, %Offset% + 0.05, back, 0.65, 0.5, false, 0, 0
		AddFloorIndicator 7, true, Ind_Button, back, 0 - %IEP%, 2.42 + 0.66 + %ExtraLateralOffset% + 0.053, 0.5, 0.5, %Offset% + 0.05
<EndFunction>

#Elevator 4 (Express)
<Floor 0>
	E4HallStation()
<EndFloor>

<Floor 3>
	E4HallStation()
<EndFloor>

<Floors 6 to 8>
	if[%floor% ! 7] E4HallStation()
<EndFloors>

#Elevator 5-7 (Local)
<Floors 0 to 8>
	if[%floor% ! 7] E5-7HallStation()
<EndFloors>

#Tower Parking Elevators
<Floors -2 to 11>
	#Shaft Doors
	ElevHallTex_Parking() #Set shaft door and panel textures
	Set StartNo = 8 #Number of the first elevator

	Set ElevDoorTex = %Prefix%ElevDoors
	Set IDP = 3.25 + 0.3

	WallOrientation = left
	AddShaftDoorComponent %StartNo%, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo%, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo%, 1, %AutoFiller%, false

	WallOrientation = left
	AddShaftDoorComponent %StartNo% + 1, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo% + 1, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo% + 1, 1, %AutoFiller%, false

	WallOrientation = left
	AddShaftDoorComponent %StartNo% + 2, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo% + 2, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo% + 2, 1, %AutoFiller%, false
	
	Set IDP = -3.25 - 0.3
	WallOrientation = right
	AddShaftDoorComponent %StartNo% + 3, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo% + 3, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo% + 3, 1, %AutoFiller%, false

	Set IDP = -3.25 - 0.3
	WallOrientation = right
	AddShaftDoorComponent %StartNo% + 4, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo% + 4, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo% + 4, 1, %AutoFiller%, false

	WallOrientation = right
	AddShaftDoorComponent %StartNo% + 5, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo% + 5, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo% + 5, 1, %AutoFiller%, false

	#Door tracks
	AddShaftTrack(8, 3, 4.14, 4.34, -10 - 4, -10 + 4, ElevDoorTrackX, ElevExt, 0.05, 1, 7)
	AddShaftTrack(9, 3, 4.14, 4.34, 0 - 4, 0 + 4, ElevDoorTrackX, ElevExt, 0.05, 1, 7)
	AddShaftTrack(10, 3, 4.14, 4.34, 10 - 4, 10 + 4, ElevDoorTrackX, ElevExt, 0.05, 1, 7)
	AddShaftTrack(11, 4, -4.34, -4.14, -10 - 4, -10 + 4, ElevDoorTrackX, ElevExt, 0.05, 1, 7)
	AddShaftTrack(12, 4, -4.34, -4.14, 0 - 4, 0 + 4, ElevDoorTrackX, ElevExt, 0.05, 1, 7)
	AddShaftTrack(13, 4, -4.34, -4.14, 10 - 4, 10 + 4, ElevDoorTrackX, ElevExt, 0.05, 1, 7)

	#****************************************#

	#Door trims/fillers
	WallTex() #Set filler textures to match with shaft walls
	Set Shaft1CX = -205 #1st shaft for elevator bank
	Set Shaft1CZ = 225
	Set Shaft2CX = -180 #1st shaft for elevator bank
	Set Shaft2CZ = 225

		AddDecoObject(PKE1_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, right, true, false, 0.05, 0.2, %Shaft1CX% + 5, %Shaft1CZ% - 10, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		AddDecoObject(PKE2_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, right, true, false, 0.05, 0.2, %Shaft1CX% + 5, %Shaft1CZ% - 0, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		AddDecoObject(PKE3_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, right, true, false, 0.05, 0.2, %Shaft1CX% + 5, %Shaft1CZ% + 10, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)

		AddDecoObject(PKE4_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, left, true, false, 0.05, 0.2, %Shaft2CX% - 5, %Shaft2CZ% - 10, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		AddDecoObject(PKE5_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, left, true, false, 0.05, 0.2, %Shaft2CX% - 5, %Shaft2CZ% - 0, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		AddDecoObject(PKE6_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, left, true, false, 0.05, 0.2, %Shaft2CX% - 5, %Shaft2CZ% + 10, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)

	#****************************************#

	#Call buttons
		#Button panels
		CreateWallBox2 external, PKE_ExtPanel_1/1, %BPanelTexture%, %Shaft1CX% + 5.025, %Shaft1CZ% - 5, 0.05, 0.5, 1, 3.5, 0, 0, false, true, true, true
		CreateWallBox2 external, PKE_ExtPanel_1/2, %BPanelTexture%, %Shaft1CX% + 5.025, %Shaft1CZ% + 5, 0.05, 0.5, 1, 3.5, 0, 0, false, true, true, true
		CreateWallBox2 external, PKE_ExtPanel_2/1, %BPanelTexture%, %Shaft2CX% - 5.025, %Shaft2CZ% - 5, 0.05, 0.5, 1, 3.5, 0, 0, false, true, true, true
		CreateWallBox2 external, PKE_ExtPanel_2/2, %BPanelTexture%, %Shaft2CX% - 5.025, %Shaft2CZ% + 5, 0.05, 0.5, 1, 3.5, 0, 0, false, true, true, true

		#Create buttons
		CallButtonElevators = 8, 9, 10, 11, 12, 13
		CreateCallButtons KW_Sounds/konecallbuttonbeep.wav, KW_Sounds/konecallbuttonbeep.wav, %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft1CX% + 5.051, %Shaft1CZ% - 5, 4 - 0.4, right, 0.4, 0.8, false, 0, 0
		CreateCallButtons KW_Sounds/konecallbuttonbeep.wav, KW_Sounds/konecallbuttonbeep.wav, %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft1CX% + 5.051, %Shaft1CZ% + 5, 4 - 0.4, right, 0.4, 0.8, false, 0, 0

		CreateCallButtons KW_Sounds/konecallbuttonbeep.wav, KW_Sounds/konecallbuttonbeep.wav, %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft2CX% - 5.051, %Shaft2CZ% - 5, 4 - 0.4, left, 0.4, 0.8, false, 0, 0
		CreateCallButtons KW_Sounds/konecallbuttonbeep.wav, KW_Sounds/konecallbuttonbeep.wav, %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft2CX% - 5.051, %Shaft2CZ% + 5, 4 - 0.4, left, 0.4, 0.8, false, 0, 0

		#Signs
		WallOrientation = left
		DrawWalls = false, true, false, false, false, false
		AddBoxSign(PKE_FS1, Blank, BlankSign%floorid%, Blank, 0, false, false, false, %Shaft1CX% + 5.001, %Shaft1CZ% - 5, 1.5, 1.5, 6.5 - 0.75 + %interfloorheight%, true)
		AddBoxSign(PKE_FS2, Blank, BlankSign%floorid%, Blank, 0, false, false, false, %Shaft1CX% + 5.001, %Shaft1CZ% + 5, 1.5, 1.5, 6.5 - 0.75 + %interfloorheight%, true)

		AddWall PKE_HallSign1, ElevHallSign, 0, %Shaft1CX% + 5.001, %Shaft1CZ% - 5 - 0.25, %Shaft1CX% + 5.001, %Shaft1CZ% - 5 + 0.25, 0.75, 0.75, 2.6, 2.6, 0, 0, false

		WallOrientation = right
		DrawWalls = true, false, false, false, false, false
		AddBoxSign(PKE_FS3, BlankSign%floorid%, Blank, Blank, 0, false, false, false, %Shaft2CX% - 5.001, %Shaft2CZ% - 5, 1.5, 1.5, 6.5 - 0.75 + %interfloorheight%, true)
		AddBoxSign(PKE_FS4, BlankSign%floorid%, Blank, Blank, 0, false, false, false, %Shaft2CX% - 5.001, %Shaft2CZ% + 5, 1.5, 1.5, 6.5 - 0.75 + %interfloorheight%, true)

		AddWall PKE_HallSign2, ElevHallSign, 0, %Shaft2CX% - 5.001, %Shaft2CZ% - 5 - 0.25, %Shaft2CX% - 5.001, %Shaft2CZ% - 5 + 0.25, 0.75, 0.75, 2.6, 2.6, 0, 0, false

	#****************************************#

	#Indicator sets
	Set Offset = 7.5

		#Elevator 8
		CreateWallBox2 external, E8LanternPanel, %LPanelTexture%, %Shaft1CX% + 5 + 0.025 + %ExtraLateralOffset%, %Shaft1CZ% - 10, 0.05, 1.2, 0.6, %Offset%, 0, 0, false, true, true, true
		DrawWalls = false, true, false, false, false, false
		AddWall E8BlankInd, IndBack, 0, %Shaft1CX% + 5.052 + %ExtraLateralOffset%, %Shaft1CZ% - 10 - 0.5, %Shaft1CX% + 5.052 + %ExtraLateralOffset%, %Shaft1CZ% - 10 + 0.5, 0.5, 0.5, %Offset% + 0.05, %Offset% + 0.05, 0, 0, false

		AddDirectionalIndicator 8, true, false, true, true, IndBack, %LanternPrefix%Up, %LanternPrefix%UpLit, %LanternPrefix%Down, %LanternPrefix%DownLit, 3.75 + 0.66 + %ExtraLateralOffset% + 0.053, 0 - 0.25, %Offset% + 0.05, right, 0.65, 0.5, false, 0, 0
		AddFloorIndicator 8, true, Ind_Button, right, 3.75 + 0.66 + %ExtraLateralOffset% + 0.053, 0 + 0.25, 0.5, 0.5, %Offset% + 0.05

		#Elevator 9
		CreateWallBox2 external, E9LanternPanel, %LPanelTexture%, %Shaft1CX% + 5 + 0.025 + %ExtraLateralOffset%, %Shaft1CZ% - 0, 0.05, 1.2, 0.6, %Offset%, 0, 0, false, true, true, true
		DrawWalls = false, true, false, false, false, false
		AddWall E9BlankInd, IndBack, 0, %Shaft1CX% + 5.052 + %ExtraLateralOffset%, %Shaft1CZ% - 0 - 0.5, %Shaft1CX% + 5.052 + %ExtraLateralOffset%, %Shaft1CZ% - 0 + 0.5, 0.5, 0.5, %Offset% + 0.05, %Offset% + 0.05, 0, 0, false

		AddDirectionalIndicator 9, true, false, true, true, IndBack, %LanternPrefix%Up, %LanternPrefix%UpLit, %LanternPrefix%Down, %LanternPrefix%DownLit, 3.75 + 0.66 + %ExtraLateralOffset% + 0.053, 0 - 0.25, %Offset% + 0.05, right, 0.65, 0.5, false, 0, 0
		AddFloorIndicator 9, true, Ind_Button, right, 3.75 + 0.66 + %ExtraLateralOffset% + 0.053, 0 + 0.25, 0.5, 0.5, %Offset% + 0.05

		#Elevator 10
		CreateWallBox2 external, E10LanternPanel, %LPanelTexture%, %Shaft1CX% + 5 + 0.025 + %ExtraLateralOffset%, %Shaft1CZ% + 10, 0.05, 1.2, 0.6, %Offset%, 0, 0, false, true, true, true
		DrawWalls = false, true, false, false, false, false
		AddWall E10BlankInd, IndBack, 0, %Shaft1CX% + 5.052 + %ExtraLateralOffset%, %Shaft1CZ% + 10 - 0.5, %Shaft1CX% + 5.052 + %ExtraLateralOffset%, %Shaft1CZ% + 10 + 0.5, 0.5, 0.5, %Offset% + 0.05, %Offset% + 0.05, 0, 0, false

		AddDirectionalIndicator 10, true, false, true, true, IndBack, %LanternPrefix%Up, %LanternPrefix%UpLit, %LanternPrefix%Down, %LanternPrefix%DownLit, 3.75 + 0.66 + %ExtraLateralOffset% + 0.053, 0 - 0.25, %Offset% + 0.05, right, 0.65, 0.5, false, 0, 0
		AddFloorIndicator 10, true, Ind_Button, right, 3.75 + 0.66 + %ExtraLateralOffset% + 0.053, 0 + 0.25, 0.5, 0.5, %Offset% + 0.05

		#Elevator 11
		CreateWallBox2 external, E11LanternPanel, %LPanelTexture%, %Shaft2CX% - 5 - 0.025 - %ExtraLateralOffset%, %Shaft2CZ% - 10, 0.05, 1.2, 0.6, %Offset%, 0, 0, false, true, true, true
		DrawWalls = true, false, false, false, false, false
		AddWall E11BlankInd, IndBack, 0, %Shaft2CX% - 5.052 - %ExtraLateralOffset%, %Shaft2CZ% - 10 - 0.5, %Shaft2CX% - 5.052 - %ExtraLateralOffset%, %Shaft2CZ% - 10 + 0.5, 0.5, 0.5, %Offset% + 0.05, %Offset% + 0.05, 0, 0, false

		AddDirectionalIndicator 11, true, false, true, true, IndBack, %LanternPrefix%Up, %LanternPrefix%UpLit, %LanternPrefix%Down, %LanternPrefix%DownLit, -3.75 - 0.66 - %ExtraLateralOffset% - 0.053, 0 + 0.25, %Offset% + 0.05, left, 0.65, 0.5, false, 0, 0
		AddFloorIndicator 11, true, Ind_Button, left, -3.75 - 0.66 - %ExtraLateralOffset% - 0.053, 0 - 0.25, 0.5, 0.5, %Offset% + 0.05

		#Elevator 12
		CreateWallBox2 external, E12LanternPanel, %LPanelTexture%, %Shaft2CX% - 5 - 0.025 - %ExtraLateralOffset%, %Shaft2CZ% - 0, 0.05, 1.2, 0.6, %Offset%, 0, 0, false, true, true, true
		DrawWalls = true, false, false, false, false, false
		AddWall E12BlankInd, IndBack, 0, %Shaft2CX% - 5.052 - %ExtraLateralOffset%, %Shaft2CZ% - 0 - 0.5, %Shaft2CX% - 5.052 - %ExtraLateralOffset%, %Shaft2CZ% - 0 + 0.5, 0.5, 0.5, %Offset% + 0.05, %Offset% + 0.05, 0, 0, false

		AddDirectionalIndicator 12, true, false, true, true, IndBack, %LanternPrefix%Up, %LanternPrefix%UpLit, %LanternPrefix%Down, %LanternPrefix%DownLit, -3.75 - 0.66 - %ExtraLateralOffset% - 0.053, 0 + 0.25, %Offset% + 0.05, left, 0.65, 0.5, false, 0, 0
		AddFloorIndicator 12, true, Ind_Button, left, -3.75 - 0.66 - %ExtraLateralOffset% - 0.053, 0 - 0.25, 0.5, 0.5, %Offset% + 0.05

		#Elevator 13
		CreateWallBox2 external, E13LanternPanel, %LPanelTexture%, %Shaft2CX% - 5 - 0.025 - %ExtraLateralOffset%, %Shaft2CZ% + 10, 0.05, 1.2, 0.6, %Offset%, 0, 0, false, true, true, true
		DrawWalls = true, false, false, false, false, false
		AddWall E13BlankInd, IndBack, 0, %Shaft2CX% - 5.052 - %ExtraLateralOffset%, %Shaft2CZ% + 10 - 0.5, %Shaft2CX% - 5.052 - %ExtraLateralOffset%, %Shaft2CZ% + 10 + 0.5, 0.5, 0.5, %Offset% + 0.05, %Offset% + 0.05, 0, 0, false

		AddDirectionalIndicator 13, true, false, true, true, IndBack, %LanternPrefix%Up, %LanternPrefix%UpLit, %LanternPrefix%Down, %LanternPrefix%DownLit, -3.75 - 0.66 - %ExtraLateralOffset% - 0.053, 0 + 0.25, %Offset% + 0.05, left, 0.65, 0.5, false, 0, 0
		AddFloorIndicator 13, true, Ind_Button, left, -3.75 - 0.66 - %ExtraLateralOffset% - 0.053, 0 - 0.25, 0.5, 0.5, %Offset% + 0.05
<EndFloors>

#Set textures (Freight Elevators)
<Function ElevHallTex_FE>
	#TexPrefix() #Set prefixes for shaft doors
	if[%floor% < 6] Set 5 = FreightA
	if[%floor% > 5] Set 5 = FreightB

	#Shaft doors
	Set DoorTexture = %5%ShaftDoors

	#Use automatic filler walls or not
	Set AutoFiller = false

	#Door trims
		#Sides
		Set DoorTrimTexture = %DoorTexture%_Trim

		#Top
		Set DoorTrimTexture_Top = %DoorTrimTexture%

	#Deco dimensions
		Set SideDecoH = 7.2
		Set TopDecoH = 0.2

	#Call button panels
	Set BPanelTexture = ElevExtPanels
	Set ButtonPrefix = Button

	#Lantern panels
	Set LPanelTexture = %BPanelTexture%
	Set LanternPrefix = Lantern

		#Lateral offset for lantern panels
		Set ExtraLateralOffset = 0
<EndFunction>

#Freight Elevators
<Function E14-15HallStation>
	#Shaft Doors
	ElevHallTex_FE() #Set shaft door and panel textures
	Set StartNo = 14 #Number of the first elevator

	Set ElevDoorTex = %Prefix%ElevDoors
	Set InitialDoorPos = 4.64 + (0.15 * 2) + 0.1

		#Elevator 14
		WallOrientation = left
		AddShaftDoorComponent %StartNo%, 1, FreightDoor1, %DoorTexture%, %DoorTexture%, 0.15, left, 0.4, 0.3, %InitialDoorPos% + (0.15 * 1), -4, %InitialDoorPos% + (0.15 * 1), -4 + (2.00 * 1), 7, 0, 0, 0, 0, 0
		AddShaftDoorComponent %StartNo%, 1, FreightDoor2, %DoorTexture%, %DoorTexture%, 0.15, left, 0.8, 0.6, %InitialDoorPos%, -4 + (2.00 * 1), %InitialDoorPos%, -4 + (2.00 * 2), 7, 0, 0, 0, 0, 0
		AddShaftDoorComponent %StartNo%, 1, FreightDoor3, %DoorTexture%2, %DoorTexture%2, 0.15, right, 0.8, 0.6, %InitialDoorPos%, -4 + (2.00 * 2), %InitialDoorPos%, -4 + (2.00 * 3), 7, 0, 0, 0, 0, 0
		AddShaftDoorComponent %StartNo%, 1, FreightDoor4, %DoorTexture%, %DoorTexture%, 0.15, right, 0.4, 0.3, %InitialDoorPos% + (0.15 * 1), -4 + (2.00 * 3), %InitialDoorPos% + (0.15 * 1), -4 + (2.00 * 4), 7, 0, -1, 0, -1, 0
		FinishShaftDoor %StartNo%, 1, %AutoFiller%, false

		#Elevator 15
		WallOrientation = left
		AddShaftDoorComponent %StartNo% + 1, 1, FreightDoor1, %DoorTexture%, %DoorTexture%, 0.15, left, 0.4, 0.3, %InitialDoorPos% + (0.15 * 1), -4, %InitialDoorPos% + (0.15 * 1), -4 + (2.00 * 1), 7, 0, 0, 0, 0, 0
		AddShaftDoorComponent %StartNo% + 1, 1, FreightDoor2, %DoorTexture%, %DoorTexture%, 0.15, left, 0.8, 0.6, %InitialDoorPos%, -4 + (2.00 * 1), %InitialDoorPos%, -4 + (2.00 * 2), 7, 0, 0, 0, 0, 0
		AddShaftDoorComponent %StartNo% + 1, 1, FreightDoor3, %DoorTexture%2, %DoorTexture%2, 0.15, right, 0.8, 0.6, %InitialDoorPos%, -4 + (2.00 * 2), %InitialDoorPos%, -4 + (2.00 * 3), 7, 0, 0, 0, 0, 0
		AddShaftDoorComponent %StartNo% + 1, 1, FreightDoor4, %DoorTexture%, %DoorTexture%, 0.15, right, 0.4, 0.3, %InitialDoorPos% + (0.15 * 1), -4 + (2.00 * 3), %InitialDoorPos% + (0.15 * 1), -4 + (2.00 * 4), 7, 0, -1, 0, -1, 0
		FinishShaftDoor %StartNo% + 1, 1, %AutoFiller%, false

	#Door tracks
	AddShaftTrack(14, 5, 5.34 - 0.3, 5.34, -7.5 - 4 - 2, -7.5 + 4 + 2, ElevDoorTrackX, ElevExt, 0.05, 1, 7)
	AddShaftTrack(15, 5, 5.34 - 0.3, 5.34, 7.5 - 4 - 2, 7.5 + 4 + 2, ElevDoorTrackX, ElevExt, 0.05, 1, 7)

	#Top fillers
	AddShaftTrack(14, 5, 5.34 - 0.15, 5.34, -7.5 - 2, -7.5 + 2, %DoorTrimTexture%, ElevExt, 0.05, 2, 7)
	AddShaftTrack(15, 5, 5.34 - 0.15, 5.34, 7.5 - 2, 7.5 + 2, %DoorTrimTexture%, ElevExt, 0.05, 2, 7)

	#****************************************#

	#Door trims/fillers
	TexPrefix() #Set filler textures to match with shaft walls
	Set Shaft1CX = -233 #1st shaft for elevator bank
	Set Shaft1CZ = -46

		#All floors
		WallOrientation = right
		AddFillerWalls %5%Wall, 0.66, %Shaft1CX% + 6, %Shaft1CZ% - 7.5, 8, 7, %interfloorheight%, false, 0, 0, true #Elevator 14
		AddFillerWalls %5%Wall, 0.66, %Shaft1CX% + 6, %Shaft1CZ% + 7.5, 8, 7, %interfloorheight%, false, 0, 0, true #Elevator 15

		#7th-8th floors
		#if[%floor% > 5] AddDecoObject(Elev14_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, right, true, false, 0.05, 0.2, %Shaft1CX% + 6, %Shaft1CZ% - 7.5, 8, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		#if[%floor% > 5] AddDecoObject(Elev15_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, right, true, false, 0.05, 0.2, %Shaft1CX% + 6, %Shaft1CZ% + 7.5, 8, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)

	#****************************************#

	#Call buttons
		#Button panels
		CreateWallBox2 external, E14-15ExtPanel, %BPanelTexture%, %Shaft1CX% + 6 + 0.025, %Shaft1CZ%, 0.05, 0.5, 1, 3.5, 0, 0, false, true, true, true

		#Create buttons
		CallButtonElevators = 14, 15
		CreateCallButtons KW_Sounds/konecallbuttonbeep.wav, KW_Sounds/konecallbuttonbeep.wav, %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft1CX% + 6 + 0.051, %Shaft1CZ%, 4 - 0.4, right, 0.4, 0.8, false, 0, 0

		#Signs
		WallOrientation = left
		DrawWalls = false, true, false, false, false, false
		AddBoxSign(E14-15_FloorSign, Blank, BlankSign%floorid%, Blank, 0, false, false, false, %Shaft1CX% + 6.001, %Shaft1CZ%, 1.5, 1.5, 6.5 - 0.75 + %interfloorheight%, true)
		AddWall E14-15HallSign, ElevHallSign, 0, %Shaft1CX% + 6.001, %Shaft1CZ% - 0.25, %Shaft1CX% + 6.001, %Shaft1CZ% + 0.25, 0.75, 0.75, 2.6, 2.6, 0, 0, false

	#****************************************#

	#Indicator sets
	Set Offset = 7.5

		#Elevator 14
		CreateWallBox2 external, E14LanternPanel, %LPanelTexture%, %Shaft1CX% + 6.025 + %ExtraLateralOffset%, %Shaft1CZ% - 7.5, 0.05, 1.2, 0.6, %Offset%, 0, 0, false, true, true, true
		DrawWalls = false, true, false, false, false, false
		AddWall E14BlankInd, IndBack, 0, %Shaft1CX% + 6.052, %Shaft1CZ% - 7.5 - 0.5, %Shaft1CX% + 6.052, %Shaft1CZ% - 7.5 + 0.5, 0.5, 0.5, %Offset% + 0.05, %Offset% + 0.05, 0, 0, false

		AddDirectionalIndicator 14, true, false, true, true, IndBack, %LanternPrefix%Up, %LanternPrefix%UpLit, %LanternPrefix%Down, %LanternPrefix%DownLit, 5.34 + 0.66 + %ExtraLateralOffset% + 0.053, 0 - 0.25, %Offset% + 0.05, right, 0.65, 0.5, false, 0, 0
		AddFloorIndicator 14, true, Ind_Button, right, 5.34 + 0.66 + %ExtraLateralOffset% + 0.053, 0 + 0.25, 0.5, 0.5, %Offset% + 0.05

		#Elevator 15
		CreateWallBox2 external, E15LanternPanel, %LPanelTexture%, %Shaft1CX% + 6.025 + %ExtraLateralOffset%, %Shaft1CZ% + 7.5, 0.05, 1.2, 0.6, %Offset%, 0, 0, false, true, true, true
		DrawWalls = false, true, false, false, false, false
		AddWall E15BlankInd, IndBack, 0, %Shaft1CX% + 6.052, %Shaft1CZ% + 7.5 - 0.5, %Shaft1CX% + 6.052, %Shaft1CZ% + 7.5 + 0.5, 0.5, 0.5, %Offset% + 0.05, %Offset% + 0.05, 0, 0, false

		AddDirectionalIndicator 15, true, false, true, true, IndBack, %LanternPrefix%Up, %LanternPrefix%UpLit, %LanternPrefix%Down, %LanternPrefix%DownLit, 5.34 + 0.66 + %ExtraLateralOffset% + 0.053, 0 - 0.25, %Offset% + 0.05, right, 0.65, 0.5, false, 0, 0
		AddFloorIndicator 15, true, Ind_Button, right, 5.34 + 0.66 + %ExtraLateralOffset% + 0.053, 0 + 0.25, 0.5, 0.5, %Offset% + 0.05
<EndFunction>

<Floors 0 to 8>
	if[%floor% ! 7] E14-15HallStation()
<EndFloors>

#Set textures (East elevators)
<Function ElevHallTex_East>
	TexPrefix() #Set prefixes for shaft doors
	Set IsInnerEdge = %param1%

	#Shaft doors
	Set DoorTexture = %5%ShaftDoors
	if[%IsInnerEdge% = true & %floor% < 0] Set DoorTexture = EastParkingShaftDoors

	#Use automatic filler walls or not
	Set AutoFiller = false

	#Door trims
		#Sides
		Set DoorTrimTexture = %DoorTexture%_Trim

		#Top
		Set DoorTrimTexture_Top = %DoorTrimTexture%

	#Deco dimensions
		Set SideDecoH = 7.2
		Set TopDecoH = 0.2
		if[%floor% > -1] Set SideDecoH = 9.5
		if[%floor% > -1] Set TopDecoH = %SideDecoH% - 7
		#if[%floor% > -1 & %floor% < 6] Set SideDecoH = %height%
		#if[%floor% > -1 & %floor% < 6] Set TopDecoH = %height% - 7
		#if[%floor% > 5] Set SideDecoH = %height% + Floor(%floor% + 1).FullHeight
		#if[%floor% > 5] Set TopDecoH = %SideDecoH% - 7

	#Call button panels
	Set BPanelTexture = ElevExtPanels
	Set ButtonPrefix = NewOtisButton

	#Lantern panels
	Set LPanelTexture = %BPanelTexture%
	Set LanternPrefix = Lantern

		#Lateral offset for lantern panels
		Set ExtraLateralOffset = 0
		#if[%floor% > 5] Set ExtraLateralOffset = 0.01
<EndFunction>

#East Elevators (Inner Edge)
<Function E16-17HallStation>
	#Shaft Doors
	ElevHallTex_East(false) #Set shaft door and panel textures
	Set StartNo = 16 #Number of the first elevator

	Set ElevDoorTex = %Prefix%ElevDoors
	Set IDP = -3.25 - 0.3

	WallOrientation = right
	AddShaftDoorComponent %StartNo%, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, left, 0.8, 0.6, -2, %IDP%, 0, %IDP%, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo%, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, right, 0.8, 0.6, 0, %IDP%, 2, %IDP%, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo%, 1, %AutoFiller%, false

	WallOrientation = right
	AddShaftDoorComponent %StartNo% + 1, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, left, 0.8, 0.6, -2, %IDP%, 0, %IDP%, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo% + 1, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, right, 0.8, 0.6, 0, %IDP%, 2, %IDP%, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo% + 1, 1, %AutoFiller%, false

	#Door tracks
	AddShaftTrack(16, 6, -5 - 4, -5 + 4, -4.34, -4.14, ElevDoorTrackZ, ElevExt, 0.05, 1, 7)
	AddShaftTrack(17, 6, 5 - 4, 5 + 4, -4.34, -4.14, ElevDoorTrackZ, ElevExt, 0.05, 1, 7)

	#****************************************#

	#Door trims/fillers
	WallTex() #Set filler textures to match with shaft walls
	Set Shaft1CX = 294
	Set Shaft1CZ = -186

		AddDecoObject(Elev16_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, front, true, false, 0.05, 0.2, %Shaft1CX% - 5, %Shaft1CZ% - 5, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		AddDecoObject(Elev17_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, front, true, false, 0.05, 0.2, %Shaft1CX% + 5, %Shaft1CZ% - 5, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)

	#****************************************#

	#Call buttons
		#Button panels
		CreateWallBox2 external, E16-17ExtPanel, %BPanelTexture%, %Shaft1CX%, %Shaft1CZ% - 5.025, 0.6 + 0.2, 0.05, 1 + 0.6 + 0.15, 3.5, 0, 0, false, true, true, true

		#Create buttons
		CallButtonElevators = 16, 17
		CreateCallButtons %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft1CX%, %Shaft1CZ% - 5.051, 4 - 0.3, front, 0.3, 0.6, false, 0, 0

		#Signs
		WallOrientation = right
		DrawWalls = true, false, false, false, false, false
		AddBoxSign(E16-17_FloorSign, BlankSign%floorid%, Blank, Blank, 0, true, false, false, %Shaft1CX%, %Shaft1CZ% - 5.001, 1.5, 1.5, 7 - 0.75 + %interfloorheight%, true)
		AddWall E16-17_HallSign, ElevHallSign, 0, %Shaft1CX% - 0.25, %Shaft1CZ% - 5.001, %Shaft1CX% + 0.25, %Shaft1CZ% - 5.001, 0.75, 0.75, 2.6, 2.6, 0, 0, false

	#****************************************#

	#Indicators above call buttons
		#Background
		Set WH = 0.6	
		Set WO = 4.5 + %interfloorheight%
		DrawWalls = true, false, false, false, false, false
		AddWall E16-17-PA-IndBG, NewOtisInd_BG, 0, %Shaft1CX% - 0.3, %Shaft1CZ% - 5.051, %Shaft1CX% + 0.3, %Shaft1CZ% - 5.051, %WH%, %WH%, %WO%, %WO%, 0, 0, true
	
		#Directional arrows
		AddDirectionalIndicator 16, false, true, true, true, Blank, NewOtisArrow_Blank, NewOtisArrow_LitUp, NewOtisArrow_Blank, NewOtisArrow_LitDown, %Shaft1CX% - 0.15, %Shaft1CZ% - 5.051, 4.5 + 0.3 + 0.15 - 0.125, front, 0.2, 0.25, false, 0, 0
		AddDirectionalIndicator 17, false, true, true, true, Blank, NewOtisArrow_Blank, NewOtisArrow_LitUp, NewOtisArrow_Blank, NewOtisArrow_LitDown, %Shaft1CX% + 0.15, %Shaft1CZ% - 5.051, 4.5 + 0.3 + 0.15 - 0.125, front, 0.2, 0.25, false, 0, 0
	
		#Floor indicators
		AddFloorIndicator 16, false, NewOtisInd_Button, front, %Shaft1CX% - 0.15, %Shaft1CZ% - 5.052, 0.3, 0.3, 4.5
		AddFloorIndicator 17, false, NewOtisInd_Button, front, %Shaft1CX% + 0.15, %Shaft1CZ% - 5.052, 0.3, 0.3, 4.5
<EndFunction>

<Function E18-19HallStation>
	#Shaft Doors
	ElevHallTex_East(false) #Set shaft door and panel textures
	Set StartNo = 18 #Number of the first elevator

	Set ElevDoorTex = %Prefix%ElevDoors
	Set IDP = -3.25 - 0.3

	WallOrientation = right
	AddShaftDoorComponent %StartNo%, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, left, 0.8, 0.6, -2, %IDP%, 0, %IDP%, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo%, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, right, 0.8, 0.6, 0, %IDP%, 2, %IDP%, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo%, 1, %AutoFiller%, false

	WallOrientation = right
	AddShaftDoorComponent %StartNo% + 1, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, left, 0.8, 0.6, -2, %IDP%, 0, %IDP%, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo% + 1, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, right, 0.8, 0.6, 0, %IDP%, 2, %IDP%, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo% + 1, 1, %AutoFiller%, false

	#Door tracks
	AddShaftTrack(18, 7, -5 - 4, -5 + 4, -4.34, -4.14, ElevDoorTrackZ, ElevExt, 0.05, 1, 7)
	AddShaftTrack(19, 7, 5 - 4, 5 + 4, -4.34, -4.14, ElevDoorTrackZ, ElevExt, 0.05, 1, 7)

	#****************************************#

	#Door trims/fillers
	WallTex() #Set filler textures to match with shaft walls
	Set Shaft1CX = 294
	Set Shaft1CZ = -36

		AddDecoObject(Elev18_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, front, true, false, 0.05, 0.2, %Shaft1CX% - 5, %Shaft1CZ% - 5, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		AddDecoObject(Elev19_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, front, true, false, 0.05, 0.2, %Shaft1CX% + 5, %Shaft1CZ% - 5, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)

	#****************************************#

	#Call buttons
		#Button panels
		CreateWallBox2 external, E18-19ExtPanel, %BPanelTexture%, %Shaft1CX%, %Shaft1CZ% - 5.025, 0.6 + 0.2, 0.05, 1 + 0.6 + 0.15, 3.5, 0, 0, false, true, true, true

		#Create buttons
		CallButtonElevators = 18, 19
		CreateCallButtons %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft1CX%, %Shaft1CZ% - 5.051, 4 - 0.3, front, 0.3, 0.6, false, 0, 0

		#Signs
		WallOrientation = right
		DrawWalls = true, false, false, false, false, false
		AddBoxSign(E18-19_FloorSign, BlankSign%floorid%, Blank, Blank, 0, true, false, false, %Shaft1CX%, %Shaft1CZ% - 5.001, 1.5, 1.5, 7 - 0.75 + %interfloorheight%, true)
		AddWall E18-19_HallSign, ElevHallSign, 0, %Shaft1CX% - 0.25, %Shaft1CZ% - 5.001, %Shaft1CX% + 0.25, %Shaft1CZ% - 5.001, 0.75, 0.75, 2.6, 2.6, 0, 0, false

	#****************************************#

	#Indicators above call buttons
		#Background
		Set WH = 0.6	
		Set WO = 4.5 + %interfloorheight%
		DrawWalls = true, false, false, false, false, false
		AddWall E18-19-PA-IndBG, NewOtisInd_BG, 0, %Shaft1CX% - 0.3, %Shaft1CZ% - 5.051, %Shaft1CX% + 0.3, %Shaft1CZ% - 5.051, %WH%, %WH%, %WO%, %WO%, 0, 0, true
	
		#Directional arrows
		AddDirectionalIndicator 18, false, true, true, true, Blank, NewOtisArrow_Blank, NewOtisArrow_LitUp, NewOtisArrow_Blank, NewOtisArrow_LitDown, %Shaft1CX% - 0.15, %Shaft1CZ% - 5.051, 4.5 + 0.3 + 0.15 - 0.125, front, 0.2, 0.25, false, 0, 0
		AddDirectionalIndicator 19, false, true, true, true, Blank, NewOtisArrow_Blank, NewOtisArrow_LitUp, NewOtisArrow_Blank, NewOtisArrow_LitDown, %Shaft1CX% + 0.15, %Shaft1CZ% - 5.051, 4.5 + 0.3 + 0.15 - 0.125, front, 0.2, 0.25, false, 0, 0
	
		#Floor indicators
