############################################################

#Floor Assignments
<Floors -1 to -2>
	ID = B(0 - %floor%)
	Name = Basement Level (0 - %floor%)
	Type = Basement
	Height = 10
	InterfloorHeight = 2
	if[%floor% = -1] Altitude = -10
<EndFloor>

<Floor -3>
	ID = -
	Name = Shaft Pit
	Type = Basement
	Height = 8
	InterfloorHeight = 2
<EndFloor>

<Floors 0 to 5>
	ID = %floor% + 1
	Name = Mall Level %floorid%
	Type = Shopping
	Height = 16
	InterfloorHeight = 2
	if[%floor% = 0] Altitude = 2
<EndFloors>

<Floors 6 to 7>
	if[%floor% = 6] ID = 7
	if[%floor% = 7] ID = 7A
	Name = Mall Level %floorid%
	Type = Shopping
	Height = 10
	InterfloorHeight = 2
<EndFloors>

<Floors 8 to 9>
	if[%floor% = 8] ID = 8
	if[%floor% = 9] ID = 8A
	Name = Mall Level %floorid%
	Type = Shopping
	Height = 10
	InterfloorHeight = 2
<EndFloors>

<Floor 10>
	ID = R
	Name = Roof
	Type = Roof
	Height = 9.5
	InterfloorHeight = 2
<EndFloor>

#Merge floors
<Floors -2 to 9>
	Group = -2 - 9
<EndFloors>

##--------------------------------------------------------------------------------##

#LANDSCAPES
#Coordinate Set
Set MainX = 822
Set MainZ = 0
Set InSTP = true

#Tranquility City Landscape
<Include buildings/KW_Maps/Tranquility City.txt>

########################################

#Common values
Set 1 = 330 #Building Dimension X (Full width: 660 ft.)
Set 2 = 500 #Building Dimension Z (Full length: 1,000 ft.)

#Cut landscape for building
Cut Landscape, -%1%, -1, -%2%, %1%, 1, %2%, false, true
Cut Landscape, -416, -1, -%2%, -%1%, 0.5, %2%, false, true #West Parking area
Cut Landscape, %1%, -1, -%2%, %1% + 150, 0.5, %2%, false, true #East Parking area

#Landscape
DrawWalls = false, true, false, false, false, false

	#Filler floors
	AddFloor landscape, FillerFloor1, Foundation, 0, -%1%, -%2%, -%1% + 240, %2% - 260 - 320, 4, 4, 0, 0
	AddFloor landscape, FillerFloor2, Foundation, 0, -%1% + 240, -%2%, -%1% + 420, -%2% + 260 - 120, 4, 4, 0, 0

##--------------------------------------------------------------------------------##

#Set texture prefixes/suffixes
<Function TexPrefix>
	#Main prefixes
	Set 5 = Shop
	if[%floor% < 0] Set 5 = Parking
	if[%floor% > 5] Set 5 = UpperShop

	###************###

	#Set heights for External Shaft/Stairwell walls
	Set SHeight = %fullheight%
	Set SOffset = 0
	if[%floor% = 0] Set SHeight = %height%
	if[%floor% = 0] Set SOffset = %interfloorheight%
	if[%floor% < 0] Set SHeight = %height% + Floor(%floor% + 1).InterfloorHeight - 0.5
	if[%floor% < 0] Set SOffset = %interfloorheight%
<EndFunction>

##--------------------------------------------------------------------------------##

#EXTERIOR & INTERIOR
#Parking levels
<Floors -2 to -1>
	TexPrefix() #Set texture prefix/suffix

	#Floors
	Set ShowBottom = false
	if[%floor% = 0] Set ShowBottom = true

	FloorOrientation = top
	DrawWalls = true, true, false, false, false, false
	TextureOverride ParkingCeiling, Road, Blank, Blank, Blank, Blank
	AddFloor WestZonePKFloor, Road, 1, -416, %2% - 260 - 320, -%1% + 240, %2% - 260, %interfloorheight%, %interfloorheight%, 0, 0, true
	#AddFloor WestZonePKFloor, Road, 1, -%1%, %2% - 260 - 320, -%1% + 240, %2% - 260, %interfloorheight%, %interfloorheight%, 0, 0, true
	TextureOverride ParkingCeiling, Road, Blank, Blank, Blank, Blank
	AddFloor CenterZonePKFloor, Road, 1, -%1% + 240, %2% - 260 - 320, -%1% + 420, %2% - 260, %interfloorheight%, %interfloorheight%, 0, 0, true

	TextureOverride ParkingCeiling, Road, Blank, Blank, Blank, Blank
	AddFloor SouthZonePKFloor, Road, 1, -%1% + 240, %2% - 260 - 320 - 160, -%1% + 420, %2% - 260 - 320, %interfloorheight%, %interfloorheight%, 0, 0, true
	TextureOverride ParkingCeiling, Road, Blank, Blank, Blank, Blank
	AddFloor SouthZonePKFloor2, Road, 1, -%1% + 240, %2% - 740 - 120, -%1% + 420, %2% - 740, %interfloorheight%, %interfloorheight%, 0, 0, true

	TextureOverride ParkingCeiling, Road, Blank, Blank, Blank, Blank
	AddFloor EastZonePKFloor, Road, 1, %1% - 240, -%2% + 260, %1% + 150, %2% - 220, %interfloorheight%, %interfloorheight%, 0, 0, true

	TextureOverride ParkingCeiling, Road, Blank, Blank, Blank, Blank
	AddFloor NorthwestZonePKFloor, Road, 1, -416, %2% - 260, -%1%, %2%, %interfloorheight%, %interfloorheight%, 0, 0, true


	#Ceilings
	FloorOrientation = bottom
	DrawWalls = true, false, false, false, false, false
	if[%floor% = -1] AddFloor WestZonePKCeiling, %5%Ceiling, 0.5, -416, %2% - 260 - 320, -%1%, %2% - 260, %fullheight% + 1, %fullheight% + 1, 0, 0, true
	if[%floor% = -1] AddFloor EastZonePKCeiling, %5%Ceiling, 0.5, %1%, -%2% + 260, %1% + 150, %2% - 220, %fullheight% + 1, %fullheight% + 1, 0, 0, true
	if[%floor% = -1] AddFloor NorthwestZonePKCeiling, %5%Ceiling, 0.5, -416, %2% - 260, -%1%, %2%, %fullheight% + 1, %fullheight% + 1, 0, 0, true

	#Perimeter walls
	TexPrefix() #Set texture prefix/suffix
	if[%floor% ! -1] Set WallHeight = %fullheight%
	if[%floor% = -1] Set WallHeight = %fullheight% + Floor(0).InterfloorHeight
	Set WallOffset = 0

		DrawWalls = false, true, false, false, false, false
		WallOrientation = left
		AddWall WestZoneFrontWall, %5%Wall, 0.5, -416, %2% - 260 - 320, -%1% + 240.5, %2% - 260 - 320, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		AddWall WestZoneLeftWall, %5%Wall, 0.5, -416, %2% - 260 - 320, -416, %2%, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		WallOrientation = right
		DrawWalls = true, false, false, false, false, false
		AddWall WestZoneBackWall, %5%Wall, 0.5, -416, %2%, -%1%, %2%, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		WallOrientation = left
		DrawWalls = false, true, false, false, false, false
		AddWall SouthZoneFrontWall, %5%Wall, 0.5, -%1% + 240, -360, -%1% + 420.5, -360, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		AddWall SouthZoneLeftWall, %5%Wall, 0.5, -%1% + 240, -360, -%1% + 240, %2% - 260 - 320 + 0.5, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		WallOrientation = right
		DrawWalls = true, false, false, false, false, false
		AddWall EastZoneRightWall, %5%Wall, 0.5, %1% + 150, -%2% + 260, %1% + 150, %2% - 220, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
<EndFloors>

########################################

#Shopping levels
<Floors 0 to 7>
	TexPrefix() #Set texture prefix/suffix

	#Floors
	Set ShowBottom = false
	if[%floor% = 0] Set ShowBottom = true

	FloorOrientation = top
	DrawWalls = %ShowBottom%, true, false, false, false, false
	TextureOverride ParkingCeiling, %5%Floor, Blank, Blank, Blank, Blank #1st floor only
	if[%floor% ! 7] AddFloor WestZoneFloor, %5%Floor, 1, -%1%, %2% - 260 - 320, -%1% + 240, %2% - 260, %interfloorheight%, %interfloorheight%, 0, 0, true
	TextureOverride ParkingCeiling, %5%Floor, Blank, Blank, Blank, Blank #1st floor only
	if[%floor% ! 7] AddFloor CenterZoneFloor, %5%Floor, 1, -%1% + 240, %2% - 260 - 320, -%1% + 420, %2% - 260, %interfloorheight%, %interfloorheight%, 0, 0, true

	TextureOverride ParkingCeiling, %5%Floor, Blank, Blank, Blank, Blank #1st floor only
	if[%floor% < 4] AddFloor SouthZoneFloor, %5%Floor, 1, -%1% + 240, %2% - 260 - 320 - 160, -%1% + 420, %2% - 260 - 320, %interfloorheight%, %interfloorheight%, 0, 0, true
	TextureOverride ParkingCeiling, %5%Floor, Blank, Blank, Blank, Blank #1st floor only
	if[%floor% < 3] AddFloor SouthZoneFloor2, %5%Floor, 1, -%1% + 240, %2% - 740 - 120, -%1% + 420, %2% - 740, %interfloorheight%, %interfloorheight%, 0, 0, true

	TextureOverride ParkingCeiling, %5%Floor, Blank, Blank, Blank, Blank #1st floor only
	if[%floor% ! 7] AddFloor EastZoneFloor, %5%Floor, 1, %1% - 240, -%2% + 260, %1%, %2% - 220, %interfloorheight%, %interfloorheight%, 0, 0, true

	#Ceilings
	FloorOrientation = bottom
	DrawWalls = true, false, false, false, false, false
	if[%floor% ! 6 & %floor% ! 7] AddFloor WestZoneCeiling, %5%Ceiling, 0.5, -%1%, %2% - 260 - 320, -%1% + 240, %2% - 260, %fullheight%, %fullheight%, 0, 0, true
	if[%floor% = 7] AddFloor WestZoneCeiling2A, %5%Ceiling, 0.5, -%1%, %2% - 260 - 320, -%1% + 120, %2% - 260, %fullheight%, %fullheight%, 0, 0, true
	if[%floor% = 7] AddFloor WestZoneCeiling2B, %5%Ceiling, 0.5, -%1% + 120, %2% - 260 - 320, -%1% + 120 + 80, 20 - 30, %fullheight%, %fullheight%, 0, 0, true
	if[%floor% = 7] AddFloor WestZoneCeiling2C, %5%Ceiling, 0.5, -%1% + 120, 140 + 30, -%1% + 120 + 80, %2% - 260, %fullheight%, %fullheight%, 0, 0, true

	if[%floor% ! 6 & %floor% ! 7] AddFloor CenterZoneCeiling, %5%Ceiling, 0.5, -%1% + 240, %2% - 260 - 320, -%1% + 420, %2% - 260, %fullheight%, %fullheight%, 0, 0, true

	if[%floor% = 3] AddFloor SouthZoneCeiling, %5%Ceiling, 0.5, -%1% + 240, %2% - 740 - 120, -%1% + 420, %2% - 260 - 320, %fullheight%, %fullheight%, 0, 0, true
	if[%floor% < 3] AddFloor SouthZoneCeiling, %5%Ceiling, 0.5, -%1% + 240, %2% - 260 - 320 - 160, -%1% + 420, %2% - 260 - 320, %fullheight%, %fullheight%, 0, 0, true
	if[%floor% < 2] AddFloor SouthZoneCeiling2, %5%Ceiling, 0.5, -%1% + 240, %2% - 740 - 120, -%1% + 420, %2% - 740, %fullheight%, %fullheight%, 0, 0, true

	if[%floor% ! 6 & %floor% ! 7] AddFloor EastZoneCeiling, %5%Ceiling, 0.5, %1% - 240, -%2% + 260, %1%, %2% - 220, %fullheight%, %fullheight%, 0, 0, true
	if[%floor% = 7] AddFloor EastZoneCeiling2, %5%Ceiling, 0.5, %1% - 240, %2% - 220 - 80, %1%, %2% - 220, %fullheight%, %fullheight%, 0, 0, true
<EndFloors>

<Floors 8 to 9>
	TexPrefix() #Set texture prefix/suffix

	#Floors
	FloorOrientation = top
	DrawWalls = %ShowBottom%, true, false, false, false, false
	if[%floor% ! 9] AddFloor WestZoneFloor2A, %5%Floor, 0.5, -%1%, %2% - 260 - 320, -%1% + 120, %2% - 260, %interfloorheight%, %interfloorheight%, 0, 0, true
	if[%floor% ! 9] AddFloor WestZoneFloor2B, %5%Floor, 0.5, -%1% + 120, %2% - 260 - 320, -%1% + 120 + 80, 20 - 30, %interfloorheight%, %interfloorheight%, 0, 0, true
	if[%floor% ! 9] AddFloor WestZoneFloor2C, %5%Floor, 0.5, -%1% + 120, 140 + 30, -%1% + 120 + 80, %2% - 260, %interfloorheight%, %interfloorheight%, 0, 0, true

	if[%floor% ! 9] AddFloor EastZoneFloor2, %5%Floor, 0.5, %1% - 240, %2% - 220 - 80, %1%, %2% - 220, %interfloorheight%, %interfloorheight%, 0, 0, true

	#Ceilings
	FloorOrientation = bottom
	DrawWalls = true, false, false, false, false, false
	if[%floor% ! 8] AddFloor WestZoneCeiling, %5%Ceiling, 0.5, -%1%, %2% - 260 - 320, -%1% + 240, %2% - 260, %fullheight%, %fullheight%, 0, 0, true
	if[%floor% ! 8] AddFloor CenterZoneCeiling, %5%Ceiling, 0.5, -%1% + 240, %2% - 260 - 320, -%1% + 420, %2% - 260, %fullheight%, %fullheight%, 0, 0, true
	if[%floor% ! 8] AddFloor EastZoneCeiling2, %5%Ceiling, 0.5, %1% - 240, -%2% + 260, %1%, %2% - 220, %fullheight%, %fullheight%, 0, 0, true
<EndFloors>

<Floors 0 to 9>
	#Perimeter walls
	TexPrefix() #Set texture prefix/suffix
	Set WallHeight = %fullheight%
	Set WallOffset = 0
	if[%floor% = 0] Set WallHeight = %height%
	if[%floor% = 0] Set WallOffset = %interfloorheight%

	DrawWalls = true, true, false, false, false, false

		#West zone
		Set Extra = 0
		if[%floor% < 4] Set Extra = 0.5

		WallOrientation = Left
		TextureOverride ExtFacade, %5%Wall, Blank, Blank, Blank, Blank
		AddWall WZ_FrontWall, ExtFacade, 0.5, -%1%, %2% - 260 - 320, -%1% + 240 + %Extra%, %2% - 260 - 320, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		TextureOverride ExtFacade, %5%Wall, Blank, Blank, Blank, Blank
		AddWall WZ_LeftWall, ExtFacade, 0.5, -%1%, %2% - 260 - 320, -%1%, %2% - 260, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		WallOrientation = Right
		TextureOverride %5%Wall, ExtFacade2, Blank, Blank, Blank, Blank
		AddWall WZ_BackWall, ExtFacade, 0.5, -%1%, %2% - 260, -%1% + 240, %2% - 260, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		#Center zone
		Set Extra = 0
		if[%floor% > 3] Set Extra = 0.5 #Reset for center zone's front wall

		WallOrientation = Right
		TextureOverride %5%Wall, ExtFacade2, Blank, Blank, Blank, Blank
		AddWall CZ_BackWall, ExtFacade, 0.5, -%1% + 240, %2% - 260, -%1% + 420 + 0.5, %2% - 260, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		WallOrientation = Left
		TextureOverride ExtFacade, %5%Wall, Blank, Blank, Blank, Blank
		if[%floor% > 3] AddWall CZ_FrontWall, ExtFacade, 0.5, -%1% + 240, %2% - 260 - 320, -%1% + 420 + %Extra%, %2% - 260 - 320, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		#South zone
		WallOrientation = Left
		TextureOverride ExtFacade, %5%Wall, Blank, Blank, Blank, Blank
		if[%floor% < 4] AddWall SZ_FrontWall, ExtFacade, 0.5, -%1% + 240, %2% - 740 - 120, -%1% + 420, %2% - 740 - 120, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		TextureOverride ExtFacade, %5%Wall, Blank, Blank, Blank, Blank
		if[%floor% < 4] AddWall SZ_LeftWall, ExtFacade, 0.5, -%1% + 240, %2% - 740 - 120, -%1% + 240, %2% - 260 - 320 + 0.5, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		WallOrientation = right
		DrawWalls = true, true, false, true, false, true #Override
		if[%floor% = 3] AddWall SZ_RightWall, %5%Wall, 0.5, -%1% + 420, %2% - 740 - 120, -%1% + 420, -%2% + 260, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		DrawWalls = true, true, false, false, false, false #Reset drawwalls

		#East zone
		WallOrientation = Left
		TextureOverride ExtFacade, %5%Wall, Blank, Blank, Blank, Blank
		if[%floor% > 7] AddWall EZ_FrontWall, ExtFacade, 0.5, %1% - 240, -%2% + 260, %1%, -%2% + 260, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		DrawWalls = true, true, false, false, false, true #Override
		TextureOverride ExtFacade, %5%Wall, Blank, Blank, Blank, %5%Wall
		if[%floor% = 7] AddWall EZ_FrontWall_EX, ExtFacade, 0.5, %1% - 240, -%2% + 260, %1%, -%2% + 260, %WallHeight% - 6, %WallHeight% - 6, %WallOffset% + 6, %WallOffset% + 6, 0, 0, true

		DrawWalls = true, true, false, false, false, false #Reset drawwalls
		TextureOverride ExtFacade, %5%Wall, Blank, Blank, Blank, Blank
		if[%floor% > 3] AddWall EZ_LeftWall1, ExtFacade, 0.5, %1% - 240, -%2% + 260, %1% - 240, %2% - 260 - 320 + 0.5, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		TextureOverride ExtFacade2, %5%Wall, Blank, Blank, Blank, Blank
		AddWall EZ_LeftWall2, ExtFacade, 0.5, %1% - 240, %2% - 260 - 0.5, %1% - 240, %2% - 220, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		WallOrientation = right
		TextureOverride %5%Wall, ExtFacade, Blank, Blank, Blank, Blank
		AddWall EZ_RightWall, ExtFacade, 0.5, %1%, -%2% + 260, %1%, %2% - 220, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
<EndFloors>

