<Function BtnPanelEastElev> #Used by Elevators 16-25
	Set PanelNumber = %param1%
	Set PanelNumber2 = %PanelNumber% + 1
	Set BtnPrefix = NewOtisButton

	if[%PanelNumber% = 1] AddButton %PanelNumber2%, , %BtnPrefix%Alarm, %BtnPrefix%Alarm, 1, 1, alarm, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%Open, %BtnPrefix%Open, 3, 1, open, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%Close, %BtnPrefix%Close, 3, 2, close, 1, 1

	AddButton %PanelNumber%, , %BtnPrefix%8, %BtnPrefix%Lit8, 5, 2, 8, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%7, %BtnPrefix%Lit7, 5, 1, 6, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%6, %BtnPrefix%Lit6, 6, 2, 5, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%5, %BtnPrefix%Lit5, 6, 1, 4, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%4, %BtnPrefix%Lit4, 7, 2, 3, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%3, %BtnPrefix%Lit3, 7, 1, 2, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%2, %BtnPrefix%Lit2, 8, 2, 1, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%1, %BtnPrefix%Lit1, 8, 1, 0, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%B1, %BtnPrefix%LitB1, 9, 2, -1, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%B2, %BtnPrefix%LitB2, 9, 1, -2, 1, 1
<EndFunction>

<Elevators 16 to 19>
	Set Prefix = East

	#Set textures and dimensions
	M10_ElevCabTex(ElevExt, %Prefix%ElevFloor, %Prefix%ElevCeiling, %Prefix%ElevWall, %Prefix%ElevWall)
	M10_ElevDimensions(7, 6.5, 8, 0.2, 0.2, false, true, true, true)
	M10_ElevPanels(%Prefix%ElevPanelMain, %Prefix%ElevPanelTop, 1.5, 1.5, 1, 0.2, true, false, false, false)

	#Finish elevator assembly
	M10_ElevInterior()
	#--------------------
	#Car Doors
	Set ElevDoorTex = %Prefix%ElevDoors
	Set IDP = -3.25

	WallOrientation = right
	AddDoorComponent 1, Left, %ElevDoorTex%, %ElevDoorTex%, 0.2, right, 0.8, 0.6, 0, %IDP%, 2, %IDP%, 7, 0, 0, 0, 0, 0
	AddDoorComponent 1, Right, %ElevDoorTex%2, %ElevDoorTex%2, 0.2, left, 0.8, 0.6, -2, %IDP%, 0, %IDP%, 7, 0, 0, 0, 0, 0
	FinishDoors 1, false, false

		#Door track
		FloorOrientation = top
		DrawWalls = true, true, true, true, true, true
		TextureOverride ElevExt, ElevDoorTrackZ, ElevExt, ElevExt, ElevExt, ElevExt
		AddFloor DoorTrack, ElevDoorTrackZ, 0.05, -2 - (2 * 1), %IDP% - 0.2, 2 + (2 * 1), %IDP%, 0, 0, 0, 0
	#--------------------
	#Button Panels
	Set Position = -2.65 #Right (Main) panel
	Set Position2 = 2.65 #Left (Secondary) panel

		#Panel backs
		CreateWallBox2 elevator, PB1, ElevPanel, %Position%, -3.05 + 0.025, 0.8, 0.05, 4.25 + 0.125 + 0.5, 2.5 - 0.125 - 0.5, 0, 0, false, true, true, true
		CreateWallBox2 elevator, PB2, ElevPanel, %Position2%, -3.05 + 0.025, 0.8, 0.05, 2 + 0.125, 2.5 - 0.125, 0, 0, false, true, true, true

		#Right Panel
		CreatePanel , 9, 2, back, %Position%, -3.05 + 0.051, 0.3, 0.15, 0.125, 0.25, 3.625, 0, 0
		CreatePanel , 9, 1, back, %Position%, -3.05 + 0.051, 0.3, 0.15, 0.125, 0.25, 3.625, 0, 0 #Alarm button only

			#Buttons
			BtnPanelEastElev(1)

		#Left Panel
		CreatePanel , 9, 2, back, %Position2%, -3.05 + 0.051, 0.3, 0.15, 0.125, 0.25, 3.625, 0, 0

			BtnPanelEastElev(3)
	#--------------------
	#Indicator sets
	Set IndOffset = 5.75

		#Right
		DrawWalls = false, true, false, false, false, false
		AddWall RightIndBack, NewOtisInd_BG, 0, %Position% - 0.25, -3.05 + 0.051, %Position% + 0.25, -3.05 + 0.051, 0.9, 0.9, %IndOffset% - 0.15, %IndOffset% - 0.15, 0, 0

		AddFloorIndicator NewOtisInd_Button, back, %Position%, -3.05 + 0.052, 0.4, 0.4, %IndOffset% + 0.15 - 0.1
		AddDirectionalIndicator true, true, true, Blank, NewOtisArrow_Blank, NewOtisArrow_LitUp, NewOtisArrow_Blank, NewOtisArrow_LitDown, %Position%, -3.05 + 0.052, %IndOffset% + 0.15 + 0.3, back, 0.24, 0.3, true, 0, 0
	#--------------------
	#Elevator number sign
	DrawWalls = false, true, false, false, false, false
	AddWall ElevNo%elevator%_Inside, IN_ElevNo%elevator%, 0, 0 - 0.25, -3.05 + 0.001, 0 + 0.25, -3.05 + 0.001, 0.5, 0.5, 7.05, 7.05, 0, 0
	#--------------------
	#Shaft components
	DrawWalls = true, true, true, true, true, true
		#Ropes
		RopePosition = 0, 8 + 0.2, 0
		RopeTexture = Ropes

		#Counterweight
		Set Position = 3.25 + 0.75
		CreateCounterweight CWeight_Frame, CWeight, 0, %Position%, 2, 6, 0.5, 0.5

		#Rails
		AddRails ElevRail, ElevRailSide, 0, 0, false, 3.5 + 0.06, 0.1
		AddRails ElevRail, ElevRailSide, 0, %Position%, false, 1 + 0.06, 0.1
<EndElevators>

