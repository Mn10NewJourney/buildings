########################################

<Function MainPlazaSupport>
	Set Prefix = %param1%
	Set SupportX = %param2% #Rightmost column
	Set SupportZ = %param3%
	CreateWallBox2 external, Support%Prefix%1A, ColumnTex, %SupportX% + (%DistanceX% * 1), %SupportZ% + 1.25, 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%1, ColumnTex, %SupportX%, %SupportZ% + 1.25, 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%2, ColumnTex, %SupportX% - (%DistanceX% * 1), %SupportZ%, 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%3, ColumnTex, %SupportX% - (%DistanceX% * 2), %SupportZ%, 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%4, ColumnTex, %SupportX% - (%DistanceX% * 3), %SupportZ%, 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%5, ColumnTex, %SupportX% - (%DistanceX% * 4), %SupportZ%, 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%6, ColumnTex, %SupportX% - (%DistanceX% * 5), %SupportZ%, 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%7, ColumnTex, %SupportX% - (%DistanceX% * 6), %SupportZ%, 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%8, ColumnTex, %SupportX% - (%DistanceX% * 7), %SupportZ%, 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%9, ColumnTex, %SupportX% - (%DistanceX% * 8), %SupportZ%, 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%10, ColumnTex, %SupportX% - (%DistanceX% * 9), %SupportZ%, 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%11, ColumnTex, %SupportX% - (%DistanceX% * 10), %SupportZ%, 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	if[%Prefix% ! N & %Prefix% ! K] CreateWallBox2 external, Support%Prefix%12, ColumnTex, %SupportX% - (%DistanceX% * 11), %SupportZ%, 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	if[%Prefix% ! N] CreateWallBox2 external, Support%Prefix%13, ColumnTex, %SupportX% - (%DistanceX% * 12), %SupportZ%, 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	if[%Prefix% ! N] CreateWallBox2 external, Support%Prefix%14, ColumnTex, %SupportX% - (%DistanceX% * 13) + 1.25, %SupportZ%, 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
<EndFunction>

<Function MainPlazaSupport2>
	Set Prefix = %param1%
	Set SupportX = %param2% #Rightmost column
	Set SupportZ = %param3%
	CreateWallBox2 external, WestSupport%Prefix%1, ColumnTex, %SupportX%, %SupportZ%, 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, WestSupport%Prefix%2, ColumnTex, %SupportX% - (%DistanceX% * 1), %SupportZ%, 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	if[%Prefix% ! W] CreateWallBox2 external, WestSupport%Prefix%3, ColumnTex, %SupportX% - (%DistanceX% * 2), %SupportZ%, 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, WestSupport%Prefix%4, ColumnTex, %SupportX% - (%DistanceX% * 3), %SupportZ%, 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, WestSupport%Prefix%5, ColumnTex, %SupportX% - (%DistanceX% * 4), %SupportZ%, 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, WestSupport%Prefix%6, ColumnTex, %SupportX% - (%DistanceX% * 5), %SupportZ%, 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, WestSupport%Prefix%7, ColumnTex, %SupportX% - (%DistanceX% * 6), %SupportZ%, 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	#CreateWallBox2 external, WestSupport%Prefix%8, ColumnTex, %SupportX% - (%DistanceX% * 7), %SupportZ%, 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
<EndFunction>

<Function MainPlazaSupport3>
	Set Prefix = %param1%
	Set SupportX = %param2% #Rightmost column
	Set SupportZ = %param3%
	CreateWallBox2 external, NWSupport%Prefix%1, ColumnTex, %SupportX%, %SupportZ%, 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, NWSupport%Prefix%2, ColumnTex, %SupportX%, %SupportZ% + (%DistanceZ% * 1), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, NWSupport%Prefix%3, ColumnTex, %SupportX%, %SupportZ% + (%DistanceZ% * 2), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, NWSupport%Prefix%4, ColumnTex, %SupportX%, %SupportZ% + (%DistanceZ% * 3), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, NWSupport%Prefix%5, ColumnTex, %SupportX%, %SupportZ% + (%DistanceZ% * 4), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, NWSupport%Prefix%6, ColumnTex, %SupportX%, %SupportZ% + (%DistanceZ% * 5), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, NWSupport%Prefix%7, ColumnTex, %SupportX%, %SupportZ% + (%DistanceZ% * 6) - 1.25, 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
<EndFunction>

#SUPPORTS
#Parking Garage Supports
<Floors -2 to -1>
	#Set Values
	TexPrefix() #Set texture prefixes
	Set DistanceX = 40 #Distance between supports X
	Set DistanceZ = 40 #Distance between supports Z

	Set SupportHeight = %fullheight%
	if[%floor% = -1] Set SupportHeight = %fullheight% + Floor(0).InterfloorHeight
	Set SupportOffset = -%interfloorheight%
	
	#West Area
	MainPlazaSupport2(P, -130, -60)
	MainPlazaSupport2(Q, -130, -60 + 40)
	MainPlazaSupport2(R, -130, -60 + 80)
	MainPlazaSupport2(S, -130, -60 + 120)
	MainPlazaSupport2(T, -130, -60 + 160)
	MainPlazaSupport2(U, -130, -60 + 200)
	MainPlazaSupport2(V, -130, -60 + 240)
	MainPlazaSupport2(W, -130, -60 + 280)
	MainPlazaSupport3(Test, -370, 260)
	
	#East and Center Areas
	MainPlazaSupport(A, %1% + 100, -220)
	MainPlazaSupport(B, %1% + 100, -220 + 40)
	MainPlazaSupport(C, %1% + 100, -220 + 80)
	MainPlazaSupport(D, %1% + 100, -220 + 120)
	MainPlazaSupport(E, %1% + 100, -220 + 160)
	MainPlazaSupport(F, %1% + 100, -220 + 200)
	MainPlazaSupport(G, %1% + 100, -220 + 240)
	MainPlazaSupport(H, %1% + 100, -220 + 280)
	MainPlazaSupport(J, %1% + 100, -220 + 320)
	MainPlazaSupport(K, %1% + 100, -220 + 360)
	MainPlazaSupport(L, %1% + 100, -220 + 400)
	MainPlazaSupport(M, %1% + 100, -220 + 440)
	MainPlazaSupport(N, %1% + 100, -220 + 480)
<EndFloors>

##--------------------------------------------------------------------------------##

#TOWER PARKING LOBBY

<Floors -2 to -1>
	CutAll -210, %interfloorheight% - 1, 210 - 5, -175, %interfloorheight% + 1, 240, false, true #Floor cuts
<EndFloors>

<Floors 0 to 11>
	CutAll -210, %interfloorheight% - 0.1, 210, -175, %interfloorheight% + 0.1, 240, false, true #Floor cuts
	CutAll -200, 0, 239.5 - 0.1, -185, %fullheight%, 239.5 + 0.1, true, false #Back wall cuts
	CutAll -200, %fullheight% - 1, 210, -185, %fullheight% + 1, 240, false, true #Ceiling cuts
<EndFloors>

<Floors -2 to -1>
	TexPrefix()
	
	#Tower Parking Lobby Floors and Ceilings
		FloorOrientation = top
		DrawWalls = true, true, false, false, false, false
		TextureOverride ParkingCeiling, ParkingFloor, Blank, Blank, Blank, Blank
		AddFloor TPKLobbyFloor_EX1, ParkingFloor, 1, -210, 210 - 5, -175, 210, %interfloorheight%, %interfloorheight%, 0, 0, true
		DrawWalls = false, true, false, false, false, false
		AddFloor TPKLobbyFloor, ParkingLobbyFloor, 0.5, -210, 210, -175, 240, %interfloorheight%, %interfloorheight%, 0, 0, true

		FloorOrientation = bottom
		DrawWalls = true, false, false, false, false, false
		AddFloor TPKLobbyCeiling, ParkingLobbyCeiling, 0.5, -200, 210, -185, 240, %fullheight%, %fullheight%, 0, 0, true

	#Tower Parking Lobby Walls
	WallOrientation = left
	DrawWalls = true, true, false, false, false, false
	
	Set WallHeight = %fullheight%
	Set WallOffset = 0
	if[%floor% = -1] Set WallHeight = %fullheight% + Floor(0).InterfloorHeight
	if[%floor% = -1] Set WallOffset = 0
	
	if[%floor% < 10] Set OutsideTex = %5%Wall
	if[%floor% > 9] Set OutsideTex = ExtFacade

		WallOrientation = left
		TextureOverride %OutsideTex%, %5%%5L%, Blank, Blank, Blank, Blank
		AddWall TPK_Front, %5%Wall, 0.5, -200, 210, -185, 210, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		WallOrientation = right
		TextureOverride %5%%5L%, %5%Wall, Blank, Blank, Blank, Blank
		AddWall TPK_Back, %5%Wall, 0.5, -200, 240, -185, 240, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

	#Tower Parking Lobby Doors
	Set IntTex = BLKEntDoorInt
	if[%floor% < 10] Set ExtTex = BLKEntDoorInt
	if[%floor% > 9] Set ExtTex = BLKEntDoorExt
	Set SideTex = BLKEntDoorSide
	
		#Set for external windows
		if[%floor% < 10] Set OutsideWinTex = MainWindowsIntB
		if[%floor% > 9] Set OutsideWinTex = MainWindowsB

		#Front doors
		Set Door_MainX = -192.5
		Set Door_MainZ = 210
		WallOrientation = left
		TextureOverride %Texture%Int, %Texture%Int, %SideTex%, %SideTex%, %SideTex%, %SideTex%
		AddStdDoor Door Manager, TowerPL_D1, , , false, %IntTex%, %SideTex%, 0.2, back, front, 75, 75, %Door_MainX% - 1.5, %Door_MainZ%, 3, 7, Floor(%floor%).Base, 0, 0, 0, 0
		TextureOverride %Texture%Int, %Texture%Int, %SideTex%, %SideTex%, %SideTex%, %SideTex%
		AddStdDoor Door Manager, TowerPL_D2, , , false, %IntTex%, %SideTex%, 0.2, front, front, 75, 75, %Door_MainX% + 1.5, %Door_MainZ%, 3, 7, Floor(%floor%).Base, 0, 0, 0, 0
		AddFillerWalls %5%Wall, 0.5, %Door_MainX%, %Door_MainZ%, 6, 7, %interfloorheight%, true, 0, 0, true

		Add3DWindows(TPKFront_WinTop, %Door_MainX%, %Door_MainZ%, front, 12, %height% - 8, 7.5, %OutsideWinTex%, MainWindowsIntB, %5%Wall, 0.5, 4/4, 1)
		Add3DWindows(TPKFront_WinSide1, %Door_MainX% - 6 + 1.375, %Door_MainZ%, front, 2.75, 6.5, 0.5, %OutsideWinTex%, MainWindowsIntB, %5%Wall, 0.5, 1/4, 1)
		Add3DWindows(TPKFront_WinSide2, %Door_MainX% + 6 - 1.375, %Door_MainZ%, front, 2.75, 6.5, 0.5, %OutsideWinTex%, MainWindowsIntB, %5%Wall, 0.5, 1/4, 1)

		#Rear doors
		#Set LobbyHeight = 10
		Set LobbyHeight = %height%

		Set Door_MainX = -192.5
		Set Door_MainZ = 240
		WallOrientation = right
		TextureOverride %IntTex%, %IntTex%, %SideTex%, %SideTex%, %SideTex%, %SideTex%
		AddStdDoor Door Manager, TowerPL_D3, , , false, %IntTex%, %SideTex%, 0.2, back, back, 75, 75, %Door_MainX% - 1.5, %Door_MainZ%, 3, 7, Floor(%floor%).Base, 0, 0, 0, 0
		TextureOverride %IntTex%, %IntTex%, %SideTex%, %SideTex%, %SideTex%, %SideTex%
		AddStdDoor Door Manager, TowerPL_D4, , , false, %IntTex%, %SideTex%, 0.2, front, back, 75, 75, %Door_MainX% + 1.5, %Door_MainZ%, 3, 7, Floor(%floor%).Base, 0, 0, 0, 0
		AddFillerWalls %5%Wall, 0.5, %Door_MainX%, %Door_MainZ%, 6, 7, %interfloorheight%, true, 0, 0, true

		Add3DWindows(TPKBack_WinTop, %Door_MainX%, %Door_MainZ%, back, 12, %LobbyHeight% - 7.5, 7.25, MainWindowsIntB, MainWindowsIntB, %5%Wall, 0.5, 4/4, 1)
		Add3DWindows(TPKBack_WinSide1, %Door_MainX% - 6 + 1.375, %Door_MainZ%, back, 2.75, 6.5, 0.5, MainWindowsIntB, MainWindowsIntB, %5%Wall, 0.5, 1/4, 1)
		Add3DWindows(TPKBack_WinSide2, %Door_MainX% + 6 - 1.375, %Door_MainZ%, back, 2.75, 6.5, 0.5, MainWindowsIntB, MainWindowsIntB, %5%Wall, 0.5, 1/4, 1)
<EndFloors>

<Floors 0 to 11>
	TexPrefix()
	
	#Tower Parking Lobby Floors and Ceilings
		Set Suffix = 
		if[%floor% > 5] Set Suffix = 2 #Override for levels 7-10

		FloorOrientation = top
		DrawWalls = false, true, false, false, false, false
		AddFloor TPKLobbyFloor, TowerParkingLobbyFloor%Suffix%, 0.5, -210, 210, -175, 240, %interfloorheight%, %interfloorheight%, 0, 0, true

		FloorOrientation = bottom
		DrawWalls = true, false, false, false, false, false
		AddFloor TPKLobbyCeiling, TowerParkingLobbyCeiling, 0.5, -200, 210, -185, 240, %fullheight%, %fullheight%, 0, 0, true

		Set TopThickness = Floor(12).FullHeight + 1
		FloorOrientation = bottom
		DrawWalls = false, true, false, false, true, false
		if[%floor% = 11] AddFloor TPKLobbyCeilingTop, ExtFacade, %TopThickness%, -200, 210, -185, 240, %fullheight%, %fullheight%, 0, 0, true

	#Tower Parking Lobby Walls
	WallOrientation = left
	DrawWalls = true, true, false, false, false, false
	
	Set WallHeight = %fullheight%
	Set WallOffset = 0
	if[%floor% = 0] Set WallHeight = %height%
	if[%floor% = 0] Set WallOffset = %interfloorheight%
	
	if[%floor% < 10] Set OutsideTex = %5%Wall
	if[%floor% > 9] Set OutsideTex = ExtFacade

		WallOrientation = left
		TextureOverride %OutsideTex%, %LobbyPrefix%Wall, Blank, Blank, Blank, Blank
		AddWall TPK_Front, %5%Wall, 0.5, -200, 210, -185, 210, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		WallOrientation = right
		DrawWalls = true, false, false, false, false, false
		TextureOverride %LobbyPrefix%Wall, %5%Wall, Blank, Blank, Blank, Blank
		AddWall TPK_Back, %5%Wall, 0.5, -200, 240, -185, 240, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

	#Tower Parking Lobby Doors
	Set IntTex = BLKEntDoorInt
	if[%floor% < 10] Set ExtTex = BLKEntDoorInt
	if[%floor% > 9] Set ExtTex = BLKEntDoorExt
	Set SideTex = BLKEntDoorSide
	
		#Set for external windows
		if[%floor% < 10] Set OutsideWinTex = MainWindowsIntB
		if[%floor% > 9] Set OutsideWinTex = MainWindowsB

		#Front doors
		Set Door_MainX = -192.5
		Set Door_MainZ = 210
		WallOrientation = left
		if[%floor% = 10] SetLock 2, 1 #Lock the roof area for staff only
		TextureOverride %ExtTex%, %IntTex%, %SideTex%, %SideTex%, %SideTex%, %SideTex%
		if[%floor% ! 7 & %floor% ! 9 & %floor% ! 11] AddStdDoor Door Manager, TowerPL_D1, , , false, %IntTex%, %SideTex%, 0.2, back, front, 75, 75, %Door_MainX% - 1.5, %Door_MainZ%, 3, 7, Floor(%floor%).Base, 0, 0, 0, 0
		TextureOverride %ExtTex%, %IntTex%, %SideTex%, %SideTex%, %SideTex%, %SideTex%
		if[%floor% ! 7 & %floor% ! 9 & %floor% ! 11] AddStdDoor Door Manager, TowerPL_D2, , , false, %IntTex%, %SideTex%, 0.2, front, front, 75, 75, %Door_MainX% + 1.5, %Door_MainZ%, 3, 7, Floor(%floor%).Base, 0, 0, 0, 0
		if[%floor% ! 7 & %floor% ! 9 & %floor% ! 11] AddFillerWalls %LobbyPrefix%Wall, 0.5, %Door_MainX%, %Door_MainZ%, 6, 7, %interfloorheight%, true, 0, 0, true
		SetLock 0, 0

		if[%floor% = 7 | %floor% = 9 | %floor% = 11] Add3DWindows(TPKFront_WinTop_Alt, %Door_MainX%, %Door_MainZ%, front, 12, %height% - 1.5, 0.75, %OutsideWinTex%, MainWindowsIntB, %LobbyPrefix%Wall, 0.5, 4/4, 2)
		if[%floor% = 6 | %floor% = 8 | %floor% = 10] Add3DWindows(TPKFront_WinTop, %Door_MainX%, %Door_MainZ%, front, 12, %height% - 7.5, 7.25, %OutsideWinTex%, MainWindowsIntB, %LobbyPrefix%Wall, 0.5, 4/4, 1)
		if[%floor% < 6] Add3DWindows(TPKFront_WinTop, %Door_MainX%, %Door_MainZ%, front, 12, %height% - 8, 7.5, %OutsideWinTex%, MainWindowsIntB, %LobbyPrefix%Wall, 0.5, 4/4, 1)
		if[%floor% ! 7 & %floor% ! 9 & %floor% ! 11] Add3DWindows(TPKFront_WinSide1, %Door_MainX% - 6 + 1.375, %Door_MainZ%, front, 2.75, 6.5, 0.5, %OutsideWinTex%, MainWindowsIntB, %LobbyPrefix%Wall, 0.5, 1/4, 1)
		if[%floor% ! 7 & %floor% ! 9 & %floor% ! 11] Add3DWindows(TPKFront_WinSide2, %Door_MainX% + 6 - 1.375, %Door_MainZ%, front, 2.75, 6.5, 0.5, %OutsideWinTex%, MainWindowsIntB, %LobbyPrefix%Wall, 0.5, 1/4, 1)

		#Rear doors
		Set LobbyHeight = 10
		if[%floor% > 5] Set LobbyHeight = %height%

		Set Door_MainX = -192.5
		Set Door_MainZ = 240
		WallOrientation = right
		TextureOverride %IntTex%, %IntTex%, %SideTex%, %SideTex%, %SideTex%, %SideTex%
		AddStdDoor Door Manager, TowerPL_D3, , , false, %IntTex%, %SideTex%, 0.2, back, back, 75, 75, %Door_MainX% - 1.5, %Door_MainZ%, 3, 7, Floor(%floor%).Base, 0, 0, 0, 0
		TextureOverride %IntTex%, %IntTex%, %SideTex%, %SideTex%, %SideTex%, %SideTex%
		AddStdDoor Door Manager, TowerPL_D4, , , false, %IntTex%, %SideTex%, 0.2, front, back, 75, 75, %Door_MainX% + 1.5, %Door_MainZ%, 3, 7, Floor(%floor%).Base, 0, 0, 0, 0
		AddFillerWalls %LobbyPrefix%Wall, 0.5, %Door_MainX%, %Door_MainZ%, 6, 7, %interfloorheight%, true, 0, 0, true

		Add3DWindows(TPKBack_WinTop, %Door_MainX%, %Door_MainZ%, back, 12, %LobbyHeight% - 7.5, 7.25, MainWindowsIntB, MainWindowsIntB, %LobbyPrefix%Wall, 0.5, 4/4, 1)
		Add3DWindows(TPKBack_WinSide1, %Door_MainX% - 6 + 1.375, %Door_MainZ%, back, 2.75, 6.5, 0.5, MainWindowsIntB, MainWindowsIntB, %LobbyPrefix%Wall, 0.5, 1/4, 1)
		Add3DWindows(TPKBack_WinSide2, %Door_MainX% + 6 - 1.375, %Door_MainZ%, back, 2.75, 6.5, 0.5, MainWindowsIntB, MainWindowsIntB, %LobbyPrefix%Wall, 0.5, 1/4, 1)
<EndFloors>

<Floor 11>
	#Roof access key
	SetKey 1
	AddModel Key1, key.mesh, true, -185 - 0.414, 0, 210.5 + 0.407, 0, 0, 0, 0, 3, false, 0, 0, 0
<EndFloor>

##--------------------------------------------------------------------------------##

#External shaft walls for all shafts
<Floor -2>
	TexPrefix()

	#South Elevators
