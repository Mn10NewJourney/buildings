		Load data/Kone_KDS_290-300/Lanterns/Arrow-Blank-Black.png, LanternDown, 1, 1, false
		Load data/Kone_KDS_290-300/Lanterns/Arrow-LitRed-Hall-Down.png, LanternDownLit, 1, 1, false

		#Inside arrows
		Load data/Kone_KDS_290-300/Directional Indicators/Arrow-Blank.png, ArrowUp, 1, 1, false
		Load data/Kone_KDS_290-300/Directional Indicators/Arrow-LitRed.png, ArrowUpLit, 1, 1, false
		ScrollAnim ArrowUpLit, 0, 1
		Load data/Kone_KDS_290-300/Directional Indicators/Arrow-Blank.png, ArrowDown, 1, 1, false
		Load data/Kone_KDS_290-300/Directional Indicators/Arrow-LitRed-Down.png, ArrowDownLit, 1, 1, false
		ScrollAnim ArrowDownLit, 0, -1

		#Floor indicators (Both outside and inside)
		Load data/black.jpg, IndBack, 1, 1, false
		Load data/black.jpg, IndBack2, 1, 1, false #This might be replaced with a slightly brighter shade of black.
		#Load data/gray2-sm.jpg, IndBack2, 1, 1, false
		AddTextRange 1, 2, IndBack, Ind_ButtonB%number%, fontgomery.ttf, 47, B%number%, 20, 0, 128, 128, center, center, 255, 0, 0, false
		AddTextRange 1, 10, IndBack, Ind_Button%number%, fontgomery.ttf, 47, %number%, 20, 0, 128, 128, center, center, 255, 0, 0, false
		AddTextRange 7, 8, IndBack, Ind_Button%number%A, fontgomery.ttf, 47, %number%A, 20, 0, 128, 128, center, center, 255, 0, 0, false

	#Signs
		#Main Floor Star
		Load data/Melvin/Aceheart/MainFloorStar.png, MainFloorStar, 1, 1, false

		#Elevator number signs (Inside)
		Load data/Melvin/transparent128.png, IN_ElevNoBack, 1, 1, false
		AddTextRange 1, 3, IN_ElevNoBack, IN_ElevNo%number%, nimbus_sans_bold.ttf, 55, %number%, -1, -1, -1, -1, center, center, 0, 255, 255, false
		AddTextRange 4, 7, IN_ElevNoBack, IN_ElevNo%number%, nimbus_sans_bold.ttf, 55, %number%, -1, -1, -1, -1, center, center, 0, 0, 0, false
		AddTextRange 8, 13, IN_ElevNoBack, IN_ElevNo%number%, nimbus_sans_bold.ttf, 55, %number%, -1, -1, -1, -1, center, center, 0, 0, 0, false

		#Floor signs (Elevator lobby)


		#Floor signs (Stairwells)
		AddTextRange 1, 2, Blank, BlankSignB%number%, nimbus_sans_bold.ttf, 72, B%number%, -1, -1, -1, -1, center, center, 0, 0, 0, false
		AddTextRange 1, 10, Blank, BlankSign%number%, nimbus_sans_bold.ttf, 72, %number%, -1, -1, -1, -1, center, center, 0, 0, 0, false
		AddTextRange 7, 8, Blank, BlankSign%number%A, nimbus_sans_bold.ttf, 72, %number%A, -1, -1, -1, -1, center, center, 0, 0, 0, false
		#AddText Blank, BlankSignR, nimbus_sans_bold.ttf, 72, R, -1, -1, -1, -1, center, center, 0, 0, 0, false

		#Restrooms
		Load data/signs_mod/Restroom1A.png, Sign_Restroom_Brown, 1, 1, false
		Load data/signs_mod/Restroom1.png, Sign_Restroom_Gray, 1, 1, false
		Load data/signs_mod/Sign_Restroom_1A.png, Sign_RestroomW_Brown, 1, 1, false
		Load data/signs_mod/Sign_Restroom_3A.png, Sign_RestroomM_Brown, 1, 1, false
		Load data/signs_mod/Sign_Restroom_1.png, Sign_RestroomW_Gray, 1, 1, false
		Load data/signs_mod/Sign_Restroom_3.png, Sign_RestroomM_Gray, 1, 1, false

		#Elevators
		Load data/signs_mod/Elev3.png, Sign_Elev, 1, 1, false
		Load data/signs_mod/Elev4A.png, Sign_ServiceElevA, 1, 1, false
		Load data/signs_mod/Elev4B.png, Sign_ServiceElevB, 1, 1, false

		#Proximity scanners
		#Load data/EG881/proxscan1.jpg, ProxScan, 1, 1, false #EG881
		Load data/EG881/Miscellaneous/HIDbadgescannergreen.jpg, HIDScanGreen, 1, 1, false #EG881
		Load data/EG881/Miscellaneous/HIDbadgescannerred.jpg, HIDScanRed, 1, 1, false #EG881

		#Exit signs
		Load data/panel-back3.jpg, StainlessSteel, 1, 1, false
