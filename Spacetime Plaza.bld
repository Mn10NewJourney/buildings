ShowFullStairs 5 = always

<Floors 0 to 10>
	StairwellSets() #Determine stairs' size

	Set 21 = 85 #Center X
	Set 22 = -36 #Center Z
	Set 23 = 4.5 #Cut X
	Set 24 = 14.5 #Cut Z
	Set 25 = 5 #Stairwell Number
	Set 26 = 0.5 #Riser Size

	#Walls
	WallOrientation = right
	DrawWalls = false, true, false, false, false, false
