########################################

#Underground parking access roadways
Set LL = Floor(-1).Base #Level B1's floor elevation
Set LL2 = %LL% + 8 #Level B1's (lowered) ceiling elevation
Set SL = 0 #Street level
Set UL = Floor(0).Base #1st floor's floor elevation

	#South-Center Entrance/Exit (5th Street to level B1)
		#Cut landscape for roadways and sidewalks
		Cut Landscape, 10 - 15 - 20, %LL2% - 1, -%2% - 20, 10 - 15, %UL% + 1, -%2%, false, true
		Cut Landscape, 10 + 15, %LL2% - 1, -%2% - 20, 10 + 15 + 20, %UL% + 1, -%2%, false, true

		Cut Landscape, 10 - 15 - 20, %LL2% - 1, -783, 10 + 15 + 20, %UL% + 1, -%2%, false, true
		Cut Landscape, 10 - 15, %LL2% - 1, -798, 10 + 15, %UL% + 1, -783, false, true

		Cut Landscape, 10 - 15, %UL% - 1, -%2%, 10 + 15, %UL% + 1, -%2% + 80, false, true #Extra cut (Added on May 31, 2026)

		FloorOrientation = top
		DrawWalls = false, true, false, false, false, false
		AddFloor landscape, SouthAccRoad, B1FSouthAccRoad, 0.5, 10 - 15, -%2% + 80, 10 + 15, %2% - 260 - 320, %LL%, %LL%, 0, 0
		AddFloor landscape, SouthAccRoad_Slope, B1FSouthAccRoad, 0.5, 10 - 15, -%2%, 10 + 15, -%2% + 80, %SL%, %LL%, 0, 0
		AddFloor landscape, SouthAccRoad_Top1, B1FSouthAccRoad, 0.5, 10 - 15, -783, 10 + 15, -%2%, %SL%, %SL%, 0, 0
		AddFloor landscape, SouthAccRoad_Top2, Road, 0.5, 10 - 15, -798, 10 + 15, -783, -0.5, %SL%, 0, 0
	
		AddFloor landscape, SouthAccRoad_Sidewalk1, Sidewalk, 0.5, 10 - 15 - 20, -783, 10 - 15, -%2%, %SL%, %SL%, 0, 0
		AddFloor landscape, SouthAccRoad_Sidewalk2, Sidewalk, 0.5, 10 + 15, -783, 10 + 15 + 20, -%2%, %SL%, %SL%, 0, 0

		#Ceiling on level B1
		FloorOrientation = bottom
		DrawWalls = true, false, false, false, false, false
		AddFloor landscape, SouthAccRoad_Ceiling, ParkingCeiling, 0.5, 10 - 15, -%2% + 80, 10 + 15, %2% - 260 - 320 + 0.5, %LL2%, %LL2%, 0, 0

		#Walls around roadways
		WallOrientation = right
		DrawWalls = false, true, false, false, false, false
		AddWall landscape, SouthAccRoad_LeftWall, ParkingWall3, 0.5, 10 - 15, -%2%, 10 - 15, %2% - 260 - 320, 8, 8, %LL%, %LL%, 0, 0
		WallOrientation = left
		DrawWalls = true, false, false, false, false, false
		AddWall landscape, SouthAccRoad_RightWall, ParkingWall3, 0.5, 10 + 15, -%2%, 10 + 15, %2% - 260 - 320, 8, 8, %LL%, %LL%, 0, 0
		
		#Auto area for ramps
		AddFloorAutoArea -10 - 15, Floor(-1).Base, -%2%, 10 + 15, Floor(0).Base + 5, -%2% + 80

	#Northeast Entrance/Exit
		#Cut landscape for roadways and sidewalks
		Cut Landscape, 350 - 120, %SL% - 1, 559 + 3, 350, %UL% + 1, 589 - 3, false, true
		Cut Landscape, 350, %SL% - 1, 559, 350 + 30, %UL% + 1, 589, false, true
		Cut Landscape, 350 - 160, %SL% - 1, %2%, 350 - 120, %SL% + 1, 589 - 3, false, true

		FloorOrientation = top
		DrawWalls = false, true, false, false, false, false
		AddFloor landscape, NEAccRoad_Bottom, Road, 0.5, 350 - 160, %2%, 350 - 120, 589 - 3, %LL%, %LL%, 0, 0
		AddFloor landscape, NEAccRoad_Slope, B1FNorthAccRoad, 0.5, 350 - 120, 559 + 3, 350, 589 - 3, %LL%, %UL%, true, false, 0, 0
		AddFloor landscape, NEAccRoad_Slope, Road, 0.5, 350, 559, 350 + 30, 589, %UL%, %UL%, 0, 0
		
		#Railings at the top
		WallOrientation = right
		DrawWalls = true, true, true, true, true, false
		AddWall landscape, NEAccRoad_LeftRail, BrickFences, 0.5, 350 - 120, 559 + 3, 350 - 120, 589 - 3, 3.5, 3.5, %UL%, %UL%, 0, 0
		AddWall landscape, NEAccRoad_FrontRail, BrickFences, 0.5, 350 - 120.5, 559 + 3, 350, 559 + 3, 3.5, 3.5, %UL%, %UL%, 0, 0
		WallOrientation = left
		AddWall landscape, NEAccRoad_BackRail, BrickFences, 0.5, 350 - 120.5, 589 - 3, 350, 589 - 3, 3.5, 3.5, %UL%, %UL%, 0, 0

		#Walls around roadways
		WallOrientation = right
		DrawWalls = false, true, false, false, false, false
		AddWall landscape, NEAccRoad_LeftWall, ParkingWall4, 0.5, 350 - 160, %2%, 350 - 160, 589 - 3, 12, 12, %LL%, %LL%, 0, 0
		AddWall landscape, NEAccRoad_LeftWall2, ParkingWall4, 0.5, 350 - 120, 559 + 3, 350 - 120, 589 - 3, 4, 4, %SL%, %SL%, 0, 0
		AddWall landscape, NEAccRoad_FrontWall, ParkingWall4, 0.5, 350 - 120, 559 + 3, 350, 559 + 3, 12, 12, %LL%, %LL%, 0, 0

		WallOrientation = left
		DrawWalls = true, false, false, false, false, false
		AddWall landscape, NEAccRoad_RightWall, ParkingWall4, 0.5, 350 - 120, %2%, 350 - 120, 559 + 3, 12, 12, %LL%, %LL%, 0, 0
		AddWall landscape, NEAccRoad_BackWall, ParkingWall4, 0.5, 350 - 160, 589 - 3, 350, 589 - 3, 12, 12, %LL%, %LL%, 0, 0

		#Ceiling on level B1
		FloorOrientation = bottom
		DrawWalls = true, false, false, false, false, false
		AddFloor landscape, NEAccRoad_Ceiling, ParkingCeiling, 0.5, 350 - 160, %2%, 350 - 120, 589 - 3, %LL2%, %LL2%, 0, 0

		#Auto area for ramps
		AddFloorAutoArea 350 - 120, Floor(-1).Base, 559 + 3, 350, Floor(0).Base + 5, 589 - 3

	#Northwest Entrance/Exit
		#Cut landscape for roadways and sidewalks
		Cut Landscape, -250, %SL% - 1, 559 + 3, -250 + 120, %UL% + 1, 589 - 3, false, true
		Cut Landscape, -250 - 30, %SL% - 1, 559, -250, %UL% + 1, 589, false, true
		Cut Landscape, -250 + 120, %SL% - 1, %2%, -250 + 160, %SL% + 1, 589 - 3, false, true

		FloorOrientation = top
		DrawWalls = false, true, false, false, false, false
		AddFloor landscape, NWAccRoad_Bottom, Road, 0.5, -250 + 120, %2%, -250 + 160, 589 - 3, %LL%, %LL%, 0, 0
		AddFloor landscape, NWAccRoad_Slope, B1FNorthAccRoad, 0.5, -250, 559 + 3, -250 + 120, 589 - 3, %UL%, %LL%, true, false, 0, 0
		AddFloor landscape, NWAccRoad_Slope, Road, 0.5, -250 - 30, 559, -250, 589, %UL%, %UL%, 0, 0

		#Railings at the top
		WallOrientation = right
		DrawWalls = true, true, true, true, true, false
		AddWall landscape, NWAccRoad_FrontRail, BrickFences, 0.5, -250, 559 + 3, -250 + 120.5, 559 + 3, 3.5, 3.5, %UL%, %UL%, 0, 0
		WallOrientation = left
		AddWall landscape, NWAccRoad_RightRail, BrickFences, 0.5, -250 + 120, 559 + 3, -250 + 120, 589 - 3, 3.5, 3.5, %UL%, %UL%, 0, 0
		AddWall landscape, NWAccRoad_BackRail, BrickFences, 0.5, -250, 589 - 3, -250 + 120.5, 589 - 3, 3.5, 3.5, %UL%, %UL%, 0, 0

		#Walls around roadways
		WallOrientation = right
		DrawWalls = false, true, false, false, false, false
		AddWall landscape, NWAccRoad_FrontWall, ParkingWall4, 0.5, -250, 559 + 3, -250 + 120, 559 + 3, 12, 12, %LL%, %LL%, 0, 0
		AddWall landscape, NWAccRoad_LeftWall, ParkingWall4, 0.5, -250 + 120, %2%, -250 + 120, 559 + 3, 12, 12, %LL%, %LL%, 0, 0

		WallOrientation = left
		DrawWalls = true, false, false, false, false, false
		AddWall landscape, NWAccRoad_RightWall, ParkingWall4, 0.5, -250 + 160, %2%, -250 + 160, 589 - 3, 12, 12, %LL%, %LL%, 0, 0
		AddWall landscape, NWAccRoad_RightWall2, ParkingWall4, 0.5, -250 + 120, 559 + 3, -250 + 120, 589 - 3, 4, 4, %SL%, %SL%, 0, 0
		AddWall landscape, NWAccRoad_BackWall, ParkingWall4, 0.5, -250, 589 - 3, -250 + 160, 589 - 3, 12, 12, %LL%, %LL%, 0, 0

		#Ceiling on level B1
		FloorOrientation = bottom
		DrawWalls = true, false, false, false, false, false
		AddFloor landscape, NWAccRoad_Ceiling, ParkingCeiling, 0.5, -250 + 120, %2%, -250 + 160, 589 - 3, %LL2%, %LL2%, 0, 0


		#Auto area for ramps
		AddFloorAutoArea -250, Floor(-1).Base, 559 + 3, -250 + 120, Floor(0).Base + 5, 589 - 3

########################################

#Shopping levels
<Floors 0 to 7>
	TexPrefix() #Set texture prefix/suffix

	#Floors
	Set ShowBottom = false
	if[%floor% = 0] Set ShowBottom = true

	FloorOrientation = top
	DrawWalls = %ShowBottom%, true, false, false, false, false
	TextureOverride ParkingCeiling, %5%Floor, Blank, Blank, Blank, Blank #1st floor only
	if[%floor% ! 7] AddFloor WestZoneFloor, %5%Floor, 1, -%1%, %2% - 260 - 320, -%1% + 240, %2% - 260, %interfloorheight%, %interfloorheight%, 0, 0, true
	TextureOverride ParkingCeiling, %5%Floor, Blank, Blank, Blank, Blank #1st floor only
	if[%floor% ! 7] AddFloor CenterZoneFloor, %5%Floor, 1, -%1% + 240, %2% - 260 - 320, -%1% + 420, %2% - 260, %interfloorheight%, %interfloorheight%, 0, 0, true

	if[%floor% = 3] AddFloor SouthZoneFloor_Top, %5%Floor, 0.5, -%1% + 240, -180, -%1% + 420, %2% - 260 - 320, %interfloorheight%, %interfloorheight%, 0, 0, true

	DrawWalls = false, true, false, false, false, false
	if[%floor% < 3] AddFloor SouthZoneFloor, %5%Floor, 0.5, -%1% + 240, %2% - 260 - 320 - 160, -%1% + 420, %2% - 260 - 320, %interfloorheight%, %interfloorheight%, 0, 0, true
	if[%floor% < 3] AddFloor SouthZoneFloor2, %5%Floor, 0.5, -%1% + 240, %2% - 740 - 120, -%1% + 420, %2% - 740, %interfloorheight%, %interfloorheight%, 0, 0, true

	DrawWalls = %ShowBottom%, true, false, false, false, false
	TextureOverride ParkingCeiling, %5%Floor, Blank, Blank, Blank, Blank #1st floor only
	if[%floor% ! 7] AddFloor EastZoneFloor, %5%Floor, 1, %1% - 240, -%2% + 260, %1%, %2% - 220, %interfloorheight%, %interfloorheight%, 0, 0, true

		#Extra carpeting
		if[%floor% ! 0 & %floor% < 4] AddFloor SouthZoneCarpet, ShopCarpet, 0.5, -40, -140, 40, -80, %interfloorheight% + 0.001, %interfloorheight% + 0.001, 0, 0, true
		#if[%floor% ! 0 & %floor% ! 7] AddFloor EastZoneCarpet, %5%Carpet, 0.5, 180, 180, 240, 240, %interfloorheight% + 0.001, %interfloorheight% + 0.001, 0, 0, true

	#Ceilings
	FloorOrientation = bottom
	DrawWalls = true, false, false, false, false, false
	if[%floor% ! 6 & %floor% ! 7] AddFloor WestZoneCeiling, %5%Ceiling, 0.5, -%1%, %2% - 260 - 320, -%1% + 240, %2% - 260, %fullheight%, %fullheight%, 0, 0, true
	if[%floor% = 7] AddFloor WestZoneCeiling2A, %5%Ceiling, 0.5, -%1%, %2% - 260 - 320, -%1% + 120, %2% - 260, %fullheight%, %fullheight%, 0, 0, true
	if[%floor% = 7] AddFloor WestZoneCeiling2B, %5%Ceiling, 0.5, -%1% + 120, %2% - 260 - 320, -%1% + 240, 20 - 30, %fullheight%, %fullheight%, 0, 0, true
	if[%floor% = 7] AddFloor WestZoneCeiling2C, %5%Ceiling, 0.5, -%1% + 120, 140 + 30, -%1% + 240, %2% - 260, %fullheight%, %fullheight%, 0, 0, true
	if[%floor% = 7] AddFloor CenterZoneCeilingEX1, %5%Ceiling, 0.5, -%1% + 240, 140 + 30, 25, %2% - 260, %fullheight%, %fullheight%, 0, 0, true
	if[%floor% = 7] AddFloor CenterZoneCeilingEX2, %5%Ceiling, 0.5, -15, 140, 25, 140 + 30, %fullheight%, %fullheight%, 0, 0, true
	if[%floor% = 7] AddFloor CenterZoneCeilingEX3, %5%Ceiling, 0.5, 25, 181, 90, 240, %fullheight%, %fullheight%, 0, 0, true

	if[%floor% ! 6 & %floor% ! 7] AddFloor CenterZoneCeiling, %5%Ceiling, 0.5, -%1% + 240, %2% - 260 - 320, -%1% + 420, %2% - 260, %fullheight%, %fullheight%, 0, 0, true

	if[%floor% = 3] AddFloor SouthZoneCeiling, %5%Ceiling, 0.5, -%1% + 240, %2% - 740 - 120, -%1% + 420, %2% - 260 - 320, %fullheight%, %fullheight%, 0, 0, true
	if[%floor% = 2] AddFloor SouthZoneCeiling_Top, %5%Ceiling, 0.5, -%1% + 240, -180, -%1% + 420, %2% - 260 - 320, %fullheight%, %fullheight%, 0, 0, true
	if[%floor% < 2] AddFloor SouthZoneCeiling, %5%Ceiling, 0.5, -%1% + 240, %2% - 260 - 320 - 160, -%1% + 420, %2% - 260 - 320, %fullheight%, %fullheight%, 0, 0, true
	if[%floor% < 2] AddFloor SouthZoneCeiling2, %5%Ceiling, 0.5, -%1% + 240, %2% - 740 - 120, -%1% + 420, %2% - 740, %fullheight%, %fullheight%, 0, 0, true

	if[%floor% ! 6 & %floor% ! 7] AddFloor EastZoneCeiling, %5%Ceiling, 0.5, %1% - 240, -%2% + 260, %1%, %2% - 220, %fullheight%, %fullheight%, 0, 0, true
	if[%floor% = 7] AddFloor EastZoneCeiling2, %5%Ceiling, 0.5, %1% - 240, 181, %1%, %2% - 220, %fullheight%, %fullheight%, 0, 0, true
	if[%floor% = 7] AddFloor EastZoneCeiling3, %5%Ceiling, 0.5, %1% - 240, -%2% + 260, %1%, -21, %fullheight%, %fullheight%, 0, 0, true
<EndFloors>

<Floors 8 to 9>
	TexPrefix() #Set texture prefix/suffix

	#Floors
	FloorOrientation = top
	DrawWalls = %ShowBottom%, true, false, false, false, false
	if[%floor% ! 9] AddFloor WestZoneFloor2A, %5%Floor, 0.5, -%1%, %2% - 260 - 320, -%1% + 120, %2% - 260, %interfloorheight%, %interfloorheight%, 0, 0, true
	if[%floor% ! 9] AddFloor WestZoneFloor2B, %5%Floor, 0.5, -%1% + 120, %2% - 260 - 320, -%1% + 240, 20 - 30, %interfloorheight%, %interfloorheight%, 0, 0, true
	if[%floor% ! 9] AddFloor WestZoneFloor2C, %5%Floor, 0.5, -%1% + 120, 140 + 30, -%1% + 240, %2% - 260, %interfloorheight%, %interfloorheight%, 0, 0, true
	if[%floor% ! 9] AddFloor CenterZoneFloorEX1, %5%Floor, 0.5, -%1% + 240, 140 + 30, 25, %2% - 260, %interfloorheight%, %interfloorheight%, 0, 0, true
	if[%floor% ! 9] AddFloor CenterZoneFloorEX2, %5%Floor, 0.5, -15, 140, 25, 140 + 30, %interfloorheight%, %interfloorheight%, 0, 0, true
	if[%floor% ! 9] AddFloor CenterZoneFloorEX3, %5%Floor, 0.5, 25, 181, 90, 240, %interfloorheight%, %interfloorheight%, 0, 0, true

	if[%floor% ! 9] AddFloor EastZoneFloor2, %5%Floor, 0.5, %1% - 240, 181, %1%, %2% - 220, %interfloorheight%, %interfloorheight%, 0, 0, true
	if[%floor% ! 9] AddFloor EastZoneFloor3, %5%Floor, 0.5, %1% - 240, -%2% + 260, %1%, -21, %interfloorheight%, %interfloorheight%, 0, 0, true

	#Ceilings
	FloorOrientation = bottom
	DrawWalls = true, false, false, false, false, false
	if[%floor% ! 8] AddFloor WestZoneCeiling, %5%Ceiling, 0.5, -%1%, %2% - 260 - 320, -%1% + 240, %2% - 260, %fullheight%, %fullheight%, 0, 0, true
	if[%floor% ! 8] AddFloor CenterZoneCeiling, %5%Ceiling, 0.5, -%1% + 240, %2% - 260 - 320, -%1% + 420, %2% - 260, %fullheight%, %fullheight%, 0, 0, true
	if[%floor% ! 8] AddFloor EastZoneCeiling2, %5%Ceiling, 0.5, %1% - 240, -%2% + 260, %1%, %2% - 220, %fullheight%, %fullheight%, 0, 0, true
<EndFloors>

<Floors 0 to 9>
	TexPrefix() #Set texture prefix/suffix

	#East-Center Divider Walls
	Set WallHeight = %fullheight%
	Set WallOffset = 0
	if[%floor% = 0] Set WallHeight = %height%
	if[%floor% = 0] Set WallOffset = %interfloorheight%

	Set SouthEnd = -215
	if[%floor% = 3] Set SouthEnd = -240
	if[%floor% > 3] Set SouthEnd = -79.5

		WallOrientation = center
		DrawWalls = true, true, true, true, false, false
		AddWall ECDivWallA, %5%Wall, 1, 90, %SouthEnd%, 90, -21 - 30, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		WallOrientation = left
		DrawWalls = false, true, true, true, false, false
		AddWall ECDivWallB, %5%Wall, 0.5, 90, -21 - 30, 90, -21, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		Set SouthEnd = 181 #Reset for "ECDivWallC"
		if[%floor% > 5] Set SouthEnd = 224
		WallOrientation = center
		DrawWalls = true, true, true, true, false, false
		AddWall ECDivWallC, %5%Wall, 1, 90, %SouthEnd%, 90, 239.5, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

	#Perimeter windows
	Set MyIFloorType = 2
	if[%floor% = 0] Set MyIFloorType = 3
	Set WinHeight = %height%
	if[%floor% > 5] Set WinHeight = %height% + Floor(%floor% + 1).FullHeight

	SetAutoSize = true, false

		#Front windows
		if[%floor% < 4] AddCustomWindows(SZ_FrontWin, ShopWindows, ShopWindowsInt, -40, %2% - 740 - 120, 40, %2% - 740 - 120, %WinHeight%, 0, 0, %MyIFloorType%, ExtFacade, %5%Wall)

		#Left windows
		if[%floor% ! 7 & %floor% ! 9] AddCustomWindows(WZ_LeftWin, ShopWindows, ShopWindowsInt, -%1%, 20, -%1%, 140, %WinHeight%, 0, 0, %MyIFloorType%, ExtFacade, %5%Wall)

		#Right windows
		Set MyIFloorType2 = 2
		if[%floor% = 5] Set MyIFloorType2 = 1
		if[%floor% = 0] Set MyIFloorType2 = 3

		Set ExtTex = ShopWindowsInt
		if[%floor% < 2] Set ExtTex = ShopWindows

		if[%floor% < 3] AddCustomWindows(EZ_RightWin1, ShopWindowsInt, %ExtTex%, %1%, -140, %1%, -100, %WinHeight%, 0, 0, %MyIFloorType2%, %5%Wall, ExtFacade)
		if[%floor% < 2] AddCustomWindows(EZ_RightWin2, ShopWindowsInt, ShopWindows, %1%, 60, %1%, 140, %WinHeight%, 0, 0, %MyIFloorType2%, %5%Wall, ExtFacade)

		Set MyIFloorType3 = 2
		if[%floor% = 2 | %floor% = 5 | %floor% = 6] Set MyIFloorType3 = 1
		if[%floor% = 2 | %floor% = 5 | %floor% = 6 | %floor% = 8] AddCustomWindows(EZ_RightWin, ShopWindowsInt, ShopWindowsInt, %1%, 100, %1%, 140, %WinHeight%, 0, 0, %MyIFloorType3%, %5%Wall, EAWall)

	SetAutoSize = true, true

	#Perimeter walls
	Set WallHeight = %fullheight%
	Set WallOffset = 0

	Set ExtTex = ExtFacade
	if[%floor% > 1] Set ExtTex = EAWall

	#Override for the 1st floor only
	if[%floor% = 0] Set WallHeight = %height%
	if[%floor% = 0] Set WallOffset = %interfloorheight%

	DrawWalls = true, true, false, false, false, false

		#West zone
		Set Extra = 0
		if[%floor% < 4] Set Extra = 0.5

		WallOrientation = Left
		TextureOverride ExtFacade, %5%Wall, Blank, Blank, Blank, Blank
		AddWall WZ_FrontWall, ExtFacade, 0.5, -%1%, %2% - 260 - 320, -%1% + 240 + %Extra%, %2% - 260 - 320, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		DrawWalls = true, true, false, true, false, false
		TextureOverride ExtFacade, %5%Wall, Blank, %5%Wall, Blank, Blank
		AddWall WZ_LeftWallA, ExtFacade, 0.5, -%1%, %2% - 260 - 320, -%1%, 20, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		DrawWalls = true, true, true, false, false, false
		TextureOverride ExtFacade, %5%Wall, %5%Wall, Blank, Blank, Blank
		AddWall WZ_LeftWallB, ExtFacade, 0.5, -%1%, 140, -%1%, %2% - 260, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		#AddWall WZ_LeftWall, ExtFacade, 0.5, -%1%, %2% - 260 - 320, -%1%, %2% - 260, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		WallOrientation = Right
		TextureOverride %5%Wall, ExtFacade2, Blank, Blank, Blank, Blank
		AddWall WZ_BackWall, ExtFacade, 0.5, -%1%, %2% - 260, -%1% + 240, %2% - 260, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		#Center zone
		Set Extra = 0
		if[%floor% > 3] Set Extra = 0.5 #Reset for center zone's front wall

		WallOrientation = Right
		TextureOverride %5%Wall, ExtFacade2, Blank, Blank, Blank, Blank
		AddWall CZ_BackWall, ExtFacade, 0.5, -%1% + 240, %2% - 260, -%1% + 420 + 0.5, %2% - 260, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		WallOrientation = Left
		TextureOverride ExtFacade, %5%Wall, Blank, Blank, Blank, Blank
		if[%floor% > 3] AddWall CZ_FrontWall, ExtFacade, 0.5, -%1% + 240, %2% - 260 - 320, -%1% + 420 + %Extra%, %2% - 260 - 320, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		#South zone
		WallOrientation = Left

		DrawWalls = true, true, false, true, false, false
		TextureOverride ExtFacade, %5%Wall, Blank, %5%Wall, Blank, Blank
		if[%floor% < 4] AddWall SZ_FrontWallA, ExtFacade, 0.5, -%1% + 240, %2% - 740 - 120, -40, %2% - 740 - 120, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		DrawWalls = true, true, true, false, false, false
		TextureOverride ExtFacade, %5%Wall, %5%Wall, Blank, Blank, Blank
		if[%floor% < 4] AddWall SZ_FrontWallB, ExtFacade, 0.5, 40, %2% - 740 - 120, -%1% + 420, %2% - 740 - 120, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		#if[%floor% < 4] AddWall SZ_FrontWall, ExtFacade, 0.5, -%1% + 240, %2% - 740 - 120, -%1% + 420, %2% - 740 - 120, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		DrawWalls = true, true, false, false, false, false
		TextureOverride ExtFacade, %5%Wall, Blank, Blank, Blank, Blank
		if[%floor% < 4] AddWall SZ_LeftWall, ExtFacade, 0.5, -%1% + 240, %2% - 740 - 120, -%1% + 240, %2% - 260 - 320 + 0.5, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		WallOrientation = right
		DrawWalls = true, true, false, true, false, true #Override
		if[%floor% = 3] AddWall SZ_RightWall, %5%Wall, 0.5, -%1% + 420, %2% - 740 - 120, -%1% + 420, -%2% + 260, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		DrawWalls = true, true, false, false, false, false #Reset drawwalls

		#East zone
		WallOrientation = Left
		TextureOverride ExtFacade, %5%Wall, Blank, Blank, Blank, Blank
		if[%floor% > 7] AddWall EZ_FrontWall, ExtFacade, 0.5, %1% - 240, -%2% + 260, %1%, -%2% + 260, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		DrawWalls = true, true, false, false, false, true #Override
		TextureOverride ExtFacade, %5%Wall, Blank, Blank, Blank, %5%Wall
		if[%floor% = 7] AddWall EZ_FrontWall_EX, ExtFacade, 0.5, %1% - 240, -%2% + 260, %1%, -%2% + 260, %WallHeight% - 6, %WallHeight% - 6, %WallOffset% + 6, %WallOffset% + 6, 0, 0, true

		DrawWalls = true, true, false, false, false, false #Reset drawwalls
		TextureOverride ExtFacade, %5%Wall, Blank, Blank, Blank, Blank
		if[%floor% > 3] AddWall EZ_LeftWall1, ExtFacade, 0.5, %1% - 240, -%2% + 260, %1% - 240, %2% - 260 - 320 + 0.5, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		TextureOverride ExtFacade2, %5%Wall, Blank, Blank, Blank, Blank
		AddWall EZ_LeftWall2, ExtFacade, 0.5, %1% - 240, %2% - 260 - 0.5, %1% - 240, %2% - 220, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		########################################

		WallOrientation = right
		TextureOverride %5%Wall, %ExtTex%, Blank, Blank, Blank, Blank
		if[%floor% < 5 & %floor% ! 0 & %floor% ! 1 & %floor% ! 2] AddWall EZ_RightWall, ExtFacade, 0.5, %1%, -%2% + 260, %1%, 140, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		TextureOverride %5%Wall, %ExtTex%, Blank, Blank, Blank, Blank
		if[%floor% < 5 & %floor% ! 0 & %floor% ! 1 & %floor% ! 2] AddWall EZ_RightWall, ExtFacade, 0.5, %1%, 140, %1%, %2% - 220, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		####################

		DrawWalls = true, true, false, true, false, false #Reset drawwalls
		TextureOverride %5%Wall, %ExtTex%, Blank, %5%Wall, Blank, Blank
		if[%floor% < 3] AddWall EZ_RightWall_%floorid%F1, ExtFacade, 0.5, %1%, -%2% + 260, %1%, -140, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		Set NorthEnd = 60
		if[%floor% = 2] Set NorthEnd = 100
		DrawWalls = true, true, true, true, false, false
		TextureOverride %5%Wall, %ExtTex%, %5%Wall, %5%Wall, Blank, Blank
		if[%floor% < 3] AddWall EZ_RightWall_%floorid%F2, ExtFacade, 0.5, %1%, -100, %1%, %NorthEnd%, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		DrawWalls = true, true, true, false, false, false
		TextureOverride %5%Wall, %ExtTex%, %5%Wall, Blank, Blank, Blank
		if[%floor% < 3] AddWall EZ_RightWall_%floorid%F3, ExtFacade, 0.5, %1%, 140, %1%, %2% - 220, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		####################

		DrawWalls = true, true, false, true, false, false #Reset drawwalls
		TextureOverride %5%Wall, %ExtTex%, Blank, %5%Wall, Blank, Blank
		if[%floor% > 4] AddWall EZ_RightWall_Top1, ExtFacade, 0.5, %1%, -%2% + 260, %1%, 100, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		DrawWalls = true, true, true, false, false, false
		TextureOverride %5%Wall, %ExtTex%, %5%Wall, Blank, Blank, Blank
		if[%floor% > 4] AddWall EZ_RightWall_Top2, ExtFacade, 0.5, %1%, 140, %1%, %2% - 220, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
<EndFloors>

########################################

#5th floor roof area
<Floor 4>
	#Roof floor
	FloorOrientation = top
	DrawWalls = false, true, false, false, false, false
	AddFloor SouthZoneRF, RoofFloor, 0.5, -%1% + 240, %2% - 740 - 120, -%1% + 420, %2% - 260 - 320, %interfloorheight%, %interfloorheight%, 0, 0, true

	#Roof railings
	DrawWalls = true, true, true, true, true, false
	Set WallHeight = %interfloorheight% + 5.5
	Set WallOffset = 0

		#South roof
		WallOrientation = Left
		AddWall SRF_FrontRail, ExtFacade, 0.5, -%1% + 240.5, %2% - 740 - 120, -%1% + 420, %2% - 740 - 120, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		#AddWall SRF_LeftRail, ExtFacade, 0.5, -%1% + 240, %2% - 740 - 120, -%1% + 240, %2% - 260 - 320, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		AddWall SRF_LeftRailA, ExtFacade, 0.5, -%1% + 240, %2% - 740 - 120, -%1% + 240, -284 - 15, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		AddWall SRF_LeftRailB, ExtFacade, 0.5, -%1% + 240, -284 + 15, -%1% + 240, -124 - 15, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		AddWall SRF_LeftRailC, ExtFacade, 0.5, -%1% + 240, -124 + 15, -%1% + 240, %2% - 260 - 320, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		WallOrientation = Right
		#AddWall SRF_RightRail, ExtFacade, 0.5, -%1% + 420, %2% - 740 - 120, -%1% + 420, %2% - 260 - 320, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		AddWall SRF_RightRailA, ExtFacade, 0.5, -%1% + 420, %2% - 740 - 120, -%1% + 420, -284 - 15, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		AddWall SRF_RightRailB, ExtFacade, 0.5, -%1% + 420, -284 + 15, -%1% + 420, -124 - 15, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		AddWall SRF_RightRailC, ExtFacade, 0.5, -%1% + 420, -124 + 15, -%1% + 420, %2% - 260 - 320, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
<EndFloor>

#9th floor roof area
<Floor 10>
	#Roof floor
	FloorOrientation = top
	DrawWalls = false, true, false, false, false, false

	AddFloor WestZoneRF, RoofFloor2, 0.5, -%1%, %2% - 260 - 320, -%1% + 240, %2% - 260, %interfloorheight%, %interfloorheight%, 0, 0, true
	AddFloor CenterZoneRF, RoofFloor2, 0.5, -%1% + 240, %2% - 260 - 320, -%1% + 420, %2% - 260, %interfloorheight%, %interfloorheight%, 0, 0, true
	AddFloor EastZoneRF, RoofFloor2, 0.5, %1% - 240, -%2% + 260, %1%, %2% - 220, %interfloorheight%, %interfloorheight%, 0, 0, true

	#Roof railings
	DrawWalls = true, true, true, true, true, false
	Set WallHeight = %interfloorheight% + 5.5
	Set WallOffset = 0

		#West roof
		WallOrientation = Left
		AddWall WRF_FrontRail, ExtFacade, 0.5, -%1% + 0.5, %2% - 260 - 320, -%1% + 240, %2% - 260 - 320, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		AddWall WRF_LeftRail, ExtFacade, 0.5, -%1%, %2% - 260 - 320, -%1%, %2% - 260 - 0.5, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		WallOrientation = Right
		#AddWall WRF_BackRail, ExtFacade, 0.5, -%1%, %2% - 260, -%1% + 240, %2% - 260, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		TextureOverride ExtFacade, ExtFacade2, ExtFacade, ExtFacade, ExtFacade, ExtFacade
		AddWall WRF_BackRail, ExtFacade, 0.5, -%1%, %2% - 260, -%1% + 240, %2% - 260, %interfloorheight% + 24, %interfloorheight% + 24, %WallOffset%, %WallOffset%, 0, 0, true

		#Center roof
		WallOrientation = Right
		#AddWall CRF_BackRail, ExtFacade, 0.5, -%1% + 240, %2% - 260, -%1% + 420, %2% - 260, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		TextureOverride ExtFacade, ExtFacade2, ExtFacade, ExtFacade, ExtFacade, ExtFacade
		AddWall CRF_BackRail, ExtFacade, 0.5, -%1% + 240, %2% - 260, -%1% + 420, %2% - 260, %interfloorheight% + 24, %interfloorheight% + 24, %WallOffset%, %WallOffset%, 0, 0, true
		WallOrientation = Left
		AddWall CRF_FrontRail, ExtFacade, 0.5, -%1% + 240, %2% - 260 - 320, -%1% + 420, %2% - 260 - 320, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		#East roof
		WallOrientation = Left
		AddWall ERF_FrontRail, ExtFacade, 0.5, %1% - 240 + 0.5, -%2% + 260, %1% - 0.5, -%2% + 260, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		AddWall ERF_LeftRail1, ExtFacade, 0.5, %1% - 240, -%2% + 260, %1% - 240, %2% - 260 - 320, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		#AddWall ERF_LeftRail2, ExtFacade, 0.5, %1% - 240, %2% - 260 - 0.5, %1% - 240, %2% - 220, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		TextureOverride ExtFacade2, ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade
		AddWall ERF_LeftRail2, ExtFacade, 0.5, %1% - 240, %2% - 260 - 0.5, %1% - 240, %2% - 220, %interfloorheight% + 24, %interfloorheight% + 24, %WallOffset%, %WallOffset%, 0, 0, true
		WallOrientation = right
		AddWall ERF_RightRail, ExtFacade, 0.5, %1%, -%2% + 260, %1%, %2% - 220, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
<EndFloor>

#Atrium cuts
	#West atrium
	Cut External, -200, Floor(1).Altitude - 1, 80 - 20, -200 + 30, Floor(6).Base + 5, 80 + 20, false, true #Shopping levels
	Cut External, -200, Floor(10).Altitude - 1, 80 - 20, -200 + 30, Floor(10).Base + 1, 80 + 20, false, true #Roof skylight

	#Center atrium
	Cut External, -90 + 40, Floor(0).Base - 0.1, 60, 60, Floor(0).Base + 1, 135, false, true #Atrium base
	Cut External, -90 + 40, Floor(1).Altitude - 1, 60, 60, Floor(6).Base + 5, 140, false, true #Shopping levels
	Cut External, -90 + 40, Floor(10).Altitude - 1, 60, 60, Floor(10).Base + 1, 130, false, true #Roof skylight

		#Extra cuts for escalators
		Cut External, -90 + 40 - 4.5, Floor(1).Altitude - 1, 100 - 15, -90 + 40, Floor(6).Base + 5, 100 + 15, false, true
		Cut External, 60, Floor(1).Altitude - 1, 100 - 15, 60 + 4.5, Floor(6).Base + 5, 100 + 15, false, true

	#South atrium
	Cut External, -30, Floor(0).Base - 0.1, -300, 30, Floor(2).Base + 5, -180, false, true #Shopping levels
	Cut External, -30, Floor(4).Altitude - 1, -300, 30, Floor(4).Base + 1, -180, false, true #Roof skylight

	#East atriums
	Cut External, 180, Floor(0).Base - 0.1, -180, 240, Floor(10).Base + 5, -60, false, true #Atrium 1 (South)
	Cut External, 180, Floor(0).Base - 0.1, 80 - 30, 240, Floor(10).Base + 5, 80 + 30, false, true #Atrium 2 (Center)

		#Extra cuts for escalators (Atrium 1)
		Cut External, 210 - 15, Floor(1).Altitude - 1, -180 - 8.5, 210 + 15, Floor(6).Base + 5, -180, false, true

		#Extra cuts for escalators (Atrium 2)
		Cut External, 180 - 8.5, Floor(1).Altitude - 1, 80 - 15, 180 - 4.5, Floor(1).Base + 5, 80 + 15, false, true #1st-2nd floors
		Cut External, 180 - 4.5, Floor(1).Altitude - 1, 80 - 15, 180, Floor(5).Base + 5, 80 + 15, false, true #2nd-6th floors

		Cut External, 240, Floor(1).Altitude - 1, 80 - 15, 240 + 4.5, Floor(5).Base + 5, 80 + 15, false, true #1st-6th floors
		Cut External, 240, Floor(5).Altitude - 1, 80 - 15, 240 + 8.5, Floor(6).Base + 5, 80 + 15, false, true #6th-7th floors


