	AddWall WARightRailA, %5%%Suffix%, 0.5, -170, 80 - 20 - 0.5, -170, 80 - 8, %RailingHeight%, %RailingHeight%, %RailingOffset%, %RailingOffset%, 0, 0, true
	AddWall WARightRailMid1, %5%%Suffix%, 0.5, -170, 80 - 4, -170, 80 + 4, %RailingHeight%, %RailingHeight%, %RailingOffset%, %RailingOffset%, 0, 0, true
