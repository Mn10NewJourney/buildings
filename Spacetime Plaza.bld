	FloorOrientation = top
	DrawWalls = false, true, false, false, false, false
	AddFloor SouthZoneRF, RoofFloor, 0.5, -%1% + 240, %2% - 740 - 120, -%1% + 420, %2% - 260 - 320, %interfloorheight%, %interfloorheight%, 0, 0, true

