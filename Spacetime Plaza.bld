#Button creation function (Elevators 1-3)
<Function BtnPanelE1-3>
	Set PanelNumber = %param1%
	Set PanelNumber2 = %PanelNumber% + 1
	Set BtnPrefix = Button

	AddButton %PanelNumber%, KW_Sounds/konebuttonbeep.wav, %BtnPrefix%4, %BtnPrefix%Lit4, 3, 2, 3, 1, 1
	AddButton %PanelNumber%, KW_Sounds/konebuttonbeep.wav, %BtnPrefix%3, %BtnPrefix%Lit3, 3, 1, 2, 1, 1
	AddButton %PanelNumber%, KW_Sounds/konebuttonbeep.wav, %BtnPrefix%2, %BtnPrefix%Lit2, 4, 2, 1, 1, 1
	AddButton %PanelNumber%, KW_Sounds/konebuttonbeep.wav, %BtnPrefix%1, %BtnPrefix%Lit1, 4, 1, 0, 1, 1
	AddButton %PanelNumber%, KW_Sounds/konebuttonbeep.wav, %BtnPrefix%B1, %BtnPrefix%LitB1, 5, 2, -1, 1, 1
	AddButton %PanelNumber%, KW_Sounds/konebuttonbeep.wav, %BtnPrefix%B2, %BtnPrefix%LitB1, 5, 1, -2, 1, 1

	if[%PanelNumber% = 1] AddButton %PanelNumber2%, , %BtnPrefix%Alarm, %BtnPrefix%Alarm, 1, 1, alarm, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%Open, %BtnPrefix%Open, 7, 1, open, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%Close, %BtnPrefix%Close, 7, 2, close, 1, 1
<EndFunction>

<Elevators 1 to 3>
	Set Prefix = South

	#Set textures and dimensions
	M10_ElevCabTex(ElevExt, %Prefix%ElevFloor, %Prefix%ElevCeiling, %Prefix%ElevWall, %Prefix%ElevWall)
	M10_ElevDimensions(6.5, 7, 8, 0.2, 0.2, true, true, false, true)
	M10_ElevPanels(%Prefix%ElevPanelMain, %Prefix%ElevPanelTop, 1.5, 1.5, 1, 0.2, false, false, true, false)

	#Finish elevator assembly
	M10_ElevInterior()
	#--------------------
	#DETAILED INTERIORS
	#1. Lights
	CreateWallBox2 elevator, E%elevator%_Light1, %Prefix%ElevCeilingLight, 0 + 1.5, 0, 2.5, 6, 0.1, 8 - 0.1, 0, 0, false, true, true, true
	CreateWallBox2 elevator, E%elevator%_Light2, %Prefix%ElevCeilingLight, 0 - 1.5, 0, 2.5, 6, 0.1, 8 - 0.1, 0, 0, false, true, true, true

	#2. Panels on walls
	Set WPTex = %Prefix%ElevWallPanel
	Set WPanelHeight = 8 - 0.5

		#Front panels
		CreateWallBox2 elevator, Panel_B1, %WPTex%, 0 - (6.1 * 1/4), -3.3 + 0.01, (6.1 * 1/2) - 0.3, 0.02, %WPanelHeight%, 0.25, 0, 0, false, true, true, true
		CreateWallBox2 elevator, Panel_B2, %WPTex%, 0 + (6.1 * 1/4), -3.3 + 0.01, (6.1 * 1/2) - 0.3, 0.02, %WPanelHeight%, 0.25, 0, 0, false, true, true, true

		#Back panels
		CreateWallBox2 elevator, Panel_B1, %WPTex%, 0 - (6.1 * 1/4), 3.3 - 0.01, (6.1 * 1/2) - 0.3, 0.02, %WPanelHeight%, 0.25, 0, 0, false, true, true, true
		CreateWallBox2 elevator, Panel_B2, %WPTex%, 0 + (6.1 * 1/4), 3.3 - 0.01, (6.1 * 1/2) - 0.3, 0.02, %WPanelHeight%, 0.25, 0, 0, false, true, true, true

		#Left panels
		CreateWallBox2 elevator, Panel_L1, %WPTex%, -3.05 + 0.01, 0 - (6.6 * 1/4), 0.02, (6.6 * 1/2) - 0.3, %WPanelHeight%, 0.25, 0, 0, false, true, true, true
		CreateWallBox2 elevator, Panel_L2, %WPTex%, -3.05 + 0.01, 0 + (6.6 * 1/4), 0.02, (6.6 * 1/2) - 0.3, %WPanelHeight%, 0.25, 0, 0, false, true, true, true
	#--------------------
	#Car Doors
	Set ElevDoorTex = %Prefix%ElevDoors
	Set IDP = 3.25

	WallOrientation = left
	AddDoorComponent 1, Left, %ElevDoorTex%, %ElevDoorTex%, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	AddDoorComponent 1, Right, %ElevDoorTex%2, %ElevDoorTex%2, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	FinishDoors 1, false, false

		#Door track
		FloorOrientation = top
		DrawWalls = true, true, true, true, true, true
		TextureOverride ElevExt, ElevDoorTrackX, ElevExt, ElevExt, ElevExt, ElevExt
		AddFloor DoorTrack, ElevDoorTrackX, 0.05, %IDP%, -2 - (2 * 1), %IDP% + 0.2, 2 + (2 * 1), 0, 0, 0, 0
	#--------------------
	#Right Panel
	Set P1_PositionX = 3.05 - 0.001
	Set P1_PositionZ = -2.65

		#Panels
		CreateWallBox2 elevator, RightPB, ElevPanel, %P1_PositionX% + 0.001 - 0.025, %P1_PositionZ%, 0.05, 0.8, 4.75, 2.25, 0, 0, false, true, true, true
		CreatePanel , 7, 2, left, %P1_PositionX% - 0.05, %P1_PositionZ%, 0.15, 0.15, 0.5, 0.25, 3.75, 0, 0
		CreatePanel , 7, 1, left, %P1_PositionX% - 0.05, %P1_PositionZ%, 0.15, 0.15, 0.5, 0.25, 3.75, 0, 0

			#Buttons
			BtnPanelE1-3(1)
			
	#Left Panel
	Set P2_PositionX = 3.05 - 0.001
	Set P2_PositionZ = 2.65

		#Panels
		CreateWallBox2 elevator, RightPB, ElevPanel, %P2_PositionX% + 0.001 - 0.025, %P2_PositionZ%, 0.05, 0.8, 4.75, 2.25, 0, 0, false, true, true, true
		CreatePanel , 7, 2, left, %P2_PositionX% - 0.05, %P2_PositionZ%, 0.15, 0.15, 0.5, 0.25, 3.75, 0, 0
		CreatePanel , 7, 1, left, %P2_PositionX% - 0.05, %P2_PositionZ%, 0.15, 0.15, 0.5, 0.25, 3.75, 0, 0

			#Buttons
			BtnPanelE1-3(3)
	#--------------------
	#Elevator number sign
	DrawWalls = true, false, false, false, false, false
	AddWall ElevNo%elevator%_Inside, IN_ElevNo%elevator%, 0, 3.05 - 0.001, 0 - 0.25, 3.05 - 0.001, 0 + 0.25, 0.5, 0.5, 7.05, 7.05, 0, 0
	#--------------------
	#Indicator sets
	Set IndOffset = 6

		#Right
		DrawWalls = true, false, false, false, false, false
		AddWall RightIndBack1, IndBack2, 0, %P1_PositionX% - 0.051, %P1_PositionZ% - 0.3, %P1_PositionX% - 0.051, %P1_PositionZ% + 0.3, 0.95, 0.95, %IndOffset% - 0.15, %IndOffset% - 0.15, 0, 0
		AddWall RightIndBack2, IndBack, 0, %P1_PositionX% - 0.052, %P1_PositionZ% - 0.2, %P1_PositionX% - 0.052, %P1_PositionZ% + 0.2, 0.8, 0.8, %IndOffset%, %IndOffset%, 0, 0

		AddFloorIndicator Ind_Button, left, %P1_PositionX% - 0.053, %P1_PositionZ%, 0.4, 0.4, %IndOffset%
		AddDirectionalIndicator true, true, true, IndBack, ArrowUp, ArrowUpLit, ArrowDown, ArrowDownLit, %P1_PositionX% - 0.053, %P1_PositionZ%, %IndOffset% + 0.375, left, 0.45, 0.4, false, 0, 0

		#Left
		DrawWalls = true, false, false, false, false, false
		AddWall LeftIndBack1, IndBack2, 0, %P2_PositionX% - 0.051, %P2_PositionZ% - 0.3, %P2_PositionX% - 0.051, %P2_PositionZ% + 0.3, 0.95, 0.95, %IndOffset% - 0.15, %IndOffset% - 0.15, 0, 0
		AddWall LeftIndBack2, IndBack, 0, %P2_PositionX% - 0.052, %P2_PositionZ% - 0.2, %P2_PositionX% - 0.052, %P2_PositionZ% + 0.2, 0.8, 0.8, %IndOffset%, %IndOffset%, 0, 0

		AddFloorIndicator Ind_Button, left, %P2_PositionX% - 0.053, %P2_PositionZ%, 0.4, 0.4, %IndOffset%
		AddDirectionalIndicator true, true, true, IndBack, ArrowUp, ArrowUpLit, ArrowDown, ArrowDownLit, %P2_PositionX% - 0.053, %P2_PositionZ%, %IndOffset% + 0.375, left, 0.45, 0.4, false, 0, 0
	#--------------------
	#Shaft components
	DrawWalls = true, true, true, true, true, true
		#Ropes
		RopePosition = 0, 8 + 0.2, 0
		RopeTexture = Ropes
	
		#Counterweight
		Set Position = -3.25 - 0.75

		CreateCounterweight CWeight_Frame, CWeight, %Position%, 0, 0.5, 6, 2, 0.5
	
		#Rails
		AddRails ElevRail, ElevRailSide, 0, 0, true, 3.5 + 0.06, 0.1
		AddRails ElevRail, ElevRailSide, %Position%, 0, true, 1 + 0.06, 0.1
<EndElevators>

#Central Elevators
<Elevator 4>
