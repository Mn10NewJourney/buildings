	if[%floor% = 6] AddWall EA2RightRail_Top, %5%%Suffix%, 0.5, 240, 80 + 15, 240 + 5 + %EPB%, 80 + 15, %RailingHeight%, %RailingHeight%, %RailingOffset%, %RailingOffset%, 0, 0, true
