<Floors -2 to 8>
	#Outer Edge (Elevators 16-21)
	if[%floor% ! 7] E16-17HallStation()
	if[%floor% ! 7] E18-19HallStation()
	if[%floor% ! 7] E20-21HallStation()

	#Inner Edge (Elevators 22-27)
	if[%floor% ! 7] E22-23HallStation()
	if[%floor% ! 7] E24-25HallStation()
	if[%floor% ! 7] E26-27HallStation()
<EndFloors>

##--------------------------------------------------------------------------------##

#GLOBAL SETTINGS
#Kone Elevators (No. 1-15)
<Elevators 1 to 15>
	#Notifications
	UpChimeSound 1 = KW_Sounds/konechimeup.wav
	DownChimeSound 1 = KW_Sounds/konechimedown.wav
	NotifyEarly = 1
	QueueResets = true
	RecallFloor = 0

	#Door settings
	if[%elevator% < 14] DoorTimer 1 = 12000
	if[%elevator% < 14] QuickClose 1 = 8000
	if[%elevator% < 14] OpenSound 1 = EG881Sounds/elevopenquick2.wav #EG881
	if[%elevator% < 14] CloseSound 1 = EG881Sounds/elevclosequick2.wav #EG881

	#Motor sounds
	MotorStartSound = EG881Sounds/motor_start3.wav #EG881
	MotorRunSound = EG881Sounds/motor_running3.wav #EG881
	MotorStopSound = EG881Sounds/motor_stop3.wav #EG881
<EndElevators>

<Elevators 1 to 3>
	CarStartSound = EG881Sounds/elevstart11.wav #EG881
	CarMoveSound = EG881Sounds/elevmove11.wav #EG881
	CarStopSound = EG881Sounds/elevstop11.wav #EG881
<EndElevators>

<Elevators 4 to 7>
	CarStartSound = EG881Sounds/elevstart12.wav #EG881
	CarMoveSound = EG881Sounds/elevmove12.wav #EG881
	CarStopSound = EG881Sounds/elevstop12.wav #EG881
<EndElevators>

<Elevators 8 to 13>
	CarStartSound = elevstart3.wav
	CarMoveSound = elevmove3.wav
	CarStopSound = elevstop3.wav
<EndElevators>

<Elevators 14 to 15>
	#Door settings
	DoorTimer 1 = 15000
	QuickClose 1 = 10000
	OpenSound 1 = EG881Sounds/freightelevatoropen1.wav #EG881
	CloseSound 1 = EG881Sounds/freightelevatorclose1.wav #EG881
	
	#Movement sounds
	CarStartSound = EG881Sounds/slowelevstart.wav #EG881
	CarMoveSound = EG881Sounds/slowelevmove.wav #EG881
	CarStopSound = EG881Sounds/slowelevstop.wav #EG881
<EndElevators>

#Otis Elevators (No. 16-27)
<Elevators 16 to 27>
	#Notifications
	NotifyEarly = 0
	QueueResets = true
	RecallFloor = 0

	#Door timers
	if[%elevator% ! 22 & %elevator% ! 23] DoorTimer 1 = 9000
	if[%elevator% ! 22 & %elevator% ! 23] QuickClose 1 = 6000
	if[%elevator% = 22 | %elevator% = 23] DoorTimer 1 = 15000
	if[%elevator% = 22 | %elevator% = 23] QuickClose 1 = 10000

	#Door sounds
	if[%elevator% ! 22 & %elevator% ! 23] OpenSound 1 = EG881Sounds/elevopen1.wav #EG881
	if[%elevator% ! 22 & %elevator% ! 23] CloseSound 1 = EG881Sounds/elevclose1.wav #EG881
	if[%elevator% = 22 | %elevator% = 23] OpenSound 1 = EG881Sounds/freightelevatoropen3.wav #EG881
	if[%elevator% = 22 | %elevator% = 23] CloseSound 1 = EG881Sounds/freightelevatorclose3.wav #EG881

	#Car sounds
	CarStartSound = EG881Sounds/elevstart10.wav #EG881
	CarMoveSound = EG881Sounds/elevmove10.wav #EG881
	CarStopSound = EG881Sounds/elevstop10.wav #EG881

	#Motor sounds
	MotorStartSound = motor_start2.wav
	MotorRunSound = motor_running2.wav
	MotorStopSound = motor_stop2.wav
<EndElevators>

<Elevators 16 to 25>
	#Chime(s)
	ChimeSound 1 = KW_Sounds/mitsubishidtchimeup.wav

	#Motor sounds
	MotorStartSound = motor_start2.wav
	MotorRunSound = motor_running2.wav
	MotorStopSound = motor_stop2.wav
<EndElevators>

<Elevators 26 to 27>
	#Chime(s)
	ChimeSound 1 = KW_Sounds/NewOtisChime2.wav

	#Motor sounds
	MotorStartSound = EG881Sounds/motor_start3.wav #EG881
	MotorRunSound = EG881Sounds/motor_running3.wav #EG881
	MotorStopSound = EG881Sounds/motor_stop3.wav #EG881
<EndElevators>

##--------------------------------------------------------------------------------##

#ESCALATORS
#Set escalator properties
	OP_EscBalustrades(GlassBalustrade, 0, 3, 0, 0)
	OP_EscLanding(EscalatorLandingX, 5.5, 0, 0, EscalatorLandingX, 5.5, 0, 0)
	OP_EscHandrails(Handrail1, 0.22, 0.125, 0, 0)
	OP_EscTruss(SilverBalustrade, ShopWall, 0.5, 3.5, 0, 0, 0, 0)

#Set escalators' direction (For criss-cross layout)
<Function EscDirections>
	if[%floor% = 1 | %floor% = 3 | %floor% = 5] Set DirectionA = up
	if[%floor% = 0 | %floor% = 2 | %floor% = 4] Set DirectionA = down

	if[%floor% = 1 | %floor% = 3 | %floor% = 5] Set DirectionB = down
	if[%floor% = 0 | %floor% = 2 | %floor% = 4] Set DirectionB = up
<EndFunction>

	#WEST ESCALATORS
		#Escalators from 1 to 2
		<Floor 0>
			OP_Escalator(MallWestEsc_%floorid%F_1, up, %floor% + 1, 1.2, EG881Sounds2/Escalators/otisescalator1.wav, Escalator3Z_Unmarked, Escalator3X, right, -200 + 1, 80 - 2, 3, 2/3, 1, 27, 0, 0, 0, 0) #EG881
			OP_Escalator(MallWestEsc_%floorid%F_2, down, %floor% + 1, 1.2, EG881Sounds2/Escalators/otisescalator1.wav, Escalator3Z_Unmarked, Escalator3X, right, -200 + 1, 80 + 2, 3, 2/3, 1, 27, 0, 0, 0, 0) #EG881
		<EndFloor>

		#Escalators from 3 to 7
		<Floors 1 to 5>
			EscDirections()
			OP_Escalator(MallWestEsc_%floorid%F_1, %DirectionA%, %floor% + 1, 1.2, EG881Sounds2/Escalators/otisescalator1.wav, Escalator3Z_Unmarked, Escalator3XB, left, -170 - 1, 80 - 6, 3, 2/3, 1, 27, 0, 0, 0, 0) #EG881
			OP_Escalator(MallWestEsc_%floorid%F_2, %DirectionB%, %floor% + 1, 1.2, EG881Sounds2/Escalators/otisescalator1.wav, Escalator3Z_Unmarked, Escalator3X, right, -200 + 1, 80 + 6, 3, 2/3, 1, 27, 0, 0, 0, 0) #EG881
		<EndFloors>

	#CENTER ESCALATORS
	OP_EscLanding(EscalatorLandingZ, 5.5, 0, 0, EscalatorLandingZ, 5.5, 0, 0) #Reset landing textures

	<Floors 0 to 5>
		OP_Escalator(MallCenterEsc_%floorid%F_1, up, %floor% + 1, 1.2, EG881Sounds2/Escalators/otisescalator1.wav, Escalator3Z_Unmarked, Escalator3ZB, front, -52.5, 100 + 15 - 1, 3, 2/3, 1, 27, 0, 0, 0, 0) #EG881
		OP_Escalator(MallCenterEsc_%floorid%F_2, down, %floor% + 1, 1.2, EG881Sounds2/Escalators/otisescalator1.wav, Escalator3Z_Unmarked, Escalator3ZB, front, 62.5, 100 + 15 - 1, 3, 2/3, 1, 27, 0, 0, 0, 0) #EG881
	<EndFloor>

	#EAST-CENTER ESCALATORS
		#Double escalators between 1-2 (Atrium's west edge)
		<Floor 0>
			OP_Escalator(MallEastEsc_%floorid%F_1, up, %floor% + 1, 1.2, EG881Sounds2/Escalators/otisescalator5.wav, Escalator3Z_Unmarked, Escalator3ZB, front, 173.5, 80 + 15 - 1, 3, 2/3, 1, 27, 0, 0, 0, 0) #EG881
			OP_Escalator(MallEastEsc_%floorid%F_2, down, %floor% + 1, 1.2, EG881Sounds2/Escalators/otisescalator5.wav, Escalator3Z_Unmarked, Escalator3ZB, front, 177.5, 80 + 15 - 1, 3, 2/3, 1, 27, 0, 0, 0, 0) #EG881
		<EndFloor>

		#Single escalators between 2-6 (Separated between the atrium's west and east edges)
		<Floors 1 to 4>
			EscDirections()
			OP_Escalator(MallEastEsc_%floorid%F_1, %DirectionA%, %floor% + 1, 1.2, EG881Sounds2/Escalators/otisescalator5.wav, Escalator3Z_Unmarked, Escalator3ZB, front, 177.5, 80 + 15 - 1, 3, 2/3, 1, 27, 0, 0, 0, 0) #EG881
			OP_Escalator(MallEastEsc_%floorid%F_2, %DirectionB%, %floor% + 1, 1.2, EG881Sounds2/Escalators/otisescalator5.wav, Escalator3Z_Unmarked, Escalator3Z, back, 242.5, 80 - 15 + 1, 3, 2/3, 1, 27, 0, 0, 0, 0) #EG881
		<EndFloors>

		#Double escalators between 6-7 (Atrium's east edge)
		<Floor 5>
			OP_Escalator(MallEastEsc_%floorid%F_1, up, %floor% + 1, 1.2, EG881Sounds2/Escalators/otisescalator5.wav, Escalator3Z_Unmarked, Escalator3Z, back, 246.5, 80 - 15 + 1, 3, 2/3, 1, 27, 0, 0, 0, 0) #EG881
			OP_Escalator(MallEastEsc_%floorid%F_2, down, %floor% + 1, 1.2, EG881Sounds2/Escalators/otisescalator5.wav, Escalator3Z_Unmarked, Escalator3Z, back, 242.5, 80 - 15 + 1, 3, 2/3, 1, 27, 0, 0, 0, 0) #EG881
		<EndFloor>

	#SOUTHEAST ESCALATORS
	OP_EscLanding(EscalatorLandingX, 5.5, 0, 0, EscalatorLandingX, 5.5, 0, 0) #Reset landing textures

		#Criss-cross escalators from 1 to 7
		<Floors 0 to 5>
			EscDirections()
			OP_Escalator(MallEastEsc_%floorid%F_3, %DirectionB%, %floor% + 1, 1.2, EG881Sounds2/Escalators/otisescalator1.wav, Escalator3Z_Unmarked, Escalator3XB, left, 210 + 15 - 1, -186.5, 3, 2/3, 1, 27, 0, 0, 0, 0) #EG881
			OP_Escalator(MallEastEsc_%floorid%F_4, %DirectionA%, %floor% + 1, 1.2, EG881Sounds2/Escalators/otisescalator1.wav, Escalator3Z_Unmarked, Escalator3X, right, 210 - 15 + 1, -182.5, 3, 2/3, 1, 27, 0, 0, 0, 0) #EG881
		<EndFloors>


##--------------------------------------------------------------------------------##

#STAIRWELLS
<Function StairwellSets>
	#Set Values
	Set NumSteps = 9 #Total: 36 steps (Double stairs)
	if[%floor% < 0 | %floor% > 5] Set NumSteps = 12 #Total: 24 steps

	#Floors with double stairs
	Set DblStairs = false
	if[%floor% > -1 & %floor% < 6] Set DblStairs = true
<EndFunction>

#****************************************#

#External stairwell walls
<Floor 0>
	#TexPrefix()
	Set 5 = Parking #Override for the interfloor area

	#South Zone Stairwells
	CreateShaftWall(%5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, -85, -124, 5, 15, ST2_IFloor, %interfloorheight% - 0.5 + 0.1, -0.1, true, true, true, true, false, true, true)
	CreateShaftWall(%5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, 85, -284, 5, 15, ST3_IFloor, %interfloorheight% - 0.5 + 0.1, -0.1, true, true, true, true, false, true, true)
	CreateShaftWall(%5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, 85, -124, 5, 15, ST4_IFloor, %interfloorheight% - 0.5 + 0.1, -0.1, true, true, true, true, false, true, true)
<EndFloor>

<Floors 0 to 3>
	TexPrefix()

	#South Zone Stairwells
	CreateShaftWall(%5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, -85, -284, 5, 15, ST1, %SHeight%, %SOffset%, true, false, true, true, false, false, true)
	CreateShaftWall(%5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, -85, -124, 5, 15, ST2, %SHeight%, %SOffset%, true, false, true, true, false, false, true)

	Set ShowRight = true
	if[%floor% = 3] Set ShowRight = false
	CreateShaftWall(%5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, 85, -284, 5, 15, ST3, %SHeight%, %SOffset%, true, true, %ShowRight%, true, false, false, true)

	CreateShaftWall(%5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, 85, -124, 5, 15, ST4, %SHeight%, %SOffset%, true, true, false, true, false, false, true)
<EndFloors>

<Floor 4>
	TexPrefix()

	#South Zone Stairwells (Roof area)
	CreateShaftWall(ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, 0.33, -85, -284, 5, 15, ST1_Top, %fullheight%, 0, true, true, true, true, true, false, true)
	CreateShaftWall(ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, 0.33, -85, -124, 5, 15, ST2_Top, %fullheight%, 0, true, true, true, true, true, false, true)
	CreateShaftWall(ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, 0.33, 85, -284, 5, 15, ST3_Top, %fullheight%, 0, true, true, true, true, true, false, true)
	CreateShaftWall(ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, 0.33, 85, -124, 5, 15, ST4_Top, %fullheight%, 0, true, true, true, true, true, false, true)
<EndFloor>

#****************************************#

<Floors -2 to 9>
	TexPrefix()

	#Central Zone Stairwells
		#South Edge
		Set ShowRight = true
		if[%floor% > -1] Set ShowRight = false
		if[%floor% > -1] CreateShaftWall(%5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, 85, -36, 5, 15, ST5, %SHeight%, %SOffset%, true, true, %ShowRight%, true, false, false, true)
		if[%floor% = 0] CreateShaftWall(ParkingWall, ParkingWall, ParkingWall, ParkingWall, ParkingWall, ParkingWall, 0.33, 85, -36, 5, 15, ST5_IFloor, %interfloorheight% - 0.5 + 0.1, -0.1, true, true, true, true, false, true, true)

		CreateShaftWall(%5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, -95, -46, 5, 15, ST6, %SHeight%, %SOffset%, true, true, true, true, false, false, true)

		Set ShowRight = true #Reset for Stairwell 7
		if[%floor% > -2] Set ShowRight = false
		CreateShaftWall(%5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, -244, -46, 5, 15, ST7, %SHeight%, %SOffset%, true, true, %ShowRight%, true, false, false, true)
	
		#North Edge
		Set ShowBack = true
		if[%floor% > -1] Set ShowBack = false
		if[%floor% > -2] CreateShaftWall(%5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, 20, 225, 5, 15, ST8, %SHeight%, %SOffset%, true, true, true, %ShowBack%, false, false, true)
		CreateShaftWall(%5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, -124, 225, 5, 15, ST9, %SHeight%, %SOffset%, true, true, true, %ShowBack%, false, false, true)
		CreateShaftWall(%5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, -284, 225, 5, 15, ST10, %SHeight%, %SOffset%, true, true, true, %ShowBack%, false, false, true)

	#****************************************#
	
	#East Zone Stairwells
		#West Edge
		CreateShaftWall(%5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, 144, -192.5, 5, 12.5, ST11, %SHeight%, %SOffset%, true, true, true, true, false, false, true)
		CreateShaftWall(%5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, 144, -33.5, 5, 12.5, ST12, %SHeight%, %SOffset%, true, true, true, true, false, false, true)
		CreateShaftWall(%5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, 144, 246.5, 5, 12.5, ST13, %SHeight%, %SOffset%, true, true, true, true, false, false, true)

		#East Edge
		CreateShaftWall(%5%%5L%, %5%Wall, %5%%5L%, %5%%5L%, %5%Wall, %5%Wall, 0.33, 296.5, -176, 12.5, 5, ST14, %SHeight%, %SOffset%, true, true, true, true, false, false, true)
		CreateShaftWall(%5%%5L%, %5%Wall, %5%%5L%, %5%Wall, %5%Wall, %5%Wall, 0.33, 296.5, -26, 12.5, 5, ST15, %SHeight%, %SOffset%, true, true, true, true, false, false, true)
		CreateShaftWall(%5%Wall, %5%Wall, %5%%5L%, %5%%5L%, %5%Wall, %5%Wall, 0.33, 296.5, 186, 12.5, 5, ST16, %SHeight%, %SOffset%, true, true, true, true, false, false, true)
	
<EndFloors>

<Floor 10>
	#Central Zone Stairwells
		#South Edge
		CreateShaftWall(ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, 0.33, 85, -36, 5, 15, ST5_Top, %SHeight%, %SOffset%, true, true, true, true, true, false, true)
		CreateShaftWall(ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, 0.33, -95, -46, 5, 15, ST6_Top, %SHeight%, %SOffset%, true, true, true, true, true, false, true)
		CreateShaftWall(ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, 0.33, -244, -46, 5, 15, ST7_Top, %SHeight%, %SOffset%, true, true, false, true, true, false, true)
	
		#North Edge
		Set ShowBack = false
		CreateShaftWall(ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, 0.33, 20, 225, 5, 15, ST8_Top, %SHeight%, %SOffset%, true, true, true, %ShowBack%, true, false, true)
		CreateShaftWall(ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, 0.33, -124, 225, 5, 15, ST9_Top, %SHeight%, %SOffset%, true, true, true, %ShowBack%, true, false, true)
		CreateShaftWall(ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, 0.33, -284, 225, 5, 15, ST10_Top, %SHeight%, %SOffset%, true, true, true, %ShowBack%, true, false, true)

	#****************************************#
	
	#East Zone Stairwells
		#West Edge
		CreateShaftWall(ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, 0.33, 144, -192.5, 5, 12.5, ST11_Top, %fullheight%, 0, true, true, true, true, true, false, true)
		CreateShaftWall(ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, 0.33, 144, -33.5, 5, 12.5, ST12_Top, %fullheight%, 0, true, true, true, true, true, false, true)
		CreateShaftWall(ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, 0.33, 144, 246.5, 5, 12.5, ST13_Top, %fullheight%, 0, true, true, true, true, true, false, true)

		#East Edge
		CreateShaftWall(ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, 0.33, 296.5, -176, 12.5, 5, ST14_Top, %fullheight%, 0, true, true, true, true, true, false, true)
		CreateShaftWall(ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, 0.33, 296.5, -26, 12.5, 5, ST15_Top, %fullheight%, 0, true, true, true, true, true, false, true)
		CreateShaftWall(ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, 0.33, 296.5, 186, 12.5, 5, ST16_Top, %fullheight%, 0, true, true, true, true, true, false, true)
<EndFloor>

#****************************************#

#South Zone West Stairwell A
	#Wall cuts for stairwell walls
	<Floors 0 to 3>
		CutAll -89.5 - 0.1, 0, -284 - 14.5, -89.5 + 0.1, %fullheight%, -284 + 14.5, true, false #Left wall cuts
	<EndFloors>

CreateStairwell 1, -85, -284, 0, 4
CutStairwell 1, -4.5, -14.5, 4.5, 14.5, 0, 5
ShowFullStairs 1 = always

<Floors 0 to 4>
	StairwellSets() #Determine stairs' size

	Set 21 = -85 #Center X
	Set 22 = -284 #Center Z
	Set 23 = 4.5 #Cut X
	Set 24 = 14.5 #Cut Z
	Set 25 = 1 #Stairwell Number
	Set 26 = 0.5 #Riser Size

	#Walls
	WallOrientation = right
	DrawWalls = false, true, false, false, false, false
	AddStairsWall %25%, Stair%25%Front, StairsWall, 0.5, -%23%, -%24%, %23%, -%24%, %fullheight%, %fullheight%, -%interfloorheight%, -%interfloorheight%, 0, 0
	AddStairsWall %25%, Stair%25%Left, StairsWall, 0.5, -%23%, -%24%, -%23%, %24%, %fullheight%, %fullheight%, -%interfloorheight%, -%interfloorheight%, 0, 0
	WallOrientation = left
	DrawWalls = true, false, false, false, false, false
	AddStairsWall %25%, Stair%25%Right, StairsWall, 0.5, %23%, -%24%, %23%, %24%, %fullheight%, %fullheight%, -%interfloorheight%, -%interfloorheight%, 0, 0
	AddStairsWall %25%, Stair%25%Back, StairsWall, 0.5, -%23%, %24%, %23%, %24%, %fullheight%, %fullheight%, -%interfloorheight%, -%interfloorheight%, 0, 0

	WallOrientation = center
	DrawWalls = true, true, true, true, false, true
	AddStairsWall %25%, Stair%25%Center, StairsWall2, 1, 0, -%24% + 5, 0, -%24% + 5 + %NumSteps%, %fullheight%, %fullheight%, -%interfloorheight%, -%interfloorheight%, 0, 0

	#DrawWalls = true, true, true, true, true, true
	#if[%floor% = 0] AddStairsWall %25%, Stair%25%Center_T1, StairsWall2, 1, 0, -%24% + 5 + 9, 0, -%24% + 5 + 12, %interfloorheight% + 3, %interfloorheight% + 3, -%interfloorheight%, -%interfloorheight%, 0, 0

	#Railing
	WallOrientation = right
	DrawWalls = true, true, true, true, true, true
	if[%floor% = 4] AddStairsWall %25%, Stair%25%Rail, StairsWall2, 0.5, -%23%, -%24% + 5 + %NumSteps%, -%23% + 4, -%24% + 5 + %NumSteps%, 0.5 + 3.5, 0.5 + 3.5, -0.5, -0.5, 0, 0

	#Ceiling
	FloorOrientation = top
	DrawWalls = true, false, false, false, false, false
	if[%floor% = 4] AddStairsFloor %25%, Stairs%25%Ceiling, StairsCeiling, 0.5, -%23%, -%24%, %23%, %24%, %height%, %height%, false, false, 0, 0

	#Stairs
	Set NumStepsU2 = %NumSteps% * 2
	Set NumStepsU3 = %NumSteps% * 3

	OP_Draw(true, true, true, true, true, true)
	if[%floor% < 4] OP_OrthoStair(%25%, ST%25%_LowerStairs, Stairs, -%23%, -%23% + 4, back, -%24% + 5 + %NumSteps%, %NumSteps%, 1, %26%, 0, 0.5)
	if[%floor% < 4] OP_OrthoStair(%25%, ST%25%_UpperStairs, Stairs, %23% - 4, %23%, front, -%24% + 5, %NumSteps%, 1, %26%, %26% * %NumSteps%, 0.5)
	if[%DblStairs% = true & %floor% < 4] OP_OrthoStair(%25%, ST%25%_LowerStairsEX, Stairs, -%23%, -%23% + 4, back, -%24% + 5 + %NumSteps%, %NumSteps%, 1, %26%, %26% * %NumStepsU2%, 0.5)
	if[%DblStairs% = true & %floor% < 4] OP_OrthoStair(%25%, ST%25%_UpperStairsEX, Stairs, %23% - 4, %23%, front, -%24% + 5, %NumSteps%, 1, %26%, %26% * %NumStepsU3%, 0.5)

	#Landings
	FloorOrientation = top
	DrawWalls = true, true, false, false, false, false
	if[%floor% = 0] AddStairsFloor %25%, Stairs%25%LandingLower, StairsFloor, 0.5, -%23%, -%24%, %23%, %24%, 0, 0, false, false, 0, 0
	if[%floor% > 0] AddStairsFloor %25%, Stairs%25%LandingLower, StairsFloor, 0.5, -%23%, -%24% + 5 + %NumSteps%, %23%, %24%, 0, 0, false, false, 0, 0
	#if[%floor% = 0] AddStairsFloor %25%, Stairs%25%LandingLower, StairsFloor, 0.5, -%23%, -%24% + 5 + 12, %23%, %24%, 0, 0, false, false, 0, 0
	#if[%floor% = 0] AddStairsFloor %25%, Stairs%25%Transition1, StairsFloor, 0.5, -%23%, -%24% + 5 + 9, -%23% + 4, -%24% + 5 + 12, 0, 0, false, false, 0, 0

	if[%floor% < 4] AddStairsFloor %25%, Stairs%25%LandingUpper, StairsFloor, 0.5, -%23%, -%24%, %23%, -%24% + 5, %26% * %NumSteps%, %26% * %NumSteps%, false, false, 0, 0

	if[%DblStairs% = true & %floor% < 4] AddStairsFloor %25%, Stairs%25%LandingLowerEX, StairsFloor, 0.5, -%23%, -%24% + 5 + %NumSteps%, %23%, %24%, %26% * %NumStepsU2%, %26% * %NumStepsU2%, false, false, 0, 0
