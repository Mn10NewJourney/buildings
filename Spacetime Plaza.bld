<Function BtnPanelE14-15>
	Set PanelNumber = %param1%
	Set PanelNumber2 = %PanelNumber% + 1
	Set BtnPrefix = Button

	AddButton %PanelNumber%, KW_Sounds/konebuttonbeep.wav, %BtnPrefix%8, %BtnPrefix%Lit8, 3, 2, 8, 1, 1
	AddButton %PanelNumber%, KW_Sounds/konebuttonbeep.wav, %BtnPrefix%7, %BtnPrefix%Lit7, 3, 1, 6, 1, 1
	AddButton %PanelNumber%, KW_Sounds/konebuttonbeep.wav, %BtnPrefix%6, %BtnPrefix%Lit6, 4, 2, 5, 1, 1
	AddButton %PanelNumber%, KW_Sounds/konebuttonbeep.wav, %BtnPrefix%5, %BtnPrefix%Lit5, 4, 1, 4, 1, 1
	AddButton %PanelNumber%, KW_Sounds/konebuttonbeep.wav, %BtnPrefix%4, %BtnPrefix%Lit4, 5, 2, 3, 1, 1
	AddButton %PanelNumber%, KW_Sounds/konebuttonbeep.wav, %BtnPrefix%3, %BtnPrefix%Lit3, 5, 1, 2, 1, 1
	AddButton %PanelNumber%, KW_Sounds/konebuttonbeep.wav, %BtnPrefix%2, %BtnPrefix%Lit2, 6, 2, 1, 1, 1
	AddButton %PanelNumber%, KW_Sounds/konebuttonbeep.wav, %BtnPrefix%1, %BtnPrefix%Lit1, 6, 1, 0, 1, 1

	if[%PanelNumber% = 1] AddButton %PanelNumber2%, , %BtnPrefix%Alarm, %BtnPrefix%Alarm, 1, 1, alarm, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%Open, %BtnPrefix%Open, 8, 1, open, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%Close, %BtnPrefix%Close, 8, 2, close, 1, 1
<EndFunction>

<Elevators 14 to 15>
	Set Prefix = Freight
	AutoEnable = false

	#Set textures and dimensions
	M10_ElevCabTex(ElevExt, %Prefix%ElevFloor, %Prefix%ElevCeiling, %Prefix%ElevWall, %Prefix%ElevWall)
	M10_ElevDimensions(9.28, 8.5, 8, 0.2, 0.2, true, true, false, true)
	M10_ElevPanels(%Prefix%ElevPanelMain, %Prefix%ElevPanelTop, 0.25, 0.25, 1, 0.2, false, false, true, false)

	#Finish elevator assembly
	M10_ElevInterior()
	#--------------------
	#DETAILED INTERIORS
	#1. Ceiling lights
	CreateWallBox2 elevator, E%elevator%_Light1, %Prefix%ElevCeilingLight, 0, -1.375, 6.5, 1, 0.1, 8 - 0.1, 0, 0, false, true, true, true
	CreateWallBox2 elevator, E%elevator%_Light2, %Prefix%ElevCeilingLight, 0, 0, 6.5, 1, 0.1, 8 - 0.1, 0, 0, false, true, true, true
	CreateWallBox2 elevator, E%elevator%_Light3, %Prefix%ElevCeilingLight, 0, 1.375, 6.5, 1, 0.1, 8 - 0.1, 0, 0, false, true, true, true

	#2. Panels on walls
	Set WPTex = %Prefix%ElevWallPanel
	Set WPanelHeight = 3.5

		#Front panel
		CreateWallBox2 elevator, Panel_F1, %WPTex%, 0, -4.05 + 0.005, 9.28 - 0.4, 0.01, %WPanelHeight%, 0, 0, 0, false, true, true, true

		#Back panel
		CreateWallBox2 elevator, Panel_B1, %WPTex%, 0, 4.05 - 0.005, 9.28 - 0.4, 0.01, %WPanelHeight%, 0, 0, 0, false, true, true, true

		#Left panel
		CreateWallBox2 elevator, Panel_L1, %WPTex%, -4.44 + 0.005, 0, 0.01, 8.5 - 0.4 - 0.02, %WPanelHeight%, 0, 0, 0, false, true, true, true
	#--------------------
	#Car Doors
	Set ElevDoorTex = %Prefix%ElevDoors
	Set InitialDoorPos = 4.64

	WallOrientation = left
	AddDoorComponent 1, FreightDoor1, %ElevDoorTex%2, %ElevDoorTex%2, 0.15, left, 0.4, 0.3, %InitialDoorPos%, -4, %InitialDoorPos%, -4 + (2.00 * 1), 7, 0, 0, 0, 0, 0
	AddDoorComponent 1, FreightDoor2, %ElevDoorTex%2, %ElevDoorTex%2, 0.15, left, 0.8, 0.6, %InitialDoorPos% + (0.15 * 1), -4 + (2.00 * 1), %InitialDoorPos% + (0.15 * 1), -4 + (2.00 * 2), 7, 0, 0, 0, 0, 0
	AddDoorComponent 1, FreightDoor3, %ElevDoorTex%, %ElevDoorTex%, 0.15, right, 0.8, 0.6, %InitialDoorPos% + (0.15 * 1), -4 + (2.00 * 2), %InitialDoorPos% + (0.15 * 1), -4 + (2.00 * 3), 7, 0, 0, 0, 0, 0
	AddDoorComponent 1, FreightDoor4, %ElevDoorTex%, %ElevDoorTex%, 0.15, right, 0.4, 0.3, %InitialDoorPos%, -4 + (2.00 * 3), %InitialDoorPos%, -4 + (2.00 * 4), 7, 0, 0, 0, 0, 0
	FinishDoors 1, false, false

		#Door track
		FloorOrientation = top
		DrawWalls = true, true, true, true, true, true
		TextureOverride ElevExt, ElevDoorTrackX, ElevExt, ElevExt, ElevExt, ElevExt
		AddFloor DoorTrack, ElevDoorTrackX, 0.05, %InitialDoorPos%, -4 - (2.00 * 1), %InitialDoorPos% + (0.15 * 2), 4 + (2.00 * 1), 0, 0, 0, 0

		#Top filler
		FloorOrientation = bottom
		DrawWalls = true, true, true, true, true, true
		TextureOverride %Prefix%ElevPanelTop, ElevExt, ElevExt, ElevExt, ElevExt, ElevExt
		AddFloor TopFiller, %Prefix%ElevPanelTop, 0.05, %InitialDoorPos%, -4 + (2.00 * 1), %InitialDoorPos% + (0.15 * 1), -4 + (2.00 * 3), 7, 7, 0, 0
	#--------------------
	#BUTTON PANELS
	#Right Panel
	Set P1_PositionX = 4.44 - 0.75
	Set P1_PositionZ = -4.05 + 0.001

		#Panels
		CreateWallBox2 elevator, RightPB, ElevPanel, %P1_PositionX%, %P1_PositionZ% - 0.001 + 0.025, 0.8, 0.05, 4.75, 2.25, 0, 0, false, true, true, true
		CreatePanel , 8, 2, back, %P1_PositionX%, %P1_PositionZ% + 0.05, 0.15, 0.15, 0.5, 0.25, 3.75, 0, 0
		CreatePanel , 8, 1, back, %P1_PositionX%, %P1_PositionZ% + 0.05, 0.15, 0.15, 0.5, 0.25, 3.75, 0, 0

			#Buttons
			BtnPanelE14-15(1)
	#--------------------
	#Indicator sets
	Set IndOffset = 6

		#Right
		DrawWalls = false, true, false, false, false, false
		AddWall RightIndBack1, IndBack2, 0, %P1_PositionX% - 0.3, %P1_PositionZ% + 0.051, %P1_PositionX% + 0.3, %P1_PositionZ% + 0.051, 0.95, 0.95, %IndOffset% - 0.15, %IndOffset% - 0.15, 0, 0
		AddWall RightIndBack2, IndBack, 0,  %P1_PositionX% - 0.2, %P1_PositionZ% + 0.052, %P1_PositionX% + 0.2, %P1_PositionZ% + 0.052, 0.8, 0.8, %IndOffset%, %IndOffset%, 0, 0

		AddFloorIndicator Ind_Button, back, %P1_PositionX%, %P1_PositionZ% + 0.053, 0.4, 0.4, %IndOffset% + 0.11
		AddDirectionalIndicator true, true, true, IndBack, ArrowUp, ArrowUpLit, ArrowDown, ArrowDownLit, %P1_PositionX%, %P1_PositionZ% + 0.053, %IndOffset% + 0.375, back, 0.45, 0.4, false, 0, 0
	#--------------------
	#Proximity scanner
	Set PSscanHeight = 0.45
	Set PScanWidth = %PSscanHeight% * 0.712
	Set PScanTex = HIDScanGreen

	DrawWalls = false, true, false, false, false, false
	AddWall ProximityScanner, %PScanTex%, 0, %P1_PositionX% - (%PScanWidth% / 2), %P1_PositionZ% + 0.05, %P1_PositionX% + (%PScanWidth% / 2), %P1_PositionZ% + 0.05, %PSscanHeight%, %PSscanHeight%, 4.875, 4.875, 0, 0
	#--------------------
	#Elevator number sign
	DrawWalls = true, false, false, false, false, false
	AddWall ElevNo%elevator%_Inside, IN_ElevNo%elevator%, 0, 4.44 - 0.001, 0 - 0.25, 4.44 + 0.001, 0 + 0.25, 0.5, 0.5, 7.05, 7.05, 0, 0
	#--------------------
	#Shaft components
	DrawWalls = true, true, true, true, true, true
		#Ropes
		RopePosition = 0, 8 + 0.2, 0
		RopeTexture = Ropes
	
		#Counterweight
		Set Position = -4.25 - 0.8
		if[%elevator% = 15] Set Position = 4.25 + 0.8
		CreateCounterweight CWeight_Frame, CWeight, 0, %Position%, 2, 6, 0.5, 0.5
	
		#Rails
		AddRails ElevRail, ElevRailSide, 0, 0, true, 4.25 + 0.06, 0.1
		AddRails ElevRail, ElevRailSide, 0, %Position%, false, 1 + 0.06, 0.1
<EndElevators>

