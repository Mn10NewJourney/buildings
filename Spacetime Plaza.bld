		AddFloor EastAtriumBase2, ABCarpet2, 0.5, 190, 20, 270, 100, %interfloorheight%, %interfloorheight%, 0, 0, true
		AddFloor EastAtriumBase3, ABCarpet2, 0.5, 190, 140, 270, 240, %interfloorheight%, %interfloorheight%, 0, 0, true
<EndFloor>

<Floor 4>
	#Skylights
