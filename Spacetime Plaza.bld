		AddWall RightIndBack, NewOtisInd_BG, 0, %Position% - 0.25, 3.05 - 0.051, %Position% + 0.25, 3.05 - 0.051, 0.9, 0.9, %IndOffset% - 0.15, %IndOffset% - 0.15, 0, 0

		AddFloorIndicator NewOtisInd_Button, front, %Position%, 3.05 - 0.052, 0.4, 0.4, %IndOffset% + 0.15 - 0.1
		AddDirectionalIndicator true, true, true, Blank, NewOtisArrow_Blank, NewOtisArrow_LitUp, NewOtisArrow_Blank, NewOtisArrow_LitDown, %Position%, 3.05 - 0.052, %IndOffset% + 0.15 + 0.3, front, 0.24, 0.3, true, 0, 0
	#--------------------
	#Elevator number sign
	DrawWalls = true, false, false, false, false, false
	AddWall ElevNo%elevator%_Inside, IN_ElevNo%elevator%, 0, 0 - 0.25, 3.05 - 0.001, 0 + 0.25, 3.05 - 0.001, 0.5, 0.5, 7.05, 7.05, 0, 0
	#--------------------
