		TextureOverride ExtFacade, ExtFacade2, ExtFacade, ExtFacade, ExtFacade, ExtFacade
		AddWall WRF_BackRail, ExtFacade, 0.5, -%1%, %2% - 260, -%1% + 240, %2% - 260, %interfloorheight% + 24, %interfloorheight% + 24, %WallOffset%, %WallOffset%, 0, 0, true

		#Center roof
		WallOrientation = Right
		#AddWall CRF_BackRail, ExtFacade, 0.5, -%1% + 240, %2% - 260, -%1% + 420, %2% - 260, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		TextureOverride ExtFacade, ExtFacade2, ExtFacade, ExtFacade, ExtFacade, ExtFacade
		AddWall CRF_BackRail, ExtFacade, 0.5, -%1% + 240, %2% - 260, -%1% + 420, %2% - 260, %interfloorheight% + 24, %interfloorheight% + 24, %WallOffset%, %WallOffset%, 0, 0, true
		WallOrientation = Left
		AddWall CRF_FrontRail, ExtFacade, 0.5, -%1% + 240, %2% - 260 - 320, -%1% + 420, %2% - 260 - 320, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		#East roof
		WallOrientation = Left
		AddWall ERF_FrontRail, ExtFacade, 0.5, %1% - 240 + 0.5, -%2% + 260, %1% - 0.5, -%2% + 260, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		AddWall ERF_LeftRail1, ExtFacade, 0.5, %1% - 240, -%2% + 260, %1% - 240, %2% - 260 - 320, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		#AddWall ERF_LeftRail2, ExtFacade, 0.5, %1% - 240, %2% - 260 - 0.5, %1% - 240, %2% - 220, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		TextureOverride ExtFacade2, ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade
		AddWall ERF_LeftRail2, ExtFacade, 0.5, %1% - 240, %2% - 260 - 0.5, %1% - 240, %2% - 220, %interfloorheight% + 24, %interfloorheight% + 24, %WallOffset%, %WallOffset%, 0, 0, true
		WallOrientation = right
		AddWall ERF_RightRail, ExtFacade, 0.5, %1%, -%2% + 260, %1%, %2% - 220, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
<EndFloor>

#Atrium cuts
	#West atrium
	Cut External, -%1% + 80, Floor(0).Base - 0.1, 20, -%1% + 220, Floor(5).Base + 5, 140, false, true #Shopping levels
	Cut External, -%1% + 120, Floor(5).Base + 5, 20, -%1% + 220, Floor(6).Base + 5, 140, false, true #Shopping levels
	Cut External, -%1% + 120, Floor(10).Altitude - 1, 20, -%1% + 220, Floor(10).Base + 1, 140, false, true #Roof skylight

	#Center atrium
