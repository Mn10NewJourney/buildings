############################################################

#Floor Assignments
<Floors -1 to -3>
	ID = B(0 - %floor%)
	Name = Basement Level (0 - %floor%)
	Type = Basement
	Height = 10
	InterfloorHeight = 2
	if[%floor% = -1] Altitude = -10
<EndFloors>

<Floors 0 to 5>
	ID = %floor% + 1
	Name = Mall Level %floorid%
	Type = Shopping
	Height = 16
	InterfloorHeight = 2
	if[%floor% = 0] Altitude = 2
<EndFloors>

<Floors 6 to 7>
	if[%floor% = 6] ID = 7
	if[%floor% = 7] ID = 7A
	Name = Mall Level %floorid%
	Type = Shopping
	Height = 10
	InterfloorHeight = 2
<EndFloors>

<Floors 8 to 9>
	if[%floor% = 8] ID = 8
	if[%floor% = 9] ID = 8A
	Name = Mall Level %floorid%
	Type = Shopping
	Height = 10
	InterfloorHeight = 2
<EndFloors>

<Floors 10 to 11>
	ID = %floor% - 1
	Name = Parking Level %floorid%
	Type = Parking
	Height = 10
	InterfloorHeight = 2
	if[%floor% = 10] Description = Mall roof level
<EndFloors>

<Floor 12>
	ID = %floor% - 1
	Name = Shaft Top
	Type = Roof
	Height = 4
	InterfloorHeight = 2
<EndFloor>

#Merge floors
<Floors -2 to 9>
	Group = -2 - 9
<EndFloors>

##--------------------------------------------------------------------------------##

#LANDSCAPES
#Coordinate Set
Set MainX = 822
Set MainZ = 0
Set InSTP = true

#Tranquility City Landscape
<Include buildings/KW_Maps/Tranquility City.txt>

########################################

#Common values
Set 1 = 330 #Building Dimension X (Full width: 660 ft.)
Set 2 = 500 #Building Dimension Z (Full length: 1,000 ft.)

#Cut landscape for building
Cut Landscape, -%1%, -1, -%2%, %1%, 1, %2%, false, true
Cut Landscape, -416, -1, -%2%, -%1%, 0.5, %2%, false, true #West Parking area
Cut Landscape, %1%, -1, -%2%, %1% + 150, 0.5, %2%, false, true #East Parking area

#Landscape
DrawWalls = false, true, false, false, false, false

	#Filler floors
	AddFloor landscape, FillerFloor1, Foundation, 0, -%1%, -%2%, -%1% + 240, %2% - 260 - 320, 4, 4, 0, 0
	AddFloor landscape, FillerFloor2, Foundation, 0, -%1% + 240, -%2%, -%1% + 420, -%2% + 260 - 120, 4, 4, 0, 0

##--------------------------------------------------------------------------------##

#Set texture prefixes/suffixes
<Function TexPrefix>
	#Main prefixes
	Set 5 = Shop
	if[%floor% < 0] Set 5 = Parking
	if[%floor% > 5] Set 5 = UpperShop

	#Parking lobby suffixes (For mall elevators serving the basements)
	Set 5L = Wall
	if[%floor% < 0] Set 5L = LobbyWall

	#Parking lobby prefixes (For tower parking elevators)
	#Set 5PK = Wall
	#if[%floor% < 0 | %floor% = 7 | %floor% > 8] Set 5PK = LobbyWall

	Set LobbyPrefix = LowerParkingLobby
	if[%floor% > 5] Set LobbyPrefix = UpperParkingLobby

	###************###

	#Set heights for External Shaft/Stairwell walls
	Set SHeight = %fullheight%
	Set SOffset = 0
	if[%floor% = 0] Set SHeight = %height%
	if[%floor% = 0] Set SOffset = %interfloorheight%
	if[%floor% < 0] Set SHeight = %height% + Floor(%floor% + 1).InterfloorHeight - 0.5
	if[%floor% < 0] Set SOffset = %interfloorheight%
<EndFunction>

##--------------------------------------------------------------------------------##

#EXTERIOR & INTERIOR
#Parking level B3 (Accounting Tower only)
<Floor -3>
	TexPrefix() #Set texture prefix/suffix

	#Floors
	Set ShowBottom = false

	FloorOrientation = top
	DrawWalls = false, true, false, false, false, false
	AddFloor OfficeZonePKFloor, Road, 0.5, -416, -%2%, -%1%, -160, %interfloorheight%, %interfloorheight%, 0, 0, true

	#Ceilings
	FloorOrientation = bottom
	DrawWalls = true, false, false, false, false, false
	AddFloor OfficeZonePKCeiling, %5%Ceiling, 0.5, -416, -%2%, -%1%, -160, %fullheight% + 1, %fullheight% + 1, 0, 0, true

	#Perimeter walls
	TexPrefix() #Set texture prefix/suffix
	if[%floor% ! -1] Set WallHeight = %fullheight%
	if[%floor% = -1] Set WallHeight = %fullheight% + Floor(0).InterfloorHeight
	Set WallOffset = 0

		DrawWalls = false, true, false, false, false, false
		WallOrientation = left
		AddWall OfficeZoneFrontWall, %5%Wall, 0.5, -416, -%2%, -%1%, -%2%, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		AddWall OfficeZoneLeftWall, %5%Wall, 0.5, -416, -%2%, -416, -160, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		WallOrientation = right
		DrawWalls = true, false, false, false, false, false
		AddWall OfficeZoneBackWall, %5%Wall, 0.5, -416, -160, -%1%, -160, %WallHeight% + 1, %WallHeight% + 1, %WallOffset%, %WallOffset%, 0, 0, true
<EndFloor>

#Parking levels B2-B1
	#Level B2: Separated between west (office/hotel) and east (shopping) sides
	#Level B1: Nearly entire floor is linked together

<Floors -2 to -1>
	TexPrefix() #Set texture prefix/suffix

	#Floors
	Set ShowBottom = false
	if[%floor% = 0] Set ShowBottom = true

	FloorOrientation = top
	DrawWalls = true, true, false, false, false, false
	TextureOverride ParkingCeiling, Road, Blank, Blank, Blank, Blank
	AddFloor SouthwestZonePKFloor, Road, 1, -416, -%2%, -%1%, -160, %interfloorheight%, %interfloorheight%, 0, 0, true

	TextureOverride ParkingCeiling, Road, Blank, Blank, Blank, Blank
	AddFloor WestZonePKFloor1, Road, 1, -416, %2% - 260 - 320, -%1% + 240, %2% - 260, %interfloorheight%, %interfloorheight%, 0, 0, true
	TextureOverride ParkingCeiling, Road, Blank, Blank, Blank, Blank
	AddFloor WestZonePKFloor2, Road, 1, -416, -160, -%1% + 200, %2% - 260 - 320, %interfloorheight%, %interfloorheight%, 0, 0, true

	#TextureOverride ParkingCeiling, Road, Blank, Blank, Blank, Blank
	DrawWalls = false, true, false, false, false, false
	if[%floor% = -1] AddFloor CenterZonePKFloor, Road, 0.5, -%1% + 240, %2% - 260 - 320, -%1% + 420, %2% - 260, %interfloorheight%, %interfloorheight%, 0, 0, true

	DrawWalls = true, true, false, false, false, false
	TextureOverride ParkingCeiling, Road, Blank, Blank, Blank, Blank
	AddFloor EastZonePKFloor, Road, 1, %1% - 240, -%2% + 260, %1% + 150, %2% - 220, %interfloorheight%, %interfloorheight%, 0, 0, true

	TextureOverride ParkingCeiling, Road, Blank, Blank, Blank, Blank
	AddFloor NorthwestZonePKFloor, Road, 1, -416, %2% - 260, -%1%, %2%, %interfloorheight%, %interfloorheight%, 0, 0, true

		DrawWalls = false, true, false, false, false, false
		#Extra floorings above roads (East zone)
		if[%floor% = -2] CreateFlr(EZ_WestUtilityFloor1, ParkingFloor, 0.5, 90, -%2% + 260, 111, %2% - 220, 0, true)
		if[%floor% = -1] CreateFlr(EZ_WestUtilityFloor1, ParkingFloor, 0.5, 90, -%2% + 260, 111, -59, 0, true)
		CreateFlr(EZ_WestUtilityFloor1A, ParkingFloor, 0.5, 111, -%2% + 260, 130, -180, 0, true)
		CreateFlr(EZ_WestUtilityFloor2, ParkingFloor, 0.5, 111, -180, 133, -61, 0, true)
		if[%floor% = -2] CreateFlr(EZ_WestUtilityFloor3, ParkingFloor, 0.5, 111, -21, 133, 221, 0, true)
		if[%floor% = -1] CreateFlr(EZ_WestUtilityFloor3, ParkingFloor, 0.5, 90, 221, 111, 280, 0, true)

		CreateFlr(EZ_NortheastECF, ParkingFloor, 0.5, 268.5, 179, 333, 261, 0, true) #ECF = Elevator core floor
		if[%floor% = -1] CreateFlr(EZ_NortheastECF_Extra, ParkingFloor, 0.5, 287, 140, 333, 179, 0, true) #ECF = Elevator core floor
		CreateFlr(EZ_SoutheastECF, ParkingFloor, 0.5, 281, -221, 333, -19, 0, true)

		CreateFlr(EZ_SouthwestECF, ParkingFloor, 0.5, 111, -221, 149, -179, 0, true)
		CreateFlr(EZ_MidwestECF, ParkingFloor, 0.5, 111, -61, 149, -19, 0, true)
		CreateFlr(EZ_NorthwestECF, ParkingFloor, 0.5, 111, 221, 149, 261, 0, true)
		
			#Elevator lobby floors

		#Extra floorings above roads (Center zone)
		if[%floor% = -1] CreateFlr(CZ_SouthUtilityFloor1, ParkingFloor, 0.5, 25, -80, 90, -59, 0, true)
		if[%floor% = -1] CreateFlr(CZ_SouthUtilityFloor2, ParkingFloor, 0.5, -90, -80, -5, -59, 0, true)

		#Extra floorings above roads (West zone)
		CreateFlr(WZ_SouthUtilityFloor1, ParkingFloor, 0.5, -130, -80, -90, -59, 0, true)
		CreateFlr(WZ_SouthUtilityFloor2, ParkingFloor, 0.5, -250, -80, -170, -59, 0, true)

			#Escalator lobby floors
			CreateFlr(WZ_EscLobbyFlr, ParkingLobbyFloor, 0.5, -210, 60, -164, 100, 0, true)

	#Ceilings
	FloorOrientation = bottom
	DrawWalls = true, false, false, false, false, false
	if[%floor% = -1] AddFloor SouthwestZonePKCeiling, %5%Ceiling, 0.5, -416, -%2%, -%1% + 240, -160, %fullheight% + 1, %fullheight% + 1, 0, 0, true
	if[%floor% = -1] AddFloor WestZonePKCeiling1, %5%Ceiling, 0.5, -416, -160, -%1%, %2% - 260, %fullheight% + 1, %fullheight% + 1, 0, 0, true
	if[%floor% = -1] AddFloor WestZonePKCeiling2, %5%Ceiling, 0.5, -%1%, -160, -%1% + 240, %2% - 260 - 320, %fullheight% + 1, %fullheight% + 1, 0, 0, true
	if[%floor% = -1] AddFloor EastZonePKCeiling, %5%Ceiling, 0.5, %1%, -%2% + 260, %1% + 150, %2% - 220, %fullheight% + 1, %fullheight% + 1, 0, 0, true
	if[%floor% = -1] AddFloor NorthwestZonePKCeiling, %5%Ceiling, 0.5, -416, %2% - 260, -%1%, %2%, %fullheight% + 1, %fullheight% + 1, 0, 0, true

	#Perimeter walls
	TexPrefix() #Set texture prefix/suffix
	if[%floor% ! -1] Set WallHeight = %fullheight%
	if[%floor% = -1] Set WallHeight = %fullheight% + Floor(0).InterfloorHeight
	Set WallOffset = 0

		#Southwest Zone
		DrawWalls = false, true, false, false, false, false
		WallOrientation = left
		AddWall SWZoneFrontWall, %5%Wall, 0.5, -416, -%2%, -%1%, -%2%, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		AddWall SWZoneLeftWall, %5%Wall, 0.5, -416, -%2%, -416, -160, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		#West Zone
		DrawWalls = false, true, false, false, false, false
		WallOrientation = left
		AddWall WestZoneFrontWall, %5%Wall, 0.5, -%1% + 200 - 0.5, %2% - 260 - 320, -%1% + 240, %2% - 260 - 320, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		AddWall WestZoneLeftWall, %5%Wall, 0.5, -416, -160, -416, %2%, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		WallOrientation = right
		DrawWalls = true, false, false, false, false, false
		AddWall WestZoneRightWall, %5%Wall, 0.5, -%1% + 200, -160, -%1% + 200, %2% - 260 - 320 + 0.5, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

