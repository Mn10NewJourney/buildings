#Button creation function (Elevators 4-7)
<Function BtnPanelE4>
	Set PanelNumber = %param1%
	Set PanelNumber2 = %PanelNumber% + 1
	Set BtnPrefix = Button

	AddButton %PanelNumber2%, KW_Sounds/konebuttonbeep.wav, %BtnPrefix%8, %BtnPrefix%Lit8, 3, 1, 8, 1, 1
	AddButton %PanelNumber2%, KW_Sounds/konebuttonbeep.wav, %BtnPrefix%7, %BtnPrefix%Lit7, 4, 1, 6, 1, 1
	AddButton %PanelNumber2%, KW_Sounds/konebuttonbeep.wav, %BtnPrefix%4, %BtnPrefix%Lit4, 5, 1, 3, 1, 1
	AddButton %PanelNumber2%, KW_Sounds/konebuttonbeep.wav, %BtnPrefix%1, %BtnPrefix%Lit1, 6, 1, 0, 1, 1

	if[%PanelNumber% = 1] AddButton %PanelNumber2%, , %BtnPrefix%Alarm, %BtnPrefix%Alarm, 1, 1, alarm, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%Open, %BtnPrefix%Open, 8, 1, open, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%Close, %BtnPrefix%Close, 8, 2, close, 1, 1
<EndFunction>

<Function BtnPanelE5-7>
	Set PanelNumber = %param1%
	Set PanelNumber2 = %PanelNumber% + 1
	Set BtnPrefix = Button

	AddButton %PanelNumber%, KW_Sounds/konebuttonbeep.wav, %BtnPrefix%8, %BtnPrefix%Lit8, 3, 2, 8, 1, 1
	AddButton %PanelNumber%, KW_Sounds/konebuttonbeep.wav, %BtnPrefix%7, %BtnPrefix%Lit7, 3, 1, 6, 1, 1
	AddButton %PanelNumber%, KW_Sounds/konebuttonbeep.wav, %BtnPrefix%6, %BtnPrefix%Lit6, 4, 2, 5, 1, 1
	AddButton %PanelNumber%, KW_Sounds/konebuttonbeep.wav, %BtnPrefix%5, %BtnPrefix%Lit5, 4, 1, 4, 1, 1
	AddButton %PanelNumber%, KW_Sounds/konebuttonbeep.wav, %BtnPrefix%4, %BtnPrefix%Lit4, 5, 2, 3, 1, 1
	AddButton %PanelNumber%, KW_Sounds/konebuttonbeep.wav, %BtnPrefix%3, %BtnPrefix%Lit3, 5, 1, 2, 1, 1
	AddButton %PanelNumber%, KW_Sounds/konebuttonbeep.wav, %BtnPrefix%2, %BtnPrefix%Lit2, 6, 2, 1, 1, 1
	AddButton %PanelNumber%, KW_Sounds/konebuttonbeep.wav, %BtnPrefix%1, %BtnPrefix%Lit1, 6, 1, 0, 1, 1

	if[%PanelNumber% = 1] AddButton %PanelNumber2%, , %BtnPrefix%Alarm, %BtnPrefix%Alarm, 1, 1, alarm, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%Open, %BtnPrefix%Open, 8, 1, open, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%Close, %BtnPrefix%Close, 8, 2, close, 1, 1
<EndFunction>

<Elevators 4 to 7>
	Set Prefix = Central
	AutoEnable = false

	#Set textures and dimensions
	M10_ElevCabTex(ElevExt2, %Prefix%ElevFloor, %Prefix%ElevCeiling, %Prefix%ElevWall, %Prefix%ElevWall)
	M10_ElevDimensions(6, 3.84, 8, 1.5, 0.2, false, true, true, false)
	M10_ElevPanels(%Prefix%ElevPanelMain, %Prefix%ElevPanelTop, 1, 1, 1, 0.2, false, false, false, true)

	#Finish elevator assembly
	M10_ElevInterior()
	#--------------------
	#Interior walls detailing
		#1. Panoramic cab
		#Floors and ceiling
		DrawWalls = true, false, false, false, false, false
		AddCustomFloor elevator, FloorInt, %Prefix%ElevFloor, -3, -1.92, -3, -1.92 - 2, -1.5, -1.92 - 3.66, 1.5, -1.92 - 3.66, 3, -1.92 - 2, 3, -1.92, 0, 0, 0
		DrawWalls = false, true, false, false, false, false
		AddCustomFloor elevator, FloorExt, ElevExt2, -3, -1.92, -3, -1.92 - 2, -1.5, -1.92 - 3.66, 1.5, -1.92 - 3.66, 3, -1.92 - 2, 3, -1.92, -1.5, 0, 0
		DrawWalls = true, true, false, false, false, false
		AddCustomFloor elevator, Ceiling, Blank, -3, -1.92, -3, -1.92 - 2, -1.5, -1.92 - 3.66, 1.5, -1.92 - 3.66, 3, -1.92 - 2, 3, -1.92, 8 + 1.5, 0, 0

		#Floor covering walls
		DrawWalls = true, true, false, false, false, false
		AddWall GlassWall1_Ext, ElevExt2, 0, -3, -1.92 - 2, -3, -1.92, 1.5, 1.5, -1.5, -1.5, 0, 0
		AddWall GlassWall2_Ext, ElevExt2, 0, -3, -1.92 - 2, -1.5, -1.92 - 3.66, 1.5, 1.5, -1.5, -1.5, 0, 0
		AddWall GlassWall3_Ext, ElevExt2, 0, -1.5, -1.92 - 3.66, 1.5, -1.92 - 3.66, 1.5, 1.5, -1.5, -1.5, 0, 0
		AddWall GlassWall4_Ext, ElevExt2, 0, 1.5, -1.92 - 3.66, 3, -1.92 - 2, 1.5, 1.5, -1.5, -1.5, 0, 0
		AddWall GlassWall5_Ext, ElevExt2, 0, 3, -1.92 - 2, 3, -1.92, 1.5, 1.5, -1.5, -1.5, 0, 0

		#Glass walls
		DrawWalls = true, true, false, false, false, false
		AddWall GlassWall1, %Prefix%ElevWallGlass, 0, -3, -1.92 - 2, -3, -1.92, 8 + 1.5, 8 + 1.5, 0, 0, 0, 0
		AddWall GlassWall2, %Prefix%ElevWallGlass, 0, -3, -1.92 - 2, -1.5, -1.92 - 3.66, 8 + 1.5, 8 + 1.5, 0, 0, 0, 0
		AddWall GlassWall3, %Prefix%ElevWallGlass, 0, -1.5, -1.92 - 3.66, 1.5, -1.92 - 3.66, 8 + 1.5, 8 + 1.5, 0, 0, 0, 0
		AddWall GlassWall4, %Prefix%ElevWallGlass, 0, 1.5, -1.92 - 3.66, 3, -1.92 - 2, 8 + 1.5, 8 + 1.5, 0, 0, 0, 0
		AddWall GlassWall5, %Prefix%ElevWallGlass, 0, 3, -1.92 - 2, 3, -1.92, 8 + 1.5, 8 + 1.5, 0, 0, 0, 0

		#2. Walls
		WallOrientation = left
		DrawWalls = true, true, false, false, false, false
		AddWall LeftInt-Link, %Prefix%ElevWall, 0, -3, -1.92, -2.8, -1.92, 8, 8, 0, 0, 0, 0
		AddWall RightInt-Link, %Prefix%ElevWall, 0, 2.8, -1.92, 3, -1.92, 8, 8, 0, 0, 0, 0
		WallOrientation = right
		DrawWalls = true, true, true, true, true, true
		AddWall CeilingDeco, %Prefix%ElevCeilingDeco, 0.01, -3, -1.92, 3, -1.92, 1.5, 1.5, 8, 8, 0, 0

		#3. Ceiling lights
		Set LightOffset = 8 - 0.001
		Set LightOffset2 = 8 - 0.002
		Set DLOffset = 8 - 0.001 #Offsets for downlights
		
		DrawWalls = true, false, false, false, false, false
		AddFloor CeilingLight, %Prefix%ElevCeilingLight, 0, -2, -0.1 - 1.5, 2, -0.1 + 1.5, %LightOffset%, %LightOffset%, 0, 0
		AddFloor CeilingGrid, %Prefix%ElevCeilingGrid, 0, -2, -0.1 - 1.5, 2, -0.1 + 1.5, %LightOffset2%, %LightOffset2%, 6, 8

		AddFloor Downlight1/1, %Prefix%ElevCeilingDL, 0, 2.35 - 0.085, -0.1 - 1.2 - 0.085, 2.35 + 0.085, -0.1 - 1.2 + 0.085, %DLOffset%, %DLOffset%, 0, 0
		AddFloor Downlight1/2, %Prefix%ElevCeilingDL, 0, 2.35 - 0.085, -0.1 + 1.2 - 0.085, 2.35 + 0.085, -0.1 + 1.2 + 0.085, %DLOffset%, %DLOffset%, 0, 0
		AddFloor Downlight2/1, %Prefix%ElevCeilingDL, 0, -2.35 - 0.085, -0.1 - 1.2 - 0.085, -2.35 + 0.085, -0.1 - 1.2 + 0.085, %DLOffset%, %DLOffset%, 0, 0
		AddFloor Downlight2/2, %Prefix%ElevCeilingDL, 0, -2.35 - 0.085, -0.1 + 1.2 - 0.085, -2.35 + 0.085, -0.1 + 1.2 + 0.085, %DLOffset%, %DLOffset%, 0, 0

		#4. Panels on walls
		Set WPTex = %Prefix%ElevWallPanel
		if[%elevator% = 4] Set WPTex = %Prefix%ElevWallPanel2

		CreateWallBox2 elevator, Panel_Left, %WPTex%, -2.8 + 0.01, -0.1, 0.02, 2, 8 - 1.5 - 0.08, 0.75, 0, 0, false, true, true, true
		CreateWallBox2 elevator, Panel_Right, %WPTex%, 2.8 - 0.01, -0.1, 0.02, 2, 8 - 1.5 - 0.08, 0.75, 0, 0, false, true, true, true
	#--------------------
	#Car Doors
	Set ElevDoorTex = %Prefix%ElevDoors

	WallOrientation = left
	AddDoorComponent 1, Left, %ElevDoorTex%, %ElevDoorTex%Side, 0.2, left, 0.8, 0.6, -2, 1.92, 0, 1.92, 7, 0, 0, 0, 0, 0
	AddDoorComponent 1, Right, %ElevDoorTex%2, %ElevDoorTex%2Side, 0.2, right, 0.8, 0.6, 0, 1.92, 2, 1.92, 7, 0, 0, 0, 0, 0
	FinishDoors 1, false, false

		#Door Track
		FloorOrientation = top
		DrawWalls = true, true, true, true, true, true
		TextureOverride ElevExt, ElevDoorTrackZ, ElevExt, ElevExt, ElevExt, ElevExt
		AddFloor DoorTrack, ElevDoorTrackZ, 0.05, -(2 * 2), 1.92, 2 * 2, 2.12, 0, 0, 0, 0
	#--------------------
	#Button Panels
	#Right Panel
	Set P1_PositionX = 2.4
	Set P1_PositionZ = 1.72 - 0.001

		#Panels
		CreateWallBox2 elevator, RightPB, ElevPanel, %P1_PositionX%, %P1_PositionZ% + 0.001 - 0.025, 0.7, 0.05, 4.75, 2.25, 0, 0, false, true, true, true
		CreatePanel , 8, 2, front, %P1_PositionX%, %P1_PositionZ% - 0.05, 0.15, 0.15, 0.5, 0.25, 3.75, 0, 0
		CreatePanel , 8, 1, front, %P1_PositionX%, %P1_PositionZ% - 0.05, 0.15, 0.15, 0.5, 0.25, 3.75, 0, 0

			#Buttons
			if[%elevator% = 4] BtnPanelE4(1)
			if[%elevator% > 4] BtnPanelE5-7(1)

	#Left Panel
	Set P2_PositionX = -2.4
	Set P2_PositionZ = 1.72 - 0.001

		#Panels
		CreateWallBox2 elevator, RightPB, ElevPanel, %P2_PositionX%, %P2_PositionZ% + 0.001 - 0.025, 0.7, 0.05, 4.75, 2.25, 0, 0, false, true, true, true
		CreatePanel , 8, 2, front, %P2_PositionX%, %P2_PositionZ% - 0.05, 0.15, 0.15, 0.5, 0.25, 3.75, 0, 0
		CreatePanel , 8, 1, front, %P2_PositionX%, %P2_PositionZ% - 0.05, 0.15, 0.15, 0.5, 0.25, 3.75, 0, 0

			#Buttons
			if[%elevator% = 4] BtnPanelE4(3)
			if[%elevator% > 4] BtnPanelE5-7(3)

	#--------------------
	#Elevator number sign
	DrawWalls = true, false, false, false, false, false
	AddWall ElevNo%elevator%_Inside, IN_ElevNo%elevator%, 0, 0 - 0.25, 1.72 - 0.001, 0 + 0.25, 1.72 - 0.001, 0.5, 0.5, 7.05, 7.05, 0, 0
	#--------------------
	#Indicator sets
	Set IndOffset = 6

		#Right
		DrawWalls = true, false, false, false, false, false
		AddWall RightIndBack1, IndBack2, 0, %P1_PositionX% - 0.25, %P1_PositionZ% - 0.051, %P1_PositionX% + 0.25, %P1_PositionZ% - 0.051, 0.95, 0.95, %IndOffset% - 0.15, %IndOffset% - 0.15, 0, 0
		AddWall RightIndBack2, IndBack, 0, %P1_PositionX% - 0.2, %P1_PositionZ% - 0.052, %P1_PositionX% + 0.2, %P1_PositionZ% - 0.052, 0.8, 0.8, %IndOffset%, %IndOffset%, 0, 0

		AddFloorIndicator Ind_Button, front, %P1_PositionX%, %P1_PositionZ% - 0.053, 0.4, 0.4, %IndOffset%
		AddDirectionalIndicator true, true, true, IndBack, ArrowUp, ArrowUpLit, ArrowDown, ArrowDownLit, %P1_PositionX%, %P1_PositionZ% - 0.053, %IndOffset% + 0.375, front, 0.45, 0.4, false, 0, 0

		#Left
		DrawWalls = true, false, false, false, false, false
		AddWall LeftIndBack1, IndBack2, 0, %P2_PositionX% - 0.25, %P2_PositionZ% - 0.051, %P2_PositionX% + 0.25, %P2_PositionZ% - 0.051, 0.95, 0.95, %IndOffset% - 0.15, %IndOffset% - 0.15, 0, 0
		AddWall LeftIndBack2, IndBack, 0, %P2_PositionX% - 0.2, %P2_PositionZ% - 0.052, %P2_PositionX% + 0.2, %P2_PositionZ% - 0.052, 0.8, 0.8, %IndOffset%, %IndOffset%, 0, 0

		AddFloorIndicator Ind_Button, front, %P2_PositionX%, %P2_PositionZ% - 0.053, 0.4, 0.4, %IndOffset%
		AddDirectionalIndicator true, true, true, IndBack, ArrowUp, ArrowUpLit, ArrowDown, ArrowDownLit, %P2_PositionX%, %P2_PositionZ% - 0.053, %IndOffset% + 0.375, front, 0.45, 0.4, false, 0, 0
	#--------------------
	#Shaft components
	DrawWalls = true, true, true, true, true, true
		#Ropes
		RopePosition = 0, 9.5, 0
		RopeTexture = Ropes
	
		#Counterweight
		if[%elevator% < 6] Set Position = 3 + 0.75
		if[%elevator% > 5] Set Position = -3 - 0.75
	
		CreateCounterweight CWeight_Frame, CWeight, %Position%, 0.5, 0.5, 6, 2, 0.5
	
		#Rails
		AddRails ElevRail, ElevRailSide, 0, 0, false, 3 + 0.06, 0.1
		AddRails ElevRail, ElevRailSide, %Position%, 0.5, true, 1 + 0.06, 0.1
<EndElevators>

#Tower Parking Elevators
#Set motors' position
<Elevators 8 to 13>
	MotorPosition = 0, Floor(12).Base + Floor(12).Height - 0.5, 0
<EndElevators>

<Elevator 8>
	Name = Tower Parking Elevator 1
	Speed = 12
	Acceleration = 0.6
	Deceleration = 0.6
	ServicedFloors = -2 - 11
	AssignedShaft = 3
	CreateElevator true, 0.59, -10, 0
<EndElevator>

<Elevator 9>
	Name = Tower Parking Elevator 2
	Speed = 12
	Acceleration = 0.6
	Deceleration = 0.6
	ServicedFloors = -2 - 11
	AssignedShaft = 3
	CreateElevator true, 0.59, 0, 0
<EndElevator>

<Elevator 10>
	Name = Tower Parking Elevator 3
	Speed = 12
	Acceleration = 0.6
	Deceleration = 0.6
	ServicedFloors = -2 - 11
	AssignedShaft = 3
	CreateElevator true, 0.59, 10, 0
<EndElevator>

#Button creation function (Tower Parking Elevators)
<Function BtnPanelTowerPK>
	Set PanelNumber = %param1%
	Set PanelNumber2 = %PanelNumber% + 1
	Set BtnPrefix = Button

	AddButton %PanelNumber%, KW_Sounds/konebuttonbeep.wav, %BtnPrefix%10, %BtnPrefix%Lit10, 3, 2, 11, 1, 1
	AddButton %PanelNumber%, KW_Sounds/konebuttonbeep.wav, %BtnPrefix%9, %BtnPrefix%Lit9, 3, 1, 10, 1, 1
	AddButton %PanelNumber%, KW_Sounds/konebuttonbeep.wav, %BtnPrefix%8A, %BtnPrefix%Lit8A, 4, 2, 9, 1, 1
	AddButton %PanelNumber%, KW_Sounds/konebuttonbeep.wav, %BtnPrefix%8, %BtnPrefix%Lit8, 4, 1, 8, 1, 1
	AddButton %PanelNumber%, KW_Sounds/konebuttonbeep.wav, %BtnPrefix%7A, %BtnPrefix%Lit7A, 5, 2, 7, 1, 1
	AddButton %PanelNumber%, KW_Sounds/konebuttonbeep.wav, %BtnPrefix%7, %BtnPrefix%Lit7, 5, 1, 6, 1, 1
	AddButton %PanelNumber%, KW_Sounds/konebuttonbeep.wav, %BtnPrefix%6, %BtnPrefix%Lit6, 6, 2, 5, 1, 1
	AddButton %PanelNumber%, KW_Sounds/konebuttonbeep.wav, %BtnPrefix%5, %BtnPrefix%Lit5, 6, 1, 4, 1, 1
	AddButton %PanelNumber%, KW_Sounds/konebuttonbeep.wav, %BtnPrefix%4, %BtnPrefix%Lit4, 7, 2, 3, 1, 1
	AddButton %PanelNumber%, KW_Sounds/konebuttonbeep.wav, %BtnPrefix%3, %BtnPrefix%Lit3, 7, 1, 2, 1, 1
	AddButton %PanelNumber%, KW_Sounds/konebuttonbeep.wav, %BtnPrefix%2, %BtnPrefix%Lit2, 8, 2, 1, 1, 1
	AddButton %PanelNumber%, KW_Sounds/konebuttonbeep.wav, %BtnPrefix%1, %BtnPrefix%Lit1, 8, 1, 0, 1, 1
	AddButton %PanelNumber%, KW_Sounds/konebuttonbeep.wav, %BtnPrefix%B1, %BtnPrefix%LitB1, 9, 2, -1, 1, 1
	AddButton %PanelNumber%, KW_Sounds/konebuttonbeep.wav, %BtnPrefix%B2, %BtnPrefix%LitB2, 9, 1, -2, 1, 1

	if[%PanelNumber% = 1] AddButton %PanelNumber2%, , %BtnPrefix%Alarm, %BtnPrefix%Alarm, 1, 1, alarm, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%Open, %BtnPrefix%Open, 11, 1, open, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%Close, %BtnPrefix%Close, 11, 2, close, 1, 1
<EndFunction>

<Elevators 8 to 10>
	Set Prefix = Parking

	#Set textures and dimensions
	M10_ElevCabTex(ElevExt, %Prefix%ElevFloor, %Prefix%ElevCeiling, %Prefix%ElevWall, %Prefix%ElevWall)
	M10_ElevDimensions(6.5, 7, 8, 0.2, 0.2, true, true, false, true)
	M10_ElevPanels(%Prefix%ElevPanelMain, %Prefix%ElevPanelTop, 1.5, 1.5, 1, 0.2, false, false, true, false)

	#Finish elevator assembly
	M10_ElevInterior()
	#--------------------
	#Car Doors
	Set ElevDoorTex = %Prefix%ElevDoors
	Set IDP = 3.25

	WallOrientation = left
	AddDoorComponent 1, Left, %ElevDoorTex%, %ElevDoorTex%, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	AddDoorComponent 1, Right, %ElevDoorTex%2, %ElevDoorTex%2, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	FinishDoors 1, false, false

		#Door track
		FloorOrientation = top
		DrawWalls = true, true, true, true, true, true
		TextureOverride ElevExt, ElevDoorTrackX, ElevExt, ElevExt, ElevExt, ElevExt
		AddFloor DoorTrack, ElevDoorTrackX, 0.05, %IDP%, -2 - (2 * 1), %IDP% + 0.2, 2 + (2 * 1), 0, 0, 0, 0
	#--------------------
	#Right Panel
	Set P1_PositionX = 3.05 - 0.001
	Set P1_PositionZ = -2.65

		#Panels
		CreateWallBox2 elevator, RightPB, ElevPanel, %P1_PositionX% + 0.001 - 0.025, %P1_PositionZ%, 0.05, 0.8, 4.75, 2.25, 0, 0, false, true, true, true
		CreatePanel , 11, 2, left, %P1_PositionX% - 0.05, %P1_PositionZ%, 0.15, 0.15, 0.5, 0.25, 3.75, 0, 0
		CreatePanel , 11, 1, left, %P1_PositionX% - 0.05, %P1_PositionZ%, 0.15, 0.15, 0.5, 0.25, 3.75, 0, 0

