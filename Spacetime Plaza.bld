		CreatePanel , 11, 2, left, %P2_PositionX% - 0.05, %P2_PositionZ%, 0.15, 0.15, 0.5, 0.25, 3.75, 0, 0
		CreatePanel , 11, 1, left, %P2_PositionX% - 0.05, %P2_PositionZ%, 0.15, 0.15, 0.5, 0.25, 3.75, 0, 0

