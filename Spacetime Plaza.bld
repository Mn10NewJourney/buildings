########################################

#Eastern Annex
<Floors 2 to 9>
	TexPrefix() #Set texture prefix/suffix

	#Floors
	FloorOrientation = top
	DrawWalls = true, true, false, true, true, true
	TextureOverride EAExtFacade, EAFloor, EAExtFacade, EAExtFacade, EAExtFacade, EAExtFacade
	if[%floor% = 2] AddFloor EABase, EAFloor, 2, %1%, -%2% + 260, %1% + 24, %2% - 220, %interfloorheight%, %interfloorheight%, 0, 0, true

	#Ceilings
	FloorOrientation = bottom
	DrawWalls = true, true, false, true, true, true
	TextureOverride EACeiling, EAExtFacade, EAExtFacade, EAExtFacade, EAExtFacade, EAExtFacade
	if[%floor% = 9] AddFloor EATop, EACeiling, 2, %1%, -%2% + 260, %1% + 24, %2% - 220, %fullheight%, %fullheight%, 0, 0, true

	#Windows
	Set MyIFloorType = 2
	if[%floor% = 2] Set MyIFloorType = 3
	Set WinHeight = %height%
	if[%floor% > 5] Set WinHeight = %height% + Floor(%floor% + 1).FullHeight

	SetAutoSize = true, false

		if[%floor% = 8] AddCustomWindows(EA_FrontWin, EAWindowsB, EAWindowsIntB, %1%, -%2% + 260, %1% + 24, -%2% + 260, %WinHeight%, 3/4, 0, 3, %5%Wall, ExtFacade)
		if[%floor% ! 7 & %floor% ! 9] AddCustomWindows(EA_RightWin, EAWindowsInt, EAWindows, %1% + 24, -%2% + 260, %1% + 24, %2% - 220, %WinHeight%, 0, 0, %MyIFloorType%, %5%Wall, ExtFacade)
		if[%floor% ! 7 & %floor% ! 9] AddCustomWindows(EA_BackWin, EAWindowsIntB, EAWindowsB, %1%, %2% - 220, %1% + 24, %2% - 220, %WinHeight%, 3/4, 0, %MyIFloorType%, %5%Wall, ExtFacade)

	SetAutoSize = true, true

	#Perimeter walls
	WallOrientation = left
	DrawWalls = true, true, false, false, true, true #Override
	TextureOverride EAExtFacade, EAWall, EAExtFacade, EAExtFacade, EAWall, EAWall
	if[%floor% = 8] AddWall EA_FrontWall, EAWall, 0.5, %1%, -%2% + 260, %1% + 24, -%2% + 260, 8, 8, %interfloorheight% - 8, %interfloorheight% - 8, 0, 0, true
<EndFloors>

