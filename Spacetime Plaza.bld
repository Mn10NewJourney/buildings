	WallOrientation = left
	AddWall EA2BackRail, %5%%Suffix%, 0.5, 180, 80 + 30, 240, 80 + 30, %RailingHeight%, %RailingHeight%, %RailingOffset%, %RailingOffset%, 0, 0, true
<EndFloors>

<Function EA1Railings>
	TexPrefix() #Wall textures
	Set RailingHeight = %interfloorheight% + 3.5
