#Upper Mid Zone Elevators
<Function E13-17HallStation>
	#Shaft Doors
	ElevHallTex() #Set shaft door and panel textures
	Set StartNo = 13 #Number of the first elevator

	Set ElevDoorTex = %Prefix%ElevDoors
	Set IDP = 3 + 0.3

	WallOrientation = left
	AddShaftDoorComponent %StartNo%, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo%, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo%, 1, %AutoFiller%, false

	WallOrientation = left
	AddShaftDoorComponent %StartNo% + 1, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo% + 1, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo% + 1, 1, %AutoFiller%, false

	WallOrientation = left
	AddShaftDoorComponent %StartNo% + 2, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo% + 2, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo% + 2, 1, %AutoFiller%, false

	WallOrientation = left
	AddShaftDoorComponent %StartNo% + 3, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo% + 3, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo% + 3, 1, %AutoFiller%, false

	WallOrientation = left
	AddShaftDoorComponent %StartNo% + 4, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo% + 4, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo% + 4, 1, %AutoFiller%, false

	#Door tracks
	AddShaftTrack(13, 5, 4.14, 4.34, -20 - 4, -20 + 4, ElevDoorTrackX, ElevExt, 0.05, 1, 7)
	AddShaftTrack(14, 5, 4.14, 4.34, -10 - 4, -10 + 4, ElevDoorTrackX, ElevExt, 0.05, 1, 7)
	AddShaftTrack(15, 5, 4.14, 4.34, 0 - 4, 0 + 4, ElevDoorTrackX, ElevExt, 0.05, 1, 7)
	AddShaftTrack(16, 5, 4.14, 4.34, 10 - 4, 10 + 4, ElevDoorTrackX, ElevExt, 0.05, 1, 7)
	AddShaftTrack(17, 5, 4.14, 4.34, 20 - 4, 20 + 4, ElevDoorTrackX, ElevExt, 0.05, 1, 7)

	#****************************************#

	#Door trims/fillers
	Set Shaft1CX = 60 #1st shaft for elevator bank
	Set Shaft1CZ = 0

		AddDecoObject(Elev13_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, right, true, false, 0.05, 0.2, %Shaft1CX% + 5, %Shaft1CZ% - 20, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		AddDecoObject(Elev14_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, right, true, false, 0.05, 0.2, %Shaft1CX% + 5, %Shaft1CZ% - 10, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		AddDecoObject(Elev15_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, right, true, false, 0.05, 0.2, %Shaft1CX% + 5, %Shaft1CZ%, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		AddDecoObject(Elev16_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, right, true, false, 0.05, 0.2, %Shaft1CX% + 5, %Shaft1CZ% + 10, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		AddDecoObject(Elev17_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, right, true, false, 0.05, 0.2, %Shaft1CX% + 5, %Shaft1CZ% + 20, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)

	#****************************************#

	#Call buttons
	CallButtonElevators = 13, 14, 15, 16, 17
	CreateCallButtons %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft1CX% + 5.001, %Shaft1CZ% - 15, 3.5, right, 0.5, 1, true, 0, 0
	CreateCallButtons %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft1CX% + 5.001, %Shaft1CZ% - 5, 3.5, right, 0.5, 1, true, 0, 0
	CreateCallButtons %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft1CX% + 5.001, %Shaft1CZ% + 5, 3.5, right, 0.5, 1, true, 0, 0
	CreateCallButtons %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft1CX% + 5.001, %Shaft1CZ% + 15, 3.5, right, 0.5, 1, true, 0, 0

		#Signs
		WallOrientation = left
		DrawWalls = false, true, false, false, false, false
		AddBoxSign(E13-17_FS1, Blank, BlankSign%floorid%, Blank, 0, false, false, false, %Shaft1CX% + 5.001, %Shaft1CZ% - 15, 1.5, 1.5, 6.5 - 0.75 + %interfloorheight%, true)
		AddBoxSign(E13-17_FS2, Blank, BlankSign%floorid%, Blank, 0, false, false, false, %Shaft1CX% + 5.001, %Shaft1CZ% + 15, 1.5, 1.5, 6.5 - 0.75 + %interfloorheight%, true)

		AddWall E13-17_HS1, ElevHallSign, 0, %Shaft1CX% + 5.001, %Shaft1CZ% - 15 - 0.25, %Shaft1CX% + 5.001, %Shaft1CZ% - 15 + 0.25, 0.75, 0.75, 2.6, 2.6, 0, 0, false
		AddWall E13-17_HS2, ElevHallSign, 0, %Shaft1CX% + 5.001, %Shaft1CZ% + 15 - 0.25, %Shaft1CX% + 5.001, %Shaft1CZ% + 15 + 0.25, 0.75, 0.75, 2.6, 2.6, 0, 0, false

	#****************************************#

	#Indicator sets
	Set Offset = 7.5

		#Set textures
		ACMEInd_LanternTex(%LanternPrefix%Up, %LanternPrefix%UpLit, %LanternPrefix%Down, %LanternPrefix%DownLit, %LPanelTexture%, DWInd_Button)

		#Indicator creation
		if[%floor% = 0] ACMELobbyInds(right, 13, %Shaft1CX% + 5 + %ExtraLateralOffset%, %Shaft1CZ% - 20, %Offset%, 0, 30)
		if[%floor% = 0] ACMELobbyInds(right, 14, %Shaft1CX% + 5 + %ExtraLateralOffset%, %Shaft1CZ% - 10, %Offset%, 0, 30)
		if[%floor% = 0] ACMELobbyInds(right, 15, %Shaft1CX% + 5 + %ExtraLateralOffset%, %Shaft1CZ%, %Offset%, 0, 30)
		if[%floor% = 0] ACMELobbyInds(right, 16, %Shaft1CX% + 5 + %ExtraLateralOffset%, %Shaft1CZ% + 10, %Offset%, 0, 30)
		if[%floor% = 0] ACMELobbyInds(right, 17, %Shaft1CX% + 5 + %ExtraLateralOffset%, %Shaft1CZ% + 20, %Offset%, 0, 30)

		if[%floor% ! 0] ACMELobbyLanterns(right, 13, %Shaft1CX% + 5 + %ExtraLateralOffset%, %Shaft1CZ% - 20, %Offset%, 0, 30)
		if[%floor% ! 0] ACMELobbyLanterns(right, 14, %Shaft1CX% + 5 + %ExtraLateralOffset%, %Shaft1CZ% - 10, %Offset%, 0, 30)
		if[%floor% ! 0] ACMELobbyLanterns(right, 15, %Shaft1CX% + 5 + %ExtraLateralOffset%, %Shaft1CZ%, %Offset%, 0, 30)
		if[%floor% ! 0] ACMELobbyLanterns(right, 16, %Shaft1CX% + 5 + %ExtraLateralOffset%, %Shaft1CZ% + 10, %Offset%, 0, 30)
		if[%floor% ! 0] ACMELobbyLanterns(right, 17, %Shaft1CX% + 5 + %ExtraLateralOffset%, %Shaft1CZ% + 20, %Offset%, 0, 30)
<EndFunction>

