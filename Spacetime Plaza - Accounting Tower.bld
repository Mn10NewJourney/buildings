	#East Service Elevator
	CreateShaftWall(ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, 0.33, 50, 19, 5, 6, SH8_RF, %height%, %interfloorheight%, true, true, true, true, true, false, true)
<EndFloor>

#Parking elevators
<Floors -3 to 1>
	TexPrefix()
	
	Set ShowLeft = true
	if[%floor% > -1] Set ShowLeft = false

	CreateShaftWall(%5%%5L%, %5%Wall, %5%%5L%, %5%%5L%, %5%Wall, %5%Wall, 0.33, -95, -40, 5, 10, SH9, %SHeight%, %SOffset%, true, %ShowLeft%, true, true, false, false, true)
<EndFloors>

#Stairwells
<Floors -3 to 41>
