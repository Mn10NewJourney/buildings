	M10_ElevCabTex(ElevExt, %Prefix%ElevFloor, %Prefix%ElevCeiling, %Prefix%ElevWall, %Prefix%ElevWall)
	M10_ElevDimensions(7.5, 6.5, 8, 0.2, 0.2, true, true, true, false)
	M10_ElevPanels(%Prefix%ElevPanelMain, %Prefix%ElevPanelTop, 1.75, 1.75, 1, 0.2, false, false, false, true)

	#Finish elevator assembly
	M10_ElevInterior()
	#--------------------
	#Car Doors
	Set ElevDoorTex = %Prefix%ElevDoors
	Set InitialDoorPos = 3.25

	WallOrientation = left
	AddDoorComponent 1, Left, %ElevDoorTex%, %ElevDoorTex%, 0.2, left, 0.8, 0.6, -2, %InitialDoorPos%, -2 + (2 * 1), %InitialDoorPos%, 7, 0, 0, 0, 0, 0
	AddDoorComponent 1, Right, %ElevDoorTex%2, %ElevDoorTex%2, 0.2, right, 0.8, 0.6, -2 + (2 * 1), %InitialDoorPos%, -2 + (2 * 2), %InitialDoorPos%, 7, 0, 0, 0, 0, 0
	FinishDoors 1, false, false

		#Door track
		FloorOrientation = top
		DrawWalls = true, true, true, true, true, true
		TextureOverride ElevExt, ElevDoorTrackZ, ElevExt, ElevExt, ElevExt, ElevExt
		AddFloor DoorTrack, ElevDoorTrackZ, 0.05, -2 - (2 * 1), %InitialDoorPos%, 2 + (2 * 1), %InitialDoorPos% + 0.2, 0, 0, 0, 0
	#--------------------
	#Button Panels
	Set Position = 2.775 #Right panel
	Set Position2 = -2.775 #Left panel

		#Panel back
		CreateWallBox2 elevator, MainPB, ElevPanel, %Position%, 3.05 - 0.025, 0.75, 0.05, 4.75, 2.25, 0, 0, false, true, true, true
		CreateWallBox2 elevator, SecondaryPB, ElevPanel, %Position2%, 3.05 - 0.025, 0.75, 0.05, 4.75, 2.25, 0, 0, false, true, true, true

