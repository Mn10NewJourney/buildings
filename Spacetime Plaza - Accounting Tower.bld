	AddButton %PanelNumber%, , %BtnPrefix%31, %BtnPrefix%Lit31, 3, 3, 30, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%30, %BtnPrefix%Lit30, 3, 1, 29, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%29, %BtnPrefix%Lit29, 4, 3, 28, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%28, %BtnPrefix%Lit28, 4, 1, 27, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%27, %BtnPrefix%Lit27, 5, 3, 26, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%26, %BtnPrefix%Lit26, 5, 1, 25, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%25, %BtnPrefix%Lit25, 6, 3, 24, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%24, %BtnPrefix%Lit24, 6, 1, 23, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%23, %BtnPrefix%Lit23, 7, 3, 22, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%1, %BtnPrefix%Lit1, 7, 1, 0, 1, 1

	AddButton %PanelNumber%, , %BtnPrefix%Open, %BtnPrefix%Open, 9, 1, open, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%Close, %BtnPrefix%Close, 9, 3, close, 1, 1
	if[%PanelNumber% = 1] AddButton %PanelNumber%, , %BtnPrefix%Alarm, %BtnPrefix%Alarm, 1, 2, alarm, 1, 1
<EndFunction>

<Elevators 13 to 17>
	Set Prefix = UpperOffice

	#Set textures and dimensions
	M10_ElevCabTex(ElevExt, %Prefix%ElevFloor, %Prefix%ElevCeiling, %Prefix%ElevWall, %Prefix%ElevWall)
	M10_ElevDimensions(6, 7, 8, 0.2, 0.2, true, true, false, true)
	M10_ElevPanels(%Prefix%ElevPanelMain, %Prefix%ElevPanelTop, 1.5, 1.5, 1, 0.2, false, false, true, false)

	#Finish elevator assembly
	M10_ElevInterior()
	#--------------------
	#Car Doors
	Set ElevDoorTex = %Prefix%ElevDoors
	Set IDP = 3

	WallOrientation = left
	AddDoorComponent 1, Left, %ElevDoorTex%, %ElevDoorTex%, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	AddDoorComponent 1, Right, %ElevDoorTex%2, %ElevDoorTex%2, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	FinishDoors 1, false, false

		#Door track
		FloorOrientation = top
		DrawWalls = true, true, true, true, true, true
		TextureOverride ElevExt, ElevDoorTrackX, ElevExt, ElevExt, ElevExt, ElevExt
		AddFloor DoorTrack, ElevDoorTrackX, 0.05, %IDP%, -2 - (2 * 1), %IDP% + 0.2, 2 + (2 * 1), 0, 0, 0, 0
	#--------------------
	#Button Panels
	Set Position = -2.65 #Right panel
	Set Position2 = 2.65 #Left panel

		#Panel back
		CreateWallBox2 elevator, MainPB, ElevPanel, 2.8 - 0.025, %Position%, 0.05, 0.75, 4.75, 2.25, 0, 0, false, true, true, true
		CreateWallBox2 elevator, SecondaryPB, ElevPanel, 2.8 - 0.025, %Position2%, 0.05, 0.75, 4.75, 2.25, 0, 0, false, true, true, true

		#Panels
		CreatePanel , 9, 3, left, 2.8 - 0.051, %Position%, 0.15, 0.15, 0.25, 0.25, 3.75, 0, 0
		CreatePanel , 9, 3, left, 2.8 - 0.051, %Position2%, 0.15, 0.15, 0.25, 0.25, 3.75, 0, 0

			#Buttons
			BtnPanelE13-17(1)
			BtnPanelE13-17(2)

	#Elevator number sign
	DrawWalls = true, false, false, false, false, false
	AddWall ElevNo%elevator%_Inside, IN_ElevNo%elevator%, 0, 2.8 - 0.051, %Position% - 0.25, 2.8 - 0.051, %Position% + 0.25, 0.5, 0.5, 6.25, 6.25, 0, 0

	#Indicator sets
	AddFloorIndicator DWInd_Button, left, 2.8 - 0.051, %Position%, 0.5, 0.286, 5.75 + 0.25 - 0.143
	AddFloorIndicator DWInd_Button, left, 2.8 - 0.051, %Position2%, 0.5, 0.286, 5.75 + 0.25 - 0.143
<EndElevators>

