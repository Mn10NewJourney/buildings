			BtnPanelE7-12(2)

	#Elevator number sign
	DrawWalls = true, false, false, false, false, false
	AddWall ElevNo%elevator%_Inside, IN_ElevNo%elevator%, 0, %Position% - 0.25, 3.05 - 0.051, %Position% + 0.25, 3.05 - 0.051, 0.5, 0.5, 6.25, 6.25, 0, 0

	#Indicator sets
	AddFloorIndicator DWInd_Button, front, %Position%, 3.05 - 0.051, 0.5, 0.286, 5.75 + 0.25 - 0.143
	AddFloorIndicator DWInd_Button, front, %Position2%, 3.05 - 0.051, 0.5, 0.286, 5.75 + 0.25 - 0.143
<EndElevators>

<Elevators 7 to 12>
	#DETAILED INTERIORS
	#Wall panels
	Set Prefix = Office
	Set PanelTex = %Prefix%ElevWallPanel2

	Set PanelDir = 2
	if[%elevator% > 9] Set PanelDir = 1

	ACTT_EWP(%PanelTex%, %PanelDir%) #Panel creation
	#--------------------
	#Shaft components
	DrawWalls = true, true, true, true, true, true
		#Ropes
		RopePosition = 0, 8.5 + 0.2, 0
		RopeTexture = Ropes
	
		#Counterweight
		Set Position = 3.25 + 0.75
		if[%elevator% > 9] Set Position = -3.25 - 0.75

		CreateCounterweight CWeight_Frame, CWeight, 0, %Position%, 2, 6, 0.5, 0.5
	
		#Rails
		AddRails ElevRail, ElevRailSide, 0, 0, false, 3.75 + 0.06, 0.1
		AddRails ElevRail, ElevRailSide, 0, %Position%, false, 1 + 0.06, 0.1
<EndElevators>

<Elevators 1 to 12>
	#DETAILED INTERIORS FOR ELEVATORS 1-12
	Set Prefix = Office

	#1. Lights
		#1a. Downlights
		Set DLOffset = 8 - 0.001
		FloorOrientation = top
		DrawWalls = true, false, false, false, true, true
		AddFloor Downlight1/1, %Prefix%ElevCeilingDL, 0, 2.45 - 0.11, -1.95 - 0.11, 2.45 + 0.11, -1.95 + 0.11, %DLOffset%, %DLOffset%, 0, 0
		AddFloor Downlight1/2, %Prefix%ElevCeilingDL, 0, 2.45 - 0.11, 0 - 0.11, 2.45 + 0.11, 0 + 0.11, %DLOffset%, %DLOffset%, 0, 0
		AddFloor Downlight1/3, %Prefix%ElevCeilingDL, 0, 2.45 - 0.11, 1.95 - 0.11, 2.45 + 0.11, 1.95 + 0.11, %DLOffset%, %DLOffset%, 0, 0

		AddFloor Downlight2/1, %Prefix%ElevCeilingDL, 0, -2.45 - 0.11, -1.95 - 0.11, -2.45 + 0.11, -1.95 + 0.11, %DLOffset%, %DLOffset%, 0, 0
		AddFloor Downlight2/2, %Prefix%ElevCeilingDL, 0, -2.45 - 0.11, 0 - 0.11, -2.45 + 0.11, 0 + 0.11, %DLOffset%, %DLOffset%, 0, 0
		AddFloor Downlight2/3, %Prefix%ElevCeilingDL, 0, -2.45 - 0.11, 1.95 - 0.11, -2.45 + 0.11, 1.95 + 0.11, %DLOffset%, %DLOffset%, 0, 0
	
		#1b. Center light
		CreateWallBox2 elevator, E%elevator%_MidLight, %Prefix%ElevCeilingLight, 0, 0, 2.5, 6.1, 0.1, 8 - 0.1, 0, 0, false, true, true, true
	
		#1c. Ceiling trims
		CreateWallBox2 elevator, E%elevator%_Trim1, %Prefix%ElevCeilingTrim, 1.5 - 0.125, 0, 0.25, 6.1, 0.1, 8 - 0.1, 0, 0, false, true, true, true
		CreateWallBox2 elevator, E%elevator%_Trim2, %Prefix%ElevCeilingTrim, -1.5 + 0.125, 0, 0.25, 6.1, 0.1, 8 - 0.1, 0, 0, false, true, true, true
<EndElevators>

