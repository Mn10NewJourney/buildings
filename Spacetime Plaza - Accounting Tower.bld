	#West Service Elevator
	CreateShaftWall(%5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, -50, -19, 5, 6, SH7, %SHeight%, %SOffset%, true, true, true, true, false, false, true)

	#East Service Elevator
