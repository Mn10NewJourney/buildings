	if[%floor% < 24] CreateShaftWall(%5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, 20, -10, 15, 5, SH4, %SHeight%, %SOffset%, true, true, true, true, false, false, true)

	#Upper Mid Zone Elevators
