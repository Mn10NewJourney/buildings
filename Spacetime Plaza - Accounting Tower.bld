		#Exit signs
		Load data/panel-back3.jpg, StainlessSteel, 1, 1, false
		Load data/Melvin/ExitSignDown.png, ExitSign, 1, 1, false
		Load data/Melvin/ExitSignUp.png, ExitSignUp, 1, 1, false
		Load data/Melvin/ExitSignLeft.png, ExitSignLeft, 1, 1, false
		Load data/Melvin/ExitSignRight.png, ExitSignRight, 1, 1, false
		Load data/Melvin/ExitSignBoth.png, ExitSignBoth, 1, 1, false
<EndTextures>

############################################################

#Floor Assignments
<Floors -1 to -3>
	ID = B(0 - %floor%)
	Name = Basement Level (0 - %floor%)
	Type = Basement
	Height = 10
	InterfloorHeight = 2
	if[%floor% = -1] Altitude = -10
<EndFloors>

<Floor -4>
	ID = -
	Name = Shaft Pit
	Type = Basement
	Height = 8
	InterfloorHeight = 2
<EndFloor>

<Floors 0 to 1>
	ID = %floor% + 1
	Name = Level %floorid%
	Type = Lobby
	Height = 22
	InterfloorHeight = 2
	if[%floor% = 0] Altitude = 2
<EndFloors>

<Floors 2 to 39>
	ID = %floor% + 1
	Name = Office Level %floorid%
	Type = Office
	Height = 10
	InterfloorHeight = 2
<EndFloors>

<Floors 40 to 41>
	if[%floor% = 40] ID = %floor% + 1
	if[%floor% = 41] ID = 41A
	Name = Mechanical Level %floorid%
	Type = Mechanical
	Height = 10
	InterfloorHeight = 2
	if[%floor% = 40] Group = 41
	if[%floor% = 41] Group = 40
<EndFloors>

<Floor 42>
	ID = %floor%
	Name = Roof
	Type = Roof
	Height = 9.5
	InterfloorHeight = 2
<EndFloor>

#Merge floors
<Floors -3 to 1>
	Group = -3 - 1
<EndFloors>

##--------------------------------------------------------------------------------##

#LANDSCAPES
#Common values
Set 1 = 100 #Building Dimension X (Full width: 200 ft.)
Set 2 = 100 #Building Dimension Z (Full length: 200 ft.)

#Landscape
DrawWalls = false, true, false, false, false, false

	#Filler floors
	AddFloor landscape, ACTT_FillerFloor, Sidewalk, 0, -%1%, -%2% - 140, %1%, -%2%, 4, 4, 0, 0

##--------------------------------------------------------------------------------##

#Set texture prefixes/suffixes
<Function TexPrefix>
	#Main prefixes
	Set 5 = Office
	if[%floor% < 0] Set 5 = Parking
	if[%floor% = 0 | %floor% = 1] Set 5 = Lobby
	if[%floor% > 39] Set 5 = Service

		#Parking lobby suffixes
		Set 5L = Wall
		if[%floor% < 0] Set 5L = LobbyWall

	###************###

	#Set heights for External Shaft/Stairwell walls
	Set SHeight = %fullheight%
	Set SOffset = 0
	if[%floor% = 0] Set SHeight = %height%
	if[%floor% = 0] Set SOffset = %interfloorheight%
	if[%floor% < 0] Set SHeight = %height% + Floor(%floor% + 1).InterfloorHeight - 0.5
	if[%floor% < 0] Set SOffset = %interfloorheight%

	###************###

	#Service elevators' shaft doors
	Set 5S = ServiceA
	if[%floor% > 1 & %floor% < 40] Set 5S = ServiceB
	if[%floor% < 0] Set 5S = ServiceC
	if[%floor% > 39] Set 5S = ServiceD
<EndFunction>

##--------------------------------------------------------------------------------##

#EXTERIOR & INTERIOR
#Underground parking levels
<Floors -3 to -1>
	TexPrefix() #Set texture prefix/suffix

	#Floors
	FloorOrientation = top
	DrawWalls = false, true, false, false, false, false
	AddFloor ACTT_PGFloor, Road, 0.5, -%1%, -%2% - 140, %1%, %2%, %interfloorheight%, %interfloorheight%, 0, 0, true

	#Ceilings
	FloorOrientation = bottom
	DrawWalls = true, false, false, false, false, false
	AddFloor ACTT_PGCeiling, %5%Ceiling, 0.5, -%1%, -%2% - 140, %1%, %2%, %fullheight% + 1, %fullheight% + 1, 0, 0, true

	#Perimeter walls
	TexPrefix() #Set texture prefix/suffix
	if[%floor% ! -1] Set WallHeight = %fullheight%
	if[%floor% = -1] Set WallHeight = %fullheight% + Floor(0).InterfloorHeight
	Set WallHeight2 = %WallHeight%
	if[%floor% = -3] Set WallHeight2 = %fullheight% + Floor(-2).InterfloorHeight
	Set WallOffset = 0

		#Set DrawWalls for Front/Left sides
		DrawWalls = false, true, false, false, false, false

		WallOrientation = left
		AddWall FrontWall, %5%Wall, 0.5, -%1%, -%2% - 140, %1%, -%2% - 140, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		#AddWall LeftWall, %5%Wall, 0.5, -%1%, -%2% - 140, -%1%, %2%, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		#Set DrawWalls for Right/Back sides
		DrawWalls = true, false, false, false, false, false

		WallOrientation = right
		AddWall RightWall, %5%Wall, 0.5, %1%, -%2% - 140, %1%, %2% + 0.5, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		if[%floor% = -3] AddWall BackWall, %5%Wall, 0.5, -%1%, %2%, %1%, %2%, %WallHeight2%, %WallHeight2%, %WallOffset%, %WallOffset%, 0, 0, true
<EndFloors>

#Lobby and office levels
<Floors 0 to 39>
	TexPrefix() #Set texture prefix/suffix

	#Floors
	FloorOrientation = top
	DrawWalls = false, true, false, false, false, false
	AddFloor ACTT_Floor, %5%Floor, 0.5, -%1%, -%2%, %1%, %2%, %interfloorheight%, %interfloorheight%, 0, 0, true
	
		#Office levels core floor
		if[%floor% > 1] CreateFlr(OfficeCoreFloor, OfficeFloor2, 0.5, -75, -35, 75, 35, 0, true)

	#Ceilings
	FloorOrientation = bottom
	DrawWalls = true, false, false, false, false, false
	AddFloor ACTT_Ceiling, %5%Ceiling, 0.5, -%1%, -%2%, %1%, %2%, %fullheight%, %fullheight%, 0, 0, true

	#Perimeter walls
	Set WL = 10 #Walls' length
	Set WallHeight = %fullheight%
	Set WallOffset = 0

	Set ExtTex = ExtFacade

	#Override for the 1st floor only
	if[%floor% ! 0] Set WallHeight2 = %WallHeight%
	if[%floor% ! 0] Set WallOffset2 = %WallOffset%
	if[%floor% = 0] Set WallHeight2 = %height%
	if[%floor% = 0] Set WallOffset2 = %interfloorheight%

		#Front walls
		WallOrientation = left
		DrawWalls = true, true, false, true, false, false
		TextureOverride ExtFacade, %5%Wall, Blank, %5%Wall, Blank, Blank
		AddWall FrontWallA, %5%Wall, 0.5, -%1%, -%2%, -%1% + %WL%, -%2%, %WallHeight2%, %WallHeight2%, %WallOffset2%, %WallOffset2%, 0, 0, true
		DrawWalls = true, true, true, false, false, false
		TextureOverride ExtFacade, %5%Wall, %5%Wall, Blank, Blank, Blank
		AddWall FrontWallB, %5%Wall, 0.5, %1% - %WL%, -%2%, %1%, -%2%, %WallHeight2%, %WallHeight2%, %WallOffset2%, %WallOffset2%, 0, 0, true

		#Left walls
		WallOrientation = left
		DrawWalls = true, true, false, true, false, false
		TextureOverride ExtFacade, %5%Wall, Blank, %5%Wall, Blank, Blank
		AddWall LeftWallA, %5%Wall, 0.5, -%1%, -%2%, -%1%, -%2% + %WL%, %WallHeight2%, %WallHeight2%, %WallOffset2%, %WallOffset2%, 0, 0, true
		DrawWalls = true, true, true, false, false, false
		TextureOverride ExtFacade, %5%Wall, %5%Wall, Blank, Blank, Blank
		AddWall LeftWallB, %5%Wall, 0.5, -%1%, %2% - %WL%, -%1%, %2%, %WallHeight2%, %WallHeight2%, %WallOffset2%, %WallOffset2%, 0, 0, true

		WallOrientation = left
		DrawWalls = true, false, false, false, false, false
		AddWall LeftWall_PKElevShaft, ExtFacade, 0.5, -%1%, -50, -%1%, -30, %WallHeight2%, %WallHeight2%, %WallOffset2%, %WallOffset2%, 0, 0, true

		#Right walls
		WallOrientation = right
		DrawWalls = true, true, false, true, false, false
		TextureOverride %5%Wall, ExtFacade, Blank, %5%Wall, Blank, Blank
		AddWall RightWallA, %5%Wall, 0.5, %1%, -%2%, %1%, -%2% + %WL%, %WallHeight2%, %WallHeight2%, %WallOffset2%, %WallOffset2%, 0, 0, true
		DrawWalls = true, true, true, false, false, false
		TextureOverride %5%Wall, ExtFacade, %5%Wall, Blank, Blank, Blank
		AddWall RightWallB, %5%Wall, 0.5, %1%, %2% - %WL%, %1%, %2%, %WallHeight2%, %WallHeight2%, %WallOffset2%, %WallOffset2%, 0, 0, true

		#Back walls
		WallOrientation = right
		DrawWalls = true, true, false, true, false, false
		TextureOverride %5%Wall, ExtFacade, Blank, %5%Wall, Blank, Blank
		AddWall BackWallA, %5%Wall, 0.5, -%1%, %2%, -%1% + %WL%, %2%, %WallHeight2%, %WallHeight2%, %WallOffset2%, %WallOffset2%, 0, 0, true
		DrawWalls = true, true, true, false, false, false
		TextureOverride %5%Wall, ExtFacade, %5%Wall, Blank, Blank, Blank
		AddWall BackWallB, %5%Wall, 0.5, %1% - %WL%, %2%, %1%, %2%, %WallHeight2%, %WallHeight2%, %WallOffset2%, %WallOffset2%, 0, 0, true

	#Perimeter windows
	Set MyIFloorType = 2
	if[%floor% = 0] Set MyIFloorType = 3

	Set WinPrefix = Main #Windows' prefixes
	if[%floor% < 2] Set WinPrefix = Lobby

	Set WinHeight = %height%

	SetAutoSize = true, false

		AddCustomWindows(FrontWin, %WinPrefix%Windows, %WinPrefix%WindowsInt, -%1% + %WL%, -%2%, %1% - %WL%, -%2%, %WinHeight%, 0, 0, %MyIFloorType%, ExtFacade, %5%Wall)
		if[%floor% > 1] AddCustomWindows(LeftWin, %WinPrefix%Windows, %WinPrefix%WindowsInt, -%1%, -%2% + %WL%, -%1%, %2% - %WL%, %WinHeight%, 0, 0, %MyIFloorType%, ExtFacade, %5%Wall)
		if[%floor% < 2] AddCustomWindows(LeftWin1, %WinPrefix%Windows, %WinPrefix%WindowsInt, -%1%, -%2% + %WL%, -%1%, -50, %WinHeight%, 0, 0, %MyIFloorType%, ExtFacade, %5%Wall)
		if[%floor% < 2] AddCustomWindows(LeftWin2, %WinPrefix%Windows, %WinPrefix%WindowsInt, -%1%, -30, -%1%, %2% - %WL%, %WinHeight%, 0, 0, %MyIFloorType%, ExtFacade, %5%Wall)

		AddCustomWindows(RightWin, %WinPrefix%WindowsInt, %WinPrefix%Windows, %1%, -%2% + %WL%, %1%, %2% - %WL%, %WinHeight%, 0, 0, %MyIFloorType%, %5%Wall, ExtFacade)
		AddCustomWindows(BacktWin, %WinPrefix%WindowsInt, %WinPrefix%Windows, -%1% + %WL%, %2%, %1% - %WL%, %2%, %WinHeight%, 0, 0, %MyIFloorType%, %5%Wall, ExtFacade)

	SetAutoSize = true, true
<EndFloors>

########################################

#Entrance doors
Set Texture = BLKEntDoor
Set SideTexture = BLKEntDoorSide

<Floor 0>
	#TexPrefix()

	#SOUTH DOORS
	Set Door_MainX = -5
	Set Door_MainZ = -%2%

	WallOrientation = left
	TextureOverride %Texture%Ext, %Texture%Int, %Texture%Side, %Texture%Side, %Texture%Side, %Texture%Side
	AddExternalDoor , , false, %Texture%Int, 0.2, 8, 75, %Door_MainX% - 1.75, %Door_MainZ%, 3.5, 8, %interfloorheight%, 0, 0
	TextureOverride %Texture%Ext, %Texture%Int, %Texture%Side, %Texture%Side, %Texture%Side, %Texture%Side
	AddExternalDoor , , false, %Texture%Int, 0.2, 5, 75, %Door_MainX% + 1.75, %Door_MainZ%, 3.5, 8, %interfloorheight%, 0, 0

	Set Door_MainX = 5
	Set Door_MainZ = -%2%

	WallOrientation = left
	TextureOverride %Texture%Ext, %Texture%Int, %Texture%Side, %Texture%Side, %Texture%Side, %Texture%Side
	AddExternalDoor , , false, %Texture%Int, 0.2, 8, 75, %Door_MainX% - 1.75, %Door_MainZ%, 3.5, 8, %interfloorheight%, 0, 0
	TextureOverride %Texture%Ext, %Texture%Int, %Texture%Side, %Texture%Side, %Texture%Side, %Texture%Side
	AddExternalDoor , , false, %Texture%Int, 0.2, 5, 75, %Door_MainX% + 1.75, %Door_MainZ%, 3.5, 8, %interfloorheight%, 0, 0

	#WEST DOORS
	Set Door_MainX = -%1%
	Set Door_MainZ = -5
	
	WallOrientation = left
	TextureOverride %Texture%Ext, %Texture%Int, %Texture%Side, %Texture%Side, %Texture%Side, %Texture%Side
	AddExternalDoor , , false, %Texture%Int, 0.2, 1, 75, %Door_MainX%, %Door_MainZ% - 1.75, 3.5, 8, %interfloorheight%, 0, 0
	TextureOverride %Texture%Ext, %Texture%Int, %Texture%Side, %Texture%Side, %Texture%Side, %Texture%Side
	AddExternalDoor , , false, %Texture%Int, 0.2, 4, 75, %Door_MainX%, %Door_MainZ% + 1.75, 3.5, 8, %interfloorheight%, 0, 0

	Set Door_MainX = -%1%
	Set Door_MainZ = 5
	
	WallOrientation = left
	TextureOverride %Texture%Ext, %Texture%Int, %Texture%Side, %Texture%Side, %Texture%Side, %Texture%Side
	AddExternalDoor , , false, %Texture%Int, 0.2, 1, 75, %Door_MainX%, %Door_MainZ% - 1.75, 3.5, 8, %interfloorheight%, 0, 0
	TextureOverride %Texture%Ext, %Texture%Int, %Texture%Side, %Texture%Side, %Texture%Side, %Texture%Side
	AddExternalDoor , , false, %Texture%Int, 0.2, 4, 75, %Door_MainX%, %Door_MainZ% + 1.75, 3.5, 8, %interfloorheight%, 0, 0
<EndFloor>

########################################

#Topside mechanical
<Floors 40 to 41>
	TexPrefix() #Set texture prefix/suffix

	#Floors
	FloorOrientation = top
	DrawWalls = false, true, false, false, false, false
	if[%floor% = 40] AddFloor ACTT_MechFlr, %5%Floor, 0.5, -%1%, -%2%, %1%, %2%, %interfloorheight%, %interfloorheight%, 0, 0, true

	#Ceilings
	FloorOrientation = bottom
	DrawWalls = true, false, false, false, false, false
	if[%floor% = 41] AddFloor ACTT_MechCeil, %5%Ceiling, 0.5, -%1%, -%2%, %1%, %2%, %fullheight%, %fullheight%, 0, 0, true

	#Perimeter walls
	TexPrefix() #Set texture prefix/suffix
	Set WallHeight = %fullheight%
	Set WallOffset = 0

		DrawWalls = true, true, false, false, false, false

		WallOrientation = left
		TextureOverride ExtFacade, %5%Wall, Blank, Blank, Blank, Blank
		AddWall FrontWall, %5%Wall, 0.5, -%1%, -%2%, %1%, -%2%, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		TextureOverride ExtFacade, %5%Wall, Blank, Blank, Blank, Blank
		AddWall LeftWall, %5%Wall, 0.5, -%1%, -%2%, -%1%, %2%, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		WallOrientation = right
		TextureOverride %5%Wall, ExtFacade, Blank, Blank, Blank, Blank
		AddWall RightWall, %5%Wall, 0.5, %1%, -%2%, %1%, %2%, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		TextureOverride %5%Wall, ExtFacade, Blank, Blank, Blank, Blank
		AddWall BackWall, %5%Wall, 0.5, -%1%, %2%, %1%, %2%, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
<EndFloors>

<Floor 41>
	#Mechanical Mezzanine
	FloorOrientation = top
	DrawWalls = true, true, false, false, false, false
	TextureOverride MMEUnderside, MMEFloor, Blank, Blank, Blank, Blank
	AddFloor MechFloor, MMEFloor, %interfloorheight%, -75, -25, 45.5, 35, %interfloorheight%, %interfloorheight%, 0, 0, true

	#Railings
	DrawWalls = true, true, true, true, true, false
	Set WallHeight = %interfloorheight% + 3.5
	Set WallOffset = 0

	WallOrientation = left
	AddWall MMERail_West, MMEWall, 0.5, -75, -25, -75, 35, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
	AddWall MMERail_South1, MMEWall, 0.5, -75 + 0.5, -25, -65, -25, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
	AddWall MMERail_South2, MMEWall, 0.5, -45, -25, 45, -25, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

	WallOrientation = right
	AddWall MMERail_East1, MMEWall, 0.5, 45.5, 0, 45.5, 13, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
	AddWall MMERail_East2, MMEWall, 0.5, 45.5, 25, 45.5, 35, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
	AddWall MMERail_North, MMEWall, 0.5, -75 + 0.5, 35, 45.5 - 0.5, 35, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
<EndFloor>

########################################

#Roof
<Floor 42>
	#Roof floor
	FloorOrientation = top
	DrawWalls = false, true, false, false, false, false
	AddFloor ACTT_Roof, RoofFloor, 0.5, -%1%, -%2%, %1%, %2%, %interfloorheight%, %interfloorheight%, 0, 0, true

		#Elevator machine room
		CreateFlr(EMRFloor, ElevMRIntFloor, 0.5, -55, -25, -45, 0, 0, true)

	#Elevator machine room enclosures
		#Ceiling
		FloorOrientation = bottom
		DrawWalls = true, true, true, true, true, true
		TextureOverride ElevMRIntCeiling, ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade
		AddFloor EMRCeiling, ElevMRIntCeiling, 1.5, -55, -25, -45, 25, %fullheight%, %fullheight%, 0, 0, true
	
		#Walls
		WallOrientation = left
		DrawWalls = true, true, false, false, false, false
		TextureOverride ExtFacade, ElevMRIntWall, ExtFacade, ExtFacade, ExtFacade, ExtFacade
		AddWall EMRLeft, ExtFacade, 0.5, -55, -13, -55, 0, %height%, %height%, %interfloorheight%, %interfloorheight%, 0, 0, true

		WallOrientation = right
		TextureOverride ElevMRIntWall, ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade
		AddWall EMRRight, ExtFacade, 0.5, -45, -13, -45, 0, %height%, %height%, %interfloorheight%, %interfloorheight%, 0, 0, true

		#Doors
		Set DTex = ServiceDoor3
		Set DSTex = %DTex%Side
		Set Door_MainX = -45
		Set Door_MainZ = -5

		WallOrientation = right
		AddStdDoor DoorManager, ACTT_Roof_EMR_Door1, , , false, %DTex%, %DSTex%, 0.2, right, right, 75, 75, %Door_MainX%, %Door_MainZ% + 1.5, 3, 7, Floor(%floor%).Base, 0, 0, 0, 0
		AddStdDoor DoorManager, ACTT_Roof_EMR_Door2, , , false, %DTex%, %DSTex%, 0.2, left, right, 75, 75,  %Door_MainX%, %Door_MainZ% - 1.5, 3, 7, Floor(%floor%).Base, 0, 0, 0, 0
		AddFillerWalls ConnectionWall, 0.5, %Door_MainX%, %Door_MainZ%, 6, 7, %interfloorheight%, false, 0, 0, true

		#Exit signs
		AddBoxSign(ACTT_Roof_EMR_Exit, ExitSign, StainlessSteel, StainlessSteel, 0.1, false, true, true, %Door_MainX% - 0.55, %Door_MainZ%, 1.8, 0.9, %interfloorheight% + 7.2, true)

	#Roof railings
	Set WallHeight = %interfloorheight% + 5.5
	Set WallOffset = 0

	WallOrientation = Left
	DrawWalls = true, true, true, true, true, false
	AddWall FrontRail, ExtFacade, 0.5, -%1% + 0.5, -%2%, %1% - 0.5, -%2%, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
	AddWall LeftRail, ExtFacade, 0.5, -%1%, -%2%, -%1%, %2%, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

	WallOrientation = Right
	AddWall RightRail, ExtFacade, 0.5, %1%, -%2%, %1%, %2%, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

	AddWall BackRail, ExtFacade, 0.5, -%1% + 0.5, %2%, %1% - 0.5, %2%, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
<EndFloor>

########################################

#SUPPORTS
#Base Supports
<Floors -3 to 1>
	#Set Values
	TexPrefix() #Set texture prefixes
	Set DistanceX = 40 #Distance between supports X
	Set DistanceZ = 40 #Distance between supports Z

	Set SupportHeight = %fullheight%
	if[%floor% = -1] Set SupportHeight = %fullheight% + Floor(0).InterfloorHeight
	Set SupportOffset = -%interfloorheight%

	if[%floor% = 0] Set SupportHeight = %height%
	if[%floor% = 0] Set SupportOffset = 0
	
	Set SupportTex = %5%Wall

	#Row A
	Set Prefix = A
	Set SupportX = %1% - 1.25
	CreateWallBox2 external, Support%Prefix%1, %SupportTex%, %SupportX%, -%2% + 1.25, 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%2, %SupportTex%, %SupportX%, -%2% + (%DistanceZ% * 1), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%3, %SupportTex%, %SupportX%, -%2% + (%DistanceZ% * 2), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%4, %SupportTex%, %SupportX%, -%2% + (%DistanceZ% * 3), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%5, %SupportTex%, %SupportX%, -%2% + (%DistanceZ% * 4), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%6, %SupportTex%, %SupportX%, -%2% + (%DistanceZ% * 5) - 1.25, 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false

	#Row B
	Set Prefix = B
	Set SupportX = %1% - (%DistanceX% * 1)
	CreateWallBox2 external, Support%Prefix%1, %SupportTex%, %SupportX%, -%2% + 1.25, 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%2, %SupportTex%, %SupportX%, -%2% + (%DistanceZ% * 1), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	if[%floor% < -1] CreateWallBox2 external, Support%Prefix%3, %SupportTex%, %SupportX%, -%2% + (%DistanceZ% * 2), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	if[%floor% < -1] CreateWallBox2 external, Support%Prefix%4, %SupportTex%, %SupportX%, -%2% + (%DistanceZ% * 3), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%5, %SupportTex%, %SupportX%, -%2% + (%DistanceZ% * 4), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%6, %SupportTex%, %SupportX%, -%2% + (%DistanceZ% * 5) - 1.25, 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false

	#Row C
	Set Prefix = C
	Set SupportX = %1% - (%DistanceX% * 2)
	CreateWallBox2 external, Support%Prefix%1, %SupportTex%, %SupportX%, -%2% + 1.25, 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%2, %SupportTex%, %SupportX%, -%2% + (%DistanceZ% * 1), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	#CreateWallBox2 external, Support%Prefix%3, %SupportTex%, %SupportX%, -%2% + (%DistanceZ% * 2), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	#CreateWallBox2 external, Support%Prefix%4, %SupportTex%, %SupportX%, -%2% + (%DistanceZ% * 3), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%5, %SupportTex%, %SupportX%, -%2% + (%DistanceZ% * 4), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%6, %SupportTex%, %SupportX%, -%2% + (%DistanceZ% * 5) - 1.25, 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false

	#Row D
	Set Prefix = D
	Set SupportX = %1% - (%DistanceX% * 3)
	CreateWallBox2 external, Support%Prefix%1, %SupportTex%, %SupportX%, -%2% + 1.25, 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%2, %SupportTex%, %SupportX%, -%2% + (%DistanceZ% * 1), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	#CreateWallBox2 external, Support%Prefix%3, %SupportTex%, %SupportX%, -%2% + (%DistanceZ% * 2), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	#CreateWallBox2 external, Support%Prefix%4, %SupportTex%, %SupportX%, -%2% + (%DistanceZ% * 3), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%5, %SupportTex%, %SupportX%, -%2% + (%DistanceZ% * 4), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%6, %SupportTex%, %SupportX%, -%2% + (%DistanceZ% * 5) - 1.25, 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false

	#Row E
	Set Prefix = E
	Set SupportX = %1% - (%DistanceX% * 4)
	CreateWallBox2 external, Support%Prefix%1, %SupportTex%, %SupportX%, -%2% + 1.25, 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%2, %SupportTex%, %SupportX%, -%2% + (%DistanceZ% * 1), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	if[%floor% < -1] CreateWallBox2 external, Support%Prefix%3, %SupportTex%, %SupportX%, -%2% + (%DistanceZ% * 2), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	if[%floor% < -1] CreateWallBox2 external, Support%Prefix%4, %SupportTex%, %SupportX%, -%2% + (%DistanceZ% * 3), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%5, %SupportTex%, %SupportX%, -%2% + (%DistanceZ% * 4), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%6, %SupportTex%, %SupportX%, -%2% + (%DistanceZ% * 5) - 1.25, 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false

	#Row F
	Set Prefix = F
	Set SupportX = -%1% + 1.25
	CreateWallBox2 external, Support%Prefix%1, %SupportTex%, %SupportX%, -%2% + 1.25, 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%2, %SupportTex%, %SupportX%, -%2% + (%DistanceZ% * 1), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%3, %SupportTex%, %SupportX%, -%2% + (%DistanceZ% * 2), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%4, %SupportTex%, %SupportX%, -%2% + (%DistanceZ% * 3), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%5, %SupportTex%, %SupportX%, -%2% + (%DistanceZ% * 4), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%6, %SupportTex%, %SupportX%, -%2% + (%DistanceZ% * 5) - 1.25, 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
<EndFloors>

##--------------------------------------------------------------------------------##

#EXTERNAL SHAFT AND STAIRWELL WALLS
#Office elevators
<Floors -1 to 41>
	TexPrefix()

	#Low Zone Elevators
	if[%floor% < 14] CreateShaftWall(%5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, -20, 10, 15, 5, SH1, %SHeight%, %SOffset%, true, true, true, true, false, false, true)
	if[%floor% < 14] CreateShaftWall(%5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, -20, -10, 15, 5, SH2, %SHeight%, %SOffset%, true, true, true, true, false, false, true)

