	#High Zone Elevators
	CreateShaftWall(%5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, -60, 0, 5, 25, SH6, %SHeight%, %SOffset%, true, true, true, true, false, false, true)
<EndFloors>

#Service elevators
<Floors -3 to 41>
