#West Service Elevator
<Elevator 23>
	Name = ACTTower West Service Elev.
	Type = Service
	Speed = 15
	Acceleration = 0.6
	Deceleration = 0.6
	ServicedFloors = -3 - 40
	AssignedShaft = 7
	CreateElevator true, 0 - 0.5, 0, 0

	#----------------------------------------#

	Set Prefix = Service

	#Set textures and dimensions
	M10_ElevCabTex(ElevExt2, %Prefix%ElevFloor, %Prefix%ElevCeiling, %Prefix%ElevWall, %Prefix%ElevWall)
	M10_ElevDimensions(6, 9.28, 8, 0.2, 0.2, true, true, true, false)
	M10_ElevPanels(%Prefix%ElevPanelMain, %Prefix%ElevPanelTop, 0.25, 1.25, 1, 0.2, false, false, false, true)

	#Finish elevator assembly
	M10_ElevInterior()
	#--------------------
	#Car Doors
	Set ElevDoorTex = %Prefix%ElevDoors
	Set IDP = 4.64

	WallOrientation = left
	AddDoorComponent 1, 2Speed_Fast, %ElevDoorTex%2, %ElevDoorTex%2, 0.15, right, 0.8, 0.6, -2.75, %IDP% + (0.15 * 1), -2.75 + (2.25 * 1), %IDP% + (0.15 * 1), 7, 0, 0, 0, 0, 0
	AddDoorComponent 1, 2Speed_Slow, %ElevDoorTex%2, %ElevDoorTex%2, 0.15, right, 0.4, 0.3, -2.75 + (2.25 * 1), %IDP%, -2.75 + (2.25 * 2), %IDP%, 7, 0, 0, 0, 0, 0
	FinishDoors 1, false, false

		#Door track
		FloorOrientation = top
		DrawWalls = true, true, true, true, true, true
		TextureOverride ElevExt, ElevDoorTrackZ, ElevExt, ElevExt, ElevExt, ElevExt
		AddFloor DoorTrack, ElevDoorTrackZ, 0.05, -2.75, %IDP%, -2.75 + (2.25 * 3), %IDP% + (0.15 * 2), 0, 0, 0, 0

		#Top filler
		FloorOrientation = bottom
		DrawWalls = true, true, true, true, true, true
		TextureOverride %Prefix%ElevPanelTop, ElevExt, ElevExt, ElevExt, ElevExt, ElevExt
		AddFloor TopFiller, %Prefix%ElevPanelTop, 0.05, -2.75, %IDP%, -2.75 + (2.25 * 1), %IDP% + (0.15 * 1), 7, 7, 0, 0

	#Gap filler
	WallOrientation = left
	DrawWalls = true, true, true, true, true, true
	TextureOverride ElevExt, ElevExt, ElevExt, %Prefix%ElevPanelMain, ElevExt, ElevExt
	AddWall GapFiller, %Prefix%ElevPanelMain, 0.15 * 2, -3, %IDP%, -2.75, %IDP%, 7, 7, 0, 0, 0, 0
	#--------------------
	#Button Panels
	Set Position = 2.275

		#Panel back
		CreateWallBox2 elevator, MainPB, ElevPanel, %Position%, 4.44 - 0.025, 0.85, 0.05, 5 + 0.75, 2 - 0.75, 0, 0, false, true, true, true

		#Panel
		CreatePanel , 15, 4, front, %Position%, 4.44 - 0.051, 0.15, 0.15, 0.2, 0.2, 3.5 - 0.125, 0, 0
		CreatePanel , 15, 3, front, %Position%, 4.44 - 0.051, 0.15, 0.15, 0.2, 0.2, 3.5 - 0.125, 0, 0 #Alarm button only

			#Buttons
			BtnPanelE23-24(1)

	#Elevator number sign
	DrawWalls = true, false, false, false, false, false
	AddWall ElevNo%elevator%_Inside, IN_ElevNo%elevator%, 0, %Position% - 0.25, 4.44 - 0.051, %Position% + 0.25, 4.44 - 0.051, 0.5, 0.5, 6.25, 6.25, 0, 0

	#Indicator sets
	AddFloorIndicator DWInd_Button, front, %Position%, 4.44 - 0.051, 0.5, 0.286, 5.75 + 0.25 - 0.143
	#--------------------
	#Proximity scanner
	Set PSscanHeight = 0.45
	Set PScanWidth = %PSscanHeight% * 0.712
	Set PScanTex = HIDScanRed

	Set ExtraOffset = 0.125

	DrawWalls = true, false, false, false, false, false
	AddWall ProximityScanner, %PScanTex%, 0, %Position% - (%PScanWidth% / 2), 4.44 - 0.051, %Position% + (%PScanWidth% / 2), 4.44 - 0.051, %PSscanHeight%, %PSscanHeight%, 4.75 + %ExtraOffset%, 4.75 + %ExtraOffset%, 0, 0
	#--------------------
	#Shaft components
	DrawWalls = true, true, true, true, true, true
		#Ropes
		RopePosition = 0, 8 + 0.2, 0
		RopeTexture = Ropes
	
		#Counterweight
		Set Position = 3 + 0.8

		CreateCounterweight CWeight_Frame, CWeight, %Position%, 0, 0.5, 6, 2, 0.5
	
		#Rails
		AddRails ElevRail, ElevRailSide, 0, 0, false, 3 + 0.06, 0.1
		AddRails ElevRail, ElevRailSide, %Position%, 0, true, 1 + 0.06, 0.1
<EndElevator>

#East Service Elevator
<Elevator 24>
	Name = ACTTower East Service Elev.
	Type = Service
	Speed = 15
	Acceleration = 0.6
	Deceleration = 0.6
	ServicedFloors = -3 - 40
	AssignedShaft = 8
	CreateElevator true, 0 + 0.5, 0, 0

	#----------------------------------------#

	Set Prefix = Service

	#Set textures and dimensions
	M10_ElevCabTex(ElevExt2, %Prefix%ElevFloor, %Prefix%ElevCeiling, %Prefix%ElevWall, %Prefix%ElevWall)
	M10_ElevDimensions(6, 9.28, 8, 0.2, 0.2, false, true, true, true)
	M10_ElevPanels(%Prefix%ElevPanelMain, %Prefix%ElevPanelTop, 1.25, 0.25, 1, 0.2, true, false, false, false)

	#Finish elevator assembly
	M10_ElevInterior()
	#--------------------
	#Car Doors
	Set ElevDoorTex = %Prefix%ElevDoors
	Set IDP = -4.64

	WallOrientation = right
	AddDoorComponent 1, 2Speed_Fast, %ElevDoorTex%2, %ElevDoorTex%2, 0.15, left, 0.8, 0.6, 2.75 - (2.25 * 1), %IDP% - (0.15 * 1), 2.75, %IDP% - (0.15 * 1), 7, 0, 0, 0, 0, 0
	AddDoorComponent 1, 2Speed_Slow, %ElevDoorTex%2, %ElevDoorTex%2, 0.15, left, 0.4, 0.3, 2.75 - (2.25 * 2), %IDP%, 2.75 - (2.25 * 1), %IDP%, 7, 0, 0, 0, 0, 0
	FinishDoors 1, false, false

		#Door track
		FloorOrientation = top
		DrawWalls = true, true, true, true, true, true
		TextureOverride ElevExt, ElevDoorTrackZ, ElevExt, ElevExt, ElevExt, ElevExt
		AddFloor DoorTrack, ElevDoorTrackZ, 0.05, 2.75 - (2.25 * 3), %IDP% - (0.15 * 2), 2.75, %IDP%, 0, 0, 0, 0

		#Top filler
		FloorOrientation = bottom
		DrawWalls = true, true, true, true, true, true
		TextureOverride %Prefix%ElevPanelTop, ElevExt, ElevExt, ElevExt, ElevExt, ElevExt
		AddFloor TopFiller, %Prefix%ElevPanelTop, 0.05, 2.75 - (2.25 * 1), %IDP% - (0.15 * 1), 2.75, %IDP%, 7, 7, 0, 0

	#Gap filler
	WallOrientation = right
	DrawWalls = true, true, true, true, true, true
	TextureOverride ElevExt, ElevExt, %Prefix%ElevPanelMain, ElevExt, ElevExt, ElevExt
	AddWall GapFiller, %Prefix%ElevPanelMain, 0.15 * 2, 2.75, %IDP%, 3, %IDP%, 7, 7, 0, 0, 0, 0
	#--------------------
	#Button Panels
	Set Position = -2.275

		#Panel back
		CreateWallBox2 elevator, MainPB, ElevPanel, %Position%, -4.44 + 0.025, 0.85, 0.05, 5 + 0.75, 2 - 0.75, 0, 0, false, true, true, true

		#Panel
		CreatePanel , 15, 4, back, %Position%, -4.44 + 0.051, 0.15, 0.15, 0.2, 0.2, 3.5 - 0.125, 0, 0
		CreatePanel , 15, 3, back, %Position%, -4.44 + 0.051, 0.15, 0.15, 0.2, 0.2, 3.5 - 0.125, 0, 0 #Alarm button only

			#Buttons
			BtnPanelE23-24(1)

	#Elevator number sign
	DrawWalls = false, true, false, false, false, false
	AddWall ElevNo%elevator%_Inside, IN_ElevNo%elevator%, 0, %Position% - 0.25, -4.44 + 0.051, %Position% + 0.25, -4.44 + 0.051, 0.5, 0.5, 6.25, 6.25, 0, 0

	#Indicator sets
	AddFloorIndicator DWInd_Button, back, %Position%, -4.44 + 0.051, 0.5, 0.286, 5.75 + 0.25 - 0.143
	#--------------------
	#Proximity scanner
	Set PSscanHeight = 0.45
	Set PScanWidth = %PSscanHeight% * 0.712
	Set PScanTex = HIDScanGreen
	
	Set ExtraOffset = 0.125

	DrawWalls = false, true, false, false, false, false
	AddWall ProximityScanner, %PScanTex%, 0, %Position% - (%PScanWidth% / 2), -4.44 + 0.051, %Position% + (%PScanWidth% / 2), -4.44 + 0.051, %PSscanHeight%, %PSscanHeight%, 4.75 + %ExtraOffset%, 4.75 + %ExtraOffset%, 0, 0
	#--------------------
	#Shaft components
	DrawWalls = true, true, true, true, true, true
		#Ropes
		RopePosition = 0, 8 + 0.2, 0
		RopeTexture = Ropes
	
		#Counterweight
		Set Position = -3 - 0.8
		CreateCounterweight CWeight_Frame, CWeight, %Position%, 0, 0.5, 6, 2, 0.5
	
		#Rails
		AddRails ElevRail, ElevRailSide, 0, 0, false, 3 + 0.06, 0.1
		AddRails ElevRail, ElevRailSide, %Position%, 0, true, 1 + 0.06, 0.1
<EndElevator>

<Elevators 23 to 24>
	Set Prefix = Service
	#MORE DETAILED INTERIORS
	#1. Panels on walls
	Set WPTex = %Prefix%ElevWallPanel
	Set WPanelHeight = 3.25

		#Front panel
		if[%elevator% = 23] CreateWallBox2 elevator, Panel_F, %WPTex%, 0, -4.44 + 0.01, 6 - 0.4 - 0.04, 0.02, %WPanelHeight%, 0, 0, 0, false, true, true, true
		if[%elevator% = 24] CreateWallBox2 elevator, Panel_B, %WPTex%, 0, 4.44 - 0.01, 6 - 0.4 - 0.04, 0.02, %WPanelHeight%, 0, 0, 0, false, true, true, true

		#Left panel
		CreateWallBox2 elevator, Panel_L, %WPTex%, -2.8 + 0.01, 0, 0.02, 9.28 - 0.4, %WPanelHeight%, 0, 0, 0, false, true, true, true

		#Right panel
		CreateWallBox2 elevator, Panel_R, %WPTex%, 2.8 - 0.01, 0, 0.02, 9.28 - 0.4, %WPanelHeight%, 0, 0, 0, false, true, true, true

	#2. Ceiling Lights
	Set LightWidth = 2.4
	Set LightLength = 3.6
	Set TrimWidth = 0.2

	CreateWallBox2 elevator, CL_Main, %Prefix%ElevCeilingLight, 0, 0, %LightWidth%, %LightLength%, 0.08, 8 - 0.08, 0, 0, false, true, true, true
<EndElevators>

#Parking Elevators
#Set motors' position
<Elevators 25 to 26>
	MotorPosition = 0, Floor(2).Altitude - 0.5, 0
<EndElevators>

<Elevator 25>
	Name = ACTTower Parking Elev. 1
	Speed = 5
	Acceleration = 0.6
	Deceleration = 0.6
	ServicedFloors = -2 - 1
	AssignedShaft = 9
	CreateElevator true, 0, -5, 0
<EndElevator>

<Elevator 26>
	Name = ACTTower Parking Elev. 1
	Speed = 5
	Acceleration = 0.6
	Deceleration = 0.6
	ServicedFloors = -2 - 1
	AssignedShaft = 9
	CreateElevator true, 0, 5, 0
<EndElevator>

<Function BtnPanelE25-26>
	Set PanelNumber = %param1%
	Set BtnPrefix = DWButton

	AddButton %PanelNumber%, , %BtnPrefix%2, %BtnPrefix%Lit2, 3, 2, 1, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%1, %BtnPrefix%Lit1, 4, 2, 0, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%B1, %BtnPrefix%LitB1, 5, 2, -1, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%B2, %BtnPrefix%LitB2, 6, 2, -2, 1, 1

	AddButton %PanelNumber%, , %BtnPrefix%Open, %BtnPrefix%Open, 8, 1, open, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%Close, %BtnPrefix%Close, 8, 3, close, 1, 1
	if[%PanelNumber% = 1] AddButton %PanelNumber%, , %BtnPrefix%Alarm, %BtnPrefix%Alarm, 1, 2, alarm, 1, 1
<EndFunction>

<Elevators 25 to 26>
	Set Prefix = Parking
	AutoEnable = false

	#Set textures and dimensions	
	M10_ElevCabTex(ElevExt3, %Prefix%ElevFloor, %Prefix%ElevCeiling, %Prefix%ElevWall, %Prefix%ElevWall)
	M10_ElevDimensions(7.68, 6, 8, 1.5, 0.2, false, false, false, false)
	M10_ElevPanels(%Prefix%ElevPanelMain, %Prefix%ElevPanelTop, 1.25, 1.25, 1, 0.2, false, false, true, false)

	#Finish elevator assembly
	M10_ElevInterior()
	#--------------------
	#Elevator walls
	Set WPTex = %Prefix%ElevWallGlassLink
	Set GlassTex = %Prefix%ElevWallGlass
	Set WPanelHeight = 8

		#Other walls surrounding the glass panels
			#Left walls
			WallOrientation = left
			DrawWalls = true, true, true, true, false, false
			TextureOverride ElevExt3, %WPTex%, ElevExt3, %WPTex%, Blank, Blank
			AddWall LeftGlassWallLink1, %WPTex%, 0.25, -3.84, -3.00, -3.84, -3.00 + 0.25, %WPanelHeight%, %WPanelHeight%, 0, 0, 0, 0
			TextureOverride ElevExt3, %WPTex%, %WPTex%, ElevExt3, Blank, Blank
			AddWall LeftGlassWallLink2, %WPTex%, 0.25, -3.84, 3.00 - 0.25, -3.84, 3.00, %WPanelHeight%, %WPanelHeight%, 0, 0, 0, 0
		
			#Front walls
			WallOrientation = left
			DrawWalls = true, true, true, true, false, false
			TextureOverride ElevExt3, %Prefix%ElevWall, %Prefix%ElevWall, %Prefix%ElevWall, Blank, Blank
			AddWall FrontWall, %Prefix%ElevWall, 0.25, 0 - 0.625, -3.00, 0 + 0.625, -3.00, %WPanelHeight%, %WPanelHeight%, 0, 0, 0, 0

			DrawWalls = true, true, true, false, false, false
			TextureOverride ElevExt3, %WPTex%, ElevExt3, Blank, Blank, Blank
			AddWall FrontGlassWallLink, %WPTex%, 0.25, 3.84 - 0.25, -3.00, 3.84, -3.00, %WPanelHeight%, %WPanelHeight%, 0, 0, 0, 0
	
			#Back walls
			WallOrientation = right
			DrawWalls = true, true, true, true, false, false
			TextureOverride %Prefix%ElevWall, ElevExt3, %Prefix%ElevWall, %Prefix%ElevWall, Blank, Blank
			AddWall BackWall, %Prefix%ElevWall, 0.25, 0 - 0.625, 3.00, 0 + 0.625, 3.00, %WPanelHeight%, %WPanelHeight%, 0, 0, 0, 0

			DrawWalls = true, true, true, false, false, false
			TextureOverride %WPTex%, ElevExt3, ElevExt3, Blank, Blank, Blank
			AddWall BackGlassWallLink, %WPTex%, 0.25, 3.84 - 0.25, 3.00, 3.84, 3.00, %WPanelHeight%, %WPanelHeight%, 0, 0, 0, 0

		#Glass panels
		DrawWalls = true, true, false, false, false, false
		TextureOverride ElevExt3, %WPTex%, ElevExt3, %WPTex%, Blank, Blank
		AddWall LeftGlassWall, %GlassTex%, 0, -3.84, -3.00 + 0.5, -3.84, 3.00 - 0.5, %WPanelHeight%, %WPanelHeight%, 0, 0, 0, 0

		AddWall FrontGlassWall_1, %GlassTex%, 0, -3.84 + 0.25, -3.00, 0 - 0.4, -3.00, %WPanelHeight%, %WPanelHeight%, 0, 0, 0, 0
		AddWall FrontGlassWall_2, %GlassTex%, 0, 0 + 0.4, -3.00, 3.84 - 0.25, -3.00, %WPanelHeight%, %WPanelHeight%, 0, 0, 0, 0

		AddWall BackGlassWall_1, %GlassTex%, 0, -3.84 + 0.25, 3.00, 0 - 0.4, 3.00, %WPanelHeight%, %WPanelHeight%, 0, 0, 0, 0
		AddWall BackGlassWall_2, %GlassTex%, 0, 0 + 0.4, 3.00, 3.84 - 0.25, 3.00, %WPanelHeight%, %WPanelHeight%, 0, 0, 0, 0
	#--------------------
	#DETAILED INTERIORS
	#1. Ceiling lights
	Set LightOffset = 8 - 0.001
	Set LightOffset2 = 8 - 0.002
	Set GridSuffix = Grid

	Set LightWidth = 7
	Set LightLength = 3.5
	
	DrawWalls = true, false, false, false, false, false
	AddFloor CeilingLight, %Prefix%ElevCeilingLight, 0, 0 - (%LightWidth% / 2), -(%LightLength% / 2), 0 + (%LightWidth% / 2), (%LightLength% / 2), %LightOffset%, %LightOffset%, 0, 0
	AddFloor CeilingGrid, %Prefix%ElevCeiling%GridSuffix%, 0, 0 - (%LightWidth% / 2), -(%LightLength% / 2), 0 + (%LightWidth% / 2), (%LightLength% / 2), %LightOffset2%, %LightOffset2%, %LightWidth% / 0.5, %LightLength% / 0.5

	#2. Downlights
	Set DLOffset = 8 - 0.001
	DrawWalls = true, false, false, false, true, true
	AddFloor Downlight1/1, %Prefix%ElevCeilingDL, 0, -2.40 - 0.11, 2.40 - 0.11, -2.40 + 0.11, 2.40 + 0.11, %DLOffset%, %DLOffset%, 0, 0
	AddFloor Downlight1/2, %Prefix%ElevCeilingDL, 0, 0 - 0.11, 2.40 - 0.11, 0 + 0.11, 2.40 + 0.11, %DLOffset%, %DLOffset%, 0, 0
	AddFloor Downlight1/3, %Prefix%ElevCeilingDL, 0, 2.40 - 0.11, 2.40 - 0.11, 2.40 + 0.11, 2.40 + 0.11, %DLOffset%, %DLOffset%, 0, 0
	AddFloor Downlight2/1, %Prefix%ElevCeilingDL, 0, -2.40 - 0.11, -2.40 - 0.11, -2.40 + 0.11, -2.40 + 0.11, %DLOffset%, %DLOffset%, 0, 0
	AddFloor Downlight2/2, %Prefix%ElevCeilingDL, 0, 0 - 0.11, -2.40 - 0.11, 0 + 0.11, -2.40 + 0.11, %DLOffset%, %DLOffset%, 0, 0
	AddFloor Downlight2/3, %Prefix%ElevCeilingDL, 0, 2.40 - 0.11, -2.40 - 0.11, 2.40 + 0.11, -2.40 + 0.11, %DLOffset%, %DLOffset%, 0, 0
	#--------------------
	#Car Doors
	Set ElevDoorTex = %Prefix%ElevDoors
	Set IDP = 3.84

	WallOrientation = left
	AddDoorComponent 1, Left, %ElevDoorTex%, %ElevDoorTex%Side, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 1.75, 7, 0, 0, 0, 0, 0
	AddDoorComponent 1, Right, %ElevDoorTex%2, %ElevDoorTex%2Side, 0.2, left, 0.8, 0.6, %IDP%, -1.75, %IDP%, 0, 7, 0, 0, 0, 0, 0
	FinishDoors 1, false, false

		#Door track
		FloorOrientation = top
		DrawWalls = true, true, true, true, true, true
		TextureOverride ElevExt, ElevDoorTrackX, ElevExt, ElevExt, ElevExt, ElevExt
		AddFloor DoorTrack, ElevDoorTrackX, 0.05, %IDP%, -1.75 - (1.75 * 1), %IDP% + 0.2, 1.75 + (1.75 * 1), 0, 0, 0, 0
	#--------------------
	#Right Panel
	Set P1_PositionX = 0
	Set P1_PositionZ = -3.25 + 0.25

		#Floor buttons
		CreateWallBox2 elevator, MainPB, ElevPanel, %P1_PositionX%, %P1_PositionZ% + 0.025, 0.75, 0.05, 4.75, 2.25, 0, 0, false, true, true, true

		CreatePanel Blank, 8, 3, back, %P1_PositionX%, %P1_PositionZ% + 0.051, 0.15, 0.15, 0.25, 0.25, 3.5, 0, 0
		BtnPanelE25-26(1)
	#--------------------
	#Left Panel
	Set P2_PositionX = 0
	Set P2_PositionZ = 3.25 - 0.25

		#Floor buttons
		CreateWallBox2 elevator, MainPB, ElevPanel, %P2_PositionX%, %P2_PositionZ% + 0.025, 0.75, 0.05, 4.75, 2.25, 0, 0, false, true, true, true

		CreatePanel Blank, 8, 3, front, %P2_PositionX%, %P2_PositionZ% - 0.051, 0.15, 0.15, 0.25, 0.25, 3.5, 0, 0
		BtnPanelE25-26(2)
	#--------------------
	#Indicator sets
	AddFloorIndicator DWInd_Button, back, %P1_PositionX%, %P1_PositionZ% + 0.051, 0.5, 0.286, 5.75 + 0.25 - 0.143
	AddFloorIndicator DWInd_Button, front, %P2_PositionX%, %P2_PositionZ% - 0.051, 0.5, 0.286, 5.75 + 0.25 - 0.143

	#Elevator number sign
	DrawWalls = true, false, false, false, false, false
	AddWall ElevNo%elevator%_Inside, IN_ElevNo%elevator%, 0, %P1_PositionX% - 0.25, %P1_PositionZ% + 0.051, %P1_PositionX% + 0.25, %P1_PositionZ% + 0.051, 0.5, 0.5, 6.25, 6.25, 0, 0
	#--------------------
	#Shaft components
	DrawWalls = true, true, true, true, true, true
		#Ropes
		RopePosition = 0, 9.5, 0
		RopeTexture = Ropes
	
		#Counterweight
		Set Position = -3.00 - 0.75
		if[%elevator% = 26] Set Position = 3.00 + 0.75

		CreateCounterweight CWeight_Frame, CWeight, 0, %Position%, 2, 6, 0.5, 0.5

		#Rails
		AddRails ElevRail, ElevRailSide, 0, 0, true, 3 + 0.06, 0.1
		AddRails ElevRail, ElevRailSide, 0, %Position%, false, 1 + 0.06, 0.1
<EndElevators>

##--------------------------------------------------------------------------------##

#HALL STATIONS

#Set textures (Office elevators)
<Function ElevHallTex>
	TexPrefix() #Set prefixes for shaft doors

	#Shaft doors
	Set DoorTexture = %5%ShaftDoors

	#Use automatic filler walls or not
	Set AutoFiller = false

	#Door trims
		#Sides
		Set DoorTrimTexture = %DoorTexture%_Trim

		#Top
		Set DoorTrimTexture_Top = %DoorTrimTexture%

	#Deco dimensions
		Set SideDecoH = %height%
		Set TopDecoH = %height% - 7
		if[%floor% ! 0 & %floor% ! 1] Set SideDecoH = 7.2
		if[%floor% ! 0 & %floor% ! 1] Set TopDecoH = 0.2

	#Call button panels
	Set BPanelTexture = ElevExtPanels
	Set ButtonPrefix = DWButton

	#Lantern panels
	Set LPanelTexture = %BPanelTexture%
	Set LanternPrefix = DWLantern

		#Lateral offset for lantern panels
		Set ExtraLateralOffset = 0
		if[%floor% = 0 | %floor% = 1] Set ExtraLateralOffset = 0.05
<EndFunction>

#****************************************#

#Low Zone Elevators
<Function E1-6HallStation>
	#Shaft Doors
	ElevHallTex() #Set shaft door and panel textures
	ShaftDoors_E1-12(1, LZ, 1, 2)

	#****************************************#

	#Door trims/fillers
	Set Shaft1CX = -20 #1st shaft for elevator bank
	Set Shaft1CZ = 10
	Set Shaft2CX = -20 #1st shaft for elevator bank
	Set Shaft2CZ = -10

		#Elevators 1-3
		AddDecoObject(Elev1_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, front, true, false, 0.05, 0.2, %Shaft1CX% - 10, %Shaft1CZ% - 5, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		AddDecoObject(Elev2_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, front, true, false, 0.05, 0.2, %Shaft1CX%, %Shaft1CZ% - 5, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		AddDecoObject(Elev3_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, front, true, false, 0.05, 0.2, %Shaft1CX% + 10, %Shaft1CZ% - 5, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)

		#Elevators 4-6
		AddDecoObject(Elev4_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, back, true, false, 0.05, 0.2, %Shaft2CX% - 10, %Shaft2CZ% + 5, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		AddDecoObject(Elev5_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, back, true, false, 0.05, 0.2, %Shaft2CX%, %Shaft2CZ% + 5, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		AddDecoObject(Elev6_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, back, true, false, 0.05, 0.2, %Shaft2CX% + 10, %Shaft2CZ% + 5, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)

	#****************************************#

	#Call buttons
	CallButtonElevators = 1, 2, 3, 4, 5, 6
	CreateCallButtons %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft1CX% - 5, %Shaft1CZ% - 5.001, 3.5, front, 0.5, 1, true, 0, 0
	CreateCallButtons %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft1CX% + 5, %Shaft1CZ% - 5.001, 3.5, front, 0.5, 1, true, 0, 0
	CreateCallButtons %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft2CX% - 5, %Shaft2CZ% + 5.001, 3.5, back, 0.5, 1, true, 0, 0
	CreateCallButtons %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft2CX% + 5, %Shaft2CZ% + 5.001, 3.5, back, 0.5, 1, true, 0, 0

		#Signs
		WallOrientation = right
		DrawWalls = true, false, false, false, false, false
		AddBoxSign(E1-6_FS1, BlankSign%floorid%, Blank, Blank, 0, true, false, false, %Shaft1CX% - 5, %Shaft1CZ% - 5.001, 1.5, 1.5, 6.5 - 0.75 + %interfloorheight%, true)
		AddBoxSign(E1-6_FS2, BlankSign%floorid%, Blank, Blank, 0, true, false, false, %Shaft1CX% + 5, %Shaft1CZ% - 5.001, 1.5, 1.5, 6.5 - 0.75 + %interfloorheight%, true)

		AddWall E1-6_HS1, ElevHallSign, 0, %Shaft1CX% - 5 - 0.25, %Shaft1CZ% - 5.001, %Shaft1CX% - 5 + 0.25, %Shaft1CZ% - 5.001, 0.75, 0.75, 2.6, 2.6, 0, 0, false

		WallOrientation = left
		DrawWalls = false, true, false, false, false, false
		AddBoxSign(E1-6_FS3, Blank, BlankSign%floorid%, Blank, 0, true, false, false, %Shaft2CX% - 5, %Shaft2CZ% + 5.001, 1.5, 1.5, 6.5 - 0.75 + %interfloorheight%, true)
		AddBoxSign(E1-6_FS4, Blank, BlankSign%floorid%, Blank, 0, true, false, false, %Shaft2CX% + 5, %Shaft2CZ% + 5.001, 1.5, 1.5, 6.5 - 0.75 + %interfloorheight%, true)

		AddWall E1-6_HS2, ElevHallSign, 0, %Shaft2CX% - 5 - 0.25, %Shaft2CZ% + 5.001, %Shaft2CX% - 5 + 0.25, %Shaft2CZ% + 5.001, 0.75, 0.75, 2.6, 2.6, 0, 0, false

	#****************************************#

	#Indicator sets
	Set Offset = 7.5

		#Set textures
		ACMEInd_LanternTex(%LanternPrefix%Up, %LanternPrefix%UpLit, %LanternPrefix%Down, %LanternPrefix%DownLit, %LPanelTexture%, DWInd_Button)

		#Indicator creation
		if[%floor% = 0] ACMELobbyInds(front, 1, %Shaft1CX% - 10, %Shaft1CZ% - 5 - %ExtraLateralOffset%, %Offset%, 0, 11)
		if[%floor% = 0] ACMELobbyInds(front, 2, %Shaft1CX%, %Shaft1CZ% - 5 - %ExtraLateralOffset%, %Offset%, 0, 11)
		if[%floor% = 0] ACMELobbyInds(front, 3, %Shaft1CX% + 10, %Shaft1CZ% - 5 - %ExtraLateralOffset%, %Offset%, 0, 11)
		if[%floor% = 0] ACMELobbyInds(back, 4, %Shaft2CX% - 10, %Shaft2CZ% + 5 + %ExtraLateralOffset%, %Offset%, 0, 11)
		if[%floor% = 0] ACMELobbyInds(back, 5, %Shaft2CX%, %Shaft2CZ% + 5 + %ExtraLateralOffset%, %Offset%, 0, 11)
		if[%floor% = 0] ACMELobbyInds(back, 6, %Shaft2CX% + 10, %Shaft2CZ% + 5 + %ExtraLateralOffset%, %Offset%, 0, 11)

		if[%floor% ! 0] ACMELobbyLanterns(front, 1, %Shaft1CX% - 10, %Shaft1CZ% - 5 - %ExtraLateralOffset%, %Offset%, 0, 11)
		if[%floor% ! 0] ACMELobbyLanterns(front, 2, %Shaft1CX%, %Shaft1CZ% - 5 - %ExtraLateralOffset%, %Offset%, 0, 11)
		if[%floor% ! 0] ACMELobbyLanterns(front, 3, %Shaft1CX% + 10, %Shaft1CZ% - 5 - %ExtraLateralOffset%, %Offset%, 0, 11)
		if[%floor% ! 0] ACMELobbyLanterns(back, 4, %Shaft2CX% - 10, %Shaft2CZ% + 5 + %ExtraLateralOffset%, %Offset%, 0, 11)
		if[%floor% ! 0] ACMELobbyLanterns(back, 5, %Shaft2CX%, %Shaft2CZ% + 5 + %ExtraLateralOffset%, %Offset%, 0, 11)
		if[%floor% ! 0] ACMELobbyLanterns(back, 6, %Shaft2CX% + 10, %Shaft2CZ% + 5 + %ExtraLateralOffset%, %Offset%, 0, 11)
<EndFunction>

#****************************************#

#Lower Mid Zone Elevators
<Function E7-12HallStation>
	#Shaft Doors
	ElevHallTex() #Set shaft door and panel textures
	ShaftDoors_E1-12(7, LZ, 3, 4)

	#****************************************#

	#Door trims/fillers
	Set Shaft1CX = 20 #1st shaft for elevator bank
	Set Shaft1CZ = 10
	Set Shaft2CX = 20 #1st shaft for elevator bank
	Set Shaft2CZ = -10

		#Elevators 7-9
		AddDecoObject(Elev7_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, front, true, false, 0.05, 0.2, %Shaft1CX% - 10, %Shaft1CZ% - 5, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		AddDecoObject(Elev8_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, front, true, false, 0.05, 0.2, %Shaft1CX%, %Shaft1CZ% - 5, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		AddDecoObject(Elev9_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, front, true, false, 0.05, 0.2, %Shaft1CX% + 10, %Shaft1CZ% - 5, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)

		#Elevators 10-12
		AddDecoObject(Elev10_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, back, true, false, 0.05, 0.2, %Shaft2CX% - 10, %Shaft2CZ% + 5, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		AddDecoObject(Elev11_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, back, true, false, 0.05, 0.2, %Shaft2CX%, %Shaft2CZ% + 5, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		AddDecoObject(Elev12_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, back, true, false, 0.05, 0.2, %Shaft2CX% + 10, %Shaft2CZ% + 5, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)

	#****************************************#

	#Call buttons
	CallButtonElevators = 7, 8, 9, 10, 11, 12
	CreateCallButtons %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft1CX% - 5, %Shaft1CZ% - 5.001, 3.5, front, 0.5, 1, true, 0, 0
	CreateCallButtons %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft1CX% + 5, %Shaft1CZ% - 5.001, 3.5, front, 0.5, 1, true, 0, 0
	CreateCallButtons %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft2CX% - 5, %Shaft2CZ% + 5.001, 3.5, back, 0.5, 1, true, 0, 0
	CreateCallButtons %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft2CX% + 5, %Shaft2CZ% + 5.001, 3.5, back, 0.5, 1, true, 0, 0

		#Signs
		WallOrientation = right
		DrawWalls = true, false, false, false, false, false
		AddBoxSign(E7-12_FS1, BlankSign%floorid%, Blank, Blank, 0, true, false, false, %Shaft1CX% - 5, %Shaft1CZ% - 5.001, 1.5, 1.5, 6.5 - 0.75 + %interfloorheight%, true)
		AddBoxSign(E7-12_FS2, BlankSign%floorid%, Blank, Blank, 0, true, false, false, %Shaft1CX% + 5, %Shaft1CZ% - 5.001, 1.5, 1.5, 6.5 - 0.75 + %interfloorheight%, true)

		AddWall E7-12_HS1, ElevHallSign, 0, %Shaft1CX% - 5 - 0.25, %Shaft1CZ% - 5.001, %Shaft1CX% - 5 + 0.25, %Shaft1CZ% - 5.001, 0.75, 0.75, 2.6, 2.6, 0, 0, false

		WallOrientation = left
		DrawWalls = false, true, false, false, false, false
		AddBoxSign(E7-12_FS3, Blank, BlankSign%floorid%, Blank, 0, true, false, false, %Shaft2CX% - 5, %Shaft2CZ% + 5.001, 1.5, 1.5, 6.5 - 0.75 + %interfloorheight%, true)
		AddBoxSign(E7-12_FS4, Blank, BlankSign%floorid%, Blank, 0, true, false, false, %Shaft2CX% + 5, %Shaft2CZ% + 5.001, 1.5, 1.5, 6.5 - 0.75 + %interfloorheight%, true)

		AddWall E7-12_HS2, ElevHallSign, 0, %Shaft2CX% - 5 - 0.25, %Shaft2CZ% + 5.001, %Shaft2CX% - 5 + 0.25, %Shaft2CZ% + 5.001, 0.75, 0.75, 2.6, 2.6, 0, 0, false

	#****************************************#

	#Indicator sets
	Set Offset = 7.5

		#Set textures
		ACMEInd_LanternTex(%LanternPrefix%Up, %LanternPrefix%UpLit, %LanternPrefix%Down, %LanternPrefix%DownLit, %LPanelTexture%, DWInd_Button)

		#Indicator creation
		if[%floor% = 0] ACMELobbyInds(front, 7, %Shaft1CX% - 10, %Shaft1CZ% - 5 - %ExtraLateralOffset%, %Offset%, 0, 21)
		if[%floor% = 0] ACMELobbyInds(front, 8, %Shaft1CX%, %Shaft1CZ% - 5 - %ExtraLateralOffset%, %Offset%, 0, 21)
		if[%floor% = 0] ACMELobbyInds(front, 9, %Shaft1CX% + 10, %Shaft1CZ% - 5 - %ExtraLateralOffset%, %Offset%, 0, 21)
		if[%floor% = 0] ACMELobbyInds(back, 10, %Shaft2CX% - 10, %Shaft2CZ% + 5 + %ExtraLateralOffset%, %Offset%, 0, 21)
		if[%floor% = 0] ACMELobbyInds(back, 11, %Shaft2CX%, %Shaft2CZ% + 5 + %ExtraLateralOffset%, %Offset%, 0, 21)
		if[%floor% = 0] ACMELobbyInds(back, 12, %Shaft2CX% + 10, %Shaft2CZ% + 5 + %ExtraLateralOffset%, %Offset%, 0, 21)

		if[%floor% ! 0] ACMELobbyLanterns(front, 7, %Shaft1CX% - 10, %Shaft1CZ% - 5 - %ExtraLateralOffset%, %Offset%, 0, 21)
		if[%floor% ! 0] ACMELobbyLanterns(front, 8, %Shaft1CX%, %Shaft1CZ% - 5 - %ExtraLateralOffset%, %Offset%, 0, 21)
		if[%floor% ! 0] ACMELobbyLanterns(front, 9, %Shaft1CX% + 10, %Shaft1CZ% - 5 - %ExtraLateralOffset%, %Offset%, 0, 21)
		if[%floor% ! 0] ACMELobbyLanterns(back, 10, %Shaft2CX% - 10, %Shaft2CZ% + 5 + %ExtraLateralOffset%, %Offset%, 0, 21)
		if[%floor% ! 0] ACMELobbyLanterns(back, 11, %Shaft2CX%, %Shaft2CZ% + 5 + %ExtraLateralOffset%, %Offset%, 0, 21)
		if[%floor% ! 0] ACMELobbyLanterns(back, 12, %Shaft2CX% + 10, %Shaft2CZ% + 5 + %ExtraLateralOffset%, %Offset%, 0, 21)
<EndFunction>

