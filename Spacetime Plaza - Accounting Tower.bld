#Button creation function (Elevators 1-6)
<Function BtnPanelE1-6>
	Set PanelNumber = %param1%
	Set BtnPrefix = DWButton

	AddButton %PanelNumber%, , %BtnPrefix%12, %BtnPrefix%Lit12, 3, 3, 11, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%11, %BtnPrefix%Lit11, 3, 1, 10, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%10, %BtnPrefix%Lit10, 4, 3, 9, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%9, %BtnPrefix%Lit9, 4, 1, 8, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%8, %BtnPrefix%Lit8, 5, 3, 7, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%7, %BtnPrefix%Lit7, 5, 1, 6, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%6, %BtnPrefix%Lit6, 6, 3, 5, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%5, %BtnPrefix%Lit5, 6, 1, 4, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%4, %BtnPrefix%Lit4, 7, 3, 3, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%3, %BtnPrefix%Lit3, 7, 1, 2, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%1, %BtnPrefix%Lit1, 8, 2, 0, 1, 1

	AddButton %PanelNumber%, , %BtnPrefix%Open, %BtnPrefix%Open, 10, 1, open, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%Close, %BtnPrefix%Close, 10, 3, close, 1, 1
	if[%PanelNumber% = 1] AddButton %PanelNumber%, , %BtnPrefix%Alarm, %BtnPrefix%Alarm, 1, 2, alarm, 1, 1
<EndFunction>

<Elevators 1 to 3>
	Set Prefix = Office

	#Set textures and dimensions
	M10_ElevCabTex(ElevExt, %Prefix%ElevFloor, %Prefix%ElevCeiling, %Prefix%ElevWall, %Prefix%ElevWall)
	M10_ElevDimensions(7.5, 6.5, 8, 0.2, 0.2, false, true, true, true)
	M10_ElevPanels(%Prefix%ElevPanelMain, %Prefix%ElevPanelTop, 1.75, 1.75, 1, 0.2, true, false, false, false)

	#Finish elevator assembly
	M10_ElevInterior()
	#--------------------
	#Car Doors
	Set ElevDoorTex = %Prefix%ElevDoors
	Set InitialDoorPos = -3.25

	WallOrientation = right
	AddDoorComponent 1, Left, %ElevDoorTex%, %ElevDoorTex%, 0.2, right, 0.8, 0.6, 2 - (2 * 1), %InitialDoorPos%, 2, %InitialDoorPos%, 7, 0, 0, 0, 0, 0
	AddDoorComponent 1, Right, %ElevDoorTex%2, %ElevDoorTex%2, 0.2, left, 0.8, 0.6, 2 - (2 * 2), %InitialDoorPos%, 2 - (2 * 1), %InitialDoorPos%, 7, 0, 0, 0, 0, 0
	FinishDoors 1, false, false

		#Door track
		FloorOrientation = top
		DrawWalls = true, true, true, true, true, true
		TextureOverride ElevExt, ElevDoorTrackZ, ElevExt, ElevExt, ElevExt, ElevExt
		AddFloor DoorTrack, ElevDoorTrackZ, 0.05, -2 - (2 * 1), %InitialDoorPos% - 0.2, 2 + (2 * 1), %InitialDoorPos%, 0, 0, 0, 0
	#--------------------
	#Button Panels
	Set Position = -2.775 #Right panel
	Set Position2 = 2.775 #Left panel

		#Panel back
		CreateWallBox2 elevator, MainPB, ElevPanel, %Position%, -3.05 + 0.025, 0.75, 0.05, 4.75, 2.25, 0, 0, false, true, true, true
		CreateWallBox2 elevator, SecondaryPB, ElevPanel, %Position2%, -3.05 + 0.025, 0.75, 0.05, 4.75, 2.25, 0, 0, false, true, true, true

		#Panels
		CreatePanel , 10, 3, back, %Position%, -3.05 + 0.051, 0.15, 0.15, 0.25, 0.25, 3.75, 0, 0
		CreatePanel , 10, 3, back, %Position2%, -3.05 + 0.051, 0.15, 0.15, 0.25, 0.25, 3.75, 0, 0

			#Buttons
			BtnPanelE1-6(1)
			BtnPanelE1-6(2)

	#Elevator number sign
	DrawWalls = false, true, false, false, false, false
	AddWall ElevNo%elevator%_Inside, IN_ElevNo%elevator%, 0, %Position% - 0.25, -3.05 + 0.051, %Position% + 0.25, -3.05 + 0.051, 0.5, 0.5, 6.25, 6.25, 0, 0

	#Indicator sets
	AddFloorIndicator DWInd_Button, back, %Position%, -3.05 + 0.051, 0.5, 0.286, 5.75 + 0.25 - 0.143
	AddFloorIndicator DWInd_Button, back, %Position2%, -3.05 + 0.051, 0.5, 0.286, 5.75 + 0.25 - 0.143
<EndElevators>

<Elevators 4 to 6>
	Set Prefix = Office

	#Set textures and dimensions
	M10_ElevCabTex(ElevExt, %Prefix%ElevFloor, %Prefix%ElevCeiling, %Prefix%ElevWall, %Prefix%ElevWall)
	M10_ElevDimensions(7.5, 6.5, 8, 0.2, 0.2, true, true, true, false)
	M10_ElevPanels(%Prefix%ElevPanelMain, %Prefix%ElevPanelTop, 1.75, 1.75, 1, 0.2, false, false, false, true)

	#Finish elevator assembly
	M10_ElevInterior()
	#--------------------
	#Car Doors
	Set ElevDoorTex = %Prefix%ElevDoors
	Set InitialDoorPos = 3.25

	WallOrientation = left
	AddDoorComponent 1, Left, %ElevDoorTex%, %ElevDoorTex%, 0.2, left, 0.8, 0.6, -2, %InitialDoorPos%, -2 + (2 * 1), %InitialDoorPos%, 7, 0, 0, 0, 0, 0
	AddDoorComponent 1, Right, %ElevDoorTex%2, %ElevDoorTex%2, 0.2, right, 0.8, 0.6, -2 + (2 * 1), %InitialDoorPos%, -2 + (2 * 2), %InitialDoorPos%, 7, 0, 0, 0, 0, 0
	FinishDoors 1, false, false

		#Door track
		FloorOrientation = top
		DrawWalls = true, true, true, true, true, true
		TextureOverride ElevExt, ElevDoorTrackZ, ElevExt, ElevExt, ElevExt, ElevExt
		AddFloor DoorTrack, ElevDoorTrackZ, 0.05, -2 - (2 * 1), %InitialDoorPos%, 2 + (2 * 1), %InitialDoorPos% + 0.2, 0, 0, 0, 0
	#--------------------
	#Button Panels
	Set Position = 2.775 #Right panel
	Set Position2 = -2.775 #Left panel

		#Panel back
		CreateWallBox2 elevator, MainPB, ElevPanel, %Position%, 3.05 - 0.025, 0.75, 0.05, 4.75, 2.25, 0, 0, false, true, true, true
		CreateWallBox2 elevator, SecondaryPB, ElevPanel, %Position2%, 3.05 - 0.025, 0.75, 0.05, 4.75, 2.25, 0, 0, false, true, true, true

		#Panels
		CreatePanel , 10, 3, front, %Position%, 3.05 - 0.051, 0.15, 0.15, 0.25, 0.25, 3.75, 0, 0
		CreatePanel , 10, 3, front, %Position2%, 3.05 - 0.051, 0.15, 0.15, 0.25, 0.25, 3.75, 0, 0

			#Buttons
			BtnPanelE1-6(1)
			BtnPanelE1-6(2)

	#Elevator number sign
	DrawWalls = true, false, false, false, false, false
	AddWall ElevNo%elevator%_Inside, IN_ElevNo%elevator%, 0, %Position% - 0.25, 3.05 - 0.051, %Position% + 0.25, 3.05 - 0.051, 0.5, 0.5, 6.25, 6.25, 0, 0

	#Indicator sets
	AddFloorIndicator DWInd_Button, front, %Position%, 3.05 - 0.051, 0.5, 0.286, 5.75 + 0.25 - 0.143
	AddFloorIndicator DWInd_Button, front, %Position2%, 3.05 - 0.051, 0.5, 0.286, 5.75 + 0.25 - 0.143
<EndElevators>

<Elevators 1 to 6>
	DisplayFloors = 0, 2-11
	#--------------------
	#DETAILED INTERIORS
	#Wall panels
	Set Prefix = Office
	Set PanelTex = %Prefix%ElevWallPanel1

	Set PanelDir = 2
	if[%elevator% > 3] Set PanelDir = 1

	ACTT_EWP(%PanelTex%, %PanelDir%) #Panel creation
	#--------------------
	#Shaft components
	DrawWalls = true, true, true, true, true, true
		#Ropes
		RopePosition = 0, 8.5 + 0.2, 0
		RopeTexture = Ropes
	
		#Counterweight
		Set Position = 3.25 + 0.75
		if[%elevator% > 3] Set Position = -3.25 - 0.75

		CreateCounterweight CWeight_Frame, CWeight, 0, %Position%, 2, 6, 0.5, 0.5
	
		#Rails
		AddRails ElevRail, ElevRailSide, 0, 0, false, 3.75 + 0.06, 0.1
		AddRails ElevRail, ElevRailSide, 0, %Position%, false, 1 + 0.06, 0.1
<EndElevators>

