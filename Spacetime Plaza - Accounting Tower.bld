	#West Stairwell
	CreateShaftWall(%5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, -50, 12.5, 5, 12.5, ACTT_ST1, %SHeight%, %SOffset%, true, true, true, true, false, false, true)

	#East Stairwell
