#Button creation function (Elevators 1-8)
<Function BtnPanelE1-8>
	Set PanelNumber = %param1%
	Set PanelNumber2 = %PanelNumber% + 1
	Set BtnPrefix = Button

	if[%PanelNumber% = 1] AddButton %PanelNumber2%, , %BtnPrefix%Alarm, %BtnPrefix%Alarm, 1, 1, alarm, 1, 1

	AddButton %PanelNumber%, , %BtnPrefix%14, %BtnPrefix%Lit14, 3, 1, 17, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%10, %BtnPrefix%Lit10, 4, 2, 13, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%9, %BtnPrefix%Lit9, 4, 1, 12, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%8A, %BtnPrefix%Lit8A, 5, 2, 11, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%8, %BtnPrefix%Lit8, 5, 1, 10, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%7A, %BtnPrefix%Lit7A, 6, 2, 9, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%7, %BtnPrefix%Lit7, 6, 1, 8, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%6, %BtnPrefix%Lit6, 7, 2, 7, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%5A, %BtnPrefix%Lit5A, 7, 1, 6, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%5, %BtnPrefix%Lit5, 8, 2, 5, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%4, %BtnPrefix%Lit4, 8, 1, 4, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%3A, %BtnPrefix%Lit3A, 9, 2, 3, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%3, %BtnPrefix%Lit3, 9, 1, 2, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%2, %BtnPrefix%Lit2, 10, 2, 1, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%1, %BtnPrefix%Lit1, 10, 1, 0, 1, 1
	AddButton %PanelNumber2%, , %BtnPrefix%B1, %BtnPrefix%LitB1, 11, 1, -1, 1, 1

	AddButton %PanelNumber%, , %BtnPrefix%Open, %BtnPrefix%Open, 13, 1, open, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%Close, %BtnPrefix%Close, 13, 2, close, 1, 1
<EndFunction>

<Elevators 1 to 4>
	Set Prefix = Parking
	DisplayFloors = -1 - 13, 17

	#Set textures and dimensions
	M10_ElevCabTex(ElevExt, %Prefix%ElevFloor, %Prefix%ElevCeiling, %Prefix%ElevWall, %Prefix%ElevWall)
	M10_ElevDimensions(7.5, 9.68, 8, 0.2, 0.2, true, true, true, false)
	M10_ElevPanels(%Prefix%ElevPanelMain, %Prefix%ElevPanelTop, 1.5, 1.5, 1, 0.2, false, false, false, true)

	#Finish elevator assembly
	M10_ElevInterior()
	#--------------------
	#Car Doors
	Set ElevDoorTex = %Prefix%ElevDoors
	Set InitialDoorPos = 4.84

	WallOrientation = left
	AddDoorComponent 1, Left, %ElevDoorTex%, %ElevDoorTex%, 0.2, left, 1, 0.75, -2.25, %InitialDoorPos%, -2.25 + (2.25 * 1), %InitialDoorPos%, 7, 0, 0, 0, 0, 0
	AddDoorComponent 1, Right, %ElevDoorTex%2, %ElevDoorTex%2, 0.2, right, 1, 0.75, -2.25 + (2.25 * 1), %InitialDoorPos%, -2.25 + (2.25 * 2), %InitialDoorPos%, 7, 0, 0, 0, 0, 0
	FinishDoors 1, false, false

		#Door track
		FloorOrientation = top
		DrawWalls = true, true, true, true, true, true
		TextureOverride ElevExt, ElevDoorTrackZ, ElevExt, ElevExt, ElevExt, ElevExt
		AddFloor DoorTrack, ElevDoorTrackZ, 0.05, -2.25 - (2.25 * 1), %InitialDoorPos%, 2.25 + (2.25 * 1), %InitialDoorPos% + 0.2, 0, 0, 0, 0
	#--------------------
	#Button Panels
	Set Position = 2.9 #Right panel
	Set Position2 = -2.9 #Left panel

		#Panel backs
		CreateWallBox2 elevator, MainPB, ElevPanel, %Position%, 4.64 - 0.025, 0.8, 0.05, 5, 2, 0, 0, false, true, true, true
		CreateWallBox2 elevator, SecondaryPB, ElevPanel, %Position2%, 4.64 - 0.025, 0.8, 0.05, 5, 2, 0, 0, false, true, true, true

		#Right panel
		CreatePanel , 13, 2, front, %Position%, 4.64 - 0.051, 0.15, 0.15, 0.5, 0.25, 3.75, 0, 0
		CreatePanel , 13, 1, front, %Position%, 4.64 - 0.051, 0.15, 0.15, 0.5, 0.25, 3.75, 0, 0 #Alarm and B1 buttons only

		#Left panel
		CreatePanel , 13, 2, front, %Position2%, 4.64 - 0.051, 0.15, 0.15, 0.5, 0.25, 3.75, 0, 0
		CreatePanel , 13, 1, front, %Position2%, 4.64 - 0.051, 0.15, 0.15, 0.5, 0.25, 3.75, 0, 0 #Alarm and B1 buttons only

			#Buttons for both panels
			BtnPanelE1-8(1)
			BtnPanelE1-8(3)
	#--------------------
	#Elevator number sign
	DrawWalls = true, false, false, false, false, false
	AddWall ElevNo%elevator%_Inside, IN_ElevNo%elevator%, 0, 0 - 0.25, 4.64 - 0.001, 0 + 0.25, 4.64 - 0.001, 0.5, 0.5, 7.05, 7.05, 0, 0

	#Indicator sets
	KSS670_PI_InternalInd(front, %Position%, 4.64 - 0.051, 6, Ind_Button, ArrowUp, ArrowUpLit, ArrowDownLit)
	KSS670_PI_InternalInd(front, %Position2%, 4.64 - 0.051, 6, Ind_Button, ArrowUp, ArrowUpLit, ArrowDownLit)

	#AddFloorIndicator Ind_Button, front, %Position%, 4.64 - 0.051, 0.45, 0.45, 6
	#AddFloorIndicator Ind_Button, front, %Position2%, 4.64 - 0.051, 0.45, 0.45, 6
<EndElevators>

<Elevators 5 to 8>
	Set Prefix = Parking

	#Set textures and dimensions
	M10_ElevCabTex(ElevExt, %Prefix%ElevFloor, %Prefix%ElevCeiling, %Prefix%ElevWall, %Prefix%ElevWall)
	M10_ElevDimensions(7.5, 9.68, 8, 0.2, 0.2, false, true, true, true)
	M10_ElevPanels(%Prefix%ElevPanelMain, %Prefix%ElevPanelTop, 1.5, 1.5, 1, 0.2, true, false, false, false)

	#Finish elevator assembly
	M10_ElevInterior()
	#--------------------
	#Car Doors
	Set ElevDoorTex = %Prefix%ElevDoors
	Set InitialDoorPos = -4.84

	WallOrientation = right
	AddDoorComponent 1, Left, %ElevDoorTex%, %ElevDoorTex%, 0.2, right, 1, 0.75, 2.25, %InitialDoorPos%, 2.25 - (2.25 * 1), %InitialDoorPos%, 7, 0, 0, 0, 0, 0
	AddDoorComponent 1, Right, %ElevDoorTex%2, %ElevDoorTex%2, 0.2, left, 1, 0.75, 2.25 - (2.25 * 1), %InitialDoorPos%, 2.25 - (2.25 * 2), %InitialDoorPos%, 7, 0, 0, 0, 0, 0
	FinishDoors 1, false, false

		#Door track
		FloorOrientation = top
		DrawWalls = true, true, true, true, true, true
		TextureOverride ElevExt, ElevDoorTrackZ, ElevExt, ElevExt, ElevExt, ElevExt
		AddFloor DoorTrack, ElevDoorTrackZ, 0.05, -2.25 - (2.25 * 1), %InitialDoorPos% - 0.2, 2.25 + (2.25 * 1), %InitialDoorPos%, 0, 0, 0, 0
	#--------------------
	#Button Panels
	Set Position = -2.9 #Right panel
	Set Position2 = 2.9 #Left panel

		#Panel back
		CreateWallBox2 elevator, MainPB, ElevPanel, %Position%, -4.64 + 0.025, 0.8, 0.05, 5, 2, 0, 0, false, true, true, true
		CreateWallBox2 elevator, SecondaryPB, ElevPanel, %Position2%, -4.64 + 0.025, 0.8, 0.05, 5, 2, 0, 0, false, true, true, true

		#Panels
		CreatePanel , 13, 2, back, %Position%, -4.64 + 0.051, 0.15, 0.15, 0.5, 0.25, 3.75, 0, 0 #Right panel
		CreatePanel , 13, 1, back, %Position%, -4.64 + 0.051, 0.15, 0.15, 0.5, 0.25, 3.75, 0, 0 #Alarm and B1 buttons only
		CreatePanel , 13, 2, back, %Position2%, -4.64 + 0.051, 0.15, 0.15, 0.5, 0.25, 3.75, 0, 0 #Left panel
		CreatePanel , 13, 1, back, %Position2%, -4.64 + 0.051, 0.15, 0.15, 0.5, 0.25, 3.75, 0, 0 #Alarm and B1 buttons only

			#Buttons
			BtnPanelE1-8(1)
			BtnPanelE1-8(3)
	#--------------------
	#Elevator number sign
	DrawWalls = false, true, false, false, false, false
	AddWall ElevNo%elevator%_Inside, IN_ElevNo%elevator%, 0, 0 - 0.25, -4.64 + 0.001, 0 + 0.25, -4.64 + 0.001, 0.5, 0.5, 7.05, 7.05, 0, 0

	#Indicator sets
	KSS670_PI_InternalInd(back, %Position%, -4.64 + 0.051, 6, Ind_Button, ArrowUp, ArrowUpLit, ArrowDownLit)
	KSS670_PI_InternalInd(back, %Position2%, -4.64 + 0.051, 6, Ind_Button, ArrowUp, ArrowUpLit, ArrowDownLit)

	#AddFloorIndicator Ind_Button, back, %Position%, -4.64 + 0.051, 0.45, 0.45, 6
	#AddFloorIndicator Ind_Button, back, %Position2%, -4.64 + 0.051, 0.45, 0.45, 6
<EndElevators>


#Interiors for Parking Elevators
<Elevators 1 to 8>
	Set Prefix = Parking

	#DETAILED INTERIORS
	#1. Middle Lights
	CreateWallBox2 elevator, E%elevator%_Light1, %Prefix%ElevCeilingLight, 0, 0, 2.5, 9.28, 0.1, 8 - 0.1, 0, 0, false, true, true, true

	#2. Edge Lights
	Set DLOffset = 8 - 0.001
	FloorOrientation = top
	DrawWalls = true, false, false, false, true, true

	AddFloor Downlight1/1, %Prefix%ElevCeilingDL, 0, -2.55 - 0.15, 2.5 - 0.15, -2.55 + 0.15, 2.5 + 0.15, %DLOffset%, %DLOffset%, 0, 0
	AddFloor Downlight1/2, %Prefix%ElevCeilingDL, 0, -2.55 - 0.15, 0 - 0.15, -2.55 + 0.15, 0 + 0.15, %DLOffset%, %DLOffset%, 0, 0
	AddFloor Downlight1/3, %Prefix%ElevCeilingDL, 0, -2.55 - 0.15, -2.5 - 0.15, -2.55 + 0.15, -2.5 + 0.15, %DLOffset%, %DLOffset%, 0, 0
	AddFloor Downlight1/1, %Prefix%ElevCeilingDL, 0, 2.55 - 0.15, 2.5 - 0.15, 2.55 + 0.15, 2.5 + 0.15, %DLOffset%, %DLOffset%, 0, 0
	AddFloor Downlight1/2, %Prefix%ElevCeilingDL, 0, 2.55 - 0.15, 0 - 0.15, 2.55 + 0.15, 0 + 0.15, %DLOffset%, %DLOffset%, 0, 0
	AddFloor Downlight1/3, %Prefix%ElevCeilingDL, 0, 2.55 - 0.15, -2.5 - 0.15, 2.55 + 0.15, -2.5 + 0.15, %DLOffset%, %DLOffset%, 0, 0

	#3. Ceiling trims
	CreateWallBox2 elevator, E%elevator%_CeilingTrim1, %Prefix%ElevCeilingTrim, -1.25 - 0.1, 0, 0.2, 9.28, 0.1, 8 - 0.1, 0, 0, false, true, true, true
	CreateWallBox2 elevator, E%elevator%_CeilingTrim2, %Prefix%ElevCeilingTrim, 1.25 + 0.1, 0, 0.2, 9.28, 0.1, 8 - 0.1, 0, 0, false, true, true, true

	#4. Panels on walls
	Set WPTex = %Prefix%ElevWallPanel
	if[%elevator% > 4] Set WPTex = %Prefix%ElevWallPanel2
	Set WPanelHeight = 8

		#Front panels
		if[%elevator% < 5] CreateWallBox2 elevator, Panel_F, %WPTex%, 0, -4.64 + 0.01, 3, 0.02, %WPanelHeight%, 0, 0, 0, false, true, true, true

		#Back panels
		if[%elevator% > 4] CreateWallBox2 elevator, Panel_B, %WPTex%, 0, 4.64 - 0.01, 3, 0.02, %WPanelHeight%, 0, 0, 0, false, true, true, true

		#Left panel
		CreateWallBox2 elevator, Panel_L, %WPTex%, -3.55 + 0.01, 0, 0.02, 4, %WPanelHeight%, 0, 0, 0, false, true, true, true

		#Right panels
		CreateWallBox2 elevator, Panel_R, %WPTex%, 3.55 - 0.01, 0, 0.02, 4, %WPanelHeight%, 0, 0, 0, false, true, true, true
	#--------------------
	#Shaft components
	DrawWalls = true, true, true, true, true, true
		#Ropes
		RopePosition = 0, 8 + 0.2, 0
		RopeTexture = Ropes
	
		#Counterweight
		Set Position = 3.75 + 0.8
		if[%elevator% = 3 | %elevator% = 4 | %elevator% = 7 | %elevator% = 8] Set Position = -3.75 - 0.8

		CreateCounterweight CWeight_Frame, CWeight, %Position%, 0, 0.5, 6, 2, 0.5
	
		#Rails
		AddRails ElevRail, ElevRailSide, 0, 0, false, 3.75 + 0.06, 0.1
		AddRails ElevRail, ElevRailSide, %Position%, 0, true, 1 + 0.06, 0.1
<EndElevators>

