		AddWall LeftWall, ExtFacade, 0.5, -%1%, -%2%, -%1%, %2% - 200, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		WallOrientation = right
		AddWall RightWall, ExtFacade, 0.5, -%1% + 200 + 80, -%2%, -%1% + 200 + 80, %2%, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		AddWall BackWall, ExtFacade, 0.5, -%1% + 200, %2%, -%1% + 200 + 80 - 0.5, %2%, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
<EndFloor>

#Topside mechanical
<Floors 44 to 45>
	TexPrefix() #Set texture prefix/suffix

	#Floors
	FloorOrientation = top
	DrawWalls = false, true, false, false, false, false
	if[%floor% = 44] AddFloor TopMechFlr, %5%Floor, 0.5, -%1%, %2% - 200, -%1% + 200, %2%, %interfloorheight%, %interfloorheight%, 0, 0, true

