	AddText Blank, BlankSign41A, nimbus_sans_bold_condensed.ttf, 65, 41A, -1, -1, -1, -1, center, center, 0, 0, 0, false
<EndTextures>

#HALL STATIONS
#Set textures (Passenger elevators)
<Function ElevHallTex>
	TexPrefix() #Set prefixes for shaft doors
	if[%floor% = 0]  Set 5 = HotelEntrance #Override

	#Shaft doors
	Set DoorTexture = %5%ShaftDoors

	#Use automatic filler walls or not
	Set AutoFiller = false

	#Door trims
		#Sides
		Set DoorTrimTexture = %DoorTexture%_Trim

		#Top
		Set DoorTrimTexture_Top = %DoorTrimTexture%

	#Deco dimensions
		Set SideDecoH = %height%
		Set TopDecoH = %height% - 7
		if[%floor% = -1] Set SideDecoH = 7.2
		if[%floor% = -1] Set TopDecoH = 0.2
		if[%floor% > 0 & %floor% < 17] Set SideDecoH = 7.2
		if[%floor% > 0 & %floor% < 17] Set TopDecoH = 0.2

	#Call button panels
	Set BPanelTexture = ElevExtPanels
	Set ButtonPrefix = Button

	#Lantern panels
	Set LPanelTexture = %BPanelTexture%
	Set LanternPrefix = Lantern

		#Lateral offset for lantern panels
		Set ExtraLateralOffset = 0.05
		if[%floor% = -1] Set ExtraLateralOffset = 0
		if[%floor% > 0 & %floor% < 17] Set ExtraLateralOffset = 0
<EndFunction>

#****************************************#

#Parking Elevators
<Function E1-8HallStation>
	#Shaft Doors
	ElevHallTex() #Set shaft door and panel textures
	
		#Elevators 1-4
		Set StartNo = 1 #Number of the first elevator
		Set IDP-ShaftDoors = 4.84 + 0.3 #IDP = Initial door position
	
		WallOrientation = left
		AddShaftDoorComponent %StartNo%, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, right, 1, 0.75, -2.25 + (2.25 * 1), %IDP-ShaftDoors%, -2.25 + (2.25 * 2), %IDP-ShaftDoors%, 7, 0, 0, 0, 0, 0
		AddShaftDoorComponent %StartNo%, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, left, 1, 0.75, -2.25, %IDP-ShaftDoors%, -2.25 + (2.25 * 1), %IDP-ShaftDoors%, 7, 0, 0, 0, 0, 0
		FinishShaftDoor %StartNo%, 1, %AutoFiller%, false
	
		WallOrientation = left
		AddShaftDoorComponent %StartNo% + 1, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, right, 1, 0.75, -2.25 + (2.25 * 1), %IDP-ShaftDoors%, -2.25 + (2.25 * 2), %IDP-ShaftDoors%, 7, 0, 0, 0, 0, 0
		AddShaftDoorComponent %StartNo% + 1, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, left, 1, 0.75, -2.25, %IDP-ShaftDoors%, -2.25 + (2.25 * 1), %IDP-ShaftDoors%, 7, 0, 0, 0, 0, 0
		FinishShaftDoor %StartNo% + 1, 1, %AutoFiller%, false
	
		WallOrientation = left
		AddShaftDoorComponent %StartNo% + 2, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, right, 1, 0.75, -2.25 + (2.25 * 1), %IDP-ShaftDoors%, -2.25 + (2.25 * 2), %IDP-ShaftDoors%, 7, 0, 0, 0, 0, 0
		AddShaftDoorComponent %StartNo% + 2, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, left, 1, 0.75, -2.25, %IDP-ShaftDoors%, -2.25 + (2.25 * 1), %IDP-ShaftDoors%, 7, 0, 0, 0, 0, 0
		FinishShaftDoor %StartNo% + 2, 1, %AutoFiller%, false
	
		WallOrientation = left
		AddShaftDoorComponent %StartNo% + 3, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, right, 1, 0.75, -2.25 + (2.25 * 1), %IDP-ShaftDoors%, -2.25 + (2.25 * 2), %IDP-ShaftDoors%, 7, 0, 0, 0, 0, 0
		AddShaftDoorComponent %StartNo% + 3, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, left, 1, 0.75, -2.25, %IDP-ShaftDoors%, -2.25 + (2.25 * 1), %IDP-ShaftDoors%, 7, 0, 0, 0, 0, 0
		FinishShaftDoor %StartNo% + 3, 1, %AutoFiller%, false
	
		#Elevators 5-8
		Set StartNo = 5 #Number of the first elevator
		Set IDP-ShaftDoors = -4.84 - 0.3 #IDP = Initial door position

		WallOrientation = right
		AddShaftDoorComponent %StartNo%, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, left, 1, 0.75, -2.25, %IDP-ShaftDoors%, -2.25 + (2.25 * 1), %IDP-ShaftDoors%, 7, 0, 0, 0, 0, 0
		AddShaftDoorComponent %StartNo%, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, right, 1, 0.75, -2.25 + (2.25 * 1), %IDP-ShaftDoors%, -2.25 + (2.25 * 2), %IDP-ShaftDoors%, 7, 0, 0, 0, 0, 0
		FinishShaftDoor %StartNo%, 1, %AutoFiller%, false
	
		WallOrientation = right
		AddShaftDoorComponent %StartNo% + 1, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, left, 1, 0.75, -2.25, %IDP-ShaftDoors%, -2.25 + (2.25 * 1), %IDP-ShaftDoors%, 7, 0, 0, 0, 0, 0
		AddShaftDoorComponent %StartNo% + 1, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, right, 1, 0.75, -2.25 + (2.25 * 1), %IDP-ShaftDoors%, -2.25 + (2.25 * 2), %IDP-ShaftDoors%, 7, 0, 0, 0, 0, 0
		FinishShaftDoor %StartNo% + 1, 1, %AutoFiller%, false
	
		WallOrientation = right
		AddShaftDoorComponent %StartNo% + 2, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, left, 1, 0.75, -2.25, %IDP-ShaftDoors%, -2.25 + (2.25 * 1), %IDP-ShaftDoors%, 7, 0, 0, 0, 0, 0
		AddShaftDoorComponent %StartNo% + 2, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, right, 1, 0.75, -2.25 + (2.25 * 1), %IDP-ShaftDoors%, -2.25 + (2.25 * 2), %IDP-ShaftDoors%, 7, 0, 0, 0, 0, 0
		FinishShaftDoor %StartNo% + 2, 1, %AutoFiller%, false
	
		WallOrientation = right
		AddShaftDoorComponent %StartNo% + 3, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, left, 1, 0.75, -2.25, %IDP-ShaftDoors%, -2.25 + (2.25 * 1), %IDP-ShaftDoors%, 7, 0, 0, 0, 0, 0
		AddShaftDoorComponent %StartNo% + 3, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, right, 1, 0.75, -2.25 + (2.25 * 1), %IDP-ShaftDoors%, -2.25 + (2.25 * 2), %IDP-ShaftDoors%, 7, 0, 0, 0, 0, 0
		FinishShaftDoor %StartNo% + 3, 1, %AutoFiller%, false

	#Door tracks
	AddShaftTrack(1, 1, 18 - 4.5, 18 + 4.5, 5.67 - 0.53, 5.67 - 0.33, ElevDoorTrackZ, ElevExt, 0.05, 1, 7)
	AddShaftTrack(2, 1, 6 - 4.5, 6 + 4.5, 5.67 - 0.53, 5.67 - 0.33, ElevDoorTrackZ, ElevExt, 0.05, 1, 7)
	AddShaftTrack(3, 1, -6 - 4.5, -6 + 4.5, 5.67 - 0.53, 5.67 - 0.33, ElevDoorTrackZ, ElevExt, 0.05, 1, 7)
	AddShaftTrack(4, 1, -18 - 4.5, -18 + 4.5, 5.67 - 0.53, 5.67 - 0.33, ElevDoorTrackZ, ElevExt, 0.05, 1, 7)

	AddShaftTrack(5, 2, 18 - 4.5, 18 + 4.5, -5.67 + 0.33, -5.67 + 0.53, ElevDoorTrackZ, ElevExt, 0.05, 1, 7)
	AddShaftTrack(6, 2, 6 - 4.5, 6 + 4.5, -5.67 + 0.33, -5.67 + 0.53, ElevDoorTrackZ, ElevExt, 0.05, 1, 7)
	AddShaftTrack(7, 2, -6 - 4.5, -6 + 4.5, -5.67 + 0.33, -5.67 + 0.53, ElevDoorTrackZ, ElevExt, 0.05, 1, 7)
	AddShaftTrack(8, 2, -18 - 4.5, -18 + 4.5, -5.67 + 0.33, -5.67 + 0.53, ElevDoorTrackZ, ElevExt, 0.05, 1, 7)

	#****************************************#

	#Door trims/fillers
	TexPrefix() #Set filler walls' textures to match with shaft walls
	Set Shaft1CX = -150 #1st shaft for elevator bank
	Set Shaft1CZ = -124
	Set Shaft2CX = -150 #2nd shaft for elevator bank
	Set Shaft2CZ = -96

		#PARKING LEVELS
			#Elevators 1-4
			WallOrientation = right
			if[%floor% < 17 & %floor% ! 0] AddFillerWalls %5%%5L%, 0.66, %Shaft1CX% + 18, %Shaft1CZ% + 6, 4.5, 7, %interfloorheight%, true, 0, 0, true #Elevator 1
			if[%floor% < 17 & %floor% ! 0] AddFillerWalls %5%%5L%, 0.66, %Shaft1CX% + 6, %Shaft1CZ% + 6, 4.5, 7, %interfloorheight%, true, 0, 0, true
			if[%floor% < 17 & %floor% ! 0] AddFillerWalls %5%%5L%, 0.66, %Shaft1CX% - 6, %Shaft1CZ% + 6, 4.5, 7, %interfloorheight%, true, 0, 0, true
			if[%floor% < 17 & %floor% ! 0] AddFillerWalls %5%%5L%, 0.66, %Shaft1CX% - 18, %Shaft1CZ% + 6, 4.5, 7, %interfloorheight%, true, 0, 0, true
	
			#Elevators 5-8
			WallOrientation = left
			if[%floor% < 17 & %floor% ! 0] AddFillerWalls %5%%5L%, 0.66, %Shaft2CX% + 18, %Shaft2CZ% - 6, 4.5, 7, %interfloorheight%, true, 0, 0, true #Elevator 4
			if[%floor% < 17 & %floor% ! 0] AddFillerWalls %5%%5L%, 0.66, %Shaft2CX% + 06, %Shaft2CZ% - 6, 4.5, 7, %interfloorheight%, true, 0, 0, true
			if[%floor% < 17 & %floor% ! 0] AddFillerWalls %5%%5L%, 0.66, %Shaft2CX% - 06, %Shaft2CZ% - 6, 4.5, 7, %interfloorheight%, true, 0, 0, true
			if[%floor% < 17 & %floor% ! 0] AddFillerWalls %5%%5L%, 0.66, %Shaft2CX% - 18, %Shaft2CZ% - 6, 4.5, 7, %interfloorheight%, true, 0, 0, true

		#LOBBY LEVELS
			#Elevators 1-4
			if[%floor% = 0 | %floor% = 17] AddDecoObject(Elev1_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, back, true, false, 0.05, 0.2, %Shaft1CX% + 18, %Shaft1CZ% + 6, 4.5, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
			if[%floor% = 0 | %floor% = 17] AddDecoObject(Elev2_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, back, true, false, 0.05, 0.2, %Shaft1CX% + 6, %Shaft1CZ% + 6, 4.5, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
			if[%floor% = 0 | %floor% = 17] AddDecoObject(Elev3_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, back, true, false, 0.05, 0.2, %Shaft1CX% - 6, %Shaft1CZ% + 6, 4.5, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
			if[%floor% = 0 | %floor% = 17] AddDecoObject(Elev4_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, back, true, false, 0.05, 0.2, %Shaft1CX% - 18, %Shaft1CZ% + 6, 4.5, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
	
			#Elevators 5-8
			if[%floor% = 0 | %floor% = 17] AddDecoObject(Elev5_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, front, true, false, 0.05, 0.2, %Shaft2CX% + 18, %Shaft2CZ% - 6, 4.5, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
			if[%floor% = 0 | %floor% = 17] AddDecoObject(Elev6_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, front, true, false, 0.05, 0.2, %Shaft2CX% + 6, %Shaft2CZ% - 6, 4.5, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
			if[%floor% = 0 | %floor% = 17] AddDecoObject(Elev7_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, front, true, false, 0.05, 0.2, %Shaft2CX% - 6, %Shaft2CZ% - 6, 4.5, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
			if[%floor% = 0 | %floor% = 17] AddDecoObject(Elev8_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, front, true, false, 0.05, 0.2, %Shaft2CX% - 18, %Shaft2CZ% - 6, 4.5, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)

	#****************************************#

	#Call buttons
	CallButtonElevators = 1, 2, 3, 4, 5, 6, 7, 8
	CreateCallButtons %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft1CX% - 12, %Shaft1CZ% + 6.001, 3.5, back, 0.5, 1, true, 0, 0
	CreateCallButtons %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft1CX% + 12, %Shaft1CZ% + 6.001, 3.5, back, 0.5, 1, true, 0, 0
	CreateCallButtons %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft2CX% - 12, %Shaft2CZ% - 6.001, 3.5, front, 0.5, 1, true, 0, 0
	CreateCallButtons %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft2CX% + 12, %Shaft2CZ% - 6.001, 3.5, front, 0.5, 1, true, 0, 0

		#Signs
		WallOrientation = left
		DrawWalls = false, true, false, false, false, false
		if[%floor% ! 0] AddBoxSign(E1-8_FS1, Blank, BlankSign%floorid%, Blank, 0, true, false, false, %Shaft1CX% - 12, %Shaft1CZ% + 6.001, 1.5, 1.5, 6.5 - 0.75 + %interfloorheight%, true)
		if[%floor% ! 0] AddBoxSign(E1-8_FS2, Blank, BlankSign%floorid%, Blank, 0, true, false, false, %Shaft1CX% + 12, %Shaft1CZ% + 6.001, 1.5, 1.5, 6.5 - 0.75 + %interfloorheight%, true)

		if[%floor% = 0] AddBoxSign(E1-8_FS1, Blank, ELFlrSign%floorid%, Blank, 0, true, false, false, %Shaft1CX% - 12, %Shaft1CZ% + 6.001, 1, 1, 5.5 + %interfloorheight%, true)
		if[%floor% = 0] AddBoxSign(E1-8_FS2, Blank, ELFlrSign%floorid%, Blank, 0, true, false, false, %Shaft1CX% + 12, %Shaft1CZ% + 6.001, 1, 1, 5.5 + %interfloorheight%, true)

		AddWall E1-8_HS1, ElevHallSign, 0, %Shaft1CX% + 12 - 0.25, %Shaft1CZ% + 6.001, %Shaft1CX% + 12 + 0.25, %Shaft1CZ% + 6.001, 0.75, 0.75, 2.6, 2.6, 0, 0, false

		WallOrientation = right
		DrawWalls = true, false, false, false, false, false
		if[%floor% ! 0] AddBoxSign(E1-6_FS3, BlankSign%floorid%, Blank, Blank, 0, true, false, false, %Shaft2CX% - 12, %Shaft2CZ% - 6.001, 1.5, 1.5, 6.5 - 0.75 + %interfloorheight%, true)
		if[%floor% ! 0] AddBoxSign(E1-6_FS4, BlankSign%floorid%, Blank, Blank, 0, true, false, false, %Shaft2CX% + 12, %Shaft2CZ% - 6.001, 1.5, 1.5, 6.5 - 0.75 + %interfloorheight%, true)
        
		if[%floor% = 0] AddBoxSign(E1-6_FS3, ELFlrSign%floorid%, Blank, Blank, 0, true, false, false, %Shaft2CX% - 12, %Shaft2CZ% - 6.001, 1, 1, 5.5 + %interfloorheight%, true)
		if[%floor% = 0] AddBoxSign(E1-6_FS4, ELFlrSign%floorid%, Blank, Blank, 0, true, false, false, %Shaft2CX% + 12, %Shaft2CZ% - 6.001, 1, 1, 5.5 + %interfloorheight%, true)

		AddWall E1-8_HS2, ElevHallSign, 0, %Shaft2CX% + 12 - 0.25, %Shaft2CZ% - 6.001, %Shaft2CX% + 12 + 0.25, %Shaft2CZ% - 6.001, 0.75, 0.75, 2.6, 2.6, 0, 0, false

	#****************************************#

	#Indicator sets
	Set Offset = 7.5

		#Set textures
		KSS670_PI_LanternTex(%LanternPrefix%Up, %LanternPrefix%UpLit, %LanternPrefix%Down, %LanternPrefix%DownLit, %LPanelTexture%, Ind_Button, ArrowUp, ArrowUpLit, ArrowDownLit)

		#Indicator creation (Lobby)
		if[%floor% = 0] KSS670_PI_LobbyInds(back, 1, %Shaft1CX% + 18, %Shaft1CZ% + 6 + %ExtraLateralOffset%, %Offset%, -1, 17)
		if[%floor% = 0] KSS670_PI_LobbyInds(back, 2, %Shaft1CX% + 6, %Shaft1CZ% + 6 + %ExtraLateralOffset%, %Offset%, -1, 17)
		if[%floor% = 0] KSS670_PI_LobbyInds(back, 3, %Shaft1CX% - 6, %Shaft1CZ% + 6 + %ExtraLateralOffset%, %Offset%, -1, 17)
		if[%floor% = 0] KSS670_PI_LobbyInds(back, 4, %Shaft1CX% - 18, %Shaft1CZ% + 6 + %ExtraLateralOffset%, %Offset%, -1, 17)

		if[%floor% = 0] KSS670_PI_LobbyInds(front, 5, %Shaft2CX% + 18, %Shaft2CZ% - 6 - %ExtraLateralOffset%, %Offset%, -1, 17)
		if[%floor% = 0] KSS670_PI_LobbyInds(front, 6, %Shaft2CX% + 6, %Shaft2CZ% - 6 - %ExtraLateralOffset%, %Offset%, -1, 17)
		if[%floor% = 0] KSS670_PI_LobbyInds(front, 7, %Shaft2CX% - 6, %Shaft2CZ% - 6 - %ExtraLateralOffset%, %Offset%, -1, 17)
		if[%floor% = 0] KSS670_PI_LobbyInds(front, 8, %Shaft2CX% - 18, %Shaft2CZ% - 6 - %ExtraLateralOffset%, %Offset%, -1, 17)

		#Indicator creation (All other floors)
		if[%floor% ! 0] KSS670_PI_LobbyLanterns(back, 1, %Shaft1CX% + 18, %Shaft1CZ% + 6 + %ExtraLateralOffset%, %Offset%, -1, 17)
		if[%floor% ! 0] KSS670_PI_LobbyLanterns(back, 2, %Shaft1CX% + 6, %Shaft1CZ% + 6 + %ExtraLateralOffset%, %Offset%, -1, 17)
		if[%floor% ! 0] KSS670_PI_LobbyLanterns(back, 3, %Shaft1CX% - 6, %Shaft1CZ% + 6 + %ExtraLateralOffset%, %Offset%, -1, 17)
		if[%floor% ! 0] KSS670_PI_LobbyLanterns(back, 4, %Shaft1CX% - 18, %Shaft1CZ% + 6 + %ExtraLateralOffset%, %Offset%, -1, 17)

		if[%floor% ! 0] KSS670_PI_LobbyLanterns(front, 5, %Shaft2CX% + 18, %Shaft2CZ% - 6 - %ExtraLateralOffset%, %Offset%, -1, 17)
		if[%floor% ! 0] KSS670_PI_LobbyLanterns(front, 6, %Shaft2CX% + 6, %Shaft2CZ% - 6 - %ExtraLateralOffset%, %Offset%, -1, 17)
		if[%floor% ! 0] KSS670_PI_LobbyLanterns(front, 7, %Shaft2CX% - 6, %Shaft2CZ% - 6 - %ExtraLateralOffset%, %Offset%, -1, 17)
		if[%floor% ! 0] KSS670_PI_LobbyLanterns(front, 8, %Shaft2CX% - 18, %Shaft2CZ% - 6 - %ExtraLateralOffset%, %Offset%, -1, 17)
<EndFunction>


#Hall station creation
<Floors -1 to 13>
	E1-8HallStation()
<EndFloors>

<Floor 17>
	E1-8HallStation()
<EndFloor>

#****************************************#

#GLOBAL SETTINGS
<Elevators 1 to 8>
	#Notifications
	NotifyEarly = 2
	#UpChimeSound 1 = EG881Sounds/MTupchime2.wav #EG881
	#DownChimeSound 1 = EG881Sounds/MTdownchime2.wav #EG881

	#Other settings
	QueueResets = true
	RecallFloor = 0

	#Door settings
	DoorTimer 1 = 15000
	QuickClose 1 = 10000

	#Motor sounds
	MotorStartSound = EG881Sounds/motor_start3.wav #EG881
	MotorRunSound = EG881Sounds/motor_running3.wav #EG881
	MotorStopSound = EG881Sounds/motor_stop3.wav #EG881
<EndElevators>

<Elevators 1 to 8>
	#Door sounds
	OpenSound 1 = EG881Sounds/elevopenquick2.wav #EG881
	CloseSound 1 = EG881Sounds/elevclosequick2.wav #EG881

	#Elevator movement sounds
	CarStartSound = elevstart5.wav
	CarMoveSound = elevmove5.wav
	CarStopSound = elevstop5.wav
<EndElevators>

##--------------------------------------------------------------------------------##

#STAIRWELLS
<Function StairwellSets>
	#Set Values
	Set NumSteps = 9 #Total: 36 steps (Double stairs)
	if[%floor% < 0 | %floor% > 1] Set NumSteps = 12 #Total: 24 steps / 48 steps (Double stairs)

	#Floors with double stairs
	Set DblStairs = false
	if[%floor% > -1 & %floor% < 2] Set DblStairs = true
	if[%floor% = 17] Set DblStairs = true
<EndFunction>

#West Stairwell
CreateStairwell 1, -140, 30 - 12.5, -2, 46
CutStairwell 1, -4.5, -12, 4.5, 12, 0, 5
ShowFullStairs 1 = always

<Floors -2 to 46>
	StairwellSets() #Determine stairs' size

	Set 21 = -140 #Center X
	Set 22 = 30 - 12.5 #Center Z
	Set 23 = 4.5 #Cut X
	Set 24 = 12 #Cut Z
	Set 25 = 1 #Stairwell Number
	Set 26 = 0.5 #Riser Size

	#Walls
	WallOrientation = right
	DrawWalls = false, true, false, false, false, false
	AddStairsWall %25%, Stair%25%Front, StairsWall, 0.5, -%23%, -%24%, %23%, -%24%, %fullheight%, %fullheight%, -%interfloorheight%, -%interfloorheight%, 0, 0
	AddStairsWall %25%, Stair%25%Left, StairsWall, 0.5, -%23%, -%24%, -%23%, %24%, %fullheight%, %fullheight%, -%interfloorheight%, -%interfloorheight%, 0, 0
	WallOrientation = left
	DrawWalls = true, false, false, false, false, false
	AddStairsWall %25%, Stair%25%Right, StairsWall, 0.5, %23%, -%24%, %23%, %24%, %fullheight%, %fullheight%, -%interfloorheight%, -%interfloorheight%, 0, 0
	AddStairsWall %25%, Stair%25%Back, StairsWall, 0.5, -%23%, %24%, %23%, %24%, %fullheight%, %fullheight%, -%interfloorheight%, -%interfloorheight%, 0, 0

	WallOrientation = center
	DrawWalls = true, true, true, true, false, true
	AddStairsWall %25%, Stair%25%Center, StairsWall2, 1, 0, -%24% + 5, 0, -%24% + 5 + %NumSteps%, %fullheight%, %fullheight%, -%interfloorheight%, -%interfloorheight%, 0, 0

	DrawWalls = true, true, true, true, true, true
	if[%floor% = 0] AddStairsWall %25%, Stair%25%Center_T1, StairsWall2, 1, 0, -%24% + 5 + 9, 0, -%24% + 5 + 12, %interfloorheight% + 3, %interfloorheight% + 3, -%interfloorheight%, -%interfloorheight%, 0, 0

	#Railing
	WallOrientation = right
	DrawWalls = true, true, true, true, true, true
	if[%floor% = 46] AddStairsWall %25%, Stair%25%Rail, StairsWall2, 0.5, %23% - 4, -%24% + 5 + %NumSteps%, %23%, -%24% + 5 + %NumSteps%, 0.5 + 3.5, 0.5 + 3.5, -0.5, -0.5, 0, 0

	#Ceiling
	FloorOrientation = top
	DrawWalls = true, false, false, false, false, false
	if[%floor% = 46] AddStairsFloor %25%, Stairs%25%Ceiling, StairsCeiling, 0.5, -%23%, -%24%, %23%, %24%, %height%, %height%, false, false, 0, 0

	#Stairs
	Set NumStepsU2 = %NumSteps% * 2
	Set NumStepsU3 = %NumSteps% * 3

	OP_Draw(true, true, true, true, true, true)
	if[%floor% < 46] OP_OrthoStair(%25%, ST%25%_LowerStairs, Stairs, %23% - 4, %23%, back, -%24% + 5 + %NumSteps%, %NumSteps%, 1, %26%, 0, 0.5)
	if[%floor% < 46] OP_OrthoStair(%25%, ST%25%_UpperStairs, Stairs, -%23%, -%23% + 4, front, -%24% + 5, %NumSteps%, 1, %26%, %26% * %NumSteps%, 0.5)
	if[%DblStairs% = true] OP_OrthoStair(%25%, ST%25%_LowerStairsEX, Stairs, %23% - 4, %23%, back, -%24% + 5 + %NumSteps%, %NumSteps%, 1, %26%, %26% * %NumStepsU2%, 0.5)
	if[%DblStairs% = true] OP_OrthoStair(%25%, ST%25%_UpperStairsEX, Stairs, -%23%, -%23% + 4, front, -%24% + 5, %NumSteps%, 1, %26%, %26% * %NumStepsU3%, 0.5)

	#Landings
	FloorOrientation = top
	DrawWalls = true, true, false, false, false, false
	if[%floor% = -2] AddStairsFloor %25%, Stairs%25%LandingLower, StairsFloor, 0.5, -%23%, -%24%, %23%, %24%, 0, 0, false, false, 0, 0
	if[%floor% > -2 & %floor% ! 0] AddStairsFloor %25%, Stairs%25%LandingLower, StairsFloor, 0.5, -%23%, -%24% + 5 + %NumSteps%, %23%, %24%, 0, 0, false, false, 0, 0
	if[%floor% = 0] AddStairsFloor %25%, Stairs%25%LandingLower, StairsFloor, 0.5, -%23%, -%24% + 5 + 12, %23%, %24%, 0, 0, false, false, 0, 0
	if[%floor% < 46] AddStairsFloor %25%, Stairs%25%LandingUpper, StairsFloor, 0.5, -%23%, -%24%, %23%, -%24% + 5, %26% * %NumSteps%, %26% * %NumSteps%, false, false, 0, 0

	if[%floor% = 0] AddStairsFloor %25%, Stairs%25%Transition2, StairsFloor, 0.5, %23% - 4, -%24% + 5 + 9, %23%, -%24% + 5 + 12, 0, 0, false, false, 0, 0
	if[%floor% = 2] AddStairsFloor %25%, Stairs%25%Transition2, StairsFloor, 0.5, -%23%, -%24% + 5 + 9, -%23% + 4, -%24% + 5 + 12, 0, 0, false, false, 0, 0

	if[%DblStairs% = true] AddStairsFloor %25%, Stairs%25%LandingLowerEX, StairsFloor, 0.5, -%23%, -%24% + 5 + %NumSteps%, %23%, %24%, %26% * %NumStepsU2%, %26% * %NumStepsU2%, false, false, 0, 0
	if[%DblStairs% = true] AddStairsFloor %25%, Stairs%25%LandingUpperEX, StairsFloor, 0.5, -%23%, -%24%, %23%, -%24% + 5, %26% * %NumStepsU3%, %26% * %NumStepsU3%, false, false, 0, 0

	#Floor Signs
	Set Suffix = %floorid%
	Set SignCenterPoint = 0

	DrawWalls = true, false, false, false, false, false
	AddStairsWall %25%, ST%25%FloorSign, BlankSign%Suffix%, 0, %SignCenterPoint% - 0.75, %24% - 0.001, %SignCenterPoint% + 0.75, %24% - 0.001, 1.5, 1.5, 3.75, 3.75, 0, 0

	#Doors
	WallOrientation = left
	TextureOverride ServiceDoor2, ServiceDoor2B, ServiceDoor2Side, ServiceDoor2Side, ServiceDoor2Side, ServiceDoor2Side
	if[%floor% ! 0] AddStairsDoor %25%, , , false, ServiceDoor2, 0.2, 4, 75, %23%, %24% - 2, 3, 7, 0, 0, 0
	WallOrientation = right
	TextureOverride ServiceDoor2B, ServiceDoor2, ServiceDoor2Side, ServiceDoor2Side, ServiceDoor2Side, ServiceDoor2Side
	if[%floor% = 0] AddStairsDoor %25%, , , false, ServiceDoor2, 0.2, 3, 75, %23% + 0.5, %24% - 2, 3, 7, 0, 0, 0

		#Filler walls
		WallOrientation = left
		AddFillerWalls ConnectionWall, 0.5, %21% + %23%, %22% + %24% - 2, 3, 7 - 0.001, %interfloorheight%, false, 0, 0, true

	#Exit Signs
	Set SignTex = ExitSign
	if[%floor% < 0] Set SignTex = ExitSignUp

	if[%floor% ! 0] AddBoxSign(Stair%25%_SignMain, StainlessSteel, %SignTex%, StainlessSteel, 0.1, false, true, true, %21% + %23% + 0.55, %22% + %24% - 2, 1.8, 0.9, %interfloorheight% + 7.2, true)
	if[%floor% = 0] AddBoxSign(Stair%25%_SignStreet, ExitSign, StainlessSteel, StainlessSteel, 0.1, false, true, true, %21% + %23% - 0.05, %22% + %24% - 2, 1.8, 0.9, %interfloorheight% + 7.2, true)
<EndFloors>

#East Stairwell
CreateStairwell 2, -80, 30 + 12.5, -2, 45
CutStairwell 2, -4.5, -12, 4.5, 12, 0, 5
ShowFullStairs 2 = always

<Floors -2 to 45>
	StairwellSets() #Determine stairs' size

	Set 21 = -80 #Center X
	Set 22 = 30 + 12.5 #Center Z
	Set 23 = 4.5 #Cut X
	Set 24 = 12 #Cut Z
	Set 25 = 2 #Stairwell Number
	Set 26 = 0.5 #Riser Size

	#Walls
	WallOrientation = right
	DrawWalls = false, true, false, false, false, false
	AddStairsWall %25%, Stair%25%Front, StairsWall, 0.5, -%23%, -%24%, %23%, -%24%, %fullheight%, %fullheight%, -%interfloorheight%, -%interfloorheight%, 0, 0
	AddStairsWall %25%, Stair%25%Left, StairsWall, 0.5, -%23%, -%24%, -%23%, %24%, %fullheight%, %fullheight%, -%interfloorheight%, -%interfloorheight%, 0, 0
	WallOrientation = left
	DrawWalls = true, false, false, false, false, false
	AddStairsWall %25%, Stair%25%Right, StairsWall, 0.5, %23%, -%24%, %23%, %24%, %fullheight%, %fullheight%, -%interfloorheight%, -%interfloorheight%, 0, 0
	AddStairsWall %25%, Stair%25%Back, StairsWall, 0.5, -%23%, %24%, %23%, %24%, %fullheight%, %fullheight%, -%interfloorheight%, -%interfloorheight%, 0, 0

	WallOrientation = center
	DrawWalls = true, true, true, true, false, true
	AddStairsWall %25%, Stair%25%Center, StairsWall2, 1, 0, %24% - 5 - %NumSteps%, 0, %24% - 5, %fullheight%, %fullheight%, -%interfloorheight%, -%interfloorheight%, 0, 0

	DrawWalls = true, true, true, true, true, true
	if[%floor% = 0] AddStairsWall %25%, Stair%25%Center_T1, StairsWall2, 1, 0, %24% - 5 - 12, 0, %24% - 5 - 9, %interfloorheight% + 3, %interfloorheight% + 3, -%interfloorheight%, -%interfloorheight%, 0, 0

	#Railing
	WallOrientation = left
	DrawWalls = true, true, true, true, true, true
	if[%floor% = 45] AddStairsWall %25%, Stair%25%Rail, StairsWall2, 0.5, -%23%, %24% - 5 - %NumSteps%, -%23% + 4, %24% - 5 - %NumSteps%, 0.5 + 3.5, 0.5 + 3.5, -0.5, -0.5, 0, 0

	#Ceiling
	FloorOrientation = top
	DrawWalls = true, false, false, false, false, false
	if[%floor% = 45] AddStairsFloor %25%, Stairs%25%Ceiling, StairsCeiling, 0.5, -%23%, -%24%, %23%, %24%, %height%, %height%, false, false, 0, 0

	#Stairs
	Set NumStepsU2 = %NumSteps% * 2
	Set NumStepsU3 = %NumSteps% * 3

	OP_Draw(true, true, true, true, true, true)
	if[%floor% < 45] OP_OrthoStair(%25%, ST%25%_LowerStairs, Stairs, -%23%, -%23% + 4, front, %24% - 5 - %NumSteps%, %NumSteps%, 1, %26%, 0, 0.5)
	if[%floor% < 45] OP_OrthoStair(%25%, ST%25%_UpperStairs, Stairs, %23% - 4, %23%, back, %24% - 5, %NumSteps%, 1, %26%, %26% * %NumSteps%, 0.5)
	if[%DblStairs% = true] OP_OrthoStair(%25%, ST%25%_LowerStairsEX, Stairs, -%23%, -%23% + 4, front, %24% - 5 - %NumSteps%, %NumSteps%, 1, %26%, %26% * %NumStepsU2%, 0.5)
	if[%DblStairs% = true] OP_OrthoStair(%25%, ST%25%_UpperStairsEX, Stairs, %23% - 4, %23%, back, %24% - 5, %NumSteps%, 1, %26%, %26% * %NumStepsU3%, 0.5)

	#Landings
	FloorOrientation = top
	DrawWalls = true, true, false, false, false, false
	if[%floor% = -2] AddStairsFloor %25%, Stairs%25%LandingLower, StairsFloor, 0.5, -%23%, -%24%, %23%, %24%, 0, 0, false, false, 0, 0
	if[%floor% > -2 & %floor% ! 0] AddStairsFloor %25%, Stairs%25%LandingLower, StairsFloor, 0.5, -%23%, -%24%, %23%, %24% - 5 - %NumSteps%, 0, 0, false, false, 0, 0
	if[%floor% = 0] AddStairsFloor %25%, Stairs%25%LandingLower, StairsFloor, 0.5, -%23%, -%24%, %23%, %24% - 5 - 12, 0, 0, false, false, 0, 0
	if[%floor% < 45] AddStairsFloor %25%, Stairs%25%LandingUpper, StairsFloor, 0.5, -%23%, %24% - 5, %23%, %24%, %26% * %NumSteps%, %26% * %NumSteps%, false, false, 0, 0

	if[%floor% = 0] AddStairsFloor %25%, Stairs%25%Transition2, StairsFloor, 0.5, -%23%, %24% - 5 - 12, -%23% + 4, %24% - 5 - 9, 0, 0, false, false, 0, 0
	if[%floor% = 2] AddStairsFloor %25%, Stairs%25%Transition2, StairsFloor, 0.5, %23% - 4, %24% - 5 - 12, %23%, %24% - 5 - 9, 0, 0, false, false, 0, 0

	if[%DblStairs% = true] AddStairsFloor %25%, Stairs%25%LandingLowerEX, StairsFloor, 0.5, -%23%, -%24%, %23%, %24% - 5 - %NumSteps%, %26% * %NumStepsU2%, %26% * %NumStepsU2%, false, false, 0, 0
	if[%DblStairs% = true] AddStairsFloor %25%, Stairs%25%LandingUpperEX, StairsFloor, 0.5, -%23%, %24% - 5, %23%, %24%, %26% * %NumStepsU3%, %26% * %NumStepsU3%, false, false, 0, 0

	#Floor Signs
	Set Suffix = %floorid%
	Set SignCenterPoint = 0

	DrawWalls = false, true, false, false, false, false
	AddStairsWall %25%, ST%25%FloorSign, BlankSign%Suffix%, 0, %SignCenterPoint% - 0.75, -%24% + 0.001, %SignCenterPoint% + 0.75, -%24% + 0.001, 1.5, 1.5, 3.75, 3.75, 0, 0

	#Doors
	WallOrientation = right
	TextureOverride ServiceDoor2B, ServiceDoor2, ServiceDoor2Side, ServiceDoor2Side, ServiceDoor2Side, ServiceDoor2Side
	if[%floor% ! 0] AddStairsDoor %25%, , , false, ServiceDoor2, 0.2, 2, 75, -%23%, -%24% + 2, 3, 7, 0, 0, 0
	WallOrientation = left
	TextureOverride ServiceDoor2, ServiceDoor2B, ServiceDoor2Side, ServiceDoor2Side, ServiceDoor2Side, ServiceDoor2Side
	if[%floor% = 0] AddStairsDoor %25%, , , false, ServiceDoor2, 0.2, 1, 75, -%23% - 0.5, -%24% + 2, 3, 7, 0, 0, 0

		#Filler walls
		WallOrientation = right
		AddFillerWalls ConnectionWall, 0.5, %21% - %23%, %22% - %24% + 2, 3, 7 - 0.001, %interfloorheight%, false, 0, 0, true

	#Exit Signs
	Set SignTex = ExitSign
	if[%floor% < 0] Set SignTex = ExitSignUp

	if[%floor% ! 0] AddBoxSign(Stair%25%_SignMain, %SignTex%, StainlessSteel, StainlessSteel, 0.1, false, true, true, %21% - %23% - 0.55, %22% - %24% + 2, 1.8, 0.9, %interfloorheight% + 7.2, true)
	if[%floor% = 0] AddBoxSign(Stair%25%_SignStreet, StainlessSteel, ExitSign, StainlessSteel, 0.1, false, true, true, %21% - %23% + 0.05, %22% - %24% + 2, 1.8, 0.9, %interfloorheight% + 7.2, true)
<EndFloors>
