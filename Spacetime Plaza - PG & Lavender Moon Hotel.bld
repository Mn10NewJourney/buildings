		AddWall FrontWall, ExtFacade, 0.5, -%1% + 0.5, %2% - 200, -%1% + 200 - 0.5, %2% - 200, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
