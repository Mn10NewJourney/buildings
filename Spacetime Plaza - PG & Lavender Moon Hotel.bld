#EXTERNAL SHAFT/STAIRWELL WALLS

#Parking elevators
<Floors -2 to 13>
	TexPrefix()

	Set ShowFront = false
	if[%floor% < 0] Set ShowFront = true

	if[%floor% ! 0] CreateShaftWall(%5%Wall, %5%Wall, %5%Wall, %5%%5L%, %5%Wall, %5%Wall, 0.33, -150, -124, 24, 6, LMH_SH1, %SHeight%, %SOffset%, %ShowFront%, true, true, true, false, false, true)
	if[%floor% ! 0] CreateShaftWall(%5%%5L%, %5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, -150, -96, 24, 6, LMH_SH2, %SHeight%, %SOffset%, true, true, true, false, false, false, true)

	if[%floor% = 0] CreateShaftWall(%5%Wall, HotelEntranceWall, %5%Wall, HotelEntranceWall, %5%Wall, %5%Wall, 0.33, -150, -124, 24, 6, LMH_SH1, %SHeight%, %SOffset%, %ShowFront%, true, true, true, false, false, true)
	if[%floor% = 0] CreateShaftWall(HotelEntranceWall, HotelEntranceWall, %5%Wall, HotelEntranceWall, %5%Wall, %5%Wall, 0.33, -150, -96, 24, 6, LMH_SH2, %SHeight%, %SOffset%, true, true, true, true, false, false, true)
<EndFloors>

<Floors 14 to 18>
	TexPrefix()

	if[%floor% ! 0] CreateShaftWall(%5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, -150, -124, 24, 6, LMH_SH1, %SHeight%, %SOffset%, false, true, true, true, false, false, true)
	if[%floor% ! 0] CreateShaftWall(%5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, -150, -96, 24, 6, LMH_SH2, %SHeight%, %SOffset%, true, true, true, false, false, false, true)
<EndFloors>

