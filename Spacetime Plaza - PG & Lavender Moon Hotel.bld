<Textures>
	#Floor signs (Elevator lobby)
	Load data/Melvin/ABH_Tex/NewFS256/FloorSignBack.png, ELFlrSignBack, 1, 1, false #1st and 14th-16th floors
	AddText ELFlrSignBack, ELFlrSign1, nimbus_sans.ttf, 117, 1, -1, -1, -1, -1, center, center, 0, 0, 0, false
	#AddTextRange 14, 16, ELFlrSignBack, ELFlrSign%number%, nimbus_sans.ttf, 117, %number%, -1, -1, -1, -1, center, center, 0, 0, 0, false

	#Floor signs (Stairwells)
	AddTextRange 1, 2, Blank, BlankSignB%number%, nimbus_sans_bold.ttf, 72, B%number%, -1, -1, -1, -1, center, center, 0, 0, 0, false
	AddTextRange 1, 42, Blank, BlankSign%number%, nimbus_sans_bold.ttf, 72, %number%, -1, -1, -1, -1, center, center, 0, 0, 0, false
	AddText Blank, BlankSign3A, nimbus_sans_bold.ttf, 72, 3A, -1, -1, -1, -1, center, center, 0, 0, 0, false
