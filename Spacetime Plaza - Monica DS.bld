#Button creation function (Elevators 1-3)
<Function BtnPanelE1-6>
	Set PanelNumber = %param1%
	Set Prefix = Button #Floor buttons
	
		#Prefixes for door control buttons
		Set Prefix_DC = TextButton

	AddButton %PanelNumber%, , %Prefix_DC%Open, %Prefix_DC%Open, 1, 1, open, 1, 1
	AddButton %PanelNumber%, , %Prefix_DC%Close, %Prefix_DC%Close, 1, 2, close, 1, 1

	AddButton %PanelNumber%, , %Prefix%8, %Prefix%Lit8, 4, 2, 8, 1, 1
	AddButton %PanelNumber%, , %Prefix%7, %Prefix%Lit7, 5, 2, 6, 1, 1
	AddButton %PanelNumber%, , %Prefix%6, %Prefix%Lit6, 6, 2, 5, 1, 1
	AddButton %PanelNumber%, , %Prefix%5, %Prefix%Lit5, 7, 2, 4, 1, 1
	AddButton %PanelNumber%, , %Prefix%4, %Prefix%Lit4, 8, 2, 3, 1, 1

	AddButton %PanelNumber%, , %Prefix%3, %Prefix%Lit3, 5, 1, 2, 1, 1
	AddButton %PanelNumber%, , %Prefix%2, %Prefix%Lit2, 6, 1, 1, 1, 1
	AddButton %PanelNumber%, , %Prefix%1, %Prefix%Lit1, 7, 1, 0, 1, 1
	AddButton %PanelNumber%, , %Prefix%B1, %Prefix%LitB1, 8, 1, -1, 1, 1
	AddButton %PanelNumber%, , %Prefix%B2, %Prefix%LitB2, 9, 1, -2, 1, 1
<EndFunction>

<Function HitachiElev_Intercom>
	Set PanelNumber = %param1%
	Set Prefix = Button

	AddButton %PanelNumber%, , %Prefix%Alarm, %Prefix%Alarm, 3, 1, alarm, 1, 1
	AddButton %PanelNumber%, , %Prefix%Alarm_Label, %Prefix%Alarm_Label, 3, 2, off, 2, 1, 0.5, 0
<EndFunction>

<Elevators 1 to 3>
	Set Prefix = West
	DisplayFloors = -2 - 6, 8

	#Set textures and dimensions
	M10_ElevCabTex(ElevExt3, %Prefix%ElevFloor, %Prefix%ElevCeiling, %Prefix%ElevWall, %Prefix%ElevWall)
	M10_ElevDimensions(6.5, 7, 8, 1.5, 0.2, true, true, false, true)
	M10_ElevPanels(%Prefix%ElevPanelMain, %Prefix%ElevPanelTop, 1.5, 1.5, 1, 0.2, false, false, true, false)

	#Finish elevator assembly
	M10_ElevInterior()
	#--------------------
	#DETAILED INTERIORS
	#1. Ceiling lights
	Set LightWidth = 2.4
	Set LightLength = 3.6

	Cut elevator, 0 - (%LightWidth% / 2), 8 - 0.1, 0 - (%LightLength% / 2), 0 + (%LightWidth% / 2), 8 + 0.1, 0 + (%LightLength% / 2), false, true

		#Light creation
		Set LightOffset1 = 8.25
		Set LightOffset2 = 8
		Set LEHight = %LightOffset1% - %LightOffset2% #LE = Light Edge

		CreateWallBox2 elevator, Light1_Edge, %Prefix%ElevCeilingLight2, 0, 0, %LightWidth%, %LightLength%, %LEHight%, %LightOffset2%, 0, 0, true, false, false, false 
		CreateWallBox2 elevator, Light1_Main, %Prefix%ElevCeilingLight3, 0, 0, %LightWidth%, %LightLength%, 0.1, %LightOffset1% - 0.1, 0, 0, false, true, true, true 

	#2. Panels on walls
	Set WPTex = %Prefix%ElevWallPanel
	Set WPanelHeight = 8 - 0.5

		#Front panels
		CreateWallBox2 elevator, Panel_B1, %WPTex%, 0 - (6.1 * 1/4), -3.3 + 0.01, (6.1 * 1/2) - 0.3, 0.02, %WPanelHeight%, 0.25, 0, 0, false, true, true, true
		CreateWallBox2 elevator, Panel_B2, %WPTex%, 0 + (6.1 * 1/4), -3.3 + 0.01, (6.1 * 1/2) - 0.3, 0.02, %WPanelHeight%, 0.25, 0, 0, false, true, true, true

		#Back panels
		CreateWallBox2 elevator, Panel_B1, %WPTex%, 0 - (6.1 * 1/4), 3.3 - 0.01, (6.1 * 1/2) - 0.3, 0.02, %WPanelHeight%, 0.25, 0, 0, false, true, true, true
		CreateWallBox2 elevator, Panel_B2, %WPTex%, 0 + (6.1 * 1/4), 3.3 - 0.01, (6.1 * 1/2) - 0.3, 0.02, %WPanelHeight%, 0.25, 0, 0, false, true, true, true

		#Left panels
		CreateWallBox2 elevator, Panel_L1, %WPTex%, -3.05 + 0.01, 0 - (6.6 * 1/4), 0.02, (6.6 * 1/2) - 0.3, %WPanelHeight%, 0.25, 0, 0, false, true, true, true
		CreateWallBox2 elevator, Panel_L2, %WPTex%, -3.05 + 0.01, 0 + (6.6 * 1/4), 0.02, (6.6 * 1/2) - 0.3, %WPanelHeight%, 0.25, 0, 0, false, true, true, true
	#--------------------
	#Car Doors
	Set ElevDoorTex = %Prefix%ElevDoors
	Set IDP = 3.25

	WallOrientation = left
	AddDoorComponent 1, Left, %ElevDoorTex%, %ElevDoorTex%, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	AddDoorComponent 1, Right, %ElevDoorTex%2, %ElevDoorTex%2, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	FinishDoors 1, false, false

		#Door track
		FloorOrientation = top
		DrawWalls = true, true, true, true, true, true
		TextureOverride ElevExt, ElevDoorTrackX, ElevExt, ElevExt, ElevExt, ElevExt
		AddFloor DoorTrack, ElevDoorTrackX, 0.05, %IDP%, -2 - (2 * 1), %IDP% + 0.2, 2 + (2 * 1), 0, 0, 0, 0
	#--------------------
	#Right Panels
	Set P1_PositionX = 3.05 - 0.001
	Set P1_PositionZ = -2.65

		#Floor buttons
		CreateWallBox2 elevator, RightPB, ElevPanel, %P1_PositionX% + 0.001 - 0.025, %P1_PositionZ%, 0.05, 0.6, 3.5, 2.5, 0, 0, false, true, true, true
		CreatePanel Blank, 9, 2, left, %P1_PositionX% - 0.05, %P1_PositionZ%, 0.3, 0.3, -0.2, -0.400, 4, 0, 0
		BtnPanelE1-6(1)
		
		#Intercom panel
		CreatePanel BlackPanel, 3, 3, left, %P1_PositionX% - 0.05, %P1_PositionZ%, 0.1, 0.1, 0.2, 0.2, 5.25, 0, 0
		HitachiElev_Intercom(2)
	#--------------------
	#Left Panel
	Set P2_PositionX = 3.05 - 0.001
	Set P2_PositionZ = 2.65

		#Floor buttons
		CreateWallBox2 elevator, LeftPB, ElevPanel, %P2_PositionX% + 0.001 - 0.025, %P2_PositionZ%, 0.05, 0.6, 2.75, 2.5, 0, 0, false, true, true, true
		CreatePanel Blank, 9, 2, left, %P2_PositionX% - 0.05, %P2_PositionZ%, 0.3, 0.3, -0.2, -0.400, 4, 0, 0
		BtnPanelE1-6(3)
	#--------------------
	#Floor indicator
	AddFloorIndicator Ind_Button, left, 3.05 - 0.001, 0, 0.8, 0.4, 7.25 - 0.2

	#Elevator number sign
	DrawWalls = true, false, false, false, false, false
	AddWall ElevNo%elevator%_Inside, IN_ElevNo%elevator%, 0, %P1_PositionX%, %P1_PositionZ% - 0.25, %P1_PositionX%, %P1_PositionZ% + 0.25, 0.5, 0.5, 6.25, 6.25, 0, 0
	#--------------------
	#Shaft components
	DrawWalls = true, true, true, true, true, true
		#Ropes
		RopePosition = 0, 8 + 1.5, 0
		RopeTexture = Ropes
	
		#Counterweight
		Set Position = -3.25 - 0.75

		CreateCounterweight CWeight_Frame, CWeight, %Position%, 0, 0.5, 6, 2, 0.5
	
		#Rails
		AddRails ElevRail, ElevRailSide, 0, 0, true, 3.5 + 0.06, 0.1
		AddRails ElevRail, ElevRailSide, %Position%, 0, true, 1 + 0.06, 0.1
<EndElevators>

#East Elevators
<Elevator 4>
	Name = Monica DS East Elevator 1
	Speed = 5
	Acceleration = 0.6
	Deceleration = 0.6
	ServicedFloors = -2 - 6, 8
	AssignedShaft = 2
	CreateElevator true, -1.92, 10, 0
<EndElevator>

<Elevator 5>
	Name = Monica DS East Elevator 2
	Speed = 5
	Acceleration = 0.6
	Deceleration = 0.6
	ServicedFloors = -2 - 6, 8
	AssignedShaft = 2
	CreateElevator true, -1.92, 0, 0
<EndElevator>

<Elevator 6>
	Name = Monica DS East Elevator 3
	Speed = 5
	Acceleration = 0.6
	Deceleration = 0.6
	ServicedFloors = -2 - 6, 8
	AssignedShaft = 2
	CreateElevator true, -1.92, -10, 8
<EndElevator>

<Elevators 4 to 6>
	DisplayFloors = -2 - 6, 8
	Set Prefix = East
	AutoEnable = false

	#Set textures and dimensions
	M10_ElevCabTex(ElevExt2, %Prefix%ElevFloor, %Prefix%ElevCeiling, %Prefix%ElevWall, %Prefix%ElevWall)
	M10_ElevDimensions(3.84, 6, 8, 1.5, 0.2, true, false, false, true)
	M10_ElevPanels(%Prefix%ElevPanelMain, %Prefix%ElevPanelTop, 1, 1, 1, 0.2, false, true, false, false)

	#Finish elevator assembly
	M10_ElevInterior()
	#--------------------
	#Interior walls detailing
		#1. Panoramic cab
		Floors and ceiling
		DrawWalls = true, false, false, false, false, false
		AddCustomFloor elevator, FloorInt, %Prefix%ElevFloor, 1.92, -3, 1.92 + 2, -3, 1.92 + 3.66, -1.5, 1.92 + 3.66, 1.5, 1.92 + 2, 3, 1.92, 3, 0, 0, 0
		DrawWalls = false, true, false, false, false, false
		AddCustomFloor elevator, FloorExt, ElevExt2, 1.92, -3, 1.92 + 2, -3, 1.92 + 3.66, -1.5, 1.92 + 3.66, 1.5, 1.92 + 2, 3, 1.92, 3, -1.5, 0, 0
		DrawWalls = true, true, false, false, false, false
		AddCustomFloor elevator, Ceiling, Blank, 1.92, -3, 1.92 + 2, -3, 1.92 + 3.66, -1.5, 1.92 + 3.66, 1.5, 1.92 + 2, 3, 1.92, 3, 8 + 1.5, 0, 0

		#Floor covering walls
		DrawWalls = true, false, false, false, false, false
		AddWall GlassWall1_Ext, ElevExt2, 0, 1.92, -3, 1.92 + 2, -3, 1.5, 1.5, -1.5, -1.5, 0, 0
		AddWall GlassWall2_Ext, ElevExt2, 0, 1.92 + 2, -3, 1.92 + 3.66, -1.5, 1.5, 1.5, -1.5, -1.5, 0, 0
		DrawWalls = false, true, false, false, false, false
		AddWall GlassWall3_Ext, ElevExt2, 0, 1.92 + 3.66, -1.5, 1.92 + 3.66, 1.5, 1.5, 1.5, -1.5, -1.5, 0, 0
		DrawWalls = false, true, false, false, false, false
		AddWall GlassWall4_Ext, ElevExt2, 0, 1.92 + 3.66, 1.5, 1.92 + 2, 3, 1.5, 1.5, -1.5, -1.5, 0, 0
		AddWall GlassWall5_Ext, ElevExt2, 0, 1.92 + 2, 3, 1.92, 3, 1.5, 1.5, -1.5, -1.5, 0, 0

		#Glass walls
		DrawWalls = true, true, false, false, false, false
		AddWall GlassWall1, %Prefix%ElevWallGlass, 0, 1.92, -3, 1.92 + 2, -3, 8 + 1.5, 8 + 1.5, 0, 0, 0, 0
		AddWall GlassWall2, %Prefix%ElevWallGlass, 0, 1.92 + 2, -3, 1.92 + 3.66, -1.5, 8 + 1.5, 8 + 1.5, 0, 0, 0, 0
		AddWall GlassWall3, %Prefix%ElevWallGlass, 0, 1.92 + 3.66, -1.5, 1.92 + 3.66, 1.5, 8 + 1.5, 8 + 1.5, 0, 0, 0, 0
		AddWall GlassWall4, %Prefix%ElevWallGlass, 0, 1.92 + 3.66, 1.5, 1.92 + 2, 3, 8 + 1.5, 8 + 1.5, 0, 0, 0, 0
		AddWall GlassWall5, %Prefix%ElevWallGlass, 0, 1.92 + 2, 3, 1.92, 3, 8 + 1.5, 8 + 1.5, 0, 0, 0, 0

		#2. Walls
		WallOrientation = right
		DrawWalls = false, true, false, false, false, false
		AddWall LeftInt-Link, %Prefix%ElevWall, 0, 1.92, -3, 1.92, -2.8, 8, 8, 0, 0, 0, 0
		WallOrientation = right
		DrawWalls = false, true, false, false, false, false
		AddWall RightInt-Link, %Prefix%ElevWall, 0, 1.92, 2.8, 1.92, 3, 8, 8, 0, 0, 0, 0
		WallOrientation = left
		DrawWalls = false, true, true, true, true, true
		AddWall CeilingDeco, %Prefix%ElevCeilingDeco, 0.01, 1.92, -3, 1.92, 3, 1.5, 1.5, 8, 8, 0, 0

		#3. Ceiling lights
		Set LightOffset = 8 - 0.001
		Set LightOffset2 = 8 - 0.002
		Set DLOffset = 8 - 0.001 #Offsets for downlights
		
		DrawWalls = true, false, false, false, false, false
		AddFloor CeilingLight, %Prefix%ElevCeilingLight, 0, 0.1 - 1.5, -2, 0.1 + 1.5, 2, %LightOffset%, %LightOffset%, 0, 0
		AddFloor CeilingGrid, %Prefix%ElevCeilingGrid, 0, 0.1 - 1.5, -2, 0.1 + 1.5, 2, %LightOffset2%, %LightOffset2%, 6, 8

		AddFloor Downlight1/1, %Prefix%ElevCeilingDL, 0, 0.1 - 1.2 - 0.085, 2.3 - 0.085, 0.1 - 1.2 + 0.085, 2.3 + 0.085, %DLOffset%, %DLOffset%, 0, 0
		AddFloor Downlight1/2, %Prefix%ElevCeilingDL, 0, 0.1 + 1.2 - 0.085, 2.3 - 0.085, 0.1 + 1.2 + 0.085, 2.3 + 0.085, %DLOffset%, %DLOffset%, 0, 0
		AddFloor Downlight2/1, %Prefix%ElevCeilingDL, 0, 0.1 - 1.2 - 0.085, -2.3 - 0.085, 0.1 - 1.2 + 0.085, -2.3 + 0.085, %DLOffset%, %DLOffset%, 0, 0
		AddFloor Downlight2/2, %Prefix%ElevCeilingDL, 0, 0.1 + 1.2 - 0.085, -2.3 - 0.085, 0.1 + 1.2 + 0.085, -2.3 + 0.085, %DLOffset%, %DLOffset%, 0, 0

		#4. Panels on walls
		Set WPTex = %Prefix%ElevWallPanel

		CreateWallBox2 elevator, Panel_Front, %WPTex%, 0.1, -2.8 + 0.01, 2, 0.02, 8 - 1.5 - 0.08, 0.75, 0, 0, false, true, true, true
		CreateWallBox2 elevator, Panel_Back, %WPTex%, 0.1, 2.8 - 0.01, 2, 0.02, 8 - 1.5 - 0.08, 0.75, 0, 0, false, true, true, true
	#--------------------
	#Car Doors
	Set ElevDoorTex = %Prefix%ElevDoors
	Set IDP = -1.92

	WallOrientation = right
	AddDoorComponent 1, Left, %ElevDoorTex%, %ElevDoorTex%Side, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	AddDoorComponent 1, Right, %ElevDoorTex%2, %ElevDoorTex%2Side, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	FinishDoors 1, false, false

		#Door Track
		FloorOrientation = top
		DrawWalls = true, true, true, true, true, true
		TextureOverride ElevExt, ElevDoorTrackX, ElevExt, ElevExt, ElevExt, ElevExt
		AddFloor DoorTrack, ElevDoorTrackX, 0.05, -2.12, -(2 * 2), -1.92, 2 * 2, 0, 0, 0, 0
	#--------------------
	#Right Panels
	Set P1_PositionX = -1.72 + 0.001
	Set P1_PositionZ = 2.4

		#Floor buttons
		CreateWallBox2 elevator, RightPB, ElevPanel, %P1_PositionX% - 0.001 + 0.025, %P1_PositionZ%, 0.05, 0.6, 3.5, 2.5, 0, 0, false, true, true, true
		CreatePanel Blank, 9, 2, right, %P1_PositionX% + 0.05, %P1_PositionZ%, 0.3, 0.3, -0.2, -0.400, 4, 0, 0
		BtnPanelE1-6(1)
		
		#Intercom panel
		CreatePanel BlackPanel, 3, 3, right, %P1_PositionX% + 0.05, %P1_PositionZ%, 0.1, 0.1, 0.2, 0.2, 5.25, 0, 0
		HitachiElev_Intercom(2)
	#--------------------
	#Left Panel
	Set P2_PositionX = -1.72 + 0.001
	Set P2_PositionZ = -2.4

		#Floor buttons
		CreateWallBox2 elevator, LeftPB, ElevPanel, %P2_PositionX% - 0.001 + 0.025, %P2_PositionZ%, 0.05, 0.6, 2.75, 2.5, 0, 0, false, true, true, true
		CreatePanel Blank, 9, 2, right, %P2_PositionX% + 0.05, %P2_PositionZ%, 0.3, 0.3, -0.2, -0.400, 4, 0, 0
		BtnPanelE1-6(3)
	#--------------------
	#Floor indicator
	AddFloorIndicator Ind_Button, right, -1.72 + 0.001, 0, 0.8, 0.4, 7.25 - 0.2

	#Elevator number sign
	DrawWalls = false, true, false, false, false, false
	AddWall ElevNo%elevator%_Inside, IN_ElevNo%elevator%, 0, %P1_PositionX%, %P1_PositionZ% - 0.25, %P1_PositionX%, %P1_PositionZ% + 0.25, 0.5, 0.5, 6.25, 6.25, 0, 0
	#--------------------
	#Shaft components
	DrawWalls = true, true, true, true, true, true
		#Ropes
		RopePosition = 0, 9.5, 0
		RopeTexture = Ropes
	
		#Counterweight
		if[%elevator% < 6] Set Position = 3 + 0.75
		if[%elevator% = 6] Set Position = -3 - 0.75
	
		CreateCounterweight CWeight_Frame, CWeight, -0.5, %Position%, 2, 6, 0.5, 0.5
	
		#Rails
		AddRails ElevRail, ElevRailSide, 0, 0, true, 3 + 0.06, 0.1
		AddRails ElevRail, ElevRailSide, -0.5, %Position%, false, 1 + 0.06, 0.1
<EndElevators>

#HALL STATIONS
#Set textures
<Function ElevHallTex>
	#Shaft doors
	TexPrefix() #Set prefixes for shaft doors
	Set DoorTexture = %5%ShaftDoors

	#Use automatic filler walls or not
	Set AutoFiller = false

	#Door trims
		#Sides
		Set DoorTrimTexture = %DoorTexture%_Trim

		#Top
		Set DoorTrimTexture_Top = %DoorTrimTexture%

	#Deco dimensions
		Set SideDecoH = 7.2
		Set TopDecoH = 0.2
		#if[%floor% > 5] Set SideDecoH = %height%
		if[%floor% > 5] Set SideDecoH = %height% + Floor(%floor% + 1).FullHeight
		if[%floor% > 5] Set TopDecoH = %SideDecoH% - 7

	#Call button panels
	Set BPanelTexture = ElevExtPanels
	Set ButtonPrefix = Button

	#Lantern panels
	Set LPanelTexture = %BPanelTexture%
	Set LanternPrefix = Lantern

		#Lateral offset for lantern panels
		Set ExtraLateralOffset = 0
		if[%floor% > 5] Set ExtraLateralOffset = 0.05
<EndFunction>

<Function ElevHallTex_E4-6>
	#Shaft doors
	TexPrefix() #Set prefixes for shaft doors
	
		#Override for glass doors
		#if[%floor% > -1 & %floor% < 6] Set 5 = DG
		#if[%floor% > 5] Set 5 = Glass
		if[%floor% > -1] Set 5 = Glass

	Set DoorTexture = %5%ShaftDoors

	#Use automatic filler walls or not
	Set AutoFiller = false

	#Door trims
		#Sides
		Set DoorTrimTexture = %DoorTexture%_Trim

		#Top
		Set DoorTrimTexture_Top = %DoorTrimTexture%

	#Deco dimensions
		Set SideDecoH = 7.2
		Set TopDecoH = 0.2
		#if[%floor% > 5] Set SideDecoH = %height% + Floor(%floor% + 1).FullHeight
		#if[%floor% > 5] Set TopDecoH = %SideDecoH% - 7

	#Call button panels
	Set BPanelTexture = ElevExtPanels
	Set ButtonPrefix = Button

	#Lantern panels
	Set LPanelTexture = %BPanelTexture%
	Set LanternPrefix = Lantern

		#Lateral offset for lantern panels
		Set ExtraLateralOffset = 0
		#if[%floor% > 5] Set ExtraLateralOffset = 0.05
<EndFunction>

#West Elevators
<Function E1-3HallStation>
	#Shaft Doors
	ElevHallTex() #Set shaft door and panel textures
	Set StartNo = 1 #Number of the first elevator

	Set IDP = 3.25 + 0.3

	WallOrientation = left
	AddShaftDoorComponent %StartNo%, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo%, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo%, 1, %AutoFiller%, false

	WallOrientation = left
	AddShaftDoorComponent %StartNo% + 1, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo% + 1, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo% + 1, 1, %AutoFiller%, false

	WallOrientation = left
	AddShaftDoorComponent %StartNo% + 2, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo% + 2, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo% + 2, 1, %AutoFiller%, false

	#Door tracks
	AddShaftTrack(1, 1, 4.14, 4.34, -10 - 3.5, -10 + 3.5, ElevDoorTrackX, ElevExt, 0.05, 1, 7)
	AddShaftTrack(2, 1, 4.14, 4.34, 0 - 3.5, 0 + 3.5, ElevDoorTrackX, ElevExt, 0.05, 1, 7)
	AddShaftTrack(3, 1, 4.14, 4.34, 10 - 3.5, 10 + 3.5, ElevDoorTrackX, ElevExt, 0.05, 1, 7)

	#****************************************#

	#Door trims/fillers
	WallTex() #Set filler textures to match with shaft walls
	Set Shaft1CX = -115 #1st shaft for elevator bank
	Set Shaft1CZ = -30

		#Levels B2-6
		WallOrientation = right
		if[%floor% < 6] AddFillerWalls %5%%5L%, 0.66, %Shaft1CX% + 5, %Shaft1CZ% - 10, 4, 7, %interfloorheight%, false, 0, 0, true #Elevator 1
		if[%floor% < 6] AddFillerWalls %5%%5L%, 0.66, %Shaft1CX% + 5, %Shaft1CZ% - 0, 4, 7, %interfloorheight%, false, 0, 0, true #Elevator 2
		if[%floor% < 6] AddFillerWalls %5%%5L%, 0.66, %Shaft1CX% + 5, %Shaft1CZ% + 10, 4, 7, %interfloorheight%, false, 0, 0, true #Elevator 3

		#Levels 7-8
		if[%floor% > 5] AddDecoObject(Elev1_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, right, true, false, 0.05, 0.2, %Shaft1CX% + 5, %Shaft1CZ% - 10, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		if[%floor% > 5] AddDecoObject(Elev2_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, right, true, false, 0.05, 0.2, %Shaft1CX% + 5, %Shaft1CZ% - 0, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		if[%floor% > 5] AddDecoObject(Elev3_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, right, true, false, 0.05, 0.2, %Shaft1CX% + 5, %Shaft1CZ% + 10, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)

	#****************************************#

	#Call buttons
	CallButtonElevators = 1, 2, 3
	CreateCallButtons %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft1CX% + 5.001, %Shaft1CZ% - 5, 3.5, right, 0.5, 1, true, 0, 0
	CreateCallButtons %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft1CX% + 5.001, %Shaft1CZ% + 5, 3.5, right, 0.5, 1, true, 0, 0

		#Signs
		Set Suffix = %floorid%

		DrawWalls = false, true, false, false, false, false
		if[%floor% > -1 & %floor% < 6] AddWall E1-3FloorSign1, ELFlrSign%Suffix%, 0, %Shaft1CX% + 5 + 0.001, %Shaft1CZ% + 5 - 0.5, %Shaft1CX% + 5 + 0.001, %Shaft1CZ% + 5 + 0.5, 1, 1, 5.5 + %interfloorheight%, 5.5 + %interfloorheight%, 0, 0, true
		if[%floor% > -1 & %floor% < 6] AddWall E1-3FloorSign2, ELFlrSign%Suffix%, 0, %Shaft1CX% + 5 + 0.001, %Shaft1CZ% - 5 - 0.5, %Shaft1CX% + 5 + 0.001, %Shaft1CZ% - 5 + 0.5, 1, 1, 5.5 + %interfloorheight%, 5.5 + %interfloorheight%, 0, 0, true

		if[%floor% < 0 | %floor% > 5] AddWall E1-3FloorSign1, BlankSign%Suffix%, 0, %Shaft1CX% + 5 + 0.001, %Shaft1CZ% + 5 - 0.75, %Shaft1CX% + 5 + 0.001, %Shaft1CZ% + 5 + 0.75, 1.5, 1.5, 6 - 0.75 + %interfloorheight%, 6 - 0.75 + %interfloorheight%, 0, 0, true
		if[%floor% < 0 | %floor% > 5] AddWall E1-3FloorSign2, BlankSign%Suffix%, 0, %Shaft1CX% + 5 + 0.001, %Shaft1CZ% - 5 - 0.75, %Shaft1CX% + 5 + 0.001, %Shaft1CZ% - 5 + 0.75, 1.5, 1.5, 6 - 0.75 + %interfloorheight%, 6 - 0.75 + %interfloorheight%, 0, 0, true

		AddWall E1-3HallSign, ElevHallSign, 0, %Shaft1CX% + 5 + 0.001, %Shaft1CZ% - 5 - 0.25, %Shaft1CX% + 5 + 0.001, %Shaft1CZ% - 5 + 0.25, 0.75, 0.75, 2.6 + %interfloorheight%, 2.6 + %interfloorheight%, 0, 0, true

	#****************************************#

	#Indicator sets
	Set Offset = 7.5

		#Set textures
		ACMEInd_LanternTex(%LanternPrefix%Up, %LanternPrefix%UpLit, %LanternPrefix%Down, %LanternPrefix%DownLit, %LPanelTexture%, OutsideInd_Button)

		#Indicator creation
		ACMELobbyInds(right, 1, %Shaft1CX% + 5 + %ExtraLateralOffset%, %Shaft1CZ% - 10, %Offset%, -2, 8, true)
		ACMELobbyInds(right, 2, %Shaft1CX% + 5 + %ExtraLateralOffset%, %Shaft1CZ% - 0, %Offset%, -2, 8, true)
		ACMELobbyInds(right, 3, %Shaft1CX% + 5 + %ExtraLateralOffset%, %Shaft1CZ% + 10, %Offset%, -2, 8, true)
<EndFunction>

#East Elevators
<Function E4-6HallStation>
	#Shaft Doors
	ElevHallTex_E4-6() #Set shaft door and panel textures
	Set StartNo = 4 #Number of the first elevator

	Set IDP = -1.92 - 0.3

	WallOrientation = right
	AddShaftDoorComponent %StartNo%, 1, Left, %DoorTexture%, %DoorTexture%Side, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo%, 1, Right, %DoorTexture%2, %DoorTexture%2Side, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo%, 1, %AutoFiller%, false

	WallOrientation = right
	AddShaftDoorComponent %StartNo% + 1, 1, Left, %DoorTexture%, %DoorTexture%Side, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo% + 1, 1, Right, %DoorTexture%2, %DoorTexture%2Side, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo% + 1, 1, %AutoFiller%, false

	WallOrientation = right
	AddShaftDoorComponent %StartNo% + 2, 1, Left, %DoorTexture%, %DoorTexture%Side, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo% + 2, 1, Right, %DoorTexture%2, %DoorTexture%2Side, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo% + 2, 1, %AutoFiller%, false

	#Door tracks
	AddShaftTrack(4, 2, -4.34, -4.14, 10 - 4, 10 + 4, ElevDoorTrackX, ElevExt, 0.05, 1, 7)
	AddShaftTrack(5, 2, -4.34, -4.14, 0 - 4, 0 + 4, ElevDoorTrackX, ElevExt, 0.05, 1, 7)
	AddShaftTrack(6, 2, -4.34, -4.14, -10 - 4, -10 + 4, ElevDoorTrackX, ElevExt, 0.05, 1, 7)

	#****************************************#

	#Door trims/fillers
	WallTex() #Set filler textures to match with shaft walls
	Set Shaft1CX = 60 #1st shaft for elevator bank
	Set Shaft1CZ = 0

		#Levels B2-B1
		WallOrientation = left
		if[%floor% < 0] AddFillerWalls %5%%5L%, 0.66, %Shaft1CX% - 5, %Shaft1CZ% + 10, 4, 7, %interfloorheight%, false, 0, 0, true #Elevator 4
		if[%floor% < 0] AddFillerWalls %5%%5L%, 0.66, %Shaft1CX% - 5, %Shaft1CZ% - 0, 4, 7, %interfloorheight%, false, 0, 0, true #Elevator 5
		if[%floor% < 0] AddFillerWalls %5%%5L%, 0.66, %Shaft1CX% - 5, %Shaft1CZ% - 10, 4, 7, %interfloorheight%, false, 0, 0, true #Elevator 6

		#Levels 1-8
		if[%floor% > -1] AddDecoObject(Elev4_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, left, true, false, 0.05, 0.2, %Shaft1CX% - 5, %Shaft1CZ% + 10, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		if[%floor% > -1] AddDecoObject(Elev5_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, left, true, false, 0.05, 0.2, %Shaft1CX% - 5, %Shaft1CZ% - 0, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		if[%floor% > -1] AddDecoObject(Elev6_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, left, true, false, 0.05, 0.2, %Shaft1CX% - 5, %Shaft1CZ% - 10, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)

	#****************************************#

	#Call buttons
	CallButtonElevators = 4, 5, 6
	CreateCallButtons %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft1CX% - 5.001, %Shaft1CZ% - 5, 3.5, left, 0.5, 1, true, 0, 0
	CreateCallButtons %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft1CX% - 5.001, %Shaft1CZ% + 5, 3.5, left, 0.5, 1, true, 0, 0

		#Signs
		Set Suffix = %floorid%

		DrawWalls = true, false, false, false, false, false
		if[%floor% > -1 & %floor% < 6] AddWall E1-3FloorSign1, ELFlrSign%Suffix%, 0, %Shaft1CX% - 5.001, %Shaft1CZ% + 5 - 0.5, %Shaft1CX% - 5.001, %Shaft1CZ% + 5 + 0.5, 1, 1, 5.5 + %interfloorheight%, 5.5 + %interfloorheight%, 0, 0, true
		if[%floor% > -1 & %floor% < 6] AddWall E1-3FloorSign2, ELFlrSign%Suffix%, 0, %Shaft1CX% - 5.001, %Shaft1CZ% - 5 - 0.5, %Shaft1CX% - 5.001, %Shaft1CZ% - 5 + 0.5, 1, 1, 5.5 + %interfloorheight%, 5.5 + %interfloorheight%, 0, 0, true

		if[%floor% < 0 | %floor% > 5] AddWall E1-3FloorSign1, BlankSign%Suffix%, 0, %Shaft1CX% - 5.001, %Shaft1CZ% + 5 - 0.75, %Shaft1CX% - 5.001, %Shaft1CZ% + 5 + 0.75, 1.5, 1.5, 6 - 0.75 + %interfloorheight%, 6 - 0.75 + %interfloorheight%, 0, 0, true
		if[%floor% < 0 | %floor% > 5] AddWall E1-3FloorSign2, BlankSign%Suffix%, 0, %Shaft1CX% - 5.001, %Shaft1CZ% - 5 - 0.75, %Shaft1CX% - 5.001, %Shaft1CZ% - 5 + 0.75, 1.5, 1.5, 6 - 0.75 + %interfloorheight%, 6 - 0.75 + %interfloorheight%, 0, 0, true

		AddWall E1-3HallSign, ElevHallSign, 0, %Shaft1CX% - 5.001, %Shaft1CZ% + 5 - 0.25, %Shaft1CX% - 5.001, %Shaft1CZ% + 5 + 0.25, 0.75, 0.75, 2.6 + %interfloorheight%, 2.6 + %interfloorheight%, 0, 0, true

	#****************************************#

	#Indicator sets
	Set Offset = 7.5

		#Set textures
		ACMEInd_LanternTex(%LanternPrefix%Up, %LanternPrefix%UpLit, %LanternPrefix%Down, %LanternPrefix%DownLit, %LPanelTexture%, OutsideInd_Button)

		#Indicator creation
		ACMELobbyInds(left, 4, %Shaft1CX% - 5 - %ExtraLateralOffset%, %Shaft1CZ% + 10, %Offset%, -2, 8, true)
		ACMELobbyInds(left, 5, %Shaft1CX% - 5 - %ExtraLateralOffset%, %Shaft1CZ% - 0, %Offset%, -2, 8, true)
		ACMELobbyInds(left, 6, %Shaft1CX% - 5 - %ExtraLateralOffset%, %Shaft1CZ% - 10, %Offset%, -2, 8, true)
<EndFunction>

<Floors -2 to 8>
	if[%floor% ! 7] E1-3HallStation()
	if[%floor% ! 7] E4-6HallStation()
<EndFloors>

#GLOBAL SETTINGS
<Elevators 1 to 6>
	#Notifications
	if[%elevator% < 4] ChimeSound 1 = mechchime9.wav
	if[%elevator% > 3] ChimeSound 1 = KW_Sounds/oldhitachichime1.wav
	ReOpen = false
	ChimeOnArrival = true
	NotifyEarly = 1
	QueueResets = true
	RecallFloor = 0

	#Door settings
	DoorTimer 1 = 12000
	QuickClose 1 = 8000
	OpenSound 1 = EG881Sounds/elevopenquick2.wav #EG881
	CloseSound 1 = EG881Sounds/elevclosequick2.wav #EG881

	#Movement sounds
	MotorStartSound = EG881Sounds/motor_start3.wav #EG881
	MotorRunSound = EG881Sounds/motor_running3.wav #EG881
	MotorStopSound = EG881Sounds/motor_stop3.wav #EG881

	CarStartSound = EG881Sounds/elevstart11.wav #EG881
	CarMoveSound = EG881Sounds/elevmove11.wav #EG881
	CarStopSound = EG881Sounds/elevstop11.wav #EG881
<EndElevators>