	CreateWallBox2 external, Support%Prefix%4, ColumnTex, %SupportX%, %2% - (%DistanceX% * 3), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%5, ColumnTex, %SupportX%, %2% - (%DistanceX% * 4), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%6, ColumnTex, %SupportX%, %2% - (%DistanceX% * 5), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false

	#Row F
	Set Prefix = F
	Set SupportX = %1% - 20 - (%DistanceX% * 5)
	CreateWallBox2 external, Support%Prefix%1, ColumnTex, %SupportX%, %2% - 1.25, 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%2, ColumnTex, %SupportX%, %2% - (%DistanceX% * 1), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%3, ColumnTex, %SupportX%, %2% - (%DistanceX% * 2), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%4, ColumnTex, %SupportX%, %2% - (%DistanceX% * 3), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	#CreateWallBox2 external, Support%Prefix%5, ColumnTex, %SupportX%, %2% - (%DistanceX% * 4), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%6, ColumnTex, %SupportX%, %2% - (%DistanceX% * 5), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
<EndFloors>

#Shopping Area Supports
<Floors 0 to 6>
	#Set Values
	TexPrefix() #Set texture prefixes
	Set DistanceX = 40 #Distance between supports X
	Set DistanceZ = 40 #Distance between supports Z

	Set SupportHeight = %fullheight%
	Set SupportOffset = -%interfloorheight%
	if[%floor% = 0] Set SupportHeight = %height%
	if[%floor% = 0] Set SupportOffset = 0

	#Rows A-F
<EndFloors>

##--------------------------------------------------------------------------------##

#External shaft walls for all shafts
<Floors -2 to 9>
	TexPrefix()

	#West Elevators
	Set ShowLeft = false
	if[%floor% < 0] Set ShowLeft = true

	CreateShaftWall(%5%Wall, %5%Wall, %5%%5L%, %5%Wall, %5%Wall, %5%Wall, 0.33, -115, -30, 5, 15, SH1, %SHeight%, %SOffset%, true, %ShowLeft%, true, true, false, false, true)

	#East Elevators
	if[%floor% < 0] CreateShaftWall(%5%Wall, %5%%5L%, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, 60, 0, 5, 15, SH2, %SHeight%, %SOffset%, true, true, true, true, false, false, true)
	if[%floor% > -1] CreateShaftWall(%5%Wall, %5%%5L%, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, 60 - 2.5, 0, 2.5, 15, SH2, %SHeight%, %SOffset%, true, true, false, true, false, false, true)
<EndFloors>

<Floor 10>
	#West Elevators
	CreateShaftWall(ExtFacade3, ExtFacade3, ExtFacade3, ExtFacade3, ExtFacade3, ExtFacade, 0.33, -115, -30, 5, 15, SH1_RF, %fullheight%, 0, true, false, true, true, true, false, true)
	CreateShaftWall(ExtFacade3, ExtFacade3, ExtFacade3, ExtFacade3, ExtFacade3, ExtFacade, 0.33, 60, 0, 5, 15, SH2_RF, %height%, %interfloorheight%, true, true, true, true, true, false, true)
<EndFloor>

##--------------------------------------------------------------------------------##

#Shafts
#West elevators
AddStdShaft(1, 1, -115, -30, 4.67, 14.67, -3, 10, ShaftIntWall2, 0.5, 0.33, 0, 2 + 5, %interfloorheight%)
ShowFullShaft 1 = true

	<Floor 10>
		#Machine room doors

		#Shaft 1
		Set DTex = ServiceDoor3
		Set DSTex = %DTex%Side
		Set Door_MainX = -115 + 5
		Set Door_MainZ = -30

		WallOrientation = right
		AddStdDoor DoorManager, %floorid%_Shaft1MR_D1, , , false, %DTex%, %DSTex%, 0.2, right, right, 75, 75, %Door_MainX%, %Door_MainZ% + 1.5, 3, 7, Floor(%floor%).Base, 0, 0, 0, 0
		AddStdDoor DoorManager, %floorid%_Shaft1MR_D2, , , false, %DTex%, %DSTex%, 0.2, left, right, 75, 75, %Door_MainX%, %Door_MainZ% - 1.5, 3, 7, Floor(%floor%).Base, 0, 0, 0, 0
		AddFillerWalls ConnectionWall, 0.66 + 0.01, %Door_MainX%, %Door_MainZ%, 6, 7, %interfloorheight%, false, 0, 0, true
	<EndFloor>

#East elevators
AddShaft 2, 60, 0, -3, 10
ShaftCut 2, -4.67 + 0.33, -14.67 + 0.33, 4.67 - 0.33, 14.67 - 0.33, 0, 5
ShaftShowFloors 2 = -2 - 8
ShaftShowOutside 2 = -2 - 8
ShowFullShaft 2 = true

#Shaft pit and base
<Floors -3 to -1>
	Set 8 = 60 #Center X
	Set 9 = 0 #Center Z
	Set 10 = 4.67 #Cut X
	Set 11 = 14.67 #Cut Z
	Set 12 = 2 #Shaft Number
	Set SHWallTex = GLEShaftWall #Wall Texture
	Set FloorThick = 0.5 #Floor/Ceiling Thickness
	Set WallThick = 0.33 #Wall Thickness
	Set ShaftWallHeight = %fullheight%

	#Shaft Floor
	FloorOrientation = bottom
	DrawWalls = false, true, false, false, false, false
	if[%floor% = -3] AddShaftFloor %12%, Shaft%12%-PitBase, %SHWallTex%, %FloorThick%, -%10%, -%11%, %10%, %11%, 0, 0, 0, 0

	#Shaft walls
	WallOrientation = left
	DrawWalls = true, true, false, false, false, false
	AddShaftWall %12%, Shaft%12%Front, %SHWallTex%, %WallThick%, -%10%, -%11%, %10%, -%11%, %ShaftWallHeight%, %ShaftWallHeight%, 0, 0, 0, 0
	AddShaftWall %12%, Shaft%12%Left, %SHWallTex%, %WallThick%, -%10%, -%11%, -%10%, %11%, %ShaftWallHeight%, %ShaftWallHeight%, 0, 0, 0, 0
	WallOrientation = right
	AddShaftWall %12%, Shaft%12%Right, %SHWallTex%, %WallThick%, %10%, -%11%, %10%, %11%, %ShaftWallHeight%, %ShaftWallHeight%, 0, 0, 0, 0
	AddShaftWall %12%, Shaft%12%Back, %SHWallTex%, %WallThick%, -%10%, %11%, %10%, %11%, %ShaftWallHeight%, %ShaftWallHeight%, 0, 0, 0, 0
<EndFloors>

#Main span
<Floors 0 to 9>
	Set 8 = 60 #Center X
	Set 9 = 0 #Center Z
	Set 10 = 4.67 #Cut X
	Set 11 = 14.67 #Cut Z
	Set 12 = 2 #Shaft Number
	Set SHWallTex = GLEShaftWall #Wall Texture
	Set FloorThick = 0.5 #Floor/Ceiling Thickness
	Set WallThick = 0.33 #Wall Thickness
	Set ShaftWallHeight = %fullheight%

	#Shaft walls
	WallOrientation = left
	DrawWalls = true, true, false, false, false, false
	AddShaftWall %12%, Shaft%12%Front, %SHWallTex%, %WallThick%, -%10%, -%11%, 0, -%11%, %ShaftWallHeight%, %ShaftWallHeight%, 0, 0, 0, 0
	if[%floor% = 0] AddShaftWall %12%, Shaft%12%FrontEX, %SHWallTex%, %WallThick%, 0, -%11%, %10%, -%11%, %interfloorheight%, %interfloorheight%, 0, 0, 0, 0
	AddShaftWall %12%, Shaft%12%Left, %SHWallTex%, %WallThick%, -%10%, -%11%, -%10%, %11%, %ShaftWallHeight%, %ShaftWallHeight%, 0, 0, 0, 0
	WallOrientation = right
	if[%floor% = 0] AddShaftWall %12%, Shaft%12%RightEX, %SHWallTex%, %WallThick%, %10%, -%11%, %10%, %11%, %interfloorheight%, %interfloorheight%, 0, 0, 0, 0
	AddShaftWall %12%, Shaft%12%Back, %SHWallTex%, %WallThick%, -%10%, %11%, 0, %11%, %ShaftWallHeight%, %ShaftWallHeight%, 0, 0, 0, 0
	if[%floor% = 0] AddShaftWall %12%, Shaft%12%BackEX, %SHWallTex%, %WallThick%, 0, %11%, %10%, %11%, %interfloorheight%, %interfloorheight%, 0, 0, 0, 0
<EndFloors>

<Floors -3 to 10>
	Set WallHeight = %fullheight%
	if[%floor% = 10] Set WallHeight = %interfloorheight%

	#Divider walls
	WallOrientation = center
	DrawWalls = true, true, false, false, false, false
	AddShaftWall %12%, Shaft%12%Divider1, GLEShaftWall, 0.66, -%10%, -5, 0, -5, %WallHeight%, %WallHeight%, 0, 0, 0, 0
	AddShaftWall %12%, Shaft%12%Divider2, GLEShaftWall, 0.66, -%10%, 5, 0, 5, %WallHeight%, %WallHeight%, 0, 0, 0, 0

	#Glass elevator tracks
	Set EachElevWidth = 6.5 #Estimated width for each glass elevator's area
	Set TrackEndpoint = %EachElevWidth% / 2

	WallOrientation = right
	DrawWalls = true, true, false, true, false, false
	AddShaftWall %12%, Shaft%12%Track1, GLETrack, 1, 0, -%11% - 0.33, 0, -10 - %TrackEndpoint%, %WallHeight%, %WallHeight%, 0, 0, 0, 0
	DrawWalls = true, true, true, true, false, false
	AddShaftWall %12%, Shaft%12%Track2, GLETrack, 1, 0, -10 + %TrackEndpoint%, 0, 0 - %TrackEndpoint%, %WallHeight%, %WallHeight%, 0, 0, 0, 0
	AddShaftWall %12%, Shaft%12%Track3, GLETrack, 1, 0, 0 + %TrackEndpoint%, 0, 10 - %TrackEndpoint%, %WallHeight%, %WallHeight%, 0, 0, 0, 0
	DrawWalls = true, true, true, false, false, false
	AddShaftWall %12%, Shaft%12%Track4, GLETrack, 1, 0, 10 + %TrackEndpoint%, 0, %11% + 0.33, %WallHeight%, %WallHeight%, 0, 0, 0, 0
<EndFloors>

#Machine room
<Floor 10>
	Set 8 = 60 #Center X
	Set 9 = 0 #Center Z
	Set 10 = 4.67 #Cut X
	Set 11 = 14.67 #Cut Z
	Set 12 = 2 #Shaft Number
	Set SHWallTex = GLEShaftWall #Wall Texture
	Set SHWallTex2 = ShaftIntWall2
	Set FloorThick = 0.5 #Floor/Ceiling Thickness
	Set WallThick = 0.33 #Wall Thickness

	#Shaft Floor
	FloorOrientation = top
	DrawWalls = true, true, false, false, false, false
	TextureOverride %SHWallTex%, %SHWallTex2%, Blank, Blank, Blank, Blank
	if[%floor% = 10] AddShaftFloor %12%, Shaft%12%-MRBase, %SHWallTex%, %FloorThick%, -%10% + %WallThick%, -%11% + %WallThick%, %10% - %WallThick%, %11% - %WallThick%, %interfloorheight%, %interfloorheight%, 0, 0

	DrawWalls = true, false, false, false, false, false
	if[%floor% = 10] AddShaftFloor %12%, Shaft%12%-MRTop, %SHWallTex2%, %FloorThick%, -%10%, -%11%, %10%, %11%, %fullheight%, %fullheight%, 0, 0

	#Interfloor walls (matching with shaft's main part)
	WallOrientation = left
	DrawWalls = true, true, false, false, false, false
	AddShaftWall %12%, Shaft%12%IF_Front, %SHWallTex%, %WallThick%, -%10%, -%11%, %10%, -%11%, %interfloorheight%, %interfloorheight%, 0, 0, 0, 0
	AddShaftWall %12%, Shaft%12%IF_Left, %SHWallTex%, %WallThick%, -%10%, -%11%, -%10%, %11%, %interfloorheight%, %interfloorheight%, 0, 0, 0, 0
	WallOrientation = right
	AddShaftWall %12%, Shaft%12%IF_Right, %SHWallTex%, %WallThick%, %10%, -%11%, %10%, %11%, %interfloorheight%, %interfloorheight%, 0, 0, 0, 0
	AddShaftWall %12%, Shaft%12%IF_Back, %SHWallTex%, %WallThick%, -%10%, %11%, %10%, %11%, %interfloorheight%, %interfloorheight%, 0, 0, 0, 0

	#Interfloor walls (Bottom covers)
	WallOrientation = left
	DrawWalls = false, false, false, false, false, true
	AddShaftWall %12%, Shaft%12%IF_Front, GLETrack, %WallThick% * 2, -%10%, -%11% - %WallThick%, %10% + %WallThick%, -%11% - %WallThick%, %interfloorheight%, %interfloorheight%, 0, 0, 0, 0
	WallOrientation = right
	AddShaftWall %12%, Shaft%12%IF_Right, GLETrack, %WallThick% * 2, %10% + %WallThick%, -%11% + %WallThick%, %10% + %WallThick%, %11% - %WallThick%, %interfloorheight%, %interfloorheight%, 0, 0, 0, 0
	AddShaftWall %12%, Shaft%12%IF_Back, GLETrack, %WallThick% * 2, -%10%, %11% + %WallThick%, %10% + %WallThick%, %11% + %WallThick%, %interfloorheight%, %interfloorheight%, 0, 0, 0, 0

	#Machine room walls
	WallOrientation = left
	DrawWalls = true, true, false, false, false, false
	AddShaftWall %12%, Shaft%12%MR_Front, %SHWallTex2%, %WallThick%, -%10%, -%11%, %10%, -%11%, %height%, %height%, %interfloorheight%, %interfloorheight%, 0, 0
	AddShaftWall %12%, Shaft%12%MR_Left, %SHWallTex2%, %WallThick%, -%10%, -%11%, -%10%, %11%, %height%, %height%, %interfloorheight%, %interfloorheight%, 0, 0
	WallOrientation = right
	AddShaftWall %12%, Shaft%12%MR_Right, %SHWallTex2%, %WallThick%, %10%, -%11%, %10%, %11%, %height%, %height%, %interfloorheight%, %interfloorheight%, 0, 0
	AddShaftWall %12%, Shaft%12%MR_Back, %SHWallTex2%, %WallThick%, -%10%, %11%, %10%, %11%, %height%, %height%, %interfloorheight%, %interfloorheight%, 0, 0
<EndFloor>

	<Floor 10>
		#Machine room doors

		#Shaft 2
		Set DTex = ServiceDoor3
		Set DSTex = %DTex%Side
		Set Door_MainX = 60 - 5
		Set Door_MainZ = 0

		WallOrientation = left
		AddStdDoor DoorManager, %floorid%_Shaft2MR_D1, , , false, %DTex%, %DSTex%, 0.2, right, left, 75, 75, %Door_MainX%, %Door_MainZ% + 1.5, 3, 7, Floor(%floor%).Base, 0, 0, 0, 0
		AddStdDoor DoorManager, %floorid%_Shaft2MR_D2, , , false, %DTex%, %DSTex%, 0.2, left, left, 75, 75, %Door_MainX%, %Door_MainZ% - 1.5, 3, 7, Floor(%floor%).Base, 0, 0, 0, 0
		AddFillerWalls ConnectionWall, 0.66 + 0.01, %Door_MainX%, %Door_MainZ%, 6, 7, %interfloorheight%, false, 0, 0, true
	<EndFloor>

#Glass panels
<Floor 0>
	Set GLEPanelTex = GLEPanel
	Set WallHeight = 8
	Set TileZ = 1

	#Shaft 2
	Set 12 = 2 #Shaft Number
	DrawWalls = true, true, false, false, false, false
	AddWall Shaft%12%PanelFront, %GLEPanelTex%, 0, 60, -14.34, 64.34, -14.34, %WallHeight%, %WallHeight%, %interfloorheight%, %interfloorheight%, 1, %TileZ%, true
	AddWall Shaft%12%PanelRight, %GLEPanelTex%, 0, 64.34, -14.66, 64.34, 14.34, %WallHeight%, %WallHeight%, %interfloorheight%, %interfloorheight%, 6, %TileZ%, true
	AddWall Shaft%12%PanelBack, %GLEPanelTex%, 0, 60, 14.34, 64.34, 14.34, %WallHeight%, %WallHeight%, %interfloorheight%, %interfloorheight%, 1, %TileZ%, true
<EndFloor>

#Windows above elevator doors
<Floors 0 to 5>
	Set WH = 6
	Set WO = 9

	Add3DWindows(E4Windows, 55, 10, left, 4 + 0.4, %WH%, %WO%, MainWindowsIntB, MainWindowsIntB, GLEShaftWall, 0.66 + 0.01, 1/4, 1)
	Add3DWindows(E5Windows, 55, 0, left, 4 + 0.4, %WH%, %WO%, MainWindowsIntB, MainWindowsIntB, GLEShaftWall, 0.66 + 0.01, 1/4, 1)
	Add3DWindows(E6Windows, 55, -10, left, 4 + 0.4, %WH%, %WO%, MainWindowsIntB, MainWindowsIntB, GLEShaftWall, 0.66 + 0.01, 1/4, 1)
<EndFloors>

<Floors 7 to 9>
	Set WH = 10
	Set WO = -1

	if[%floor% ! 8] Add3DWindows(E4Windows, 55, 10, left, 4 + 0.4, %WH%, %WO%, MainWindowsIntB, MainWindowsIntB, GLEShaftWall, 0.66 + 0.01, 1/4, 1)
	if[%floor% ! 8] Add3DWindows(E5Windows, 55, 0, left, 4 + 0.4, %WH%, %WO%, MainWindowsIntB, MainWindowsIntB, GLEShaftWall, 0.66 + 0.01, 1/4, 1)
	if[%floor% ! 8] Add3DWindows(E6Windows, 55, -10, left, 4 + 0.4, %WH%, %WO%, MainWindowsIntB, MainWindowsIntB, GLEShaftWall, 0.66 + 0.01, 1/4, 1)
<EndFloors>

