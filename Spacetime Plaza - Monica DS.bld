		Load data/panel-back3.jpg, StainlessSteel, 1, 1, false
		Load data/Melvin/ExitSignDown.png, ExitSign, 1, 1, false
		Load data/Melvin/ExitSignUp.png, ExitSignUp, 1, 1, false
		Load data/Melvin/ExitSignLeft.png, ExitSignLeft, 1, 1, false
		Load data/Melvin/ExitSignRight.png, ExitSignRight, 1, 1, false
		Load data/Melvin/ExitSignBoth.png, ExitSignBoth, 1, 1, false
<EndTextures>

############################################################

#Floor Assignments
<Floors -1 to -2>
	ID = B(0 - %floor%)
	Name = Basement Level (0 - %floor%)
	Type = Basement
	Height = 10
	InterfloorHeight = 2
	if[%floor% = -1] Altitude = -10
<EndFloor>

<Floor -3>
	ID = -
	Name = Shaft Pit
	Type = Basement
	Height = 8
	InterfloorHeight = 2
<EndFloor>

<Floor -3>
	ID = -
	Name = Shaft Pit
	Type = Basement
	Height = 8
	InterfloorHeight = 2
<EndFloor>

<Floors 0 to 5>
	ID = %floor% + 1
	Name = Shopping Level %floorid%
	Type = Shopping
	Height = 16
	InterfloorHeight = 2
	if[%floor% = 0] Altitude = 2
<EndFloors>

<Floors 6 to 7>
	if[%floor% = 6] ID = 7
	if[%floor% = 7] ID = 7A
	Name = Shopping Level %floorid%
	Type = Shopping
	Height = 10
	InterfloorHeight = 2
<EndFloors>

<Floors 8 to 9>
	if[%floor% = 8] ID = 8
	if[%floor% = 9] ID = 8A
	Name = Mall Level %floorid%
	Type = Shopping
	Height = 10
	InterfloorHeight = 2
<EndFloors>

<Floor 10>
	ID = R
	Name = Roof
	Type = Roof
	Height = 9.5
	InterfloorHeight = 2
<EndFloor>

#Merge floors
<Floors -2 to 9>
	Group = -2 - 9
<EndFloors>

##--------------------------------------------------------------------------------##

#Common values
Set 1 = 120 #Building Dimension X (Full width: 240 ft.)
Set 2 = 110 #Building Dimension Z (Full length: 220 ft.)

#Landscape
DrawWalls = false, true, false, false, false, false

	#Moonlight Square
	AddFloor landscape, MonicaDS_MoonlightSquare, EastSquareFloor, 0, %1%, -%2%, %1% + 150, %2%, 4, 4, 0, 0

##--------------------------------------------------------------------------------##

#Set texture prefixes/suffixes
<Function TexPrefix>
	#Main prefixes
	Set 5 = Shop
	if[%floor% < 0] Set 5 = Parking
	if[%floor% > 5] Set 5 = UpperShop
	
	#Parking lobby suffixes
	Set 5L = Wall
	if[%floor% < 0] Set 5L = LobbyWall

	###************###

	#Set heights for External Shaft/Stairwell walls
	Set SHeight = %fullheight%
	Set SOffset = 0
	if[%floor% = 0] Set SHeight = %height%
	if[%floor% = 0] Set SOffset = %interfloorheight%
	if[%floor% < 0] Set SHeight = %height% + Floor(%floor% + 1).InterfloorHeight - 0.5
	if[%floor% < 0] Set SOffset = %interfloorheight%
<EndFunction>

##--------------------------------------------------------------------------------##

#EXTERIOR & INTERIOR
#Parking levels
<Floors -2 to -1>
	TexPrefix() #Set texture prefix/suffix

	#Floors
	FloorOrientation = top
	DrawWalls = true, true, false, false, false, false
	TextureOverride ParkingCeiling, Road, Blank, Blank, Blank, Blank
	AddFloor MonicaDS_PGFloor, Road, 1, -%1%, -%2%, %1% + 150, %2%, %interfloorheight%, %interfloorheight%, 0, 0, true

	#Ceilings
	FloorOrientation = bottom
	DrawWalls = true, false, false, false, false, false
	if[%floor% = -1] AddFloor MonicaDS_PGCeiling, %5%Ceiling, 0.5, %1%, -%2%, %1% + 150, %2%, %fullheight% + 1, %fullheight% + 1, 0, 0, true

	#Perimeter walls
	TexPrefix() #Set texture prefix/suffix
	if[%floor% ! -1] Set WallHeight = %fullheight%
	if[%floor% = -1] Set WallHeight = %fullheight% + Floor(0).InterfloorHeight
	Set WallOffset = 0

		#Set DrawWalls for Front/Left sides
		DrawWalls = false, true, false, false, false, false

		WallOrientation = left
		#AddWall FrontWall, %5%Wall, 0.5, -%1%, -%2%, %1% + 150, -%2%, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		#AddWall LeftWall, %5%Wall, 0.5, -%1%, -%2%, -%1%, %2%, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		#Set DrawWalls for Right/Back sides
		DrawWalls = true, false, false, false, false, false

		WallOrientation = right
		AddWall RightWall, %5%Wall, 0.5, %1% + 150, -%2%, %1% + 150, %2%, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		AddWall BackWall, %5%Wall, 0.5, -%1%, %2%, %1% + 150, %2%, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
<EndFloors>

########################################

#Shopping levels
<Floors 0 to 9>
	TexPrefix() #Set texture prefix/suffix

	#Floors
	Set ShowBottom = false
	if[%floor% = 0] Set ShowBottom = true

	FloorOrientation = top
	DrawWalls = %ShowBottom%, true, false, false, false, false
	TextureOverride ParkingCeiling, %5%Floor, Blank, Blank, Blank, Blank #1st floor only
	if[%floor% ! 7 & %floor% ! 9] AddFloor MonicaDSFloor, %5%Floor, 1, -%1%, -%2%, %1%, %2%, %interfloorheight%, %interfloorheight%, 0, 0, true
	#if[%floor% = 7] AddFloor Level%floorid%Floor, %5%Floor, 1, 27.5, -80, %1%, %2%, %interfloorheight%, %interfloorheight%, 0, 0, true

	#Ceilings
	FloorOrientation = bottom
	DrawWalls = true, false, false, false, false, false
	if[%floor% ! 6 & %floor% ! 8] AddFloor MonicaDSCeiling, %5%Ceiling, 0.5, -%1%, -%2%, %1%, %2%, %fullheight%, %fullheight%, 0, 0, true
	#if[%floor% = 6] AddFloor Level%floorid%Ceiling, %5%Ceiling, 1, 27.5, -80, %1%, %2%, %fullheight%, %fullheight%, 0, 0, true

	#Perimeter walls
	TexPrefix() #Set texture prefix/suffix
	Set WallHeight = %fullheight%
	Set WallOffset = 0

	#Override for the 1st floor only
	if[%floor% ! 0] Set WallHeight2 = %WallHeight%
	if[%floor% ! 0] Set WallOffset2 = %WallOffset%
	if[%floor% = 0] Set WallHeight2 = %height%
	if[%floor% = 0] Set WallOffset2 = %interfloorheight%

		DrawWalls = true, true, false, false, false, false

		WallOrientation = left
		#TextureOverride ExtFacade, %5%Wall, Blank, Blank, Blank, Blank
		#AddWall FrontWall, %5%Wall, 0.5, -%1%, -%2%, %1%, -%2%, %WallHeight2%, %WallHeight2%, %WallOffset2%, %WallOffset2%, 0, 0, true
		TextureOverride ExtFacade2, %5%Wall, Blank, Blank, Blank, Blank
		AddWall LeftWall, %5%Wall, 0.5, -%1%, -%2%, -%1%, %2%, %WallHeight2%, %WallHeight2%, %WallOffset2%, %WallOffset2%, 0, 0, true

		WallOrientation = right
		DrawWalls = true, true, false, true, false, false
		TextureOverride %5%Wall, ExtFacade, Blank, %5%Wall, Blank, Blank
		AddWall RightWall1, %5%Wall, 0.5, %1%, -%2%, %1%, -30, %WallHeight2%, %WallHeight2%, %WallOffset2%, %WallOffset2%, 0, 0, true

		DrawWalls = true, true, true, false, false, false
		TextureOverride %5%Wall, ExtFacade, %5%Wall, Blank, Blank, Blank
		AddWall RightWall2, %5%Wall, 0.5, %1%, 30, %1%, %2%, %WallHeight2%, %WallHeight2%, %WallOffset2%, %WallOffset2%, 0, 0, true

		DrawWalls = true, true, false, false, false, false
		TextureOverride %5%Wall, ExtFacade, Blank, Blank, Blank, Blank
		AddWall BackWall, %5%Wall, 0.5, -%1%, %2%, %1%, %2%, %WallHeight2%, %WallHeight2%, %WallOffset2%, %WallOffset2%, 0, 0, true

	#Perimeter windows
	Set MyIFloorType = 2
	if[%floor% = 0] Set MyIFloorType = 3
	Set WinHeight = %height%
	if[%floor% > 5] Set WinHeight = %height% + Floor(%floor% + 1).FullHeight

	SetAutoSize = true, false

		#Right windows
		if[%floor% ! 7 & %floor% ! 9] AddCustomWindows(RightWin, ShopWindowsInt, ShopWindows, %1%, -30, %1%, 30, %WinHeight%, 0, 0, %MyIFloorType%, %5%Wall, ExtFacade)

	SetAutoSize = true, true
<EndFloors>

#9th floor roof area
<Floor 10>
	#Roof floor
	FloorOrientation = top
	DrawWalls = false, true, false, false, false, false
	AddFloor Roof, RoofFloor, 0.5, -%1%, -%2%, %1%, %2%, %interfloorheight%, %interfloorheight%, 0, 0, true

	#Roof railings
	Set WallHeight = %interfloorheight% + 5.5
	Set WallOffset = 0

	WallOrientation = Left
	DrawWalls = true, true, true, true, true, false
	#AddWall RF-FrontRail, ExtFacade, 0.5, -%1% + 0.5, -%2%, %1% - 0.5, -%2%, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
	#AddWall RF-LeftRail, ExtFacade, 0.5, -%1%, -%2%, -%1%, %2%, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
	TextureOverride ExtFacade2, ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade
	AddWall RF-LeftRail, ExtFacade, 0.5, -%1%, -%2%, -%1%, %2%, %interfloorheight% + 24, %interfloorheight% + 24, %WallOffset%, %WallOffset%, 0, 0, true

	WallOrientation = Right
	AddWall RF-RightRail, ExtFacade, 0.5, %1%, -%2%, %1%, %2%, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
	AddWall RF-BackRail, ExtFacade, 0.5, -%1% + 0.5, %2%, %1% - 0.5, %2%, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
<EndFloor>

#Atrium cuts
	#Shopping levels
	Cut External, %1% - 60, Floor(0).Base + 5, -30, %1%, Floor(8).Base + 5, 30, false, true #East
	Cut External, -60, Floor(0).Base + 5, -30, -20 + 20, Floor(8).Base + 5, 30, false, true #West

	#Roof cut for skylight
	Cut External, %1% - 60 + 5, Floor(10).Altitude - 1, -30, %1% - 5, Floor(10).Base + 1, 30, false, true #East
	Cut External, -60, Floor(10).Altitude - 1, -30, -20 + 20, Floor(10).Base + 1, 30, false, true #West

<Floor 10>
	#Skylight
	DrawWalls = true, true, false, false, false, false
	TextureOverride SkylightInt, Skylight, Blank, Blank, Blank, Blank
	AddFloor EastSkylight, SkylightInt, 0, %1% - 55, -30, %1% - 5, 30, %interfloorheight%, %interfloorheight%, 5/4, 6, true
	TextureOverride SkylightInt, Skylight, Blank, Blank, Blank, Blank
	AddFloor WestSkylight, SkylightInt, 0, -60, -30, -20 + 20, 30, %interfloorheight%, %interfloorheight%, 6/4, 6, true

	#Skylight atrium cover
	CreateWallBox2 external, EastSLAtriumCover, UpperShopWall2, %1% - 30, 0, 50, 60, %interfloorheight%, -%interfloorheight%, 0, 0, true, false, false, false
	CreateWallBox2 external, WestSLAtriumCover, UpperShopWall2, -30, 0, 60, 60, %interfloorheight%, -%interfloorheight%, 0, 0, true, false, false, false
<EndFloor>

#Atrium railings
<Function AtriumRails-East>
	TexPrefix() #Wall textures
	
	Set Suffix = Wall2

	#East atrium railings
	Set RailingHeight = %interfloorheight% + 3.5
	Set RailingOffset = 0

	WallOrientation = right
	DrawWalls = true, true, true, true, true, false
	AddWall EALeftRailA, %5%%Suffix%, 0.5, %1% - 60, -30.5, %1% - 60, -15, %RailingHeight%, %RailingHeight%, %RailingOffset%, %RailingOffset%, 0, 0, true
	AddWall EALeftRailB, %5%%Suffix%, 0.5, %1% - 60, 15, %1% - 60, 30.5, %RailingHeight%, %RailingHeight%, %RailingOffset%, %RailingOffset%, 0, 0, true
	AddWall EAFrontRail, %5%%Suffix%, 0.5, %1% - 60, -30, %1% - 0.5, -30, %RailingHeight%, %RailingHeight%, %RailingOffset%, %RailingOffset%, 0, 0, true
	WallOrientation = left
	AddWall EABackRail, %5%%Suffix%, 0.5, %1% - 60, 30, %1% - 0.5, 30, %RailingHeight%, %RailingHeight%, %RailingOffset%, %RailingOffset%, 0, 0, true
<EndFunction>

<Floors 1 to 8>
	if[%floor% ! 7] AtriumRails-East()
<EndFloors>

########################################

#Entrance doors
Set Texture = BLKEntDoor
Set SideTexture = BLKEntDoorSide

<Floor 0>
	#EAST DOORS
		#Access point E1
		Set Door_MainX = %1%
		Set Door_MainZ = 15
		WallOrientation = right
		TextureOverride %Texture%Int, %Texture%Ext, %Texture%Side, %Texture%Side, %Texture%Side, %Texture%Side
		AddExternalDoor , , false, %Texture%Int, 0.2, 2, 75, %Door_MainX%, %Door_MainZ% - 1.75, 3.5, 8, %interfloorheight%, 0, 0
		TextureOverride %Texture%Int, %Texture%Ext, %Texture%Side, %Texture%Side, %Texture%Side, %Texture%Side
		AddExternalDoor , , false, %Texture%Int, 0.2, 3, 75, %Door_MainX%, %Door_MainZ% + 1.75, 3.5, 8, %interfloorheight%, 0, 0

		#Access point E2
		Set Door_MainX = %1%
		Set Door_MainZ = -15
		WallOrientation = right
		TextureOverride %Texture%Int, %Texture%Ext, %Texture%Side, %Texture%Side, %Texture%Side, %Texture%Side
		AddExternalDoor , , false, %Texture%Int, 0.2, 2, 75, %Door_MainX%, %Door_MainZ% - 1.75, 3.5, 8, %interfloorheight%, 0, 0
		TextureOverride %Texture%Int, %Texture%Ext, %Texture%Side, %Texture%Side, %Texture%Side, %Texture%Side
		AddExternalDoor , , false, %Texture%Int, 0.2, 3, 75, %Door_MainX%, %Door_MainZ% + 1.75, 3.5, 8, %interfloorheight%, 0, 0
<EndFloor>

########################################

#SUPPORTS
#Parking Garage Supports
<Floors -2 to -1>
	#Set Values
	TexPrefix() #Set texture prefixes
	Set DistanceX = 40 #Distance between supports X
	Set DistanceZ = 40 #Distance between supports Z

	Set SupportHeight = %fullheight%
	if[%floor% = -1] Set SupportHeight = %fullheight% + Floor(0).InterfloorHeight
	Set SupportOffset = -%interfloorheight%
	
	#Row AA
	Set Prefix = AA
	Set SupportX = %1% + 20
	CreateWallBox2 external, Support%Prefix%1, ColumnTex, %SupportX%, %2% - 1.25, 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%2, ColumnTex, %SupportX%, %2% - (%DistanceX% * 1), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%3, ColumnTex, %SupportX%, %2% - (%DistanceX% * 2), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%4, ColumnTex, %SupportX%, %2% - (%DistanceX% * 3), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%5, ColumnTex, %SupportX%, %2% - (%DistanceX% * 4), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%6, ColumnTex, %SupportX%, %2% - (%DistanceX% * 5), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false

