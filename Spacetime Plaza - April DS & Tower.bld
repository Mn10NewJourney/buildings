	AddWall Shaft%12%WindowsRight, MainWindowsIntB, 0, 10, -8.75, 10, -3.75, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 1/4, 1, true
	TextureOverride MainWindowsIntB, MainWindowsB, Blank, Blank, Blank, Blank
	AddWall Shaft%12%WindowsBack, MainWindowsIntB, 0, -10, -3.75, 10, -3.75, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 4/4, 1, true
<EndFloors>

	<Floor 19>
