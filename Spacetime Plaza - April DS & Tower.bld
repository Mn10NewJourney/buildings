<Floors -2 to 6>
	TexPrefix()

	#Store Elevators
	CreateShaftWall(%5%%5L%, %5%Wall, %5%%5L%, %5%Wall, %5%Wall, %5%Wall, 0.33, -105, -25, 5, 15, SH1, %SHeight%, %SOffset%, true, true, true, true, false, false, true)

	#Service Elevators
	Set ShowRight = false
	if[%floor% < 0] Set ShowRight = true
	CreateShaftWall(%5%Wall, %SP%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, 114, -70, 6, 10, SH2, %SHeight%, %SOffset%, true, true, %ShowRight%, true, false, false, true)
<EndFloors>

<Floor 7>
	TexPrefix()

	#Store Elevators
	CreateShaftWall(%5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, -105, -25, 5, 15, SH1_8F, %SHeight%, %SOffset%, true, false, false, false, false, false, true)

	#Manual wall creation (Left and right walls)
	Set WallHeight = %height%
	Set WallOffset = %interfloorheight%

	WallOrientation = left
	DrawWalls = true, false, false, false, false, false
	AddWall Shaft1LeftE_8F, %5%Wall, 0.5, -110, -40, -110, -8.75, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

	WallOrientation = right
	DrawWalls = false, true, false, false, false, false
	AddWall Shaft1RightE_8F, %5%Wall, 0.5, -100, -40, -100, -8.75, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
<EndFloor>

<Floors -2 to 19>
	TexPrefix()

	#Tower Interior Elevators
	CreateShaftWall(%5%Wall, %5%Wall, %5%%5L%, %5%%5L%, %5%Wall, %5%Wall, 0.33, -115, -70, 5, 10, SH3, %SHeight%, %SOffset%, true, false, true, true, false, false, true)
	CreateShaftWall(%5%Wall, %5%%5L%, %5%Wall, %5%%5L%, %5%Wall, %5%Wall, 0.33, -95, -70, 5, 10, SH4, %SHeight%, %SOffset%, true, true, true, true, false, false, true)
<EndFloors>

<Floors 5 to 19>
	TexPrefix()

	#Tower Glass Elevator
	if[%floor% = 5] CreateShaftWall(%5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, 0, -8.75, 10, 5, SH5, %height%, %interfloorheight%, true, true, true, true, false, false, true)
	if[%floor% > 5] CreateShaftWall(%5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, 0, -8.75 - 2.5, 10, 2.5, SH5_Int, %fullheight%, 0, true, true, true, false, false, false, true)

	if[%floor% > 17] CreateShaftWall(ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, 0.33, 0, -8.75 + 2.5, 10, 2.5, SH5_Ext, %fullheight%, 0, false, true, true, true, true, false, true)
<EndFloors>

<Floors 7 to 19>
	TexPrefix()

	#Service Elevators
	CreateShaftWall(%5%Wall, %SP%Wall, %5%Wall, %5%Wall, %5%Wall, %5%Wall, 0.33, 114, -70, 6, 10, SH2, %SHeight%, %SOffset%, true, true, false, true, false, false, true)
<EndFloors>

<Floor 20>
	#Service Elevators
	CreateShaftWall(ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, ExtFacade, 0.33, 114, -70, 6, 10, SH2, %fullheight%, 0, true, true, true, true, true, false, true)
<EndFloor>

