<Function BtnPanelE10-11>
	Set PanelNumber = %param1%
	Set BtnPrefix = ZENButton

	AddButton %PanelNumber%, , %BtnPrefix%19, %BtnPrefix%Lit19, 3, 3, 18, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%18, %BtnPrefix%Lit18, 3, 2, 17, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%17, %BtnPrefix%Lit17, 3, 1, 16, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%16, %BtnPrefix%Lit16, 4, 3, 15, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%15, %BtnPrefix%Lit15, 4, 2, 14, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%14, %BtnPrefix%Lit14, 4, 1, 13, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%13, %BtnPrefix%Lit13, 5, 3, 12, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%12, %BtnPrefix%Lit12, 5, 2, 11, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%11, %BtnPrefix%Lit11, 5, 1, 10, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%10, %BtnPrefix%Lit10, 6, 3, 9, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%9, %BtnPrefix%Lit9, 6, 2, 8, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%8, %BtnPrefix%Lit8, 6, 1, 7, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%7, %BtnPrefix%Lit7, 7, 3, 6, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%6, %BtnPrefix%Lit6, 7, 2, 5, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%5, %BtnPrefix%Lit5, 7, 1, 4, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%4, %BtnPrefix%Lit4, 8, 3, 3, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%3, %BtnPrefix%Lit3, 8, 2, 2, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%2, %BtnPrefix%Lit2, 8, 1, 1, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%1, %BtnPrefix%Lit1, 9, 3, 0, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%B1, %BtnPrefix%LitB1, 9, 2, -1, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%B2, %BtnPrefix%LitB2, 9, 1, -2, 1, 1

	AddButton %PanelNumber%, , %BtnPrefix%Open, %BtnPrefix%Open, 11, 1, open, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%Close, %BtnPrefix%Close, 11, 3, close, 1, 1
	if[%PanelNumber% = 1] AddButton %PanelNumber%, , %BtnPrefix%Alarm, %BtnPrefix%Alarm, 1, 2, alarm, 1, 1
<EndFunction>

<Elevators 10 to 11>
	Set Prefix = Service

	#Set textures and dimensions
	M10_ElevCabTex(ElevExt, %Prefix%ElevFloor, %Prefix%ElevCeiling, %Prefix%ElevWall, %Prefix%ElevWall)
	M10_ElevDimensions(9.28, 6, 8, 0.2, 0.2, true, false, true, true)
	M10_ElevPanels(%Prefix%ElevPanelMain, %Prefix%ElevPanelTop, 1.25, 0.25, 1, 0.2, false, true, false, false)

	#Finish elevator assembly
	M10_ElevInterior()
	#--------------------
	#DETAILED INTERIORS
	#1. Lights
	Set LightWidth = 4.5
	Set LightLength = 3
	Set TrimWidth = 0.2

	CreateWallBox2 elevator, CL_Main, %Prefix%ElevCeilingLight, 0, 0, %LightWidth%, %LightLength%, 0.05, 8 - 0.05, 0, 0, false, true, true, true

	#1a. Trims around lights
	CreateWallBox2 elevator, CL_Trim_Front, %Prefix%ElevCeilingTrim2, 0, 0 - (%LightLength% / 2) - (%TrimWidth% / 2), %LightWidth%, %TrimWidth%, 0.05, 8 - 0.05, 0, 0, false, true, true, true
	CreateWallBox2 elevator, CL_Trim_Back, %Prefix%ElevCeilingTrim2, 0, 0 + (%LightLength% / 2) + (%TrimWidth% / 2), %LightWidth%, %TrimWidth%, 0.05, 8 - 0.05, 0, 0, false, true, true, true
	CreateWallBox2 elevator, CL_Trim_Left, %Prefix%ElevCeilingTrim, 0 - (%LightWidth% / 2) - (%TrimWidth% / 2), 0, %TrimWidth%, %LightLength% + (%TrimWidth% * 2), 0.05, 8 - 0.05, 0, 0, false, true, true, true
	CreateWallBox2 elevator, CL_Trim_Right, %Prefix%ElevCeilingTrim, 0 + (%LightWidth% / 2) + (%TrimWidth% / 2), 0, %TrimWidth%, %LightLength% + (%TrimWidth% * 2), 0.05, 8 - 0.05, 0, 0, false, true, true, true

	#2. Panels on walls
	Set WPTex = %Prefix%ElevWallPanel
	Set WPanelHeight = 8 - 0.5
	
		#Front panels
		CreateWallBox2 elevator, Panel_F1, %WPTex%, 0 - (8.88 * 1/3), -2.8 + 0.01, (8.88 * 1/3) - 0.3, 0.02, %WPanelHeight%, 0.25 + 0.05, 0, 0, false, true, true, true
		CreateWallBox2 elevator, Panel_F2, %WPTex%, 0, -2.8 + 0.01, (8.88 * 1/3) - 0.3, 0.02, %WPanelHeight%, 0.25 + 0.05, 0, 0, false, true, true, true
		CreateWallBox2 elevator, Panel_F3, %WPTex%, 0 + (8.88 * 1/3), -2.8 + 0.01, (8.88 * 1/3) - 0.3, 0.02, %WPanelHeight%, 0.25 + 0.05, 0, 0, false, true, true, true

		#Back panels
		CreateWallBox2 elevator, Panel_B1, %WPTex%, 0 - (8.88 * 1/3), 2.8 - 0.01, (8.88 * 1/3) - 0.3, 0.02, %WPanelHeight%, 0.25 + 0.05, 0, 0, false, true, true, true
		CreateWallBox2 elevator, Panel_B2, %WPTex%, 0, 2.8 - 0.01, (8.88 * 1/3) - 0.3, 0.02, %WPanelHeight%, 0.25 + 0.05, 0, 0, false, true, true, true
		CreateWallBox2 elevator, Panel_B3, %WPTex%, 0 + (8.88 * 1/3), 2.8 - 0.01, (8.88 * 1/3) - 0.3, 0.02, %WPanelHeight%, 0.25 + 0.05, 0, 0, false, true, true, true

		#Right panels
		CreateWallBox2 elevator, Panel_R1, %WPTex%, 4.44 - 0.01, 0 - (5.6 * 1/4), 0.02, (5.6 * 1/2) - 0.3, %WPanelHeight%, 0.25 + 0.05, 0, 0, false, true, true, true
		CreateWallBox2 elevator, Panel_R2, %WPTex%, 4.44 - 0.01, 0 + (5.6 * 1/4), 0.02, (5.6 * 1/2) - 0.3, %WPanelHeight%, 0.25 + 0.05, 0, 0, false, true, true, true
	#--------------------
	#Car Doors
	Set ElevDoorTex = %Prefix%ElevDoors
	Set IDP = -4.64

	WallOrientation = right
	AddDoorComponent 1, 2Speed_Fast, %ElevDoorTex%, %ElevDoorTex%, 0.15, left, 0.8, 0.6, %IDP% - (0.15 * 1), 2.75 - (2.25 * 1), %IDP% - (0.15 * 1), 2.75, 7, 0, 0, 0, 0, 0
	AddDoorComponent 1, 2Speed_Slow, %ElevDoorTex%, %ElevDoorTex%, 0.15, left, 0.4, 0.3, %IDP%, 2.75 - (2.25 * 2), %IDP%, 2.75 - (2.25 * 1), 7, 0, 0, 0, 0, 0
	FinishDoors 1, false, false

		#Door track
		FloorOrientation = top
		DrawWalls = true, true, true, true, true, true
		TextureOverride ElevExt, ElevDoorTrackX, ElevExt, ElevExt, ElevExt, ElevExt
		AddFloor DoorTrack, ElevDoorTrackX, 0.05, %IDP% - (0.15 * 2) - 0.01, 2.75 - (2.25 * 3), %IDP%, 2.75, 0, 0, 0, 0

		#Top filler
		FloorOrientation = bottom
		DrawWalls = true, true, true, true, true, true
		TextureOverride %Prefix%ElevPanelTop, ElevExt, ElevExt, ElevExt, ElevExt, ElevExt
		AddFloor TopFiller, %Prefix%ElevPanelTop, 0.05, %IDP% - (0.15 * 1), 2.75 - (2.25 * 1), %IDP%, 2.75, 7, 7, 0, 0

	#Gap filler
	WallOrientation = right
	DrawWalls = true, true, true, true, true, true
	TextureOverride ElevExt, ElevExt, %Prefix%ElevPanelMain, ElevExt, ElevExt, ElevExt
	AddWall GapFiller, %Prefix%ElevPanelMain, 0.15 * 2, %IDP%, 2.75, %IDP%, 3, 7, 7, 0, 0, 0, 0
	#--------------------
	#Button Panel
	Set P1_PositionX = -4.44 + 0.001
	Set P1_PositionZ = -2.275

		#Right panel
		CreatePanel , 11, 3, right, %P1_PositionX%, %P1_PositionZ%, 0.15, 0.15, 0.125, 0.125, 3.75, 0, 0

			#Buttons
			BtnPanelE10-11(1)
	#--------------------
	#Indicator sets
	Set IndOffset = 5.75 + 0.25 - (0.4 / 2)

		#Right
		DrawWalls = false, true, false, false, false, false
		AddWall RightIndBack, Ind_DarkBlue, 0, %P1_PositionX%, %P1_PositionZ% - 0.3, %P1_PositionX%, %P1_PositionZ% + 0.3, 0.3, 0.3, %IndOffset%, %IndOffset%, 0, 0

		AddFloorIndicator Ind_Button, right, %P1_PositionX% + 0.002, %P1_PositionZ% + 0.15, 0.3, 0.3, %IndOffset%
		AddDirectionalIndicator true, true, true, Blank, Arrow_Blank, Arrow_LitUp, Arrow_Blank, Arrow_LitDown, %P1_PositionX% + 0.002, %P1_PositionZ% - 0.15, %IndOffset% + 0.015, rights, 0.3, 0.275, true, 0, 0

	#Elevator number sign
	DrawWalls = false, true, false, false, false, false
	AddWall ElevNo%elevator%_Inside, IN_ElevNo%elevator%, 0, %P1_PositionX% + 0.001, %P1_PositionZ% - 0.25, %P1_PositionX% + 0.001, %P1_PositionZ% + 0.25, 0.5, 0.5, 6.25, 6.25, 0, 0
	#--------------------
	#Shaft components
	DrawWalls = true, true, true, true, true, true
		#Ropes
		RopePosition = 0, 8 + 0.2, 0
		RopeTexture = Ropes
	
		#Counterweight
		Set Position = -3 - 0.8

		CreateCounterweight CWeight_Frame, CWeight, 0, %Position%, 2, 6, 0.5, 0.5
	
		#Rails
		AddRails ElevRail, ElevRailSide, 0, 0, true, 3 + 0.06, 0.1
		AddRails ElevRail, ElevRailSide, 0, %Position%, false, 1 + 0.06, 0.1
<EndElevators>

#HALL STATIONS
#Set textures (Store elevators)
<Function ElevHallTex-Store>
	TexPrefix() #Set prefixes for shaft doors

	#Shaft doors
	Set DoorTexture = GlassShaftDoors
	if[%floor% < 0] Set DoorTexture = PLShaftDoors

	#Use automatic filler walls or not
	Set AutoFiller = false

	#Door trims
		#Sides
		Set DoorTrimTexture = %DoorTexture%_Trim

		#Top
		Set DoorTrimTexture_Top = %DoorTrimTexture%

	#Deco dimensions
		Set SideDecoH = %height%
		Set TopDecoH = %height% - 7
		if[%floor% < 0] Set SideDecoH = 7.2
		if[%floor% < 0] Set TopDecoH = 0.2

	#Call button panels
	Set BPanelTexture = ElevExtPanels
	Set ButtonPrefix = ZENButton

	#Lantern panels
	Set LPanelTexture = %BPanelTexture%
	Set LanternPrefix = ZENLanternPanel

		#Lateral offset for lantern panels
		Set ExtraLateralOffset = 0
		if[%floor% > -1] Set ExtraLateralOffset = 0.01
<EndFunction>

#Set textures (Tower Glass Elevators)
<Function ElevHallTex-TG>
	TexPrefix() #Set prefixes for shaft doors

	#Shaft doors
	Set DoorTexture = GlassShaftDoors
	if[%floor% = 7] Set DoorTexture = DGShaftDoors #Override for the 8th floor only

	#Use automatic filler walls or not
	Set AutoFiller = false

	#Door trims
		#Sides
		Set DoorTrimTexture = %DoorTexture%_Trim

		#Top
		Set DoorTrimTexture_Top = %DoorTrimTexture%

	#Deco dimensions
		Set SideDecoH = 7.2
		Set TopDecoH = 0.2
		if[%floor% = 6] Set SideDecoH = %height%
		if[%floor% = 6] Set TopDecoH = %height% - 7
		if[%floor% = 7] Set SideDecoH = 8
		if[%floor% = 7] Set TopDecoH = 1

	#Call button panels
	Set BPanelTexture = ElevExtPanels
	Set ButtonPrefix = ZENButton

	#Lantern panels
	Set LPanelTexture = ZENLanternPanel
	#Set LPanelTexture = %BPanelTexture%
	Set LanternPrefix = ZENLantern

		#Lateral offset for lantern panels
		Set ExtraLateralOffset = 0
		#if[%floor% > -1] Set ExtraLateralOffset = 0.01
<EndFunction>

#Set textures (Tower Interior Elevators)
<Function ElevHallTex-TI>
	TexPrefix() #Set prefixes for shaft doors

	#Shaft doors
	Set DoorTexture = %5%ShaftDoors

	#Use automatic filler walls or not
	Set AutoFiller = false

	#Door trims
		#Sides
		Set DoorTrimTexture = %DoorTexture%_Trim

		#Top
		Set DoorTrimTexture_Top = %DoorTrimTexture%

	#Deco dimensions
		Set SideDecoH = 7.2
		Set TopDecoH = 0.2
		if[%floor% > -1 & %floor% < 7] Set SideDecoH = %height%
		if[%floor% > -1 & %floor% < 7] Set TopDecoH = %height% - 7
		if[%floor% = 7] Set SideDecoH = 8
		if[%floor% = 7] Set TopDecoH = 1

	#Call button panels
	Set BPanelTexture = ElevExtPanels
	Set ButtonPrefix = ZENButton

	#Lantern panels
	Set LPanelTexture = ZENLanternPanel
	#Set LPanelTexture = %BPanelTexture%
	Set LanternPrefix = ZENLantern

		#Lateral offset for lantern panels
		Set ExtraLateralOffset = 0
		#if[%floor% > -1] Set ExtraLateralOffset = 0.01
<EndFunction>

#Store elevators
<Function AprilDS_StoreElev_Ind>
	#Set values
		Set ElevNo = %param1% #Elevtor number
		Set PA = %param2% #Indicator position Z
	
	#Background
	Set WH = 0.6
	Set WO = 4.5 + %interfloorheight%
	DrawWalls = false, true, false, false, false, false
	AddWall E%ElevNo%-PA-IndBG, Ind_DarkBlue, 0, %Shaft1CX% + 5 + 0.051, %PA% - 0.15, %Shaft1CX% + 5 + 0.051, %PA% + 0.15, %WH%, %WH%, %WO%, %WO%, 0, 0, true

	#Directional arrows
	AddDirectionalIndicator %ElevNo%, false, true, true, true, Blank, Arrow_Blank, Arrow_LitUp, Arrow_Blank, Arrow_LitDown, %Shaft1CX% + 5 + 0.051, %PA%, 4.5 + 0.3, right, 0.3, 0.275, false, 0, 0

	#Floor indicators
	AddFloorIndicator %ElevNo%, false, Ind_Button, right, %Shaft1CX% + 5 + 0.052, %PA%, 0.3, 0.3, 4.5
<EndFunction>

<Floors -2 to 6>
	#Shaft Doors
	ElevHallTex-Store() #Set shaft door and panel textures
	Set StartNo = 1 #Number of the first elevator

	Set ElevDoorTex = %Prefix%ElevDoors
	Set IDP = 3.25 + 0.3

	WallOrientation = left
	AddShaftDoorComponent %StartNo%, 1, Left, %DoorTexture%, %DoorTexture%Side, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo%, 1, Right, %DoorTexture%2, %DoorTexture%2Side, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo%, 1, %AutoFiller%, false

	WallOrientation = left
	AddShaftDoorComponent %StartNo% + 1, 1, Left, %DoorTexture%, %DoorTexture%Side, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo% + 1, 1, Right, %DoorTexture%2, %DoorTexture%2Side, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo% + 1, 1, %AutoFiller%, false

	WallOrientation = left
	AddShaftDoorComponent %StartNo% + 2, 1, Left, %DoorTexture%, %DoorTexture%Side, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo% + 2, 1, Right, %DoorTexture%2, %DoorTexture%2Side, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo% + 2, 1, %AutoFiller%, false

	#Door tracks
	AddShaftTrack(1, 1, 4.14, 4.34, -10 - 4, -10 + 4, ElevDoorTrackX, ElevExt, 0.05, 1, 7)
	AddShaftTrack(2, 1, 4.14, 4.34, 0 - 4, 0 + 4, ElevDoorTrackX, ElevExt, 0.05, 1, 7)
	AddShaftTrack(3, 1, 4.14, 4.34, 10 - 4, 10 + 4, ElevDoorTrackX, ElevExt, 0.05, 1, 7)

	#****************************************#

	#Door trims/fillers
	WallTex() #Set filler textures to match with shaft walls
	Set Shaft1CX = -105 #1st shaft for elevator bank
	Set Shaft1CZ = -25

		AddDecoObject(Elev1_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, right, true, false, 0.05, 0.2, %Shaft1CX% + 5, %Shaft1CZ% - 10, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		AddDecoObject(Elev2_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, right, true, false, 0.05, 0.2, %Shaft1CX% + 5, %Shaft1CZ% - 0, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		AddDecoObject(Elev3_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, right, true, false, 0.05, 0.2, %Shaft1CX% + 5, %Shaft1CZ% + 10, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)

	#****************************************#

	#Call buttons
		#Button panels
		CreateWallBox2 external, E1ExtPanel, %BPanelTexture%, %Shaft1CX% + 5 + 0.025, %Shaft1CZ% - 10 + 2 + 0.75, 0.05, 0.3 + 0.2, 1 + 0.6 + 0.15, 3.5, 0, 0, false, true, true, true
		CreateWallBox2 external, E2ExtPanel, %BPanelTexture%, %Shaft1CX% + 5 + 0.025, %Shaft1CZ% - 0 + 2 + 0.75, 0.05, 0.3 + 0.2, 1 + 0.6 + 0.15, 3.5, 0, 0, false, true, true, true
		CreateWallBox2 external, E3ExtPanel, %BPanelTexture%, %Shaft1CX% + 5 + 0.025, %Shaft1CZ% + 10 + 2 + 0.75, 0.05, 0.3 + 0.2, 1 + 0.6 + 0.15, 3.5, 0, 0, false, true, true, true

		#Create buttons
		CallButtonElevators = 1, 2, 3
		CreateCallButtons %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft1CX% + 5 + 0.051, %Shaft1CZ% - 10 + 2 + 0.75, 4 - 0.4, right, 0.35, 0.7, false, 0, 0
		CreateCallButtons %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft1CX% + 5 + 0.051, %Shaft1CZ% - 0 + 2 + 0.75, 4 - 0.4, right, 0.35, 0.7, false, 0, 0
		CreateCallButtons %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft1CX% + 5 + 0.051, %Shaft1CZ% + 10 + 2 + 0.75, 4 - 0.4, right, 0.35, 0.7, false, 0, 0

		#Signs
		WallOrientation = left
		DrawWalls = false, true, false, false, false, false
		AddBoxSign(E1-3_FS1, Blank, BlankSign%floorid%, Blank, 0, false, false, false, %Shaft1CX% + 5.001, %Shaft1CZ% - 5, 1.5, 1.5, 6.5 - 0.75 + %interfloorheight%, true)
		AddBoxSign(E1-3_FS2, Blank, BlankSign%floorid%, Blank, 0, false, false, false, %Shaft1CX% + 5.001, %Shaft1CZ% + 5, 1.5, 1.5, 6.5 - 0.75 + %interfloorheight%, true)

		AddWall E1-3HallSign, ElevHallSign, 0, %Shaft1CX% + 5.001, %Shaft1CZ% + 0 + 2.75 - 0.25, %Shaft1CX% + 5.001, %Shaft1CZ% + 0 + 2.75 + 0.25, 0.75, 0.75, 2.6, 2.6, 0, 0, false

	#****************************************#

	#Indicators above call buttons
	AprilDS_StoreElev_Ind(1, %Shaft1CZ% - 10 + 2 + 0.75)
	AprilDS_StoreElev_Ind(2, %Shaft1CZ% - 0 + 2 + 0.75)
	AprilDS_StoreElev_Ind(3, %Shaft1CZ% + 10 + 2 + 0.75)
<EndFloors>

#Tower Glass Elevators
<Floors 6 to 17>
	#Shaft Doors
	ElevHallTex-TG() #Set shaft door and panel textures
	Set StartNo = 4 #Number of the first elevator

	Set ElevDoorTex = %Prefix%ElevDoors
	Set IDP = 3.25 + 0.3

	Set IDP = -1.92 - 0.3

	WallOrientation = right
	AddShaftDoorComponent %StartNo%, 1, Left, %DoorTexture%, %DoorTexture%Side, 0.2, left, 0.8, 0.6, -2, %IDP%, 0, %IDP%, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo%, 1, Right, %DoorTexture%2, %DoorTexture%2Side, 0.2, right, 0.8, 0.6, 0, %IDP%, 2, %IDP%, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo%, 1, %AutoFiller%, false

	WallOrientation = right
	AddShaftDoorComponent %StartNo% + 1, 1, Left, %DoorTexture%, %DoorTexture%Side, 0.2, left, 0.8, 0.6, -2, %IDP%, 0, %IDP%, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo% + 1, 1, Right, %DoorTexture%2, %DoorTexture%2Side, 0.2, right, 0.8, 0.6, 0, %IDP%, 2, %IDP%, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo% + 1, 1, %AutoFiller%, false

	#Door tracks
	AddShaftTrack(4, 5, -5 - 4, -5 + 4, -4.34, -4.14, ElevDoorTrackZ, ElevExt, 0.05, 1, 7)
	AddShaftTrack(5, 5, 5 - 4, 5 + 4, -4.34, -4.14, ElevDoorTrackZ, ElevExt, 0.05, 1, 7)

	#****************************************#

	#Door trims/fillers
	WallTex() #Set filler textures to match with shaft walls
	Set Shaft1CX = 0 #1st shaft for elevator bank
	Set Shaft1CZ = -8.75

		#Decos on 5th floor
		AddDecoObject(Elev4_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, front, true, false, 0.05, 0.2, %Shaft1CX% - 5, %Shaft1CZ% - 5, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		AddDecoObject(Elev5_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, front, true, false, 0.05, 0.2, %Shaft1CX% + 5, %Shaft1CZ% - 5, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)

	#****************************************#

	#Call buttons
		#Button panels
		CreateWallBox2 external, E4-5ExtPanel, %BPanelTexture%, %Shaft1CX%, %Shaft1CZ% - 5.025, 0.6 + 0.2, 0.05, 1 + 0.6 + 0.15, 3.5, 0, 0, false, true, true, true

		#Create buttons
		CallButtonElevators = 4, 5
		CreateCallButtons %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft1CX%, %Shaft1CZ% - 5.051, 4 - 0.4, front, 0.35, 0.7, false, 0, 0

		#Signs
		WallOrientation = right
		DrawWalls = true, false, false, false, false, false
		if[%floor% ! 7] AddBoxSign(E4-5_FS1, BlankSign%floorid%, Blank, Blank, 0, true, false, false, %Shaft1CX%, %Shaft1CZ% - 5.001, 1.5, 1.5, 6.5 - 0.75 + %interfloorheight%, true)
		if[%floor% = 7] AddBoxSign(E4-5_FS1, ELFlrSign%floorid%, Blank, Blank, 0, true, false, false, %Shaft1CX%, %Shaft1CZ% - 5.001, 1, 1, 7 - 1 + %interfloorheight%, true)

		AddWall E4-5HallSign, ElevHallSign, 0, %Shaft1CX% - 0.25, %Shaft1CZ% - 5.001, %Shaft1CX% + 0.25, %Shaft1CZ% - 5.001, 0.75, 0.75, 2.6, 2.6, 0, 0, false

	#****************************************#

	#Lanterns next to doors
	AddDirectionalIndicator 4, true, false, false, true, %LPanelTexture%, %LanternPrefix%Up, %LanternPrefix%UpLit, %LanternPrefix%Down, %LanternPrefix%DownLit, 2 + 1, -1.92 - 0.5 - 0.661, 6, front, 0.414, 1, true, 0, 0
	AddDirectionalIndicator 5, true, false, false, true, %LPanelTexture%, %LanternPrefix%Up, %LanternPrefix%UpLit, %LanternPrefix%Down, %LanternPrefix%DownLit, -2 - 1, -1.92 - 0.5 - 0.661, 6, front, 0.414, 1, true, 0, 0

	#Indicators above call buttons
		#Background
		Set WH = 0.6	
		Set WO = 4.5 + %interfloorheight%
		DrawWalls = true, false, false, false, false, false
		AddWall E4-5-PA-IndBG, Ind_DarkBlue, 0, %Shaft1CX% - 0.3, %Shaft1CZ% - 5.051, %Shaft1CX% + 0.3, %Shaft1CZ% - 5.051, %WH%, %WH%, %WO%, %WO%, 0, 0, true
	
		#Directional arrows
		AddDirectionalIndicator 4, false, true, true, true, Blank, Arrow_Blank, Arrow_LitUp, Arrow_Blank, Arrow_LitDown, %Shaft1CX% - 0.15, %Shaft1CZ% - 5.051, 4.5 + 0.3, front, 0.3, 0.275, false, 0, 0
		AddDirectionalIndicator 5, false, true, true, true, Blank, Arrow_Blank, Arrow_LitUp, Arrow_Blank, Arrow_LitDown, %Shaft1CX% + 0.15, %Shaft1CZ% - 5.051, 4.5 + 0.3, front, 0.3, 0.275, false, 0, 0
	
		#Floor indicators
		AddFloorIndicator 4, false, Ind_Button, front, %Shaft1CX% - 0.15, %Shaft1CZ% - 5.052, 0.3, 0.3, 4.5
		AddFloorIndicator 5, false, Ind_Button, front, %Shaft1CX% + 0.15, %Shaft1CZ% - 5.052, 0.3, 0.3, 4.5
<EndFloors>

#Tower Interior Elevators
<Function E6-9HallStation>
	#Shaft Doors
	ElevHallTex-TI() #Set shaft door and panel textures
	Set StartNo = 6 #Number of the first elevator

	Set ElevDoorTex = %Prefix%ElevDoors
	Set IDP = 3.25 + 0.3

	WallOrientation = left
	AddShaftDoorComponent %StartNo%, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo%, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo%, 1, %AutoFiller%, false

	WallOrientation = left
	AddShaftDoorComponent %StartNo% + 1, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo% + 1, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo% + 1, 1, %AutoFiller%, false

	Set IDP = -3.25 - 0.3
	WallOrientation = right
	AddShaftDoorComponent %StartNo% + 2, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo% + 2, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo% + 2, 1, %AutoFiller%, false

	WallOrientation = right
	AddShaftDoorComponent %StartNo% + 3, 1, Left, %DoorTexture%, %DoorTexture%, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	AddShaftDoorComponent %StartNo% + 3, 1, Right, %DoorTexture%2, %DoorTexture%2, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	FinishShaftDoor %StartNo% + 3, 1, %AutoFiller%, false

	#Door tracks
	AddShaftTrack(6, 3, 4.14, 4.34, -5 - 4, -5 + 4, ElevDoorTrackX, ElevExt, 0.05, 1, 7)
	AddShaftTrack(7, 3, 4.14, 4.34, 5 - 4, 5 + 4, ElevDoorTrackX, ElevExt, 0.05, 1, 7)
	AddShaftTrack(8, 4, -4.34, -4.14, -5 - 4, -5 + 4, ElevDoorTrackX, ElevExt, 0.05, 1, 7)
	AddShaftTrack(9, 4, -4.34, -4.14, 5 - 4, 5 + 4, ElevDoorTrackX, ElevExt, 0.05, 1, 7)

	#****************************************#

	#Door trims/fillers
	WallTex() #Set filler textures to match with shaft walls
	Set Shaft1CX = -115 #1st shaft for elevator bank
	Set Shaft1CZ = -70
	Set Shaft2CX = -95 #1st shaft for elevator bank
	Set Shaft2CZ = -70

		AddDecoObject(Elev6_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, right, true, false, 0.05, 0.2, %Shaft1CX% + 5, %Shaft1CZ% - 5, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		AddDecoObject(Elev7_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, right, true, false, 0.05, 0.2, %Shaft1CX% + 5, %Shaft1CZ% + 5, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		AddDecoObject(Elev8_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, left, true, false, 0.05, 0.2, %Shaft2CX% - 5, %Shaft2CZ% - 5, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		AddDecoObject(Elev9_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, left, true, false, 0.05, 0.2, %Shaft2CX% - 5, %Shaft2CZ% + 5, 4, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)

	#****************************************#

	#Call buttons
		#Button panels
		CreateWallBox2 external, E6-9ExtPanel1, %BPanelTexture%, %Shaft1CX% + 5.025, %Shaft1CZ%, 0.05, 0.6 + 0.2, 1 + 0.6 + 0.15, 3.5, 0, 0, false, true, true, true
		CreateWallBox2 external, E6-9ExtPanel2, %BPanelTexture%, %Shaft2CX% - 5.025, %Shaft2CZ%, 0.05, 0.6 + 0.2, 1 + 0.6 + 0.15, 3.5, 0, 0, false, true, true, true

		#Create buttons
		CallButtonElevators = 6, 7, 8, 9
		CreateCallButtons %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft1CX% + 5 + 0.051, %Shaft1CZ%, 4 - 0.4, right, 0.35, 0.7, false, 0, 0
		CreateCallButtons %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft2CX% - 5 - 0.051, %Shaft2CZ%, 4 - 0.4, left, 0.35, 0.7, false, 0, 0

		#Signs
		WallOrientation = left
		DrawWalls = false, true, false, false, false, false
		if[%floor% ! 7] AddBoxSign(E6-9_FS1, Blank, BlankSign%floorid%, Blank, 0, false, false, false, %Shaft1CX% + 5.001, %Shaft1CZ%, 1.5, 1.5, 6.5 - 0.75 + %interfloorheight%, true)
		if[%floor% = 7] AddBoxSign(E6-9_FS1, Blank, ELFlrSign%floorid%, Blank, 0, false, false, false, %Shaft1CX% + 5.001, %Shaft1CZ%, 1, 1, 7 - 1 + %interfloorheight%, true)
		AddWall E6-9HallSign1, ElevHallSign, 0, %Shaft1CX% + 5.051, %Shaft1CZ% - 0.25, %Shaft1CX% + 5.051, %Shaft1CZ% + 0.25, 0.75, 0.75, 2.6, 2.6, 0, 0, false

		WallOrientation = right
		DrawWalls = true, false, false, false, false, false
		if[%floor% ! 7] AddBoxSign(E6-9_FS2, BlankSign%floorid%, Blank, Blank, 0, false, false, false, %Shaft2CX% - 5.001, %Shaft2CZ%, 1.5, 1.5, 6.5 - 0.75 + %interfloorheight%, true)
		if[%floor% = 7] AddBoxSign(E6-9_FS2, ELFlrSign%floorid%, Blank, Blank, 0, false, false, false, %Shaft2CX% - 5.001, %Shaft2CZ%, 1, 1, 7 - 1 + %interfloorheight%, true)
		AddWall E6-9HallSign1, ElevHallSign, 0, %Shaft2CX% - 5.051, %Shaft2CZ% - 0.25, %Shaft2CX% - 5.051, %Shaft2CZ% + 0.25, 0.75, 0.75, 2.6, 2.6, 0, 0, false

	#****************************************#

	#Lanterns next to doors
	AddDirectionalIndicator 6, true, false, false, true, %LPanelTexture%, %LanternPrefix%Up, %LanternPrefix%UpLit, %LanternPrefix%Down, %LanternPrefix%DownLit, 3.25 + 0.5 + 0.661, 2 + 1, 6, right, 0.414, 1, true, 0, 0
	AddDirectionalIndicator 7, true, false, false, true, %LPanelTexture%, %LanternPrefix%Up, %LanternPrefix%UpLit, %LanternPrefix%Down, %LanternPrefix%DownLit, 3.25 + 0.5 + 0.661, -2 - 1, 6, right, 0.414, 1, true, 0, 0
	AddDirectionalIndicator 8, true, false, false, true, %LPanelTexture%, %LanternPrefix%Up, %LanternPrefix%UpLit, %LanternPrefix%Down, %LanternPrefix%DownLit, -3.25 - 0.5 - 0.661, 2 + 1, 6, left, 0.414, 1, true, 0, 0
	AddDirectionalIndicator 9, true, false, false, true, %LPanelTexture%, %LanternPrefix%Up, %LanternPrefix%UpLit, %LanternPrefix%Down, %LanternPrefix%DownLit, -3.25 - 0.5 - 0.661, -2 - 1, 6, left, 0.414, 1, true, 0, 0

	#Indicators above call buttons
		#Background
		Set WH = 0.6	
		Set WO = 4.5 + %interfloorheight%
		DrawWalls = false, true, false, false, false, false
		AddWall E6-7-PA-IndBG, Ind_DarkBlue, 0, %Shaft1CX% + 5.051, %Shaft1CZ% - 0.3, %Shaft1CX% + 5.051, %Shaft1CZ% + 0.3, %WH%, %WH%, %WO%, %WO%, 0, 0, true
		DrawWalls = true, false, false, false, false, false
		AddWall E8-9-PA-IndBG, Ind_DarkBlue, 0, %Shaft2CX% - 5.051, %Shaft2CZ% - 0.3, %Shaft2CX% - 5.051, %Shaft2CZ% + 0.3, %WH%, %WH%, %WO%, %WO%, 0, 0, true
	
		#Directional arrows
		AddDirectionalIndicator 6, false, true, true, true, Blank, Arrow_Blank, Arrow_LitUp, Arrow_Blank, Arrow_LitDown, %Shaft1CX% + 5.051, %Shaft1CZ% - 0.15, 4.5 + 0.3, right, 0.3, 0.275, false, 0, 0
		AddDirectionalIndicator 7, false, true, true, true, Blank, Arrow_Blank, Arrow_LitUp, Arrow_Blank, Arrow_LitDown, %Shaft1CX% + 5.051, %Shaft1CZ% + 0.15, 4.5 + 0.3, right, 0.3, 0.275, false, 0, 0
		AddDirectionalIndicator 8, false, true, true, true, Blank, Arrow_Blank, Arrow_LitUp, Arrow_Blank, Arrow_LitDown, %Shaft2CX% - 5.051, %Shaft2CZ% - 0.15, 4.5 + 0.3, left, 0.3, 0.275, false, 0, 0
		AddDirectionalIndicator 9, false, true, true, true, Blank, Arrow_Blank, Arrow_LitUp, Arrow_Blank, Arrow_LitDown, %Shaft2CX% - 5.051, %Shaft2CZ% + 0.15, 4.5 + 0.3, left, 0.3, 0.275, false, 0, 0
	
		#Floor indicators
		AddFloorIndicator 6, false, Ind_Button, right, %Shaft1CX% + 5.052, %Shaft1CZ% - 0.15, 0.3, 0.3, 4.5
		AddFloorIndicator 7, false, Ind_Button, right, %Shaft1CX% + 5.052, %Shaft1CZ% + 0.15, 0.3, 0.3, 4.5
		AddFloorIndicator 8, false, Ind_Button, left, %Shaft2CX% - 5.052, %Shaft2CZ% - 0.15, 0.3, 0.3, 4.5
		AddFloorIndicator 9, false, Ind_Button, left, %Shaft2CX% - 5.052, %Shaft2CZ% + 0.15, 0.3, 0.3, 4.5
<EndFunction>

<Floors -2 to 2>
	if[%floor% ! 1] E6-9HallStation()
<EndFloors>

<Floors 6 to 17>
	if[%floor% ! 1] E6-9HallStation()
<EndFloors>

#Set textures (Service Elevators)
<Function ElevHallTex-Service>
	TexPrefix() #Set prefixes for shaft doors

	#Shaft doors
	Set DoorTexture = %5S%ShaftDoors

	#Use automatic filler walls or not
	Set AutoFiller = false

	#Door trims
		#Sides
		Set DoorTrimTexture = %DoorTexture%_Trim

		#Top
		Set DoorTrimTexture_Top = %DoorTrimTexture%

	#Deco dimensions
		Set SideDecoH = 7.2
		Set TopDecoH = 0.2

	#Call button panels
	Set BPanelTexture = ElevExtPanels
	Set ButtonPrefix = ZENButton

	#Lantern panels
	Set LPanelTexture = ZENLanternPanel
	#Set LPanelTexture = %BPanelTexture%
	Set LanternPrefix = ZENLantern

		#Lateral offset for lantern panels
		Set ExtraLateralOffset = 0
<EndFunction>

<Floors -2 to 18>
	#Shaft Doors
	ElevHallTex-Service() #Set shaft door and panel textures
	Set StartNo = 10 #Number of the first elevator
	Set IDP = -4.64 - 0.4

		WallOrientation = right
		AddShaftDoorComponent %StartNo%, 1, 2Speed_Fast, %DoorTexture%, %DoorTexture%, 0.15, left, 0.8, 0.6, %IDP%, 2.75 - (2.25 * 1), %IDP%, 2.75, 7, 0, -1, 0, -1, 0
		AddShaftDoorComponent %StartNo%, 1, 2Speed_Slow, %DoorTexture%2, %DoorTexture%2, 0.15, left, 0.4, 0.3, %IDP% - (0.15 * 1), 2.75 - (2.25 * 2), %IDP% - (0.15 * 1), 2.75 - (2.25 * 1), 7, 0, 0, 0, 0, 0
		FinishShaftDoor %StartNo%, 1, %AutoFiller%, false
		
		WallOrientation = right
		AddShaftDoorComponent %StartNo% + 1, 1, 2Speed_Fast, %DoorTexture%, %DoorTexture%, 0.15, left, 0.8, 0.6, %IDP%, 2.75 - (2.25 * 1), %IDP%, 2.75, 7, 0, -1, 0, -1, 0
		AddShaftDoorComponent %StartNo% + 1, 1, 2Speed_Slow, %DoorTexture%2, %DoorTexture%2, 0.15, left, 0.4, 0.3, %IDP% - (0.15 * 1), 2.75 - (2.25 * 2), %IDP% - (0.15 * 1), 2.75 - (2.25 * 1), 7, 0, 0, 0, 0, 0
		FinishShaftDoor %StartNo% + 1, 1, %AutoFiller%, false

	#Door tracks
	AddShaftTrack(10, 2, -5.34, -5.04, 6 - 4.5, 6 + 2.25, ElevDoorTrackX, ElevExt, 0.05, 1, 7)
	AddShaftTrack(11, 2, -5.34, -5.04, -4 - 4.5, -4 + 2.25, ElevDoorTrackX, ElevExt, 0.05, 1, 7)

		#Top fillers
		AddShaftTrack(10, 2, -5.34, -5.34 + 0.15, 6, 6 + 2.25, %DoorTrimTexture%, ElevExt, 0.05, 2, 7)
		AddShaftTrack(11, 2, -5.34, -5.34 + 0.15, -4, -4 + 2.25, %DoorTrimTexture%, ElevExt, 0.05, 2, 7)

	#Gap fillers
		WallOrientation = left
		DrawWalls = true, true, true, true, true, true
		TextureOverride ElevExt, ElevExt, %DoorTrimTexture%, %DoorTrimTexture%, ElevExt, ElevExt
		AddShaftWall 2, GapFiller_Elev10, ElevExt, 0.15 * 2, -5.34, 6 + 2.25, -5.34, 6 + 2.25 + 0.25, 7, 7, %interfloorheight%, %interfloorheight%, 0, 0

		TextureOverride ElevExt, ElevExt, %DoorTrimTexture%, %DoorTrimTexture%, ElevExt, ElevExt
		AddShaftWall 2, GapFiller_Elev10, ElevExt, 0.15 * 2, -5.34, -4 + 2.25, -5.34, -4 + 2.25 + 0.25, 7, 7, %interfloorheight%, %interfloorheight%, 0, 0


	#****************************************#

	#Door trims/fillers
	WallTex() #Set filler textures to match with shaft walls
	Set Shaft1CX = 114 #1st shaft for elevator bank
	Set Shaft1CZ = -70

		AddDecoObject(E10_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, left, true, false, 0.05, 0.2, %Shaft1CX% - 6, %Shaft1CZ% + 6, 4.5, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)
		AddDecoObject(E11_Deco, %DoorTrimTexture%, %DoorTrimTexture_Top%, left, true, false, 0.05, 0.2, %Shaft1CX% - 6, %Shaft1CZ% - 4, 4.5, 7, %SideDecoH%, %TopDecoH%, 0, true, %DoorTrimTexture%, 0.66, external)

	#****************************************#

	#Call buttons
		#Button panels
		CreateWallBox2 external, E10-11ExtPanel, %BPanelTexture%, %Shaft1CX% - 6.025, %Shaft1CZ% + 1, 0.05, 0.6 + 0.2, 1 + 0.6 + 0.15, 3.5, 0, 0, false, true, true, true

		#Create buttons
		CallButtonElevators = 10, 11
		CreateCallButtons %BPanelTexture%, %ButtonPrefix%Up, %ButtonPrefix%UpLit, %ButtonPrefix%Down, %ButtonPrefix%DownLit, %Shaft1CX% - 6.051, %Shaft1CZ% + 1, 4 - 0.4, left, 0.35, 0.7, false, 0, 0

		#Signs
		WallOrientation = right
		DrawWalls = true, false, false, false, false, false
		AddBoxSign(E10-11_FS2, ServFlrSign%floorid%, Blank, Blank, 0, false, false, false, %Shaft1CX% - 6.001, %Shaft1CZ% + 1, 1, 1, 7 - 1 + %interfloorheight%, true)
		AddWall E10-11HallSign1, ElevHallSign, 0, %Shaft1CX% - 6.051, %Shaft1CZ% + 1 - 0.25, %Shaft1CX% - 6.051, %Shaft1CZ% + 1 + 0.25, 0.75, 0.75, 2.6, 2.6, 0, 0, false

	#****************************************#

	#Lanterns next to doors
	AddDirectionalIndicator 10, true, false, false, true, %LPanelTexture%, %LanternPrefix%Up, %LanternPrefix%UpLit, %LanternPrefix%Down, %LanternPrefix%DownLit, -4.64 - 0.4 - 0.3 - 0.661, 0.5 - 2.25 - 1, 6, left, 0.414, 1, true, 0, 0
	AddDirectionalIndicator 11, true, false, false, true, %LPanelTexture%, %LanternPrefix%Up, %LanternPrefix%UpLit, %LanternPrefix%Down, %LanternPrefix%DownLit, -4.64 - 0.4 - 0.3 - 0.661, 0.5 - 2.25 - 1, 6, left, 0.414, 1, true, 0, 0

	#Indicators above call buttons
		#Background
		Set WH = 0.6	
		Set WO = 4.5 + %interfloorheight%
		DrawWalls = true, false, false, false, false, false
		AddWall E10-11-PA-IndBG, Ind_DarkBlue, 0, %Shaft1CX% - 6.051, %Shaft1CZ% + 1 - 0.3, %Shaft1CX% - 6.051, %Shaft1CZ% + 1 + 0.3, %WH%, %WH%, %WO%, %WO%, 0, 0, true
	
		#Directional arrows
		AddDirectionalIndicator 10, false, true, true, true, Blank, Arrow_Blank, Arrow_LitUp, Arrow_Blank, Arrow_LitDown, %Shaft1CX% - 6.051, %Shaft1CZ% + 1 + 0.15, 4.5 + 0.3, left, 0.3, 0.275, false, 0, 0
		AddDirectionalIndicator 11, false, true, true, true, Blank, Arrow_Blank, Arrow_LitUp, Arrow_Blank, Arrow_LitDown, %Shaft1CX% - 6.051, %Shaft1CZ% + 1 - 0.15, 4.5 + 0.3, left, 0.3, 0.275, false, 0, 0
	
		#Floor indicators
		AddFloorIndicator 10, false, Ind_Button, left, %Shaft1CX% - 6.052, %Shaft1CZ% + 1 + 0.15, 0.3, 0.3, 4.5
		AddFloorIndicator 11, false, Ind_Button, left, %Shaft1CX% - 6.052, %Shaft1CZ% + 1 - 0.15, 0.3, 0.3, 4.5
<EndFloors>

#GLOBAL SETTINGS
<Elevators 1 to 11>
	#Double-stage chimes
	NotifyEarly = 3

	EarlyUpChimeSound 1 = KW_Sounds/NewOtis_ArriveChime.wav
	EarlyDownChimeSound 1 = KW_Sounds/NewOtis_ArriveChime.wav

	ChimeSound 1 = KW_Sounds/NewOtisChime2.wav

	#Other settings
	QueueResets = true
	LevelingOpen = 0.2
	if[%elevator% ! 4 & %elevator% ! 5] RecallFloor = 0

	#Door settings
	DoorTimer 1 = 15000
	QuickClose 1 = 10000

	#Motor sounds
	MotorStartSound = EG881Sounds/motor_start3.wav #EG881
	MotorRunSound = EG881Sounds/motor_running3.wav #EG881
	MotorStopSound = EG881Sounds/motor_stop3.wav #EG881
<EndElevators>

<Elevators 1 to 3>
	#Elevator movement sounds
	CarStartSound = EG881Sounds/elevstart11.wav #EG881
	CarMoveSound = EG881Sounds/elevmove11.wav #EG881
	CarStopSound = EG881Sounds/elevstop11.wav #EG881

	#Door sounds
	OpenSound 1 = EG881Sounds/elevopen2.wav #EG881
	CloseSound 1 = EG881Sounds/elevclose2.wav #EG881
<EndElevators>

<Elevators 4 to 5>
	#Elevator movement sounds
	CarStartSound = EG881Sounds/elevstart12.wav #EG881
	CarMoveSound = EG881Sounds/elevmove12.wav #EG881
	CarStopSound = EG881Sounds/elevstop12.wav #EG881
<EndElevators>

<Elevators 6 to 9>
	#Elevator movement sounds
	CarStartSound = elevstart5.wav
	CarMoveSound = elevmove5.wav
	CarStopSound = elevstop5.wav
<EndElevators>

<Elevators 4 to 9>
	#Door sounds
	OpenSound 1 = EG881Sounds/elevopenairlock.wav #EG881
	CloseSound 1 = EG881Sounds/elevcloseairlock.wav #EG881
<EndElevators>

<Elevators 10 to 11>
	#Door sounds
	OpenSound 1 = EG881Sounds/freightelevatoropen3.wav #EG881
	CloseSound 1 = EG881Sounds/freightelevatorclose3.wav #EG881
	
	#Elevator movement sounds
	CarStartSound = elevstart3.wav
	CarMoveSound = elevmove3.wav
	CarStopSound = elevstop3.wav
<EndElevators>