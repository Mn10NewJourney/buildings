#Button creation function (Elevators 1-3)
<Function BtnPanelE6-9>
	Set PanelNumber = %param1%
	Set BtnPrefix = ZENButton

	AddButton %PanelNumber%, , %BtnPrefix%18, %BtnPrefix%Lit18, 3, 3, 17, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%17, %BtnPrefix%Lit17, 3, 1, 16, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%16, %BtnPrefix%Lit16, 4, 3, 15, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%15, %BtnPrefix%Lit15, 4, 1, 14, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%14, %BtnPrefix%Lit14, 5, 3, 13, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%13, %BtnPrefix%Lit13, 5, 1, 12, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%12, %BtnPrefix%Lit12, 6, 3, 11, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%11, %BtnPrefix%Lit11, 6, 1, 10, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%10, %BtnPrefix%Lit10, 7, 3, 9, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%9, %BtnPrefix%Lit9, 7, 1, 8, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%8, %BtnPrefix%Lit8, 8, 3, 7, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%7, %BtnPrefix%Lit7, 8, 1, 6, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%3, %BtnPrefix%Lit3, 9, 3, 2, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%1, %BtnPrefix%Lit1, 9, 1, 0, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%B1, %BtnPrefix%LitB1, 10, 3, -1, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%B2, %BtnPrefix%LitB2, 10, 1, -2, 1, 1

	AddButton %PanelNumber%, , %BtnPrefix%Open, %BtnPrefix%Open, 12, 1, open, 1, 1
	AddButton %PanelNumber%, , %BtnPrefix%Close, %BtnPrefix%Close, 12, 3, close, 1, 1
	if[%PanelNumber% = 1] AddButton %PanelNumber%, , %BtnPrefix%Alarm, %BtnPrefix%Alarm, 1, 2, alarm, 1, 1
<EndFunction>

<Elevators 6 to 7>
	Set Prefix = Tower

	#Set textures and dimensions
	M10_ElevCabTex(ElevExt3, %Prefix%ElevFloor, %Prefix%ElevCeiling, %Prefix%ElevWall, %Prefix%ElevWall)
	M10_ElevDimensions(6.5, 7, 8, 0.2, 0.2, true, true, false, true)
	M10_ElevPanels(%Prefix%ElevPanelMain, %Prefix%ElevPanelTop, 1.5, 1.5, 1, 0.2, false, false, true, false)

	#Finish elevator assembly
	M10_ElevInterior()
	#--------------------
	#Car Doors
	Set ElevDoorTex = %Prefix%ElevDoors
	Set IDP = 3.25

	WallOrientation = left
	AddDoorComponent 1, Left, %ElevDoorTex%, %ElevDoorTex%, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	AddDoorComponent 1, Right, %ElevDoorTex%2, %ElevDoorTex%2, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	FinishDoors 1, false, false

		#Door track
		FloorOrientation = top
		DrawWalls = true, true, true, true, true, true
		TextureOverride ElevExt, ElevDoorTrackX, ElevExt, ElevExt, ElevExt, ElevExt
		AddFloor DoorTrack, ElevDoorTrackX, 0.05, %IDP%, -2 - (2 * 1), %IDP% + 0.2, 2 + (2 * 1), 0, 0, 0, 0
	#--------------------
	#Button Panels
	Set Position = -2.65 #Right panel
	Set Position2 = 2.65 #Left panel

		#Panels
		CreatePanel , 12, 3, left, 3.05 - 0.001, %Position%, 0.15, 0.15, 0.125, 0.125, 3.5, 0, 0
		CreatePanel , 12, 3, left, 3.05 - 0.001, %Position2%, 0.15, 0.15, 0.125, 0.125, 3.5, 0, 0

			#Buttons
			BtnPanelE6-9(1)
			BtnPanelE6-9(2)

	#Elevator number sign
	DrawWalls = true, false, false, false, false, false
	AddWall ElevNo%elevator%_Inside, IN_ElevNo%elevator%, 0, 3.05 - 0.001, 0 - 0.25, 3.05 - 0.001, 0 + 0.25, 0.5, 0.5, 7.05, 7.05, 0, 0

	#Indicator sets
	Set IndOffset = 5.75 + 0.25 - (0.4 / 2)

		#Right
		DrawWalls = true, false, false, false, false, false
		AddWall RightIndBack, Ind_DarkBlue, 0, 3.05 - 0.001, %Position% - 0.3, 3.05 - 0.001, %Position% + 0.3, 0.3, 0.3, %IndOffset%, %IndOffset%, 0, 0

		AddFloorIndicator Ind_Button, left, 3.05 - 0.002, %Position% - 0.15, 0.3, 0.3, %IndOffset%
		AddDirectionalIndicator true, true, true, Blank, Arrow_Blank, Arrow_LitUp, Arrow_Blank, Arrow_LitDown, 3.05 - 0.002, %Position% + 0.15, %IndOffset% + 0.015, left, 0.3, 0.275, true, 0, 0

		#Left
		DrawWalls = true, false, false, false, false, false
		AddWall LeftIndBack, Ind_DarkBlue, 0, 3.05 - 0.001, %Position2% - 0.3, 3.05 - 0.001, %Position2% + 0.3, 0.3, 0.3, %IndOffset%, %IndOffset%, 0, 0

		AddFloorIndicator Ind_Button, left, 3.05 - 0.002, %Position2% - 0.15, 0.3, 0.3, %IndOffset%
		AddDirectionalIndicator true, true, true, Blank, Arrow_Blank, Arrow_LitUp, Arrow_Blank, Arrow_LitDown, 3.05 - 0.002, %Position2% + 0.15, %IndOffset% + 0.015, left, 0.3, 0.275, true, 0, 0
	#--------------------
	#Shaft components
	DrawWalls = true, true, true, true, true, true
		#Ropes
		RopePosition = 0, 8 + 0.2, 0
		RopeTexture = Ropes
	
		#Counterweight
		Set Position = -3.25 - 0.75

		CreateCounterweight CWeight_Frame, CWeight, %Position%, 0, 0.5, 6, 2, 0.5
	
		#Rails
		AddRails ElevRail, ElevRailSide, 0, 0, true, 3.5 + 0.06, 0.1
		AddRails ElevRail, ElevRailSide, %Position%, 0, true, 1 + 0.06, 0.1
<EndElevators>

<Elevator 8>
	Name = April Tower Interior Elevator 3
	Speed = 15
	Acceleration = 0.6
	Deceleration = 0.6
	ServicedFloors = -2 - -1, 0, 2, 6 - 17
	AssignedShaft = 4
	CreateElevator true, -0.59, -5, 17
<EndElevator>

<Elevator 9>
	Name = April Tower Interior Elevator 4
	Speed = 15
	Acceleration = 0.6
	Deceleration = 0.6
	ServicedFloors = -2 - -1, 0, 2, 6 - 17
	AssignedShaft = 4
	CreateElevator true, -0.59, 5, 17
<EndElevator>

<Elevators 8 to 9>
	Set Prefix = Tower

	#Set textures and dimensions
	M10_ElevCabTex(ElevExt3, %Prefix%ElevFloor, %Prefix%ElevCeiling, %Prefix%ElevWall, %Prefix%ElevWall)
	M10_ElevDimensions(6.5, 7, 8, 0.2, 0.2, true, false, true, true)
	M10_ElevPanels(%Prefix%ElevPanelMain, %Prefix%ElevPanelTop, 1.5, 1.5, 1, 0.2, false, true, false, false)

	#Finish elevator assembly
	M10_ElevInterior()
	#--------------------
	#Car Doors
	Set ElevDoorTex = %Prefix%ElevDoors
	Set IDP = -3.25

	WallOrientation = right
	AddDoorComponent 1, Left, %ElevDoorTex%, %ElevDoorTex%, 0.2, left, 0.8, 0.6, %IDP%, -2, %IDP%, 0, 7, 0, 0, 0, 0, 0
	AddDoorComponent 1, Right, %ElevDoorTex%2, %ElevDoorTex%2, 0.2, right, 0.8, 0.6, %IDP%, 0, %IDP%, 2, 7, 0, 0, 0, 0, 0
	FinishDoors 1, false, false

		#Door track
		FloorOrientation = top
		DrawWalls = true, true, true, true, true, true
		TextureOverride ElevExt, ElevDoorTrackX, ElevExt, ElevExt, ElevExt, ElevExt
		AddFloor DoorTrack, ElevDoorTrackX, 0.05, %IDP% - 0.2, -2 - (2 * 1), %IDP%, 2 + (2 * 1), 0, 0, 0, 0
	#--------------------
	#Button Panels
	Set Position = 2.65 #Right panel
	Set Position2 = -2.65 #Left panel

		#Panels
		CreatePanel , 12, 3, right, -3.05 + 0.001, %Position%, 0.15, 0.15, 0.125, 0.125, 3.5, 0, 0
		CreatePanel , 12, 3, right, -3.05 + 0.001, %Position2%, 0.15, 0.15, 0.125, 0.125, 3.5, 0, 0

			#Buttons
			BtnPanelE6-9(1)
			BtnPanelE6-9(2)

	#Elevator number sign
	DrawWalls = false, true, false, false, false, false
	AddWall ElevNo%elevator%_Inside, IN_ElevNo%elevator%, 0, -3.05 + 0.001, 0 - 0.25, -3.05 + 0.001, 0 + 0.25, 0.5, 0.5, 7.05, 7.05, 0, 0

	#Indicator sets
	Set IndOffset = 5.75 + 0.25 - (0.4 / 2)

		#Right
		DrawWalls = false, true, false, false, false, false
		AddWall RightIndBack, Ind_DarkBlue, 0, -3.05 + 0.001, %Position% - 0.3, -3.05 + 0.001, %Position% + 0.3, 0.3, 0.3, %IndOffset%, %IndOffset%, 0, 0

		AddFloorIndicator Ind_Button, right, -3.05 + 0.002, %Position% + 0.15, 0.3, 0.3, %IndOffset%
		AddDirectionalIndicator true, true, true, Blank, Arrow_Blank, Arrow_LitUp, Arrow_Blank, Arrow_LitDown, -3.05 + 0.002, %Position% - 0.15, %IndOffset% + 0.015, right, 0.3, 0.275, true, 0, 0

		#Left
		DrawWalls = false, true, false, false, false, false
		AddWall LeftIndBack, Ind_DarkBlue, 0, -3.05 + 0.001, %Position2% - 0.3, -3.05 + 0.001, %Position2% + 0.3, 0.3, 0.3, %IndOffset%, %IndOffset%, 0, 0

		AddFloorIndicator Ind_Button, right, -3.05 + 0.002, %Position2% + 0.15, 0.3, 0.3, %IndOffset%
		AddDirectionalIndicator true, true, true, Blank, Arrow_Blank, Arrow_LitUp, Arrow_Blank, Arrow_LitDown, -3.05 + 0.002, %Position2% - 0.15, %IndOffset% + 0.015, right, 0.3, 0.275, true, 0, 0
	#--------------------
	#Shaft components
	DrawWalls = true, true, true, true, true, true
		#Ropes
		RopePosition = 0, 8 + 0.2, 0
		RopeTexture = Ropes
	
		#Counterweight
		Set Position = 3.25 + 0.75

		CreateCounterweight CWeight_Frame, CWeight, %Position%, 0, 0.5, 6, 2, 0.5
	
		#Rails
		AddRails ElevRail, ElevRailSide, 0, 0, true, 3.5 + 0.06, 0.1
		AddRails ElevRail, ElevRailSide, %Position%, 0, true, 1 + 0.06, 0.1
<EndElevators>

<Elevators 6 to 9>
	RecallFloor = 0

	#DETAILED INTERIORS
	#1. Lights
		#1a. Downlights
		Set DLOffset = 8 - 0.001
		FloorOrientation = top
		DrawWalls = true, false, false, false, true, true
		AddFloor Downlight1/1, %Prefix%ElevCeilingDL, 0, -1.95 - 0.11, 2.45 - 0.11, -1.95 + 0.11, 2.45 + 0.11, %DLOffset%, %DLOffset%, 0, 0
		AddFloor Downlight1/2, %Prefix%ElevCeilingDL, 0, 0 - 0.11, 2.45 - 0.11, 0 + 0.11, 2.45 + 0.11, %DLOffset%, %DLOffset%, 0, 0
		AddFloor Downlight1/3, %Prefix%ElevCeilingDL, 0, 1.95 - 0.11, 2.45 - 0.11, 1.95 + 0.11, 2.45 + 0.11, %DLOffset%, %DLOffset%, 0, 0
		AddFloor Downlight2/1, %Prefix%ElevCeilingDL, 0, -1.95 - 0.11, -2.45 - 0.11, -1.95 + 0.11, -2.45 + 0.11, %DLOffset%, %DLOffset%, 0, 0
		AddFloor Downlight2/2, %Prefix%ElevCeilingDL, 0, 0 - 0.11, -2.45 - 0.11, 0 + 0.11, -2.45 + 0.11, %DLOffset%, %DLOffset%, 0, 0
		AddFloor Downlight2/3, %Prefix%ElevCeilingDL, 0, 1.95 - 0.11, -2.45 - 0.11, 1.95 + 0.11, -2.45 + 0.11, %DLOffset%, %DLOffset%, 0, 0
	
		#1b. Center light
		CreateWallBox2 elevator, E%elevator%_MidLight, %Prefix%ElevCeilingLight, 0, 0, 6.1, 2.5, 0.1, 8 - 0.1, 0, 0, false, true, true, true
	
		#1c. Ceiling trims
		CreateWallBox2 elevator, E%elevator%_Trim1, %Prefix%ElevCeilingTrim, 0, 1.5 - 0.125, 6.1, 0.25, 0.1, 8 - 0.1, 0, 0, false, true, true, true
		CreateWallBox2 elevator, E%elevator%_Trim2, %Prefix%ElevCeilingTrim, 0, -1.5 + 0.125, 6.1, 0.25, 0.1, 8 - 0.1, 0, 0, false, true, true, true

	#2. Panels on walls
	Set WPTex = %Prefix%ElevWallPanel
	Set WPanelHeight = 8

	Set Direction = %param2%

		#Front/back panels
		CreateWallBox2 elevator, E%elevator%Panel_Front, %WPTex%, 0, -3.3 + 0.01, 2, 0.02, %WPanelHeight%, 0, 0, 0, false, true, true, true
		CreateWallBox2 elevator, E%elevator%Panel_Back, %WPTex%, 0, 3.3 - 0.01, 2, 0.02, %WPanelHeight%, 0, 0, 0, false, true, true, true

		#Left/right panels
		if[%elevator% < 8] CreateWallBox2 elevator, E%elevator%Panel_Left, %WPTex%, -3.05 + 0.01, 0, 0.02, 4, %WPanelHeight%, 0, 0, 0, false, true, true, true
		if[%elevator% > 7] CreateWallBox2 elevator, E%elevator%Panel_Right, %WPTex%, 3.05 - 0.01, 0, 0.02, 4, %WPanelHeight%, 0, 0, 0, false, true, true, true
<EndElevators>

