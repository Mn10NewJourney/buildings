#Shafts
#Store elevators
AddStdShaft(1, 1, -105, -25, 4.67, 14.67, -3, 7, ShaftIntWall3, 0.5, 0.33, 0, 2 + 5, %interfloorheight%)
ShowFullShaft 1 = true
ShaftShowFloors 1 = 0 - 6
ShaftShowOutside 1 = 0 - 6

	<Floor 7>
