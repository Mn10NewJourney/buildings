		AddTextRange 1, 2, Ind_ButtonBlank, Ind_ButtonB%number%, nimbus_sans_bold.ttf, 55, B%number%, -1, -1, -1, -1, center, center, 255, 255, 0, false
		AddTextRange 1, 19, Ind_ButtonBlank, Ind_Button%number%, nimbus_sans_bold.ttf, 55, %number%, -1, -1, -1, -1, center, center, 255, 255, 0, false

	#Signs
		#Elevator number signs (Inside)
		Load data/Melvin/transparent128.png, IN_ElevNoBack, 1, 1, false
		AddTextRange 1, 9, IN_ElevNoBack, IN_ElevNo%number%, nimbus_sans_bold.ttf, 55, A%number%, -1, -1, -1, -1, center, center, 0, 0, 0, false
		AddTextRange 10, 11, IN_ElevNoBack, IN_ElevNo%number%, nimbus_sans_bold_condensed.ttf, 55, A%number%, -1, -1, -1, -1, center, center, 0, 0, 0, false

		#Floor signs (Elevator lobbies)
		Load data/Melvin/ABH_Tex/NewFS256/FloorSignBack.png, ELFlrSignBack, 1, 1, false #8th floor	
		AddText ELFlrSignBack, ELFlrSign8, nimbus_sans.ttf, 117, 8, -1, -1, -1, -1, center, center, 0, 0, 0, false

		Load data/graygradient.jpg, ServFlrSignBack, 1, 1, false #Service elevators
		AddTextRange 1, 2, ServFlrSignBack, ServFlrSignB%number%, nimbus_sans_bold.ttf, 128, B%number%, -1, -1, -1, -1, center, center, 0, 0, 0, false
		AddTextRange 1, 19, ServFlrSignBack, ServFlrSign%number%, nimbus_sans_bold.ttf, 128, %number%, -1, -1, -1, -1, center, center, 0, 0, 0, false

		#Floor signs (Stairwells)
		AddTextRange 1, 2, Blank, BlankSignB%number%, nimbus_sans_bold.ttf, 72, B%number%, -1, -1, -1, -1, center, center, 0, 0, 0, false
		AddTextRange 1, 19, Blank, BlankSign%number%, nimbus_sans_bold.ttf, 72, %number%, -1, -1, -1, -1, center, center, 0, 0, 0, false
		AddText Blank, BlankSign19A, nimbus_sans_bold_condensed.ttf, 65, 19A, -1, -1, -1, -1, center, center, 0, 0, 0, false
		AddText Blank, BlankSignR, nimbus_sans_bold.ttf, 72, R, -1, -1, -1, -1, center, center, 0, 0, 0, false

		#Restrooms
		Load data/signs_mod/Restroom1A.png, Sign_Restroom_Brown, 1, 1, false
		Load data/signs_mod/Restroom1.png, Sign_Restroom_Gray, 1, 1, false
		Load data/signs_mod/Sign_Restroom_1A.png, Sign_RestroomW_Brown, 1, 1, false
		Load data/signs_mod/Sign_Restroom_3A.png, Sign_RestroomM_Brown, 1, 1, false
		Load data/signs_mod/Sign_Restroom_1.png, Sign_RestroomW_Gray, 1, 1, false
		Load data/signs_mod/Sign_Restroom_3.png, Sign_RestroomM_Gray, 1, 1, false

		#Elevators
		Load data/signs_mod/Elev3.png, Sign_Elev, 1, 1, false
		Load data/signs_mod/Elev4A.png, Sign_ServiceElevA, 1, 1, false
		Load data/signs_mod/Elev4B.png, Sign_ServiceElevB, 1, 1, false

		#Proximity scanners
		#Load data/EG881/proxscan1.jpg, ProxScan, 1, 1, false #EG881
		Load data/EG881/Miscellaneous/HIDbadgescannergreen.jpg, HIDScanGreen, 1, 1, false #EG881
		Load data/EG881/Miscellaneous/HIDbadgescannerred.jpg, HIDScanRed, 1, 1, false #EG881

		#Exit signs
		Load data/panel-back3.jpg, StainlessSteel, 1, 1, false
		Load data/Melvin/ExitSignDown.png, ExitSign, 1, 1, false
		Load data/Melvin/ExitSignUp.png, ExitSignUp, 1, 1, false
		Load data/Melvin/ExitSignLeft.png, ExitSignLeft, 1, 1, false
		Load data/Melvin/ExitSignRight.png, ExitSignRight, 1, 1, false
		Load data/Melvin/ExitSignBoth.png, ExitSignBoth, 1, 1, false
<EndTextures>

############################################################

#Floor Assignments
<Floors -1 to -2>
	ID = B(0 - %floor%)
	Name = Basement Level (0 - %floor%)
	Type = Basement
	Height = 10
	InterfloorHeight = 2
	if[%floor% = -1] Altitude = -10
<EndFloor>

<Floor -3>
	ID = -
	Name = Shaft Pit
	Type = Basement
	Height = 8
	InterfloorHeight = 2
<EndFloor>

<Floors 0 to 6>
	ID = %floor% + 1
	Name = Store Level %floorid%
	Type = Shopping
	Height = 16
	InterfloorHeight = 2
	if[%floor% = 0] Altitude = 2
<EndFloors>

<Floor 7>
	ID = %floor% + 1
	Name = Event Area
	Type = Conference
	Height = 16
	InterfloorHeight = 2
<EndFloor>

<Floors 8 to 17>
	ID = %floor% + 1
	Name = Tower Level %floorid%
	Type = Recreation
	Height = 10
	InterfloorHeight = 2
<EndFloor>

<Floors 18 to 19>
	if[%floor% = 18] ID = %floor% + 1
	if[%floor% = 19] ID = 19A
	Name = Mechanical Level %floorid%
	Type = Mechanical
	Height = 10
	InterfloorHeight = 2
<EndFloors>

<Floor 20>
	ID = R
	Name = Roof
	Type = Roof
	Height = 9.5
	InterfloorHeight = 2
<EndFloor>

#Merge floors
<Floors -2 to 7>
	Group = -2 - 7
<EndFloors>

##--------------------------------------------------------------------------------##

#Common values
Set 1 = 120 #Building Dimension X (Full width: 240 ft.)
Set 2 = 130 #Building Dimension Z (Full length: 260 ft.)

#Landscape
DrawWalls = false, true, false, false, false, false

	#Moonlight Square
	AddFloor landscape, AprilDS_MoonlightSquare, EastSquareFloor, 0, %1%, -%2%, %1% + 150, %2%, 4, 4, 0, 0

##--------------------------------------------------------------------------------##

#Set texture prefixes/suffixes
<Function TexPrefix>
	#Main prefixes
	Set 5 = Shop
	if[%floor% < 0] Set 5 = Parking
	if[%floor% = 7] Set 5 = 8F
	if[%floor% > 7 & %floor% < 18] Set 5 = Tower
	if[%floor% > 17] Set 5 = Service
	
	#Parking lobby suffixes
	Set 5L = Wall
	if[%floor% < 0] Set 5L = LobbyWall

	###************###
	
	#Service lobby prefixes
	Set SP = %5%
	if[%floor% < 18] Set SP = SA

	#Service elevators' shaft doors
	Set 5S = ServiceA
	if[%floor% > 17] Set 5S = ServiceB

	###************###

	#Set heights for External Shaft/Stairwell walls
	Set SHeight = %fullheight%
	Set SOffset = 0
	if[%floor% = 0] Set SHeight = %height%
	if[%floor% = 0] Set SOffset = %interfloorheight%
	if[%floor% < 0] Set SHeight = %height% + Floor(%floor% + 1).InterfloorHeight - 0.5
	if[%floor% < 0] Set SOffset = %interfloorheight%
<EndFunction>

##--------------------------------------------------------------------------------##

#EXTERIOR & INTERIOR
#Parking levels
<Floors -2 to -1>
	TexPrefix() #Set texture prefix/suffix

	#Floors
	FloorOrientation = top
	DrawWalls = true, true, false, false, false, false
	TextureOverride ParkingCeiling, Road, Blank, Blank, Blank, Blank
	AddFloor AprilDS_PGFloor, Road, 1, -%1%, -%2%, %1% + 150, %2%, %interfloorheight%, %interfloorheight%, 0, 0, true

	#Ceilings
	FloorOrientation = bottom
	DrawWalls = true, false, false, false, false, false
	if[%floor% = -1] AddFloor AprilDS_PGCeiling, %5%Ceiling, 0.5, %1%, -%2%, %1% + 150, %2%, %fullheight% + 1, %fullheight% + 1, 0, 0, true

	#Perimeter walls
	TexPrefix() #Set texture prefix/suffix
	if[%floor% ! -1] Set WallHeight = %fullheight%
	if[%floor% = -1] Set WallHeight = %fullheight% + Floor(0).InterfloorHeight
	Set WallOffset = 0

		#Set DrawWalls for Front/Left sides
		DrawWalls = false, true, false, false, false, false

		WallOrientation = left
		AddWall FrontWall, %5%Wall, 0.5, -%1%, -%2%, %1% + 150, -%2%, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		#AddWall LeftWall, %5%Wall, 0.5, -%1%, -%2%, -%1%, %2%, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		AddWall LeftWall, %5%Wall, 0.5, -%1%, -%2%, -%1%, -%2% + 140.5, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		#Set DrawWalls for Right/Back sides
		DrawWalls = true, false, false, false, false, false

		WallOrientation = right
		AddWall RightWall, %5%Wall, 0.5, %1% + 150, -%2%, %1% + 150, %2%, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		#AddWall BackWall, %5%Wall, 0.5, -%1%, %2%, %1% + 150, %2%, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
<EndFloors>

########################################

#Shopping levels
<Floors 0 to 6>
	TexPrefix() #Set texture prefix/suffix

	#Floors
	Set ShowBottom = false
	if[%floor% = 0] Set ShowBottom = true

	FloorOrientation = top
	DrawWalls = %ShowBottom%, true, false, false, false, false
	TextureOverride ParkingCeiling, %5%Floor, Blank, Blank, Blank, Blank #1st floor only
	AddFloor AprilDSFloor, %5%Floor, 1, -%1%, -%2%, %1%, %2%, %interfloorheight%, %interfloorheight%, 0, 0, true

	#Ceilings
	FloorOrientation = bottom
	DrawWalls = true, false, false, false, false, false
	AddFloor AprilDSCeiling, %5%Ceiling, 0.5, -%1%, -%2%, %1%, %2%, %fullheight%, %fullheight%, 0, 0, true

	#Perimeter walls
	TexPrefix() #Set texture prefix/suffix
	Set WallHeight = %fullheight%
	Set WallOffset = 0

	#Override for the 1st floor only
	if[%floor% ! 0] Set WallHeight2 = %WallHeight%
	if[%floor% ! 0] Set WallOffset2 = %WallOffset%
	if[%floor% = 0] Set WallHeight2 = %height%
	if[%floor% = 0] Set WallOffset2 = %interfloorheight%

		DrawWalls = true, true, false, false, false, false

		WallOrientation = left
		TextureOverride ExtFacade, %5%Wall, Blank, Blank, Blank, Blank
		AddWall FrontWall, %5%Wall, 0.5, -%1%, -%2%, %1%, -%2%, %WallHeight2%, %WallHeight2%, %WallOffset2%, %WallOffset2%, 0, 0, true

		Set ShowSP = false
		if[%floor% < 4] Set ShowSP = true
		DrawWalls = true, true, false, %ShowSP%, false, false
		Set LeftEndpoint = %2%
		if[%floor% < 3] Set LeftEndpoint = -%2% + 140.5
		TextureOverride ExtFacade, %5%Wall, Blank, %5%Wall, Blank, Blank
		AddWall LeftWall, %5%Wall, 0.5, -%1%, -%2%, -%1%, %LeftEndpoint%, %WallHeight2%, %WallHeight2%, %WallOffset2%, %WallOffset2%, 0, 0, true

		DrawWalls = true, true, false, false, false, false

		WallOrientation = right
		TextureOverride %5%Wall, ExtFacade, Blank, Blank, Blank, Blank
		AddWall RightWall, %5%Wall, 0.5, %1%, -%2%, %1%, %2%, %WallHeight2%, %WallHeight2%, %WallOffset2%, %WallOffset2%, 0, 0, true
		#AddWall BackWall, %5%Wall, 0.5, -%1%, %2%, %1%, %2%, %WallHeight2%, %WallHeight2%, %WallOffset2%, %WallOffset2%, 0, 0, true
<EndFloors>

#8th floor roof area
<Floor 7>
	#Roof floor
	FloorOrientation = top
	DrawWalls = false, true, false, false, false, false
	AddFloor 8F-SouthRoof, RoofFloor, 0.5, -%1%, -%2%, %1%, -91.25, %interfloorheight%, %interfloorheight%, 0, 0, true
	AddFloor 8F-NorthRoof, RoofFloor, 0.5, -%1%, -8.75, %1%, %2%, %interfloorheight%, %interfloorheight%, 0, 0, true

	#South roof railings
	Set WallHeight = %interfloorheight% + 5.5
	Set WallOffset = 0

	WallOrientation = Left
	DrawWalls = true, true, true, true, true, false
	AddWall S-FrontRail, ExtFacade, 0.5, -%1% + 0.5, -%2%, %1% - 0.5, -%2%, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
	AddWall S-LeftRail, ExtFacade, 0.5, -%1%, -%2%, -%1%, -91.25, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

	WallOrientation = Right
	AddWall S-RightRail, ExtFacade, 0.5, %1%, -%2%, %1%, -91.25, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

	#North roof railings
	WallOrientation = Left
	DrawWalls = true, true, true, true, true, false
	AddWall N-LeftRail, ExtFacade, 0.5, -%1%, -8.75, -%1%, %2%, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

	WallOrientation = Right
	AddWall N-RightRail, ExtFacade, 0.5, %1%, -8.75, %1%, %2%, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
	#AddWall N-BackRail, ExtFacade, 0.5, -%1% + 0.5, %2%, %1% - 0.5, %2%, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
<EndFloor>

#Tower levels
<Floors 7 to 19>
	TexPrefix() #Set texture prefix/suffix

	#Floors
	FloorOrientation = top
	DrawWalls = false, true, false, false, false, false
	if[%floor% ! 19] AddFloor AprilTowerFloor, %5%Floor, 0.5, -%1%, -91.25, %1%, -8.75, %interfloorheight%, %interfloorheight%, 0, 0, true

	#Ceilings
	FloorOrientation = bottom
	DrawWalls = true, false, false, false, false, false
	if[%floor% ! 18] AddFloor AprilTowerCeiling, %5%Ceiling, 0.5, -%1%, -91.25, %1%, -8.75, %fullheight%, %fullheight%, 0, 0, true
<EndFloors>

<Floors 7 to 17>
	#Perimeter windows
	Set MyIFloorType = 2
	if[%floor% = 7] Set MyIFloorType = 1
	Set WinHeight = %height%

	SetAutoSize = true, false
		#Front windows
		AddCustomWindows(FrontWin1, MainWindows, MainWindowsInt, -110, -91.25, -100, -91.25, %WinHeight%, 0, 0, %MyIFloorType%, ExtFacade, %5%Wall)
		AddCustomWindows(FrontWin2, MainWindows, MainWindowsInt, -80, -91.25, 80, -91.25, %WinHeight%, 0, 0, %MyIFloorType%, ExtFacade, %5%Wall)
		AddCustomWindows(FrontWin3, MainWindowsB, MainWindowsIntB, 90, -91.25, 108, -91.25, %WinHeight%, 4/4, 1, %MyIFloorType%, ExtFacade, %5%Wall)

		#Left windows
		AddCustomWindows(LeftWin, MainWindows, MainWindowsInt, -%1%, -60, -%1%, -40, %WinHeight%, 0, 0, %MyIFloorType%, ExtFacade, %5%Wall)

		#Right windows
		AddCustomWindows(RightWin, MainWindowsInt, MainWindows, %1%, -60, %1%, -15, %WinHeight%, 0, 0, %MyIFloorType%, %5%Wall, ExtFacade)

		#Back windows
		AddCustomWindows(BackWin1, MainWindowsInt, MainWindows, -%1% + 20, -8.75, -15, -8.75, %WinHeight%, 0, 0, %MyIFloorType%, %5%Wall, ExtFacade)
		AddCustomWindows(BackWin2, MainWindowsInt, MainWindows, 15, -8.75, 115, -8.75, %WinHeight%, 0, 0, %MyIFloorType%, %5%Wall, ExtFacade)
	SetAutoSize = true, true

	#--------------------#

	#Perimeter walls
	TexPrefix() #Set texture prefix/suffix
	Set WallHeight = %fullheight%
	Set WallOffset = 0

		#FRONT AND LEFT
		DrawWalls = true, true, false, false, false, false

		WallOrientation = left
		TextureOverride ExtFacade, %5%Wall, Blank, Blank, Blank, Blank
		AddWall FrontWall1, %5%Wall, 0.5, -%1%, -91.25, -110, -91.25, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		TextureOverride ExtFacade, %5%Wall, Blank, Blank, Blank, Blank
		AddWall FrontWall2, %5%Wall, 0.5, -100, -91.25, -80, -91.25, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		TextureOverride ExtFacade, %SP%Wall, Blank, Blank, Blank, Blank
		AddWall FrontWall3, %SP%Wall, 0.5, 80, -91.25, 90, -91.25, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		DrawWalls = true, true, true, false, false, false
		TextureOverride ExtFacade, %SP%Wall, %SP%Wall, Blank, Blank, Blank
		AddWall FrontWall4, %SP%Wall, 0.5, 108, -91.25, %1%, -91.25, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		DrawWalls = true, true, false, false, false, false
		TextureOverride ExtFacade, %5%Wall, Blank, Blank, Blank, Blank
		AddWall LeftWall1, ExtFacade, 0.5, -%1%, -91.25, -%1%, -80, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		DrawWalls = true, false, false, false, false, false
		AddWall LeftWall1A, ExtFacade, 0.5, -%1%, -80, -%1%, -60, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		DrawWalls = true, true, false, false, false, false
		TextureOverride ExtFacade, %5%Wall, Blank, Blank, Blank, Blank
		AddWall LeftWall2, %5%Wall, 0.5, -%1%, -40, -%1%, -8.75, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true


		#RIGHT AND BACK
		WallOrientation = right
		DrawWalls = false, true, false, false, false, false
		#TextureOverride %5%Wall, ExtFacade, Blank, %5%Wall, Blank, Blank
		AddWall RightWall1_EX, ExtFacade, 0.5, %1%, -91.25, %1%, -60, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		DrawWalls = true, false, false, false, false, false
		AddWall RightWall1_IN, %SP%Wall, 0.5, %1%, -91.25, %1%, -80, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		DrawWalls = true, true, true, false, false, false
		TextureOverride %5%Wall, ExtFacade, %5%Wall, Blank, Blank, Blank
		AddWall RightWall2, %5%Wall, 0.5, %1%, -15, %1%, -8.75, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true


		Set IntWallDim = 20
		if[%floor% = 7] Set IntWallDim = 10
		DrawWalls = true, false, false, true, false, false
		AddWall BackWall_FarWest_Int, %5%Wall, 0.5, -%1%, -8.75, -%1% + %IntWallDim%, -8.75, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		DrawWalls = false, true, false, false, false, false
		AddWall BackWall_FarWest_Ext, ExtFacade, 0.5, -%1%, -8.75, -%1% + 20, -8.75, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		DrawWalls = true, true, true, true, false, false
		TextureOverride %5%Wall, ExtFacade, %5%Wall, %5%Wall, Blank, Blank
		AddWall BackWall1, ExtFacade, 0.5, -15, -8.75, -10, -8.75, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		TextureOverride %5%Wall, ExtFacade, %5%Wall, %5%Wall, Blank, Blank
		AddWall BackWall2, ExtFacade, 0.5, 10, -8.75, 15, -8.75, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		DrawWalls = true, true, true, false, false, false
		TextureOverride %5%Wall, ExtFacade, %5%Wall, Blank, Blank, Blank
		AddWall BackWall3, %5%Wall, 0.5, 115, -8.75, %1%, -8.75, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
<EndFloors>

<Floors 18 to 19>
	#Perimeter walls (Mechanical floors)
	TexPrefix() #Set texture prefix/suffix
	Set WallHeight = %fullheight%
	Set WallOffset = 0

		DrawWalls = true, true, false, false, false, false

		WallOrientation = left
		TextureOverride ExtFacade, %5%Wall, Blank, Blank, Blank, Blank
		AddWall FrontWall, %5%Wall, 0.5, -%1%, -91.25, %1%, -91.25, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		TextureOverride ExtFacade, %5%Wall, Blank, Blank, Blank, Blank
		AddWall LeftWall, %5%Wall, 0.5, -%1%, -91.25, -%1%, -8.75, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

		WallOrientation = right
		TextureOverride %5%Wall, ExtFacade, Blank, Blank, Blank, Blank
		AddWall RightWall, %5%Wall, 0.5, %1%, -91.25, %1%, -8.75, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		TextureOverride %5%Wall, ExtFacade, Blank, Blank, Blank, Blank
		AddWall BackWall1, %5%Wall, 0.5, -%1%, -8.75, -10, -8.75, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
		TextureOverride %5%Wall, ExtFacade, Blank, Blank, Blank, Blank
		AddWall BackWall2, %5%Wall, 0.5, 10, -8.75, %1%, -8.75, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
<EndFloors>

#Rooftop (20th floor)
<Floor 20>
	#Roof floor
	FloorOrientation = top
	DrawWalls = false, true, false, false, false, false
	AddFloor Rooftop, RoofFloor, 0.5, -%1%, -91.25, %1%, -8.75, %interfloorheight%, %interfloorheight%, 0, 0, true

	#South roof railings
	Set WallHeight = %interfloorheight% + 5.5
	Set WallOffset = 0

	WallOrientation = Left
	DrawWalls = true, true, true, true, true, false
	AddWall Rooftop-FrontRail, ExtFacade, 0.5, -%1% + 0.5, -91.25, %1% - 12, -91.25, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
	AddWall Rooftop-LeftRail, ExtFacade, 0.5, -%1%, -91.25, -%1%, -8.75, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true

	WallOrientation = Right
	AddWall Rooftop-RightRail, ExtFacade, 0.5, %1%, -91.25 + 1.25 + 30, %1%, -8.75, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
	AddWall Rooftop-BackRail, ExtFacade, 0.5, -%1% + 0.5, -8.75, %1% - 0.5, -8.75, %WallHeight%, %WallHeight%, %WallOffset%, %WallOffset%, 0, 0, true
<EndFloor>


########################################

#SUPPORTS
#Parking Garage Supports
<Floors -2 to -1>
	#Set Values
	TexPrefix() #Set texture prefixes
	Set DistanceX = 40 #Distance between supports X
	Set DistanceZ = 40 #Distance between supports Z

	Set SupportHeight = %fullheight%
	if[%floor% = -1] Set SupportHeight = %fullheight% + Floor(0).InterfloorHeight
	Set SupportOffset = -%interfloorheight%
	
	#Row AA
	Set Prefix = AA
	Set SupportX = %1% + 20
	CreateWallBox2 external, Support%Prefix%1, ColumnTex, %SupportX%, -%2% + 1.25, 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%2, ColumnTex, %SupportX%, -%2% + (%DistanceX% * 1), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%3, ColumnTex, %SupportX%, -%2% + (%DistanceX% * 2), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%4, ColumnTex, %SupportX%, -%2% + (%DistanceX% * 3), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
	CreateWallBox2 external, Support%Prefix%5, ColumnTex, %SupportX%, -%2% + (%DistanceX% * 4), 2, 2, %SupportHeight%, %SupportOffset%, 0, 0, false, true, false, false
